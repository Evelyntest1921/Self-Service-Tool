VAR @jid, @detailRows, @detailRow, @detailCount
VAR @dispName, @dispType, @dispEmailName, @dispEmailId, @dispDeName, @dispDeId, @dispCampaignId, @dispSurveyId
VAR @dispQueryKey, @dispAutomationGuid, @dispAutomationName, @dispQueryText, @isStackBuild, @isSurveyBuild, @showChecklist
VAR @dispJourneyStatus, @dispAutomationStatus, @dispSentCount, @journeyStatusColor, @automationStatusColor
VAR @surveyUrlRows, @surveyUrlRow, @buildNavContext, @buildNavActive
VAR @chkCampaignId, @chkCampaignStatus, @chkCampaignMsg, @chkCampaignIcon
VAR @chkPublishStatus, @chkPublishMsg, @chkPublishIcon
VAR @chkEmailIdStatus, @chkEmailIdMsg, @chkJbEmailId, @chkEmailIdIcon
VAR @chkSubjectStatus, @chkSubjectMsg, @chkSubjectVal, @chkSubjectIcon
VAR @chkBccStatus, @chkBccMsg, @chkBccVal, @chkBccIcon
VAR @chkTrackingStatus, @chkTrackingMsg, @chkTrackingIcon
VAR @chkSfStepsStatus, @chkSfStepsMsg, @chkSfStepsIcon
VAR @chkAnalyticsStatus, @chkAnalyticsMsg, @chkAnalyticsIcon
VAR @chkEntryStatus, @chkEntryMsg, @chkJbEntryId, @chkEntryIcon
VAR @chkSenderStatus, @chkSenderMsg, @chkSenderName, @chkSenderProfileId, @chkSenderIcon
VAR @chkAutoNameStatus, @chkAutoNameMsg, @chkAutoNameIcon
VAR @chkQueryStatus, @chkQueryMsg, @chkQueryText, @chkQueryIcon
VAR @chkAutoStatusStatus, @chkAutoStatusMsg, @chkAutoStatusIcon
VAR @deleteRequested, @removeLogOnly, @deleteEmailFromPost, @purgeRequested
VAR @authOk, @accessToken, @subdomain
VAR @resultText, @pageStatus
VAR @logDelCount, @analyticsDelCnt
VAR @attemptPurgeBuild, @purgeBuildLog, @purgeEmailOk
VAR @attemptDeleteAsset, @step3bResult
VAR @surveyPurgeId, @surveyDelResponses, @surveyDelQuestions, @surveyDelMaster, @surveyDeleteLog, @willRemoveBuildLog
VAR @updRaw


SET @purgeRequested = IIF(NOT Empty(RequestParameter("confirmPurgeBuild")),"1","0")
SET @showChecklist = IIF(NOT Empty(RequestParameter("checklist")),"1","0")
SET @jid = Trim(RequestParameter("journeyId"))
SET @deleteRequested = IIF(NOT Empty(RequestParameter("confirmDeleteAsset")),"1","0")
SET @removeLogOnly = IIF(NOT Empty(RequestParameter("confirmRemoveLog")),"1","0")
SET @deleteEmailFromPost = Trim(RequestParameter("deleteEmailId"))


SET @resultText = ""
SET @step3bResult = ""
SET @authOk = "false"
SET @accessToken = ""
SET @subdomain = ""
SET @pageStatus = "view"
SET @dispName = ""
SET @dispType = ""
SET @dispEmailName = ""
SET @dispEmailId = ""
SET @dispDeName = ""
SET @dispDeId = ""
SET @dispCampaignId = ""
SET @dispSurveyId = ""
SET @detailCount = 0


SET @dispUpdated = ""


SET @attemptPurgeBuild = "false"
SET @purgeBuildLog = ""
SET @purgeEmailOk = "false"
SET @isStackBuild = "false"
SET @isSurveyBuild = "false"
SET @buildNavContext = "false"
SET @buildNavActive = "manage"
SET @dispQueryKey = ""
SET @dispQueryText = ""
SET @dispAutomationGuid = ""
SET @dispAutomationName = ""
SET @dispJourneyStatus = ""
SET @dispAutomationStatus = ""
SET @dispSentCount = ""
SET @journeyStatusColor = "#6366f1"
SET @automationStatusColor = "#dc2626"
SET @chkCampaignId = ""
SET @chkCampaignStatus = "pending"
SET @chkCampaignMsg = ""
SET @chkAutoNameStatus = "skip"
SET @chkAutoNameMsg = ""
SET @chkQueryStatus = "skip"
SET @chkQueryMsg = ""
SET @chkQueryText = ""
SET @chkAutoStatusStatus = "skip"
SET @chkAutoStatusMsg = ""
SET @chkTrackingStatus = "pending"
SET @chkTrackingMsg = ""
SET @chkPublishStatus = "pending"
SET @chkPublishMsg = ""
SET @chkEmailIdStatus = "pending"
SET @chkEmailIdMsg = ""
SET @chkJbEmailId = ""
SET @chkSubjectStatus = "pending"
SET @chkSubjectMsg = ""
SET @chkSubjectVal = ""
SET @chkBccStatus = "pending"
SET @chkBccMsg = ""
SET @chkBccVal = ""
SET @chkSfStepsStatus = "pending"
SET @chkSfStepsMsg = ""
SET @chkAnalyticsStatus = "pending"
SET @chkAnalyticsMsg = ""
SET @chkEntryStatus = "pending"
SET @chkEntryMsg = ""
SET @chkJbEntryId = ""
SET @chkSenderStatus = "pending"
SET @chkSenderMsg = ""
SET @chkSenderName = ""
SET @chkSenderProfileId = ""
IF NOT Empty(@jid) THEN
  SET @buildNavContext = "true"
ENDIF
IF Empty(@jid) THEN
SET @pageStatus = "nodata"
ELSE
SET @detailRows = LookupRows(@DETAIL_EXTERNAL_KEY_DE,"journeyId",@jid)
SET @detailCount = RowCount(@detailRows)
IF @detailCount > 0 THEN
  SET @detailRow = Row(@detailRows,1)
  SET @dispName = Field(@detailRow,"journeyName")
  SET @dispType = Field(@detailRow,"journeyType")
  SET @dispEmailName = Field(@detailRow,"emailName")
  SET @dispEmailId = Trim(Field(@detailRow,"emailId"))
  SET @dispDeName = Field(@detailRow,"deName")
  SET @dispDeId = Field(@detailRow,"deId")
  SET @dispSurveyId = Trim(Field(@detailRow,"surveyId"))
  IF IndexOf(@dispType,"Survey") > 0 THEN
    SET @isSurveyBuild = "true"
  ENDIF
  IF Trim(@dispType) == @STACK_JOURNEY_TYPE THEN
    SET @isStackBuild = "true"
    SET @dispQueryKey = Trim(Field(@detailRow,"queryKey"))
    SET @dispAutomationGuid = Trim(Field(@detailRow,"automationGuid"))
    SET @dispAutomationName = Trim(Field(@detailRow,"automationName"))
  ENDIF
  SET @updRaw = Field(@detailRow,"updateDate")
  SET @dispJourneyStatus = Trim(Field(@detailRow,"journeyStatus"))
  IF Empty(@dispJourneyStatus) THEN
    SET @dispJourneyStatus = Trim(Field(@detailRow,"JourneyStatus"))
  ENDIF
  SET @dispAutomationStatus = Trim(Field(@detailRow,"automationStatus"))
  IF Empty(@dispAutomationStatus) THEN
    SET @dispAutomationStatus = Trim(Field(@detailRow,"AutomationStatus"))
  ENDIF
  SET @dispSentCount = Trim(Field(@detailRow,"sentCount"))
  IF Empty(@dispSentCount) THEN
    SET @dispSentCount = Trim(Field(@detailRow,"SentCount"))
  ENDIF
  IF NOT Empty(@dispJourneyStatus) THEN
    IF Lowercase(@dispJourneyStatus) == "draft" THEN
      SET @journeyStatusColor = "#9ca3af"
    ELSEIF Lowercase(@dispJourneyStatus) == "running" THEN
      SET @journeyStatusColor = "#10b981"
    ELSEIF Lowercase(@dispJourneyStatus) == "stopped" THEN
      SET @journeyStatusColor = "#f59e0b"
    ENDIF
  ENDIF
  IF NOT Empty(@dispAutomationStatus) THEN
    IF Lowercase(@dispAutomationStatus) == "paused" THEN
      SET @automationStatusColor = "#f59e0b"
    ELSEIF Lowercase(@dispAutomationStatus) == "ready" OR Lowercase(@dispAutomationStatus) == "scheduled" OR Lowercase(@dispAutomationStatus) == "running" OR Lowercase(@dispAutomationStatus) == "waiting" THEN
      SET @automationStatusColor = "#10b981"
    ENDIF
  ENDIF
  IF NOT Empty(@updRaw) THEN
    SET @dispUpdated = Format(@updRaw, "yyyy-MM-dd HH:mm:ss")
  ELSE
    SET @dispUpdated = ""
  ENDIF
ELSE
  SET @pageStatus = "notfound"
ENDIF
ENDIF


IF (@showChecklist == "1") AND (@detailCount > 0) THEN
SET @authRow = LookupRows("SFMC_AUTH","User","Admin")
IF RowCount(@authRow) > 0 THEN
  SET @authR = Row(@authRow,1)
  SET @clientId = Field(@authR,"clientId")
  SET @clientSecret = Field(@authR,"clientSecret")
  SET @subdomain = Field(@authR,"subdomain")
  IF NOT Empty(@clientId) AND NOT Empty(@clientSecret) AND NOT Empty(@subdomain) THEN
    SET @authUrl = Concat("https://",@subdomain,".auth.marketingcloudapis.com/v2/token")
    SET @accountId = Trim(Field(@authR,"accountId"))
    SET @authPayload = Concat('{"grant_type":"client_credentials","client_id":"',@clientId,'","client_secret":"',@clientSecret,'"')
    IF NOT Empty(@accountId) THEN
      SET @authPayload = Concat(@authPayload,',"account_id":"',@accountId,'"')
    ENDIF
    SET @authPayload = Concat(@authPayload,'}')
    SET @authStatus = HTTPPost2(@authUrl,"application/json",@authPayload,false,@authResponse,@authResponseHeader)
    IF @authStatus == 200 THEN
      SET @tokenPattern = '"access_token":"([^"]+)"'
      SET @accessToken = RegExMatch(@authResponse,@tokenPattern,1)
      IF NOT Empty(@accessToken) THEN
        SET @authOk = "true"
      ELSE
        SET @chkCampaignMsg = "Auth response missing access token."
      ENDIF
    ELSE
      SET @chkCampaignMsg = Concat("Auth HTTP ",@authStatus)
    ENDIF
  ELSE
    SET @chkCampaignMsg = "SFMC_AUTH incomplete for subdomain or credentials."
  ENDIF
ELSE
  SET @chkCampaignMsg = "SFMC_AUTH has no Admin row."
ENDIF
ENDIF


IF (@removeLogOnly == "1") AND (@detailCount > 0) THEN
SET @postedJid = Trim(RequestParameter("postedJourneyId"))
IF Empty(@postedJid) THEN
  SET @postedJid = @jid
ENDIF
IF @postedJid != @jid THEN
  SET @pageStatus = "tamper"
  SET @resultText = "Journey identifier did not match."
ELSE
  SET @logDelCount = DeleteData(@DETAIL_EXTERNAL_KEY_DE,"journeyId",@jid)
  IF @logDelCount > 0 THEN
    SET @pageStatus = "removed_log"
    Redirect(Concat(@HOME_URL,"?logRemoved=1"))
  ELSE
    SET @pageStatus = "drop_log_failed"
    SET @resultText = Concat("DeleteData returned zero rows deleted. Typical causes: Cloud Page lacks delete rights on ",@DETAIL_EXTERNAL_KEY_DE,", the External Key or journeyId column differs from LookupRows expectations, or the row was removed already.")
  ENDIF
ENDIF
ENDIF


SET @attemptDeleteAsset = "false"
SET @attemptPurgeBuild = "false"


IF ((@deleteRequested == "1") OR (@purgeRequested == "1")) AND (@detailCount > 0) THEN
SET @postedJidDel = Trim(RequestParameter("postedJourneyId"))
IF Empty(@postedJidDel) THEN
  SET @postedJidDel = @jid
ENDIF
IF (@postedJidDel != @jid) OR Empty(@deleteEmailFromPost) OR (@deleteEmailFromPost != @dispEmailId) THEN
  SET @pageStatus = "tamper"
  SET @resultText = "Deletion request did not match this build row."
ELSE
  IF (@purgeRequested == "1") THEN
    SET @attemptPurgeBuild = "true"
  ELSEIF (@deleteRequested == "1") THEN
    SET @attemptDeleteAsset = "true"
  ENDIF
  SET @authRow = LookupRows("SFMC_AUTH","User","Admin")
  IF RowCount(@authRow) > 0 THEN
    SET @authR = Row(@authRow,1)
    SET @clientId = Field(@authR,"clientId")
    SET @clientSecret = Field(@authR,"clientSecret")
    SET @subdomain = Field(@authR,"subdomain")
    IF NOT Empty(@clientId) AND NOT Empty(@clientSecret) AND NOT Empty(@subdomain) THEN
      SET @authUrl = Concat("https://",@subdomain,".auth.marketingcloudapis.com/v2/token")
      SET @accountId = Trim(Field(@authR,"accountId"))
      SET @authPayload = Concat('{"grant_type":"client_credentials","client_id":"',@clientId,'","client_secret":"',@clientSecret,'"')
      IF NOT Empty(@accountId) THEN
        SET @authPayload = Concat(@authPayload,',"account_id":"',@accountId,'"')
      ENDIF
      SET @authPayload = Concat(@authPayload,'}')
      SET @authStatus = HTTPPost2(@authUrl,"application/json",@authPayload,false,@authResponse,@authResponseHeader)
      IF @authStatus == 200 THEN
        SET @tokenPattern = '"access_token":"([^"]+)"'
        SET @accessToken = RegExMatch(@authResponse,@tokenPattern,1)
        IF NOT Empty(@accessToken) THEN
          SET @resultText = "Auth succeeded."
          SET @authOk = "true"
        ELSE
          SET @resultText = "Auth response missing access token."
          SET @authOk = "false"
        ENDIF
      ELSE
        SET @resultText = Concat("Auth HTTP ",@authStatus," — ",Substring(IIF(NOT Empty(@authResponse),@authResponse,"(empty)"),1,200))
        SET @authOk = "false"
      ENDIF
    ELSE
      SET @resultText = "SFMC_AUTH incomplete for subdomain or credentials."
    ENDIF
  ELSE
    SET @resultText = "SFMC_AUTH has no Admin row."
  ENDIF
ENDIF
ENDIF
