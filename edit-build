<script>
(function () {
 function copyText(text) {
  if (!text) {
   return;
  }
  if (navigator.clipboard && navigator.clipboard.writeText) {
   navigator.clipboard.writeText(text).catch(function () {
    fallbackCopy(text);
   });
   return;
  }
  fallbackCopy(text);
 }
 function fallbackCopy(text) {
  var ta = document.createElement("textarea");
  ta.value = text;
  ta.setAttribute("readonly", "");
  ta.style.position = "fixed";
  ta.style.left = "-9999px";
  document.body.appendChild(ta);
  ta.select();
  try {
   document.execCommand("copy");
  } catch (copyErr) {}
  document.body.removeChild(ta);
 }
 var autoLinks = document.querySelectorAll(".js-automation-home-link");
 var ai;
 for (ai = 0; ai < autoLinks.length; ai++) {
  autoLinks[ai].addEventListener("click", function () {
   var name = this.getAttribute("data-automation-name") || "";
   if (name) {
    copyText(name);
   }
  });
 }
 var btn = document.getElementById("chkQuerySqlBtn");
 var pre = document.getElementById("chkQuerySqlPre");
 if (btn && pre) {
  btn.addEventListener("click", function () {
   var show = pre.hidden;
   pre.hidden = !show;
   btn.textContent = show ? "Hide query SQL" : "View query SQL";
  });
 }
 var scheduleFreq = document.getElementById("automationFrequency");
 var minuteWrap = document.getElementById("automationMinuteIntervalWrap");
 function syncMinuteIntervalField() {
  if (!scheduleFreq || !minuteWrap) {
   return;
  }
  minuteWrap.hidden = scheduleFreq.value !== "minute";
 }
 if (scheduleFreq) {
  scheduleFreq.addEventListener("change", syncMinuteIntervalField);
  syncMinuteIntervalField();
 }
 var scheduleStart = document.getElementById("automationStartDate");
 if (scheduleStart && !scheduleStart.value) {
  var nextHour = new Date();
  nextHour.setMinutes(0, 0, 0);
  nextHour.setHours(nextHour.getHours() + 1);
  function two(n) {
   return n < 10 ? "0" + n : String(n);
  }
  scheduleStart.value =
   nextHour.getFullYear() +
   "-" +
   two(nextHour.getMonth() + 1) +
   "-" +
   two(nextHour.getDate()) +
   "T" +
   two(nextHour.getHours()) +
   ":" +
   two(nextHour.getMinutes());
 }
 var expandBtns = document.querySelectorAll(".detail-expand-btn");
 var bi;
 for (bi = 0; bi < expandBtns.length; bi++) {
  expandBtns[bi].addEventListener("click", function () {
   var panelId = this.getAttribute("aria-controls") || "";
   var panel = panelId ? document.getElementById(panelId) : null;
   if (!panel) {
    return;
   }
   var willOpen = panel.hidden;
   var allPanels = document.querySelectorAll(".detail-row-expand");
   var allBtns = document.querySelectorAll(".detail-expand-btn");
   var pi;
   for (pi = 0; pi < allPanels.length; pi++) {
    allPanels[pi].hidden = true;
   }
   var bj;
   for (bj = 0; bj < allBtns.length; bj++) {
    allBtns[bj].setAttribute("aria-expanded", "false");
    allBtns[bj].classList.remove("is-open");
   }
   if (willOpen) {
    panel.hidden = false;
    this.setAttribute("aria-expanded", "true");
    this.classList.add("is-open");
   }
  });
 }
})();
(function(){
 var showLogBtn = document.getElementById("showLogBtn");
 var apiLog = document.getElementById("apiLog");
 if (showLogBtn && apiLog) {
  showLogBtn.onclick = function() {
   apiLog.classList.toggle("is-visible");
   showLogBtn.textContent = apiLog.classList.contains("is-visible") ? "Hide log" : "Show log";
  };
 }
})();
</script>
