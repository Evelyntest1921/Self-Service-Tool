<script runat="server" language="javascript">
Platform.Load("core", "1");


function strTrim(s) {
 if (s == null || s === undefined) {
   return "";
 }
 return String(s).replace(/^\s+|\s+$/g, "");
}


function lookupSenderProfile(profileId) {
 if (!profileId) {
   return null;
 }
 try {
   var prox = new Script.Util.WSProxy();
   var props = ["Name", "FromName", "FromAddress", "CustomerKey", "ObjectID"];
   var byKey = prox.retrieve("SenderProfile", props, {
     Property: "CustomerKey",
     SimpleOperator: "equals",
     Value: String(profileId)
   });
   if (byKey && byKey.Results && byKey.Results.length > 0) {
     return byKey.Results[0];
   }
   var byObj = prox.retrieve("SenderProfile", props, {
     Property: "ObjectID",
     SimpleOperator: "equals",
     Value: String(profileId)
   });
   if (byObj && byObj.Results && byObj.Results.length > 0) {
     return byObj.Results[0];
   }
 } catch (spErr) {}
 return null;
}


function lookupQueryText(queryKey) {
 if (!queryKey) {
   return "";
 }
 try {
   var proxQ = new Script.Util.WSProxy();
   var qdRes = proxQ.retrieve(
     "QueryDefinition",
     ["CustomerKey", "QueryText", "Name"],
     {
       Property: "CustomerKey",
       SimpleOperator: "equals",
       Value: String(queryKey)
     }
   );
   if (qdRes && qdRes.Results && qdRes.Results.length > 0) {
     return String(qdRes.Results[0].QueryText || "");
   }
 } catch (qLookupErr) {}
 return "";
}


function truncQueryDisplay(text) {
 var s = String(text || "");
 if (s.length > 4000) {
   return s.substring(0, 4000) + "...";
 }
 return s;
}


function automationStatusLabel(statusId, statusText) {
 if (statusText) {
   return String(statusText);
 }
 var map = {
   0: "Unknown",
   1: "Building",
   2: "Ready",
   3: "Running",
   4: "Paused",
   5: "Stopped",
   6: "Scheduled",
   7: "Waiting",
   8: "Inactive"
 };
 if (statusId !== undefined && statusId !== null && map[statusId]) {
   return map[statusId];
 }
 if (statusId !== undefined && statusId !== null) {
   return "Status " + statusId;
 }
 return "Unknown";
}


function automationStatusIsOk(label) {
 var u = String(label || "").toLowerCase();
 return (
   u === "ready" ||
   u === "scheduled" ||
   u === "running" ||
   u === "waiting"
 );
}


function automationStatusLevel(label) {
 if (automationStatusIsOk(label)) {
   return "pass";
 }
 if (String(label || "").toLowerCase() === "paused") {
   return "warn";
 }
 return "fail";
}


function logDeField(jid, colName) {
 if (!jid || !colName) {
   return "";
 }
 try {
   var rows = Platform.Function.LookupRows(
     "Bd_journey_analytics",
     "journeyId",
     String(jid)
   );
   if (!rows || rows.length === 0) {
     return "";
   }
   var val = rows[0][colName];
   if (val === undefined || val === null) {
     return "";
   }
   return strTrim(String(val));
 } catch (logDeEx) {
   return "";
 }
}


function resolveEntryDeRowCount(deCustomerKey, deName) {
 var key = strTrim(deCustomerKey);
 var name = strTrim(deName);
 if (key && key.toUpperCase() !== "N/A") {
   try {
     return Platform.Function.DataExtensionRowCount(key);
   } catch (keyCountEx) {}
 }
 if (!name || name.toUpperCase() === "N/A") {
   return 0;
 }
 try {
   var prox = new Script.Util.WSProxy();
   var deFilter = {
     Property: "Name",
     SimpleOperator: "equals",
     Value: name
   };
   var rde = prox.retrieve("DataExtension", ["CustomerKey"], deFilter);
   if (rde && rde.Results && rde.Results.length > 0 && rde.Results[0].CustomerKey) {
     return Platform.Function.DataExtensionRowCount(String(rde.Results[0].CustomerKey));
   }
 } catch (deLookupEx) {}
 try {
   return Platform.Function.DataExtensionRowCount(name);
 } catch (deCountEx) {}
 return 0;
}


function resolveJourneyEntryEventId(sub, token, jid) {
 var journeyId = strTrim(jid);
 if (!journeyId || !sub || !token || journeyId.indexOf("email:") === 0) {
   return "";
 }
 try {
   var jGetUrl =
     "https://" +
     sub +
     ".rest.marketingcloudapis.com/interaction/v1/interactions/" +
     encodeURIComponent(journeyId) +
     "?extras=all";
   var jGetReq = new Script.Util.HttpRequest(jGetUrl);
   jGetReq.emptyContentHandling = 0;
   jGetReq.continueOnError = true;
   jGetReq.setHeader("Authorization", "Bearer " + token);
   jGetReq.method = "GET";
   var jGetResp = jGetReq.send();
   if (jGetResp.statusCode == 200 || jGetResp.statusCode == 201) {
     var jObj = Platform.Function.ParseJSON(String(jGetResp.content));
     var triggers = jObj && jObj.triggers ? jObj.triggers : [];
     if (triggers.length > 0 && triggers[0]) {
       var trigMeta = triggers[0].metaData || {};
       var entryId = strTrim(trigMeta.eventDefinitionId || "");
       if (!entryId && triggers[0].arguments) {
         entryId = strTrim(triggers[0].arguments.eventDefinitionId || "");
       }
       return entryId;
     }
   }
 } catch (entryEvEx) {}
 return "";
}


function resolveDeObjectIdByCustomerKey(customerKey) {
 var key = strTrim(customerKey);
 if (!key || key.toUpperCase() === "N/A") {
   return "";
 }
 try {
   var prox = new Script.Util.WSProxy();
   var rde = prox.retrieve("DataExtension", ["ObjectID"], {
     Property: "CustomerKey",
     SimpleOperator: "equals",
     Value: key
   });
   if (rde && rde.Results && rde.Results.length > 0 && rde.Results[0].ObjectID) {
     return String(rde.Results[0].ObjectID);
   }
 } catch (deKeyEx) {}
 return "";
}


function isGuidLike(id) {
 var value = strTrim(id);
 if (!value) {
   return false;
 }
