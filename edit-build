 IF @chkSfStepsStatus == "pass" THEN
  SET @chkSfStepsIcon = "pass"
 ELSEIF @chkSfStepsStatus == "skip" THEN
  SET @chkSfStepsIcon = "skip"
 ELSE
  SET @chkSfStepsIcon = "fail"
 ENDIF
 IF @chkAnalyticsStatus == "pass" THEN
  SET @chkAnalyticsIcon = "pass"
 ELSEIF @chkAnalyticsStatus == "skip" THEN
  SET @chkAnalyticsIcon = "skip"
 ELSE
  SET @chkAnalyticsIcon = "fail"
 ENDIF
 IF @chkSenderStatus == "pass" THEN
  SET @chkSenderIcon = "pass"
 ELSEIF @chkSenderStatus == "skip" THEN
  SET @chkSenderIcon = "skip"
 ELSE
  SET @chkSenderIcon = "fail"
 ENDIF
 IF @isStackBuild == "true" THEN
  IF @chkAutoNameStatus == "pass" THEN
   SET @chkAutoNameIcon = "pass"
  ELSEIF @chkAutoNameStatus == "skip" THEN
   SET @chkAutoNameIcon = "skip"
  ELSE
   SET @chkAutoNameIcon = "fail"
  ENDIF
  IF @chkQueryStatus == "pass" THEN
   SET @chkQueryIcon = "pass"
  ELSEIF @chkQueryStatus == "skip" THEN
   SET @chkQueryIcon = "skip"
  ELSE
   SET @chkQueryIcon = "fail"
  ENDIF
  IF @chkAutoStatusStatus == "pass" THEN
   SET @chkAutoStatusIcon = "pass"
  ELSEIF @chkAutoStatusStatus == "skip" THEN
   SET @chkAutoStatusIcon = "skip"
  ELSEIF @chkAutoStatusStatus == "warn" THEN
   SET @chkAutoStatusIcon = "warn"
  ELSE
   SET @chkAutoStatusIcon = "fail"
  ENDIF
 ENDIF
ENDIF
