if (stackBuildPage == "true" && queryKeyPage) {
 dispQueryTextVal = truncQueryDisplay(lookupQueryText(queryKeyPage));
}
Platform.Variable.SetValue("@dispQueryText", dispQueryTextVal);


var stackAutoGuid = strTrim(Platform.Variable.GetValue("@dispAutomationGuid") || "");
var stackAutoName = strTrim(Platform.Variable.GetValue("@dispAutomationName") || "");
if (stackBuildPage == "true") {
 var jidForAutoGuid = Platform.Variable.GetValue("@jid") || "";
 if (!stackAutoGuid && jidForAutoGuid) {
   stackAutoGuid = logDeField(jidForAutoGuid, "automationGuid");
 }
 if (!stackAutoName && jidForAutoGuid) {
   stackAutoName = logDeField(jidForAutoGuid, "automationName");
 }
 Platform.Variable.SetValue("@dispAutomationGuid", stackAutoGuid);
 Platform.Variable.SetValue("@dispAutomationName", stackAutoName);
}


var showChecklist = Platform.Variable.GetValue("@showChecklist") || "";
if (showChecklist == "1") {
 var chkAuthOk = Platform.Variable.GetValue("@authOk") || "";
 var chkToken = Platform.Variable.GetValue("@accessToken") || "";
 var chkSubdomain = Platform.Variable.GetValue("@subdomain") || "";
 var chkJid = Platform.Variable.GetValue("@jid") || "";
 var chkIsStack = Platform.Variable.GetValue("@isStackBuild") || "";
 var chkLogEmailId = strTrim(Platform.Variable.GetValue("@dispEmailId") || "");
 var chkLogDeId = strTrim(Platform.Variable.GetValue("@dispDeId") || "");
 var chkLogCampaignId = logDeField(chkJid, "campaignId");
 var campStatus = "fail";
 var campMsg = "No campaign id on build log.";
 var campId = chkLogCampaignId;
 var pubStatus = "skip";
 var pubMsg = "No journey to inspect.";
 var emailIdStatus = "skip";
 var emailIdMsg = "No journey email step.";
 var jbEmailId = "";
 var subjectStatus = "skip";
 var subjectMsg = "No subject on journey email step.";
 var subjectVal = "";
 var bccStatus = "skip";
 var bccMsg = "No journey email step.";
 var bccVal = "";
 var trackStatus = "skip";
 var trackMsg = "No journey guid on this build.";
 var sfStepsStatus = "skip";
 var sfStepsMsg = "No journey to inspect.";
 var analyticsStatus = "skip";
 var analyticsMsg = "No journey to inspect.";
 var entryStatus = "skip";
 var entryMsg = "No journey entry trigger.";
 var jbEntryId = "";
 var senderStatus = "skip";
 var senderMsg = "No sender profile on journey email step.";
 var senderProfileName = "";
 var senderProfileId = "";
 var autoNameStatus = "skip";
 var autoNameMsg = "";
 var queryStatus = "skip";
 var queryMsg = "";
 var autoStatusStatus = "skip";
 var autoStatusMsg = "";
 if (chkLogCampaignId && chkLogCampaignId.substring(0, 3) === "701") {
   campStatus = "pass";
   campMsg = "Campaign id recorded at build time.";
 } else if (chkLogCampaignId) {
   campStatus = "fail";
   campMsg = "Build log campaign id is not a valid Salesforce campaign (701...).";
 }
 if (chkIsStack == "true") {
   var autoName = logDeField(chkJid, "automationName");
   var queryKey = strTrim(Platform.Variable.GetValue("@dispQueryKey") || "");
   if (autoName) {
     autoNameStatus = "pass";
     autoNameMsg = autoName;
   } else {
     autoNameStatus = "fail";
     autoNameMsg = "No automation name on build log.";
   }
   if (queryKey) {
     var queryText = dispQueryTextVal || lookupQueryText(queryKey);
     queryText = truncQueryDisplay(queryText);
     if (queryText) {
       queryStatus = "pass";
       queryMsg = queryKey;
     } else {
       queryStatus = "fail";
       queryMsg = "Query not found for key " + queryKey + ".";
     }
     Platform.Variable.SetValue("@chkQueryText", queryText);
   } else {
     Platform.Variable.SetValue("@chkQueryText", "");
   }
   autoStatusStatus = "fail";
   autoStatusMsg = "No automation id on build log.";
   if (chkAuthOk == "true" && chkToken && chkSubdomain) {
     var autoId = logDeField(chkJid, "automationGuid");
     if (autoId) {
       try {
         var autoGetUrl =
           "https://" +
           chkSubdomain +
           ".rest.marketingcloudapis.com/automation/v1/automations/" +
           encodeURIComponent(autoId);
         var autoGetReq = new Script.Util.HttpRequest(autoGetUrl);
         autoGetReq.emptyContentHandling = 0;
         autoGetReq.retries = 1;
         autoGetReq.continueOnError = true;
         autoGetReq.setHeader("Authorization", "Bearer " + chkToken);
         autoGetReq.method = "GET";
         var autoGetResp = autoGetReq.send();
         if (autoGetResp.statusCode == 200 || autoGetResp.statusCode == 201) {
           var autoObj = null;
           try {
             autoObj = Platform.Function.ParseJSON(String(autoGetResp.content));
           } catch (autoPe) {
             autoObj = null;
           }
           if (autoObj) {
             var autoLabel = automationStatusLabel(autoObj.statusId, autoObj.status);
             autoStatusMsg = autoLabel;
             autoStatusStatus = automationStatusLevel(autoLabel);
           } else {
             autoStatusStatus = "fail";
             autoStatusMsg = "Could not parse automation response.";
           }
         } else {
           autoStatusStatus = "fail";
           autoStatusMsg = "Automation GET HTTP " + autoGetResp.statusCode + ".";
         }
       } catch (autoErr) {
         autoStatusStatus = "fail";
         autoStatusMsg =
           "Automation lookup failed: " + (autoErr.message || String(autoErr));
       }
     }
   }
 }
 if (chkAuthOk == "true" && chkToken && chkSubdomain) {
   var jidStr = chkJid ? String(chkJid) : "";
   var jidPref = jidStr.length >= 7 ? jidStr.substring(0, 7).toLowerCase() : "";
   if (jidStr && jidPref !== "email:") {
     try {
       var jGetUrl =
         "https://" +
         chkSubdomain +
         ".rest.marketingcloudapis.com/interaction/v1/interactions/" +
         encodeURIComponent(strTrim(jidStr)) +
         "?extras=all";
       var jGetReq = new Script.Util.HttpRequest(jGetUrl);
       jGetReq.emptyContentHandling = 0;
       jGetReq.retries = 1;
       jGetReq.continueOnError = true;
       jGetReq.setHeader("Authorization", "Bearer " + chkToken);
       jGetReq.method = "GET";
       var jGetResp = jGetReq.send();
       if (jGetResp.statusCode == 200 || jGetResp.statusCode == 201) {
         var jObj = null;
         try {
           jObj = Platform.Function.ParseJSON(String(jGetResp.content));
         } catch (pe) {
           jObj = null;
         }
         if (jObj) {
           var jStatus = jObj.status ? String(jObj.status) : "";
           var lastPub = jObj.lastPublishedDate ? String(jObj.lastPublishedDate) : "";
           var neverPublished = !lastPub || lastPub.indexOf("0001-01-01") >= 0;
           if (jStatus === "Published" && !neverPublished) {
             pubStatus = "pass";
             pubMsg = "Published (last " + lastPub.substring(0, 10) + ").";
           } else if (jStatus === "Draft" || neverPublished) {
             pubStatus = "fail";
             pubMsg = "Journey is " + (jStatus || "Draft") + " - publish before send.";
           } else {
             pubStatus = "fail";
             pubMsg = "Journey status: " + (jStatus || "unknown") + ".";
           }
           var triggers = jObj.triggers || [];
           if (triggers.length > 0 && triggers[0]) {
             var trigMeta = triggers[0].metaData || {};
             jbEntryId = strTrim(trigMeta.eventDefinitionId || "");
             if (!jbEntryId && triggers[0].arguments) {
               jbEntryId = strTrim(triggers[0].arguments.eventDefinitionId || "");
             }
           }
           if (jbEntryId) {
             if (chkLogDeId && chkLogDeId.toUpperCase() !== "N/A" && jbEntryId === chkLogDeId) {
               entryStatus = "pass";
               entryMsg = "Entry event matches build log (" + jbEntryId + ").";
             } else {
               entryStatus = "pass";
               entryMsg = "Entry event id: " + jbEntryId + ".";
               if (chkLogDeId && chkLogDeId.toUpperCase() !== "N/A") {
                 entryMsg = entryMsg + " DE customer key logged as " + chkLogDeId + ".";
               }
             }
           } else {
             entryStatus = "fail";
             entryMsg = "No eventDefinitionId on journey trigger.";
           }
           var analytics = null;
           if (jObj.defaults && jObj.defaults.properties) {
             analytics = jObj.defaults.properties.analyticsTracking || null;
           }
           if (analytics && analytics.enabled === true) {
             var domains = analytics.urlDomainsToTrack || [];
             var domainList = [];
             var di;
             for (di = 0; di < domains.length; di++) {
               if (domains[di]) {
                 domainList.push(String(domains[di]));
               }
             }
             if (domainList.length > 0) {
               analyticsStatus = "pass";
               analyticsMsg =
                 String(analytics.analyticsType || "analytics") +
                 " enabled, domains: " +
                 domainList.join(", ");
             } else {
               analyticsStatus = "fail";
               analyticsMsg = "Analytics enabled but urlDomainsToTrack is empty.";
             }
           } else {
             analyticsStatus = "skip";
             analyticsMsg = "Analytics tracking not enabled on journey.";
           }
           var emailFound = false;
           var trackingOn = false;
           var sfTypes = [];
           var sfSeen = {};
           if (jObj.activities && jObj.activities.length) {
             var ai;
             for (ai = 0; ai < jObj.activities.length; ai++) {
               var act = jObj.activities[ai];
               if (!act) {
                 continue;
               }
               if (act.type === "EMAILV2" || act.type === "EMAIL") {
                 emailFound = true;
                 var ts =
                   (act.configurationArguments &&
                     act.configurationArguments.triggeredSend) ||
                   {};
                 if (ts.isSalesforceTracking === true) {
                   trackingOn = true;
                 }
                 if (!jbEmailId && ts.emailId) {
                   jbEmailId = String(ts.emailId);
                 }
                 if (!subjectVal) {
                   subjectVal = strTrim(
                     ts.emailSubject || ts.dynamicEmailSubject || ""
                   );
                 }
                 if (!bccVal && ts.bccEmail) {
                   bccVal = strTrim(String(ts.bccEmail));
                 }
                 if (!senderProfileId && ts.senderProfileId) {
                   senderProfileId = strTrim(String(ts.senderProfileId));
                 }
               }
               if (act.type === "SALESCLOUDACTIVITY") {
                 var objMap =
                   act.arguments && act.arguments.objectMap
                     ? act.arguments.objectMap.objects
                     : null;
                 if (objMap && objMap.length) {
                   var oi;
                   for (oi = 0; oi < objMap.length; oi++) {
                     var sfType = objMap[oi] && objMap[oi].type ? String(objMap[oi].type) : "";
                     if (sfType && !sfSeen[sfType]) {
                       sfSeen[sfType] = true;
                       sfTypes.push(sfType);
                     }
                   }
                 } else {
                   if (!sfSeen.SALESCLOUDACTIVITY) {
                     sfSeen.SALESCLOUDACTIVITY = true;
                     sfTypes.push("SALESCLOUDACTIVITY");
                   }
                 }
               }
             }
           }
           if (jbEmailId) {
             emailIdMsg = jbEmailId;
             if (chkLogEmailId) {
               emailIdStatus = jbEmailId === chkLogEmailId ? "pass" : "fail";
             } else {
               emailIdStatus = "pass";
             }
           } else if (emailFound) {
             emailIdStatus = "fail";
             emailIdMsg = "Email activity found but emailId is missing.";
           } else {
             emailIdStatus = "fail";
             emailIdMsg = "No EMAILV2 activity in journey.";
           }
           if (subjectVal) {
             var subjU = subjectVal.toUpperCase();
             if (
               subjU.indexOf("UAT") === 0 ||
               subjU.indexOf("UAT ") === 0 ||
               subjU.indexOf("UAT-") === 0 ||
               subjU.indexOf("UAT:") === 0
             ) {
               subjectStatus = "fail";
               subjectMsg = "Subject looks like UAT: " + subjectVal;
             } else {
               subjectStatus = "pass";
               subjectMsg = subjectVal;
             }
           } else if (emailFound) {
             subjectStatus = "fail";
             subjectMsg = "Email step has no subject configured.";
           }
           if (emailFound) {
             if (bccVal) {
               bccStatus = "pass";
               bccMsg = bccVal;
             } else {
               bccStatus = "skip";
               bccMsg = "No BCC configured.";
             }
           }
           if (senderProfileId) {
             var spRow = lookupSenderProfile(senderProfileId);
             var spName = "";
             var spFrom = "";
             var spAddr = "";
             if (spRow) {
               spName = strTrim(spRow.Name || "");
               spFrom = strTrim(spRow.FromName || "");
               spAddr = strTrim(spRow.FromAddress || "");
             }
             senderProfileName = spName || spFrom || "";
             if (spFrom && spAddr) {
               senderMsg = spFrom + " <" + spAddr + ">";
             } else if (spAddr) {
               senderMsg = spAddr;
             } else if (spFrom) {
               senderMsg = spFrom;
             } else if (spName) {
               senderMsg = spName;
             }
             if (senderProfileName || senderMsg) {
               senderStatus = "pass";
             } else {
               senderStatus = "fail";
               senderMsg =
                 "Could not resolve sender profile for id " +
                 senderProfileId +
                 ".";
             }
           } else if (emailFound) {
             senderStatus = "fail";
             senderMsg = "Sender profile id missing on email step.";
           }
           if (sfTypes.length > 0) {
             sfStepsStatus = "pass";
             sfStepsMsg = sfTypes.join(", ");
           } else {
             sfStepsStatus = "fail";
             sfStepsMsg = "No SALESCLOUDACTIVITY steps found.";
           }
           if (!emailFound) {
             trackStatus = "fail";
             trackMsg = "No email activity found in journey.";
           } else if (trackingOn && sfTypes.length > 0) {
             trackStatus = "pass";
             trackMsg = "Send to Salesforce tracking is enabled.";
           } else if (trackingOn) {
             trackStatus = "fail";
             trackMsg = "Email tracking is on but no Salesforce activity step was found.";
           } else {
             trackStatus = "fail";
             trackMsg = "Send to Salesforce tracking is off on the email step.";
           }
         } else {
           pubStatus = "fail";
           pubMsg = "Could not parse journey response.";
           trackStatus = "fail";
           trackMsg = "Could not parse journey response.";
         }
       } else {
         pubStatus = "fail";
         pubMsg = "Journey GET HTTP " + jGetResp.statusCode + ".";
         trackStatus = "fail";
         trackMsg = "Journey GET HTTP " + jGetResp.statusCode + ".";
         emailIdStatus = "fail";
         emailIdMsg = "Journey GET failed.";
         entryStatus = "fail";
         entryMsg = "Journey GET failed.";
       }
     } catch (jErr) {
       pubStatus = "fail";
       pubMsg = "Journey lookup failed: " + (jErr.message || String(jErr));
       trackStatus = "fail";
       trackMsg = "Journey lookup failed.";
     }
   } else if (jidPref === "email:") {
     pubStatus = "skip";
     pubMsg = "Email-only build (no Journey Builder canvas).";
     trackStatus = "skip";
     trackMsg = "Not applicable for email-only builds.";
   }
 } else {
   var authFailMsg =
     Platform.Variable.GetValue("@chkCampaignMsg") ||
     "Auth failed - checklist could not run.";
   pubStatus = "fail";
   pubMsg = authFailMsg;
   emailIdStatus = "fail";
   emailIdMsg = authFailMsg;
   subjectStatus = "fail";
   subjectMsg = authFailMsg;
   bccStatus = "fail";
   bccMsg = authFailMsg;
   trackStatus = "fail";
   trackMsg = authFailMsg;
   sfStepsStatus = "fail";
   sfStepsMsg = authFailMsg;
   analyticsStatus = "fail";
   analyticsMsg = authFailMsg;
   entryStatus = "fail";
   entryMsg = authFailMsg;
   senderStatus = "fail";
   senderMsg = authFailMsg;
   if (!chkLogCampaignId) {
     campMsg = authFailMsg;
   }
   if (chkIsStack == "true") {
     autoNameStatus = "fail";
     autoNameMsg = authFailMsg;
     queryStatus = "fail";
     queryMsg = authFailMsg;
     autoStatusStatus = "fail";
     autoStatusMsg = authFailMsg;
   }
 }
 if (chkLogEmailId) {
  emailIdMsg = chkLogEmailId;
 } else if (jbEmailId) {
  emailIdMsg = jbEmailId;
 } else if (!emailIdMsg || emailIdMsg === "No journey email step.") {
  emailIdMsg = "—";
 }
 emailIdStatus = "pass";
 Platform.Variable.SetValue("@chkCampaignId", campId);
 Platform.Variable.SetValue("@chkCampaignStatus", campStatus);
 Platform.Variable.SetValue("@chkCampaignMsg", campMsg);
 Platform.Variable.SetValue("@chkPublishStatus", pubStatus);
 Platform.Variable.SetValue("@chkPublishMsg", pubMsg);
 Platform.Variable.SetValue("@chkEmailIdStatus", emailIdStatus);
 Platform.Variable.SetValue("@chkEmailIdMsg", emailIdMsg);
 Platform.Variable.SetValue("@chkJbEmailId", jbEmailId);
 Platform.Variable.SetValue("@chkSubjectStatus", subjectStatus);
 Platform.Variable.SetValue("@chkSubjectMsg", subjectMsg);
 Platform.Variable.SetValue("@chkSubjectVal", subjectVal);
 Platform.Variable.SetValue("@chkBccStatus", bccStatus);
 Platform.Variable.SetValue("@chkBccMsg", bccMsg);
 Platform.Variable.SetValue("@chkBccVal", bccVal);
 Platform.Variable.SetValue("@chkTrackingStatus", trackStatus);
 Platform.Variable.SetValue("@chkTrackingMsg", trackMsg);
 Platform.Variable.SetValue("@chkSfStepsStatus", sfStepsStatus);
 Platform.Variable.SetValue("@chkSfStepsMsg", sfStepsMsg);
 Platform.Variable.SetValue("@chkAnalyticsStatus", analyticsStatus);
 Platform.Variable.SetValue("@chkAnalyticsMsg", analyticsMsg);
 Platform.Variable.SetValue("@chkEntryStatus", entryStatus);
 Platform.Variable.SetValue("@chkEntryMsg", entryMsg);
 Platform.Variable.SetValue("@chkJbEntryId", jbEntryId);
 Platform.Variable.SetValue("@chkSenderStatus", senderStatus);
 Platform.Variable.SetValue("@chkSenderMsg", senderMsg);
 Platform.Variable.SetValue("@chkSenderName", senderProfileName);
 Platform.Variable.SetValue("@chkSenderProfileId", senderProfileId);
 Platform.Variable.SetValue("@chkAutoNameStatus", autoNameStatus);
 Platform.Variable.SetValue("@chkAutoNameMsg", autoNameMsg);
 Platform.Variable.SetValue("@chkQueryStatus", queryStatus);
 Platform.Variable.SetValue("@chkQueryMsg", queryMsg);
 Platform.Variable.SetValue("@chkAutoStatusStatus", autoStatusStatus);
 Platform.Variable.SetValue("@chkAutoStatusMsg", autoStatusMsg);
}


Platform.Variable.SetValue("@step3bResult", step3bResult);
</script>
%%[
VAR @combinedLog, @trailBody


IF (@attemptJourneyAction == "true") AND (@journeyActionOk == "true") AND NOT Empty(@journeyActionNewStatus) THEN
 UpsertDE(
  @DETAIL_EXTERNAL_KEY_DE,
  1,
  "journeyId", @jid,
  "journeyStatus", Substring(@journeyActionNewStatus,1,50),
  "updateDate", Now()
 )
 SET @dispJourneyStatus = @journeyActionNewStatus
 SET @journeyBtnLabel = "Activate Journey"
 SET @journeyBtnClass = "btn-activate"
 SET @journeyActionConfirm = "Publish and activate this journey?"
 IF Lowercase(@dispJourneyStatus) == "running" OR Lowercase(@dispJourneyStatus) == "published" THEN
  SET @journeyBtnLabel = "Stop Journey"
  SET @journeyBtnClass = "btn-stop"
  SET @journeyActionConfirm = "Stop this journey? Contacts already in flight may still receive messages."
 ENDIF
 SET @journeyStatusColor = "#6366f1"
 IF Lowercase(@dispJourneyStatus) == "draft" THEN
  SET @journeyStatusColor = "#9ca3af"
 ELSEIF Lowercase(@dispJourneyStatus) == "running" OR Lowercase(@dispJourneyStatus) == "published" THEN
  SET @journeyStatusColor = "#10b981"
 ELSEIF Lowercase(@dispJourneyStatus) == "stopped" THEN
  SET @journeyStatusColor = "#f59e0b"
 ENDIF
ENDIF


IF (@attemptAutomationAction == "true") AND (@automationActionOk == "true") AND NOT Empty(@automationActionNewStatus) THEN
 UpsertDE(
  @DETAIL_EXTERNAL_KEY_DE,
  1,
  "journeyId", @jid,
  "automationStatus", Substring(@automationActionNewStatus,1,50),
  "automationActive", IIF(@automationAction == "activate", "true", "false"),
  "updateDate", Now()
 )
 SET @dispAutomationStatus = @automationActionNewStatus
 SET @dispAutomationActive = IIF(@automationAction == "activate", "true", "false")
 SET @automationStatusColor = "#6366f1"
 IF Lowercase(@dispAutomationStatus) == "paused" THEN
  SET @automationStatusColor = "#f59e0b"
 ELSEIF Lowercase(@dispAutomationStatus) == "ready" OR Lowercase(@dispAutomationStatus) == "scheduled" OR Lowercase(@dispAutomationStatus) == "running" OR Lowercase(@dispAutomationStatus) == "waiting" THEN
  SET @automationStatusColor = "#10b981"
 ENDIF
 SET @showAutomationActivate = "false"
 SET @showAutomationPause = "false"
 IF @dispAutomationActive == "true" THEN
  SET @showAutomationPause = "true"
 ELSE
  SET @showAutomationActivate = "true"
 ENDIF
ENDIF


IF (@attemptJourneyAction == "true") AND (@authOk != "true") AND Empty(@journeyActionMsg) THEN
 SET @journeyActionMsg = IIF(NOT Empty(@resultText), @resultText, "Could not authenticate to SFMC.")
ENDIF


IF @attemptPurgeBuild == "true" THEN
SET @trailBody = IIF(NOT Empty(@purgeBuildLog), @purgeBuildLog, Concat("Purge incomplete. ",Substring(IIF(NOT Empty(@step3bResult), @step3bResult, ""),1,620)))
ELSE
SET @trailBody = IIF(NOT Empty(@step3bResult), Substring(@step3bResult, 1, 620), "")
ENDIF


SET @combinedLog = Concat(IIF(NOT Empty(@resultText), Concat(@resultText," "), ""), Substring(IIF(NOT Empty(@trailBody), @trailBody, ""),1,6200))


SET @surveyDeleteLog = ""
SET @willRemoveBuildLog = "false"
IF (@attemptPurgeBuild == "true") AND (@authOk == "true") AND (@purgeEmailOk == "true") THEN
SET @willRemoveBuildLog = "true"
ELSEIF (@attemptDeleteAsset == "true") AND (@authOk == "true") AND (IndexOf(IIF(NOT Empty(@step3bResult), @step3bResult, ""),"OK - Email deleted") > 0) THEN
SET @willRemoveBuildLog = "true"
ENDIF
IF (@willRemoveBuildLog == "true") AND (@isSurveyBuild == "true") THEN
SET @surveyPurgeId = @dispSurveyId
IF NOT Empty(@surveyPurgeId) AND @surveyPurgeId != "N/A" THEN
SET @surveyDelResponses = DeleteData("SST_SP_Survey_Responses_DE", "SurveyID", @surveyPurgeId)
SET @surveyDelQuestions = DeleteData("SST_SP_Survey_Questions_DE", "SurveyID", @surveyPurgeId)
SET @surveyDelMaster = DeleteData("SST_SP_Surveys_Master_DE", "SurveyID", @surveyPurgeId)
SET @surveyDeleteLog = Concat("[Survey ", @surveyPurgeId, "] Responses=", @surveyDelResponses, " Questions=", @surveyDelQuestions, " Master=", @surveyDelMaster, ".")
ELSE
SET @surveyDeleteLog = "[Survey] SKIP - no surveyId on build log."
ENDIF
ENDIF
IF NOT Empty(@surveyDeleteLog) THEN
SET @combinedLog = Concat(@combinedLog, " ", @surveyDeleteLog)
ENDIF
SET @purgeResultHasFail = "0"
IF IndexOf(@combinedLog,"FAILED") > 0 OR IndexOf(@combinedLog,"DELETE FAILED") > 0 THEN
 SET @purgeResultHasFail = "1"
ENDIF


IF (@attemptPurgeBuild == "true") AND (@authOk == "true") AND (@purgeEmailOk == "true") THEN
SET @analyticsDelCnt = DeleteData(@DETAIL_EXTERNAL_KEY_DE,"journeyId",@jid)
SET @pageStatus = "purged"
ELSEIF (@attemptPurgeBuild == "true") AND (@authOk == "true") AND (@purgeEmailOk != "true") THEN
SET @pageStatus = "purge_partial"
ELSEIF (@attemptDeleteAsset == "true") AND (@authOk == "true") AND (IndexOf(IIF(NOT Empty(@step3bResult), @step3bResult, ""),"OK - Email deleted") > 0) THEN
SET @analyticsDelCnt = DeleteData(@DETAIL_EXTERNAL_KEY_DE,"journeyId",@jid)
SET @pageStatus = "deleted"
ENDIF
IF @pageStatus == "purge_partial" THEN
 SET @purgeResultHasFail = "1"
ENDIF
VAR @jidIsJbGuid
SET @jidIsJbGuid = IIF(Substring(IIF(NOT Empty(@jid), @jid, ""),1,7) == "email:", "false","true")
VAR @jidForJbUi
SET @jidForJbUi = IIF(Substring(IIF(NOT Empty(@jid), @jid, ""),1,7) == "email:", "", @jid)
IF @showChecklist == "1" THEN
 IF @chkCampaignStatus == "pass" THEN
  SET @chkCampaignIcon = "pass"
 ELSEIF @chkCampaignStatus == "skip" THEN
  SET @chkCampaignIcon = "skip"
 ELSE
  SET @chkCampaignIcon = "fail"
 ENDIF
 IF @chkPublishStatus == "pass" THEN
  SET @chkPublishIcon = "pass"
 ELSEIF @chkPublishStatus == "skip" THEN
  SET @chkPublishIcon = "skip"
 ELSE
  SET @chkPublishIcon = "fail"
 ENDIF
 IF @chkEntryStatus == "pass" THEN
  SET @chkEntryIcon = "pass"
 ELSEIF @chkEntryStatus == "skip" THEN
  SET @chkEntryIcon = "skip"
 ELSE
  SET @chkEntryIcon = "fail"
 ENDIF
 SET @chkEmailIdIcon = "pass"
 IF @chkSubjectStatus == "pass" THEN
  SET @chkSubjectIcon = "pass"
 ELSEIF @chkSubjectStatus == "skip" THEN
  SET @chkSubjectIcon = "skip"
 ELSE
  SET @chkSubjectIcon = "fail"
 ENDIF
