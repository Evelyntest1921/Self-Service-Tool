IF RowCount(@surveyUrlRows) > 0 THEN
 SET @surveyUrlRow = Row(@surveyUrlRows,1)
 SET @SURVEY_STAGE_URL = Field(@surveyUrlRow,"create")
 SET @SURVEY_ANALYTICS_URL = Field(@surveyUrlRow,"analytics")
ENDIF
SET @MC_CLOUD = "https://mc.s13.exacttarget.com/cloud/"
SET @DETAIL_EXTERNAL_KEY_DE = "Bd_journey_analytics"
