<script runat="server" language="javascript">
Platform.Load("core", "1");


function strTrim(s) {
 if (s == null || s === undefined) {
   return "";
 }
 return String(s).replace(/^\s+|\s+$/g, "");
}


function lookupSenderProfile(profileId) {
 if (!profileId) {
   return null;
 }
 try {
   var prox = new Script.Util.WSProxy();
   var props = ["Name", "FromName", "FromAddress", "CustomerKey", "ObjectID"];
   var byKey = prox.retrieve("SenderProfile", props, {
     Property: "CustomerKey",
     SimpleOperator: "equals",
     Value: String(profileId)
   });
   if (byKey && byKey.Results && byKey.Results.length > 0) {
     return byKey.Results[0];
   }
   var byObj = prox.retrieve("SenderProfile", props, {
     Property: "ObjectID",
     SimpleOperator: "equals",
     Value: String(profileId)
   });
   if (byObj && byObj.Results && byObj.Results.length > 0) {
     return byObj.Results[0];
   }
 } catch (spErr) {}
 return null;
}


function lookupQueryText(queryKey) {
 if (!queryKey) {
   return "";
 }
 try {
   var proxQ = new Script.Util.WSProxy();
   var qdRes = proxQ.retrieve(
     "QueryDefinition",
     ["CustomerKey", "QueryText", "Name"],
     {
       Property: "CustomerKey",
       SimpleOperator: "equals",
       Value: String(queryKey)
     }
   );
   if (qdRes && qdRes.Results && qdRes.Results.length > 0) {
     return String(qdRes.Results[0].QueryText || "");
   }
 } catch (qLookupErr) {}
 return "";
}


function truncQueryDisplay(text) {
 var s = String(text || "");
 if (s.length > 4000) {
   return s.substring(0, 4000) + "...";
 }
 return s;
}


function automationStatusLabel(statusId, statusText) {
 if (statusText) {
   return String(statusText);
 }
 var map = {
   0: "Unknown",
   1: "Building",
   2: "Ready",
   3: "Running",
   4: "Paused",
   5: "Stopped",
   6: "Scheduled",
   7: "Waiting",
   8: "Inactive"
 };
 if (statusId !== undefined && statusId !== null && map[statusId]) {
   return map[statusId];
 }
 if (statusId !== undefined && statusId !== null) {
   return "Status " + statusId;
 }
 return "Unknown";
}


function automationStatusIsOk(label) {
 var u = String(label || "").toLowerCase();
 return (
   u === "ready" ||
   u === "scheduled" ||
   u === "running" ||
   u === "waiting"
 );
}


function automationStatusLevel(label) {
 if (automationStatusIsOk(label)) {
   return "pass";
 }
 if (String(label || "").toLowerCase() === "paused") {
   return "warn";
 }
 return "fail";
}


function logDeField(jid, colName) {
 if (!jid || !colName) {
   return "";
 }
 try {
   var rows = Platform.Function.LookupRows(
     "Bd_journey_analytics",
     "journeyId",
     String(jid)
   );
   if (!rows || rows.length === 0) {
     return "";
   }
   var val = rows[0][colName];
   if (val === undefined || val === null) {
     return "";
   }
   return strTrim(String(val));
 } catch (logDeEx) {
   return "";
 }
}


var authOk = Platform.Variable.GetValue("@authOk") || "";
var accessToken = Platform.Variable.GetValue("@accessToken") || "";
var subdomain = Platform.Variable.GetValue("@subdomain") || "";
var attemptDeleteAsset =
 Platform.Variable.GetValue("@attemptDeleteAsset") || "";
var attemptPurgeBuild =
 Platform.Variable.GetValue("@attemptPurgeBuild") || "";
var deleteEmailFromPost =
 Platform.Variable.GetValue("@deleteEmailFromPost") || "";
var jidClean = Platform.Variable.GetValue("@jid") || "";
var dispDeIdVal = Platform.Variable.GetValue("@dispDeId") || "";
var dispDeNameVal = Platform.Variable.GetValue("@dispDeName") || "";
var step3bResult = " Step 3b SKIP — Nothing to delete.";
var purgeParts = [];


function truncLog(part) {
 if (purgeParts.join(" ").length > 8200 && part.length > 200) {
   part = String(part).substring(0, 200) + "...";
 }
 purgeParts.push(String(part || ""));
}


function deleteEmailAsset(sdom, tok, aid) {
 if (!aid) {
   truncLog("[Email asset] SKIP - no asset id.");
   return false;
 }
 try {
   var deleteUrl =
     "https://" +
     sdom +
     ".rest.marketingcloudapis.com/asset/v1/content/assets/" +
     aid;
   var deleteReq = new Script.Util.HttpRequest(deleteUrl);
   deleteReq.emptyContentHandling = 0;
   deleteReq.retries = 2;
   deleteReq.continueOnError = true;
   deleteReq.setHeader("Authorization", "Bearer " + tok);
   deleteReq.method = "DELETE";
   var deleteResp = deleteReq.send();
   if (deleteResp.statusCode == 200 || deleteResp.statusCode == 204) {
     truncLog("[Email asset] DELETE OK.");
     return true;
   }
   truncLog("[Email asset] DELETE HTTP " + deleteResp.statusCode + ".");
 } catch (e0) {
   truncLog("[Email asset] FAILED: " + (e0.message || String(e0)));
 }
 return false;
}


function purgeHttpDel(sdom, tok, url) {
 try {
   var req = new Script.Util.HttpRequest(url);
   req.emptyContentHandling = 0;
   req.continueOnError = true;
   req.setHeader("Authorization", "Bearer " + tok);
   req.method = "DELETE";
   var resp = req.send();
   return resp.statusCode;
 } catch (purgeDelEx) {
   return 0;
 }
}


try {
 if (attemptPurgeBuild == "true" && authOk == "true" && accessToken && subdomain) {
   var isStackPurge = Platform.Variable.GetValue("@isStackBuild") || "";
   if (isStackPurge == "true") {
     var autoDelId = strTrim(Platform.Variable.GetValue("@dispAutomationGuid") || "");
     var queryDelKey = strTrim(Platform.Variable.GetValue("@dispQueryKey") || "");
     if (!autoDelId && jidClean) {
       autoDelId = logDeField(jidClean, "automationGuid");
     }
     if (!queryDelKey && jidClean) {
       queryDelKey = logDeField(jidClean, "queryKey");
     }
     if (autoDelId) {
       var autoDelUrl =
         "https://" +
         subdomain +
         ".rest.marketingcloudapis.com/automation/v1/automations/" +
         encodeURIComponent(String(autoDelId));
       var autoSt = purgeHttpDel(subdomain, accessToken, autoDelUrl);
       if (autoSt == 200 || autoSt == 204) {
         truncLog("[Automation] DELETE OK.");
       } else {
         truncLog("[Automation] DELETE HTTP " + autoSt + ".");
       }
     } else {
       truncLog("[Automation] SKIP - no id on build log.");
     }
     if (queryDelKey) {
       try {
         var proxQDel = new Script.Util.WSProxy();
         var qdDelRes = proxQDel.retrieve(
           "QueryDefinition",
           ["ObjectID"],
           {
             Property: "CustomerKey",
             SimpleOperator: "equals",
             Value: String(queryDelKey)
           }
         );
         if (
           qdDelRes &&
           qdDelRes.Results &&
           qdDelRes.Results.length > 0 &&
           qdDelRes.Results[0].ObjectID
         ) {
           var qDelResult = proxQDel.deleteItem("QueryDefinition", {
             ObjectID: String(qdDelRes.Results[0].ObjectID)
           });
           if (
             qDelResult &&
             qDelResult.Results &&
             qDelResult.Results.length > 0 &&
             qDelResult.Results[0].Status == "OK"
           ) {
             truncLog("[Query] DELETE OK.");
           } else {
             truncLog("[Query] deleteItem did not report OK.");
           }
         } else {
           truncLog("[Query] SKIP - not found for key " + queryDelKey + ".");
         }
       } catch (qDelEx) {
         truncLog("[Query] FAILED: " + (qDelEx.message || String(qDelEx)));
       }
     } else {
       truncLog("[Query] SKIP - no key on build log.");
     }
   }
   var jStr = jidClean ? String(jidClean) : "";
   var pref = jStr.length >= 7 ? jStr.substring(0, 7).toLowerCase() : "";
   if (jStr && pref != "email:") {
     try {
       var jUrl =
         "https://" +
         subdomain +
         ".rest.marketingcloudapis.com/interaction/v1/interactions/" +
         strTrim(jStr);
       var jr = new Script.Util.HttpRequest(jUrl);
       jr.emptyContentHandling = 0;
       jr.continueOnError = true;
       jr.setHeader("Authorization", "Bearer " + accessToken);
       jr.method = "DELETE";
       var jrsp = jr.send();
       truncLog("[Journey] DELETE HTTP " + jrsp.statusCode + ".");
     } catch (jex) {
       truncLog("[Journey] DELETE fault: " + (jex.message || String(jex)));
     }
   } else {
     truncLog("[Journey] SKIP - email-only build (no journey GUID in log key).");
   }


   var evRaw = dispDeIdVal ? strTrim(dispDeIdVal) : "";
   var evU = evRaw.toUpperCase();
   if (evRaw && evU != "N/A") {
     var dataExtensionId = null;
     try {
       var getEventUrl =
         "https://" +
         subdomain +
         ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" +
         evRaw;
       var getReq = new Script.Util.HttpRequest(getEventUrl);
       getReq.emptyContentHandling = 0;
       getReq.continueOnError = true;
       getReq.setHeader("Authorization", "Bearer " + accessToken);
       getReq.method = "GET";
       var getResp = getReq.send();
       if ((getResp.statusCode == 200 || getResp.statusCode == 201) && getResp.content) {
         var evtObj = Platform.Function.ParseJSON(String(getResp.content));
         dataExtensionId =
           evtObj.dataExtensionId || evtObj.dataExtensionID || null;
       }
       var eventDeleteUrl =
         "https://" +
         subdomain +
         ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" +
         evRaw;
       var evDel = new Script.Util.HttpRequest(eventDeleteUrl);
       evDel.emptyContentHandling = 0;
       evDel.continueOnError = true;
       evDel.setHeader("Authorization", "Bearer " + accessToken);
       evDel.method = "DELETE";
       var evRsp = evDel.send();
       if (evRsp.statusCode == 200 || evRsp.statusCode == 204) {
         truncLog("[Entry event definition] DELETE OK.");
       } else {
         truncLog("[Entry event definition] DELETE HTTP " + evRsp.statusCode + ".");
       }
     } catch (evEx) {
       truncLog("[Entry event definition] FAILED: " + (evEx.message || String(evEx)));
     }
     try {
       var deObjId = dataExtensionId;
       if (!deObjId && dispDeNameVal) {
         var proxLook = new Script.Util.WSProxy();
         var deFilter = {
           Property: "Name",
           SimpleOperator: "equals",
           Value: String(dispDeNameVal)
         };
         var rde = proxLook.retrieve("DataExtension", ["ObjectID"], deFilter);
         if (
           rde &&
           rde.Results &&
           rde.Results.length > 0 &&
           rde.Results[0].ObjectID
         ) {
           deObjId = rde.Results[0].ObjectID;
         }
       }
       if (deObjId) {
         var proxDel = new Script.Util.WSProxy();
         var deResult = proxDel.deleteItem(
           "DataExtension",
           { ObjectID: deObjId }
         );
         if (
           deResult &&
           deResult.Results &&
           deResult.Results.length > 0 &&
           deResult.Results[0].Status == "OK"
         ) {
           truncLog("[Entry data extension] DELETED.");
         } else {
           truncLog("[Entry data extension] deleteItem did not report OK.");
         }
