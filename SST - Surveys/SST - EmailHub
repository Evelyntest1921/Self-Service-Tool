    background: #0060f5;
    color: #ffffff;
    cursor: pointer;
    font-size: 16px;
    padding: 12px 18px;
  }
  .notice {
    margin-bottom: 20px;
    padding: 14px 16px;
    border: 1px solid;
    background: #ffffff;
  }
  .success {
    border-color: #24a148;
    color: #0e6027;
  }
  .error {
    border-color: #da1e28;
    color: #a2191f;
  }
  .small {
    color: #525252;
    font-size: 13px;
    line-height: 18px;
  }
</style>
<main class="page">
  <div class="card">
    <h1>SST Email Hub</h1>
    <p>Create the survey email layout without AMPscript first. Leave Category ID blank for this test.</p>
    <script runat="server">
      function bodyHtmlSafe(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }
      var bodyResultStatus = Platform.Variable.GetValue("@emailHubResultStatus");
      var bodyResultMessage = Platform.Variable.GetValue("@emailHubResultMessage");
      var bodyAssetId = Platform.Variable.GetValue("@emailHubAssetId");
      var bodyCustomerKey = Platform.Variable.GetValue("@emailHubCustomerKey");
      if (bodyResultStatus) {
        Write('<div class="notice ' + bodyHtmlSafe(bodyResultStatus) + '"><strong>' + bodyHtmlSafe(bodyResultMessage) + '</strong>');
        if (bodyAssetId) {
          Write('<br>Asset ID: ' + bodyHtmlSafe(bodyAssetId));
        }
        if (bodyCustomerKey) {
          Write('<br>Customer Key: ' + bodyHtmlSafe(bodyCustomerKey));
        }
        Write('</div>');
      }
    </script>
    <form method="post">
      <input type="hidden" name="createEmail" value="1">
      <label for="accessKey">Access Key</label>
      <input id="accessKey" name="accessKey" type="password" autocomplete="off">
      <label for="emailName">Email Name</label>
      <input id="emailName" name="emailName" value="SST Survey Email">
      <label for="subject">Subject</label>
      <input id="subject" name="subject" value="Got 2 minutes? Tell us what you think">
      <label for="preheader">Preheader</label>
      <input id="preheader" name="preheader" value="We would appreciate a few minutes of your time.">
      <label for="categoryId">Content Builder Category ID Optional</label>
      <input id="categoryId" name="categoryId" value="">
      <label for="textBody">Text Body</label>
      <textarea id="textBody" name="textBody">We're always looking for ways to improve, and your input makes a big difference. Take Survey: https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt?id=SURV_20260612_102301</textarea>
      <button type="submit">Create Survey Email</button>
    </form>
    <p class="small">Testing key is <strong>10</strong>. Keep Category ID blank unless you have a valid Content Builder folder ID from this BU.</p>
  </div>
</main>
