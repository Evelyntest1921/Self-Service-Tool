<script runat="server">
Platform.Load("core", "1");

var adminCreateKey = "";
var defaultCategoryId = 556442;
var defaultSubject = "Got 2 minutes? Tell us what you think";
var defaultTextBody = "We're always looking for ways to improve, and your input makes a big difference. Take Survey: https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt";
var resultStatus = "";
var resultMessage = "";

function formField(name) {
  var value = "";
  try {
    value = Platform.Request.GetFormField(name);
  } catch (e) {}
  return value || "";
}

function trimValue(value) {
  return String(value || "").replace(/^\s+|\s+$/g, "");
}

function encodeHtml(value) {
  return String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function shortKey() {
  return String(Platform.Function.GUID()).replace(/-/g, "").substring(0, 8);
}

function ampBlock(lines) {
  var pct = String.fromCharCode(37, 37);
  return pct + "[" + lines.join("\n") + "]" + pct;
}

function ampValue(value) {
  var pct = String.fromCharCode(37, 37);
  return pct + "=" + value + "=" + pct;
}

function ampToken(value) {
  var pct = String.fromCharCode(37, 37);
  return pct + value + pct;
}

function buildEmailHtml() {
  var greetingAmp = ampBlock([
    "SET @firstName = AttributeValue(\"FirstName\")",
    "IF EMPTY(@firstName) THEN",
    "  SET @firstName = AttributeValue(\"CampaignMember:Common:FirstName\")",
    "ENDIF",
    "IF EMPTY(@firstName) THEN",
    "  SET @fullGreeting = \"Hello,\"",
    "ELSE",
    "  SET @fullGreeting = Concat(\"Hello \", @firstName, \",\")",
    "ENDIF"
  ]);
  var footerAmp = ampValue("ContentBlockByKey(\"Email_Footer_2407\")");
  var surveyContactToken = ampToken("CampaignMember:Common:Id");
  return [
    "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#eaeaea;margin:0;padding:0;\">",
    "<tr><td align=\"center\">",
    "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#393939;\">",
    "<tr><td style=\"padding:30px;\"><a href=\"https://magmutual.com/\" target=\"_blank\"><img src=\"https://image.go.magmutual.com/lib/fe2f11747364047d731d72/m/1/MM_PrimaryLogo_Reversed.png\" alt=\"MagMutual\" width=\"200\" border=\"0\" style=\"display:block;\"></a></td></tr>",
    "<tr><td style=\"padding:20px 45px 30px;font-family:Arial,Helvetica,sans-serif;color:#ffffff;\"><h1 style=\"font-size:32px;line-height:36px;margin:0;color:#ffffff;\">Got 2 minutes? Tell us what you think</h1></td></tr>",
    "</table>",
    "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;\">",
    "<tr><td style=\"padding:30px;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:20px;color:#161616;\">",
    "<div style=\"display:none;\">" + greetingAmp + "</div>",
    "<p style=\"margin:0 0 20px;\">" + ampValue("v(@fullGreeting)") + "</p>",
    "<p style=\"margin:0 0 20px;\">We're always looking for ways to improve, and your input makes a big difference. We've put together a short survey and would really appreciate a few minutes of your time.</p>",
    "<table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td bgcolor=\"#0060F5\" style=\"background:#0060F5;\"><a href=\"https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt?id=SURV_20260612_102301&contact=" + surveyContactToken + "\" target=\"_blank\" style=\"display:block;padding:10px 99px 10px 10px;color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;text-decoration:none;\">Take Survey</a></td></tr></table>",
    "<p style=\"margin:20px 0 0;\">If you have any questions or run into any issues, don't hesitate to reach out.</p>",
    "<p style=\"margin:20px 0 0;\">Thank you for sharing your thoughts &mdash; we truly value your feedback!</p>",
    "<p style=\"margin:20px 0 0;\">Best regards,<br>MagMutual Insurance</p>",
    "</td></tr>",
    "</table>",
    footerAmp,
    "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;\">",
    "<tr><td align=\"center\" style=\"padding:20px 30px;font-family:Arial,Helvetica,sans-serif;font-size:9px;line-height:12px;color:#808080;\">",
    ampToken("Member_Busname") + " " + ampToken("Member_Addr") + "<br>" + ampToken("Member_City") + ", " + ampToken("Member_State") + ", " + ampToken("Member_PostalCode"),
    "</td></tr>",
    "</table>",
    "</td></tr>",
    "</table>"
  ].join("");
}

function createEmail(name, subject, textBody, categoryId) {
  var prox = new Script.Util.WSProxy();
  var email = {
    Name: name,
    Subject: subject,
    HTMLBody: buildEmailHtml(),
    TextBody: textBody,
    CharacterSet: "utf-8",
    CategoryID: categoryId,
    CategoryIDSpecified: true
  };
  return prox.createItem("Email", email);
}

if (formField("createEmail") == "1") {
  try {
    if (!adminCreateKey) {
      throw "Set adminCreateKey at the top of this CloudPage before creating emails.";
    }
    if (formField("accessKey") != adminCreateKey) {
      throw "Invalid access key.";
    }
    var emailName = trimValue(formField("emailName"));
    if (!emailName) {
      emailName = "SST Survey Email " + shortKey();
    }
    var subject = trimValue(formField("subject"));
    if (!subject) {
      subject = defaultSubject;
    }
    var textBody = trimValue(formField("textBody"));
    if (!textBody) {
      textBody = defaultTextBody;
    }
    var categoryId = parseInt(trimValue(formField("categoryId")) || defaultCategoryId, 10);
    if (isNaN(categoryId)) {
      throw "Folder Category ID must be a number.";
    }
    var response = createEmail(emailName, subject, textBody, categoryId);
    if (response && response.Status == "OK") {
      resultStatus = "success";
      resultMessage = "Email created successfully.";
    } else if (response && response.Results && response.Results.length > 0) {
      resultStatus = "error";
      resultMessage = String(response.Results[0].StatusMessage || response.Results[0].ErrorCode || "Email create failed.");
    } else {
      resultStatus = "error";
      resultMessage = "Email create failed.";
    }
  } catch (ex) {
    resultStatus = "error";
    resultMessage = String(ex);
  }
}

Platform.Variable.SetValue("@emailHubResultStatus", resultStatus);
Platform.Variable.SetValue("@emailHubResultMessage", resultMessage);
</script>
<style>
  body {
    margin: 0;
    background: #f4f4f4;
    color: #161616;
    font-family: Arial, Helvetica, sans-serif;
  }
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 20px;
  }
  .card {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    padding: 24px;
  }
  h1 {
    margin: 0 0 8px;
    font-size: 28px;
    line-height: 34px;
  }
  p {
    margin: 0 0 18px;
    line-height: 22px;
  }
  label {
    display: block;
    margin: 16px 0 6px;
    font-weight: bold;
  }
  input,
  textarea {
    box-sizing: border-box;
    width: 100%;
    border: 1px solid #8d8d8d;
    padding: 10px;
    font: inherit;
  }
  textarea {
    min-height: 90px;
  }
  button {
    margin-top: 20px;
    border: 0;
    background: #0060f5;
    color: #ffffff;
    cursor: pointer;
    font-size: 16px;
    padding: 12px 18px;
  }
  .notice {
    margin-bottom: 20px;
    padding: 14px 16px;
    border: 1px solid;
    background: #ffffff;
  }
  .success {
    border-color: #24a148;
    color: #0e6027;
  }
  .error {
    border-color: #da1e28;
    color: #a2191f;
  }
  .small {
    color: #525252;
    font-size: 13px;
    line-height: 18px;
  }
</style>
<main class="page">
  <div class="card">
    <h1>SST Email Hub</h1>
    <p>Create the survey email using the SOAP Email object.</p>
    <script runat="server">
      function bodyEncodeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }
      var bodyResultStatus = Platform.Variable.GetValue("@emailHubResultStatus");
      var bodyResultMessage = Platform.Variable.GetValue("@emailHubResultMessage");
      if (bodyResultStatus) {
        Write('<div class="notice ' + bodyEncodeHtml(bodyResultStatus) + '"><strong>' + bodyEncodeHtml(bodyResultMessage) + '</strong></div>');
      }
    </script>
    <form method="post">
      <input type="hidden" name="createEmail" value="1">
      <label for="accessKey">Access Key</label>
      <input id="accessKey" name="accessKey" type="password" autocomplete="off">
      <label for="emailName">Email Name</label>
      <input id="emailName" name="emailName" value="SST Survey Email">
      <label for="subject">Subject</label>
      <input id="subject" name="subject" value="Got 2 minutes? Tell us what you think">
      <label for="categoryId">Email Studio Folder Category ID</label>
      <input id="categoryId" name="categoryId" value="556442">
      <label for="textBody">Text Body</label>
      <textarea id="textBody" name="textBody">We're always looking for ways to improve, and your input makes a big difference. Take Survey: https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt</textarea>
      <button type="submit">Create Email</button>
    </form>
    <p class="small">Set <strong>adminCreateKey</strong> at the top of this CloudPage before deploying. This version creates a legacy Email Studio email, matching the SOAP documentation in your reference file.</p>
  </div>
</main>
