        "</table>",
        "</td></tr>",
        "</table>"
      ].join("");
    }
    function updatePreview() {
      el("previewSubject").textContent = el("subject").value || "Got 2 minutes? Tell us what you think";
      el("previewPreheader").textContent = el("preheader").value || "We would appreciate a few minutes of your time.";
      el("emailPreviewFrame").srcdoc = previewHtml();
    }
    ["subject", "preheader", "textBody"].forEach(function (id) {
      el(id).addEventListener("input", updatePreview);
    });
    updatePreview();
  })();
</script>
