<script runat="server">
Platform.Load("core", "1");

var adminCreateKey = "";
var authDataExtension = "SFMC_AUTH";
var authUser = "Admin";
var defaultCategoryId = 556442;
var defaultSubject = "Got 2 minutes? Tell us what you think";
var defaultPreheader = "We would appreciate a few minutes of your time.";
var defaultTextBody = "We're always looking for ways to improve, and your input makes a big difference. Take Survey: https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt";
var resultStatus = "";
var resultMessage = "";
var createdAssetId = "";
var createdCustomerKey = "";

function formField(name) {
  var value = "";
  try {
    value = Request.GetFormField(name);
  } catch (e) {}
  if (!value) {
    try {
      value = Platform.Request.GetFormField(name);
    } catch (e2) {}
  }
  return value || "";
}

function trimValue(value) {
  return String(value || "").replace(/^\s+|\s+$/g, "");
}

function htmlEncode(value) {
  return String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function safeJson(value) {
  return Platform.Function.Stringify(value);
}

function parseJson(value) {
  return Platform.Function.ParseJSON(String(value || "{}"));
}

function compactGuid() {
  return Platform.Function.GUID().replace(/-/g, "");
}

function lookupAuth() {
  var rows = Platform.Function.LookupRows(authDataExtension, "User", authUser);
  if (!rows || rows.length < 1) {
    throw new Error("Missing SFMC_AUTH row for User=Admin.");
  }
  var row = rows[0];
  var clientId = trimValue(row.clientId);
  var clientSecret = trimValue(row.clientSecret);
  var subdomain = trimValue(row.subdomain);
  var accountId = trimValue(row.accountId);
  if (!clientId || !clientSecret || !subdomain) {
    throw new Error("SFMC_AUTH row must include clientId, clientSecret, and subdomain.");
  }
  return {
    clientId: clientId,
    clientSecret: clientSecret,
    subdomain: subdomain,
    accountId: accountId
  };
}

function requestToken(auth) {
  var payload = {
    grant_type: "client_credentials",
    client_id: auth.clientId,
    client_secret: auth.clientSecret
  };
  if (auth.accountId) {
    payload.account_id = auth.accountId;
  }
  var req = new Script.Util.HttpRequest("https://" + auth.subdomain + ".auth.marketingcloudapis.com/v2/token");
  req.emptyContentHandling = 0;
  req.retries = 2;
  req.continueOnError = true;
  req.contentType = "application/json";
  req.method = "POST";
  req.postData = safeJson(payload);
  var resp = req.send();
  var body = String(resp.content || "");
  if (resp.statusCode != 200) {
    throw new Error("Auth failed with HTTP " + resp.statusCode + ": " + body);
  }
  var parsed = parseJson(body);
  if (!parsed.access_token) {
    throw new Error("Auth succeeded but no access_token was returned.");
  }
  return parsed.access_token;
}

function postAsset(subdomain, token, payload) {
  var req = new Script.Util.HttpRequest("https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets");
  req.emptyContentHandling = 0;
  req.retries = 2;
  req.continueOnError = true;
  req.contentType = "application/json";
  req.setHeader("Authorization", "Bearer " + token);
  req.method = "POST";
  req.postData = safeJson(payload);
  var resp = req.send();
  var body = String(resp.content || "");
  if (resp.statusCode != 200 && resp.statusCode != 201) {
    throw new Error("Create email failed with HTTP " + resp.statusCode + ": " + body);
  }
  return parseJson(body);
}

if (formField("createEmail") == "1") {
  try {
    if (!adminCreateKey) {
      throw new Error("Set adminCreateKey at the top of this CloudPage before creating emails.");
    }
    if (formField("accessKey") != adminCreateKey) {
      throw new Error("Invalid access key.");
    }
    var emailHtml = formField("emailHtml");
    if (!trimValue(emailHtml)) {
      throw new Error("Email HTML was not submitted.");
    }
    var emailName = trimValue(formField("emailName"));
    if (!emailName) {
      emailName = "SST Survey Email " + compactGuid().substring(0, 8);
    }
    var subject = trimValue(formField("subject"));
    if (!subject) {
      subject = defaultSubject;
    }
    var preheader = trimValue(formField("preheader"));
    if (!preheader) {
      preheader = defaultPreheader;
    }
    var textBody = trimValue(formField("textBody"));
    if (!textBody) {
      textBody = defaultTextBody;
    }
    var categoryId = parseInt(trimValue(formField("categoryId")) || defaultCategoryId, 10);
    if (isNaN(categoryId)) {
      throw new Error("Folder Category ID must be a number.");
    }
    createdCustomerKey = "sst-survey-email-" + compactGuid();
    var auth = lookupAuth();
    var token = requestToken(auth);
    var payload = {
      name: emailName,
      customerKey: createdCustomerKey,
      assetType: {
        id: 208,
        name: "htmlemail"
      },
      category: {
        id: categoryId
      },
      channels: {
        email: true,
        web: false
      },
      views: {
        html: {
          content: emailHtml
        },
        text: {
          content: textBody
        },
        subjectline: {
          content: subject
        },
        preheader: {
          content: preheader
        }
      },
      data: {
        email: {
          options: {
            characterEncoding: "utf-8"
          }
        }
      }
    };
    var created = postAsset(auth.subdomain, token, payload);
    createdAssetId = String(created.id || "");
    resultStatus = "success";
    resultMessage = "Email created successfully.";
  } catch (ex) {
    resultStatus = "error";
    resultMessage = ex.message || String(ex);
  }
}

Platform.Variable.SetValue("@emailHubResultStatus", resultStatus);
Platform.Variable.SetValue("@emailHubResultMessage", resultMessage);
Platform.Variable.SetValue("@emailHubAssetId", createdAssetId);
Platform.Variable.SetValue("@emailHubCustomerKey", createdCustomerKey);
</script>
