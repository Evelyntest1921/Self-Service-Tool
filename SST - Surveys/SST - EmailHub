if (formValue("createEmail") == "1") {
  try {
    if (!adminCreateKey) {
      throw "Set adminCreateKey at the top of this CloudPage before creating emails.";
    }
    if (formValue("accessKey") != adminCreateKey) {
      throw "Invalid access key.";
    }
    var emailName = clean(formValue("emailName"));
    if (!emailName) {
      emailName = "SST Survey Email " + guidKey().substring(0, 8);
    }
    var subject = clean(formValue("subject"));
    if (!subject) {
      subject = "Got 2 minutes? Tell us what you think";
    }
    var preheader = clean(formValue("preheader"));
    if (!preheader) {
      preheader = "We would appreciate a few minutes of your time.";
    }
    var textBody = clean(formValue("textBody"));
    if (!textBody) {
      textBody = "We're always looking for ways to improve, and your input makes a big difference. Take Survey: https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt?id=SURV_20260612_102301";
    }
    createdCustomerKey = "sst-" + guidKey();
    var payload = {
      name: emailName,
      customerKey: createdCustomerKey,
      assetType: {
        id: 208,
        name: "htmlemail"
      },
      channels: {
        email: true,
        web: false
      },
      views: {
        html: {
          content: minimalEmailHtml(textBody)
        },
        text: {
          content: textBody
        },
        subjectline: {
          content: subject
        },
        preheader: {
          content: preheader
        }
      },
      data: {
        email: {
          options: {
            characterEncoding: "utf-8"
          }
        }
      }
    };
    var categoryId = clean(formValue("categoryId"));
    if (categoryId) {
      var parsedCategoryId = parseInt(categoryId, 10);
      if (isNaN(parsedCategoryId)) {
        throw "Category ID must be a number when provided.";
      }
      payload.category = {
        id: parsedCategoryId
      };
    }
    var auth = getAuthConfig();
    var token = getAccessToken(auth);
    var created = createAsset(auth, token, payload);
    createdAssetId = String(created.id || "");
    resultStatus = "success";
    resultMessage = "Minimal Content Builder email created.";
  } catch (ex) {
    resultStatus = "error";
    resultMessage = String(ex);
  }
}

