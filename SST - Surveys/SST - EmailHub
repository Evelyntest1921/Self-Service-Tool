<script runat="server">
Platform.Load("core", "1");

var adminCreateKey = "10";
var resultStatus = "";
var resultMessage = "";
var createdAssetId = "";
var createdCustomerKey = "";

function formValue(name) {
  var value = "";
  try {
    value = Platform.Request.GetFormField(name);
  } catch (e) {}
  return value || "";
}

function clean(value) {
  return String(value || "").replace(/^\s+|\s+$/g, "");
}

function htmlSafe(value) {
  return String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function asJson(value) {
  return Platform.Function.Stringify(value);
}

function fromJson(value) {
  return Platform.Function.ParseJSON(String(value || "{}"));
}

function guidKey() {
  return String(Platform.Function.GUID()).replace(/-/g, "");
}

function ampBlock(lines) {
  var pct = String.fromCharCode(37, 37);
  return pct + "[" + lines.join("\n") + "]" + pct;
}

function ampValue(value) {
  var pct = String.fromCharCode(37, 37);
  return pct + "=" + value + "=" + pct;
}

function field(row, name) {
  if (!row) return "";
  return row[name] || row[String(name)] || "";
}

function getAuthConfig() {
  var rows = Platform.Function.LookupRows("SFMC_AUTH", "User", "Admin");
  if (!rows || rows.length < 1) {
    throw "Missing SFMC_AUTH row for User=Admin.";
  }
  var row = rows[0];
  var clientId = clean(field(row, "clientId"));
  var clientSecret = clean(field(row, "clientSecret"));
  var subdomain = clean(field(row, "subdomain"));
  var accountId = clean(field(row, "accountId"));
  if (!clientId || !clientSecret || !subdomain) {
    throw "SFMC_AUTH must include clientId, clientSecret, and subdomain.";
  }
  return {
    clientId: clientId,
    clientSecret: clientSecret,
    subdomain: subdomain,
    accountId: accountId
  };
}

function getAccessToken(auth) {
  var payload = {
    grant_type: "client_credentials",
    client_id: auth.clientId,
    client_secret: auth.clientSecret
  };
  if (auth.accountId) {
    payload.account_id = auth.accountId;
  }
  var req = new Script.Util.HttpRequest("https://" + auth.subdomain + ".auth.marketingcloudapis.com/v2/token");
  req.emptyContentHandling = 0;
  req.retries = 2;
  req.continueOnError = true;
  req.contentType = "application/json";
  req.method = "POST";
  req.postData = asJson(payload);
  var resp = req.send();
  var body = String(resp.content || "");
  if (resp.statusCode != 200) {
    throw "Auth HTTP " + resp.statusCode + ": " + body;
  }
  var parsed = fromJson(body);
  if (!parsed.access_token) {
    throw "Auth response did not include access_token.";
  }
  return parsed.access_token;
}

function createAsset(auth, token, payload) {
  var req = new Script.Util.HttpRequest("https://" + auth.subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets");
  req.emptyContentHandling = 0;
  req.retries = 2;
  req.continueOnError = true;
  req.contentType = "application/json";
  req.setHeader("Authorization", "Bearer " + token);
  req.method = "POST";
  req.postData = asJson(payload);
  var resp = req.send();
  var body = String(resp.content || "");
  if (resp.statusCode != 200 && resp.statusCode != 201) {
    throw "Asset create HTTP " + resp.statusCode + ": " + body;
  }
  return fromJson(body);
}

function minimalEmailHtml() {
  var personalizationAmp = ampBlock([
    "SET @surveyContactId = AttributeValue(\"CampaignMember:Common:Id\")",
    "IF EMPTY(@surveyContactId) THEN",
    "  SET @surveyContactId = AttributeValue(\"ContactId\")",
    "ENDIF",
    "IF EMPTY(@surveyContactId) THEN",
    "  SET @surveyContactId = _subscriberKey",
    "ENDIF",
    "SET @firstName = AttributeValue(\"CampaignMember:Common:FirstName\")",
    "IF EMPTY(@firstName) THEN",
    "  SET @firstName = AttributeValue(\"FirstName\")",
    "ENDIF",
    "IF EMPTY(@firstName) THEN",
    "  SET @fullGreeting = \"Hello,\"",
    "ELSE",
    "  SET @fullGreeting = Concat(\"Hello \", @firstName, \",\")",
    "ENDIF"
  ]);
  var surveyContactId = ampValue("v(@surveyContactId)");
  var fullGreeting = ampValue("v(@fullGreeting)");
  var footerBlock = ampValue("ContentBlockByKey(\"Email_Footer_2407\")");
  return [
    "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#eaeaea;margin:0;padding:0;\">",
    "<tr><td align=\"center\">",
    "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#393939;\">",
    "<tr><td style=\"padding:30px;\"><a href=\"https://magmutual.com/\" target=\"_blank\"><img src=\"https://image.go.magmutual.com/lib/fe2f11747364047d731d72/m/1/MM_PrimaryLogo_Reversed.png\" alt=\"MagMutual\" width=\"200\" border=\"0\" style=\"display:block;\"></a></td></tr>",
    "<tr><td style=\"padding:20px 45px 30px;font-family:Arial,Helvetica,sans-serif;color:#ffffff;\"><h1 style=\"font-size:32px;line-height:36px;margin:0;color:#ffffff;\">Got 2 minutes? Tell us what you think</h1></td></tr>",
    "</table>",
    "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;\">",
    "<tr><td style=\"padding:30px;font-family:Arial,Helvetica,sans-serif;color:#161616;font-size:14px;line-height:20px;\">",
    "<div style=\"display:none;\">" + personalizationAmp + "</div>",
    "<p style=\"margin:0 0 20px;\">" + fullGreeting + "</p>",
    "<p style=\"margin:0 0 20px;\">We're always looking for ways to improve, and your input makes a big difference. We've put together a short survey and would really appreciate a few minutes of your time.</p>",
    "<table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td bgcolor=\"#0060F5\" style=\"background:#0060F5;\"><a href=\"https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt?id=SURV_20260612_102301&contact=" + surveyContactId + "\" target=\"_blank\" style=\"display:block;padding:10px 99px 10px 10px;color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;text-decoration:none;\">Take Survey</a></td></tr></table>",
    "<p style=\"margin:20px 0 0;\">If you have any questions or run into any issues, don't hesitate to reach out.</p>",
    "<p style=\"margin:20px 0 0;\">Thank you for sharing your thoughts &mdash; we truly value your feedback!</p>",
    "<p style=\"margin:20px 0 0;\">Best regards,<br>MagMutual Insurance</p>",
    "</td></tr>",
    "</table>",
    footerBlock,
    "</td></tr>",
    "</table>"
  ].join("");
}

if (formValue("createEmail") == "1") {
  try {
    if (!adminCreateKey) {
      throw "Set adminCreateKey at the top of this CloudPage before creating emails.";
    }
    if (formValue("accessKey") != adminCreateKey) {
      throw "Invalid access key.";
    }
    var emailName = clean(formValue("emailName"));
    if (!emailName) {
      emailName = "SST Survey Email " + guidKey().substring(0, 8);
    }
    var subject = clean(formValue("subject"));
    if (!subject) {
      subject = "Got 2 minutes? Tell us what you think";
    }
    var preheader = clean(formValue("preheader"));
    if (!preheader) {
      preheader = "We would appreciate a few minutes of your time.";
    }
    var textBody = clean(formValue("textBody"));
    if (!textBody) {
      textBody = "We're always looking for ways to improve, and your input makes a big difference. Take Survey: https://cloud.go.magmutual.com/MH1Fdf3gkpiWmvpt?id=SURV_20260612_102301";
    }
    createdCustomerKey = "sst-" + guidKey();
    var payload = {
      name: emailName,
      customerKey: createdCustomerKey,
      assetType: {
        id: 208,
        name: "htmlemail"
      },
      channels: {
        email: true,
        web: false
      },
      views: {
        html: {
          content: minimalEmailHtml()
        },
        text: {
          content: textBody
        },
        subjectline: {
          content: subject
        },
        preheader: {
          content: preheader
        }
      },
      data: {
        email: {
          options: {
            characterEncoding: "utf-8"
          }
        }
      }
    };
    var categoryId = clean(formValue("categoryId"));
    if (categoryId) {
      var parsedCategoryId = parseInt(categoryId, 10);
      if (isNaN(parsedCategoryId)) {
        throw "Category ID must be a number when provided.";
      }
      payload.category = {
        id: parsedCategoryId
      };
    }
    var auth = getAuthConfig();
    var token = getAccessToken(auth);
    var created = createAsset(auth, token, payload);
    createdAssetId = String(created.id || "");
    resultStatus = "success";
    resultMessage = "Minimal Content Builder email created.";
  } catch (ex) {
    resultStatus = "error";
    resultMessage = String(ex);
  }
}

Platform.Variable.SetValue("@emailHubResultStatus", resultStatus);
Platform.Variable.SetValue("@emailHubResultMessage", resultMessage);
Platform.Variable.SetValue("@emailHubAssetId", createdAssetId);
Platform.Variable.SetValue("@emailHubCustomerKey", createdCustomerKey);
</script>
<style>
  body {
    margin: 0;
    background: #f4f4f4;
    color: #161616;
    font-family: Arial, Helvetica, sans-serif;
  }
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 20px;
  }
  .card {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    padding: 24px;
  }
  h1 {
    margin: 0 0 8px;
    font-size: 28px;
    line-height: 34px;
  }
  p {
    margin: 0 0 18px;
    line-height: 22px;
  }
  label {
    display: block;
    margin: 16px 0 6px;
    font-weight: bold;
  }
  input,
  textarea {
    box-sizing: border-box;
    width: 100%;
    border: 1px solid #8d8d8d;
    padding: 10px;
    font: inherit;
  }
  textarea {
    min-height: 90px;
  }
  button {
    margin-top: 20px;
