<script runat="server">
Platform.Load("core", "1");

var adminCreateKey = "";
var resultStatus = "";
var resultMessage = "";
var createdAssetId = "";
var createdCustomerKey = "";

function formValue(name) {
  var value = "";
  try {
    value = Platform.Request.GetFormField(name);
  } catch (e) {}
  return value || "";
}

function clean(value) {
  return String(value || "").replace(/^\s+|\s+$/g, "");
}

function htmlSafe(value) {
  return String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function asJson(value) {
  return Platform.Function.Stringify(value);
}

function fromJson(value) {
  return Platform.Function.ParseJSON(String(value || "{}"));
}

function guidKey() {
  return String(Platform.Function.GUID()).replace(/-/g, "");
}

function field(row, name) {
  if (!row) return "";
  return row[name] || row[String(name)] || "";
}

function getAuthConfig() {
  var rows = Platform.Function.LookupRows("SFMC_AUTH", "User", "Admin");
  if (!rows || rows.length < 1) {
    throw "Missing SFMC_AUTH row for User=Admin.";
  }
  var row = rows[0];
  var clientId = clean(field(row, "clientId"));
  var clientSecret = clean(field(row, "clientSecret"));
  var subdomain = clean(field(row, "subdomain"));
  var accountId = clean(field(row, "accountId"));
  if (!clientId || !clientSecret || !subdomain) {
    throw "SFMC_AUTH must include clientId, clientSecret, and subdomain.";
  }
  return {
    clientId: clientId,
    clientSecret: clientSecret,
    subdomain: subdomain,
    accountId: accountId
  };
}

function getAccessToken(auth) {
  var payload = {
    grant_type: "client_credentials",
    client_id: auth.clientId,
    client_secret: auth.clientSecret
  };
  if (auth.accountId) {
    payload.account_id = auth.accountId;
  }
  var req = new Script.Util.HttpRequest("https://" + auth.subdomain + ".auth.marketingcloudapis.com/v2/token");
  req.emptyContentHandling = 0;
  req.retries = 2;
  req.continueOnError = true;
  req.contentType = "application/json";
  req.method = "POST";
  req.postData = asJson(payload);
  var resp = req.send();
  var body = String(resp.content || "");
  if (resp.statusCode != 200) {
    throw "Auth HTTP " + resp.statusCode + ": " + body;
  }
  var parsed = fromJson(body);
  if (!parsed.access_token) {
    throw "Auth response did not include access_token.";
  }
  return parsed.access_token;
}

function createAsset(auth, token, payload) {
  var req = new Script.Util.HttpRequest("https://" + auth.subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets");
  req.emptyContentHandling = 0;
  req.retries = 2;
  req.continueOnError = true;
  req.contentType = "application/json";
  req.setHeader("Authorization", "Bearer " + token);
  req.method = "POST";
  req.postData = asJson(payload);
  var resp = req.send();
  var body = String(resp.content || "");
  if (resp.statusCode != 200 && resp.statusCode != 201) {
    throw "Asset create HTTP " + resp.statusCode + ": " + body;
  }
  return fromJson(body);
}

function minimalEmailHtml() {
  return [
    "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#f4f4f4;\">",
    "<tr><td align=\"center\" style=\"padding:30px;\">",
    "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;\">",
    "<tr><td style=\"padding:30px;font-family:Arial,Helvetica,sans-serif;color:#161616;\">",
    "<h1 style=\"margin:0 0 20px;font-size:28px;line-height:34px;color:#161616;\">Email Hub Test</h1>",
    "<p style=\"margin:0 0 20px;font-size:16px;line-height:24px;\">This is a simplified Content Builder email created from the Email Hub CloudPage.</p>",
    "<a href=\"https://magmutual.com/\" target=\"_blank\" style=\"display:inline-block;background:#0060F5;color:#ffffff;padding:12px 18px;text-decoration:none;font-size:16px;\">Test Link</a>",
    "</td></tr>",
    "</table>",
    "</td></tr>",
    "</table>"
  ].join("");
}

if (formValue("createEmail") == "1") {
  try {
    if (!adminCreateKey) {
      throw "Set adminCreateKey at the top of this CloudPage before creating emails.";
    }
    if (formValue("accessKey") != adminCreateKey) {
      throw "Invalid access key.";
    }
    var emailName = clean(formValue("emailName"));
    if (!emailName) {
      emailName = "SST Email Hub Test " + guidKey().substring(0, 8);
    }
    var subject = clean(formValue("subject"));
    if (!subject) {
      subject = "Email Hub Test";
    }
    var preheader = clean(formValue("preheader"));
    if (!preheader) {
      preheader = "Testing Content Builder email creation.";
    }
    var textBody = clean(formValue("textBody"));
    if (!textBody) {
      textBody = "This is a simplified Content Builder email created from the Email Hub CloudPage.";
    }
    createdCustomerKey = "sst-email-hub-test-" + guidKey();
    var payload = {
      name: emailName,
      customerKey: createdCustomerKey,
      assetType: {
        id: 208,
        name: "htmlemail"
      },
      channels: {
        email: true,
        web: false
      },
      views: {
        html: {
          content: minimalEmailHtml()
        },
        text: {
          content: textBody
        },
        subjectline: {
          content: subject
        },
        preheader: {
          content: preheader
        }
      },
      data: {
        email: {
          options: {
            characterEncoding: "utf-8"
          }
        }
      }
    };
    var categoryId = clean(formValue("categoryId"));
    if (categoryId) {
      var parsedCategoryId = parseInt(categoryId, 10);
      if (isNaN(parsedCategoryId)) {
        throw "Category ID must be a number when provided.";
      }
      payload.category = {
        id: parsedCategoryId
      };
    }
    var auth = getAuthConfig();
    var token = getAccessToken(auth);
    var created = createAsset(auth, token, payload);
    createdAssetId = String(created.id || "");
    resultStatus = "success";
    resultMessage = "Minimal Content Builder email created.";
  } catch (ex) {
    resultStatus = "error";
    resultMessage = String(ex);
  }
}

Platform.Variable.SetValue("@emailHubResultStatus", resultStatus);
Platform.Variable.SetValue("@emailHubResultMessage", resultMessage);
Platform.Variable.SetValue("@emailHubAssetId", createdAssetId);
Platform.Variable.SetValue("@emailHubCustomerKey", createdCustomerKey);
</script>
<style>
  body {
    margin: 0;
    background: #f4f4f4;
    color: #161616;
    font-family: Arial, Helvetica, sans-serif;
  }
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 20px;
  }
  .card {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    padding: 24px;
  }
  h1 {
    margin: 0 0 8px;
    font-size: 28px;
    line-height: 34px;
  }
  p {
    margin: 0 0 18px;
    line-height: 22px;
  }
  label {
    display: block;
    margin: 16px 0 6px;
    font-weight: bold;
  }
  input,
  textarea {
    box-sizing: border-box;
    width: 100%;
    border: 1px solid #8d8d8d;
    padding: 10px;
    font: inherit;
  }
  textarea {
    min-height: 90px;
  }
  button {
    margin-top: 20px;
