    color: var(--text-secondary);
    display: flex;
    font-size: 14px;
    gap: 8px;
  }
  .breadcrumb-link {
    align-items: center;
    color: var(--primary-color);
    display: inline-flex;
    font-weight: 500;
    text-decoration: none;
  }
  .breadcrumb-current {
    color: var(--gray-900);
    font-weight: 600;
  }
  .card {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 24px;
    width: 100%;
  }
  h1 {
    margin: 0 0 8px;
    font-size: 28px;
    line-height: 34px;
  }
  p {
    margin: 0 0 18px;
    line-height: 22px;
  }
