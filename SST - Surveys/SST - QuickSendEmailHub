<script runat="server">
  function previewJsonSafe(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }
  Write('<textarea id="previewDataJson" hidden>' + previewJsonSafe(Platform.Variable.GetValue("@quickSendEmailPreviewDataJson") || "{}") + '</textarea>');
</script>
<script>
  (function () {
    var previewData = {};
    try {
      previewData = JSON.parse(document.getElementById("previewDataJson").value || "{}");
    } catch (e) {}
    function el(id) {
      return document.getElementById(id);
    }
    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }
    function textToHtml(value) {
      return escapeHtml(value).replace(/\r\n|\r|\n/g, "<br>");
    }
    function previewHtml() {
      var introBody = textToHtml(el("introBody").value);
      var greeting = escapeHtml(previewData.fullGreeting || "Hello,");
      var signatureHtml = previewData.signatureHtml || "<p style=\"margin:20px 0 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:20px;color:#161616;\">Best regards,<br><br><span style=\"font-style:italic;font-family:serif;font-size:20px;\">MagMutual</span><br>MagMutual Insurance</p>";
      return [
        "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;margin:0;padding:30px 0;\">",
        "<tr><td align=\"left\">",
        "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;max-width:100%;\">",
        "<tr><td style=\"font-family:Arial,Helvetica,sans-serif;color:#161616;font-size:14px;line-height:20px;padding:0 20px;\">",
        "<p style=\"margin:0 0 18px;\">" + greeting + "</p>",
        "<p style=\"margin:0 0 18px;\">" + introBody + "</p>",
        signatureHtml,
        "</td></tr>",
        "<tr><td align=\"left\" style=\"padding:30px 20px 0;font-family:Arial,Helvetica,sans-serif;font-size:9px;line-height:12px;color:#808080;\"><u></u><br></td></tr>",
        "</table>",
        "</td></tr>",
        "</table>"
      ].join("");
    }
    function updatePreview() {
      el("previewSubject").textContent = el("subject").value || "Recommended Learning Center resources";
      el("previewPreheader").textContent = el("preheader").value || "Helpful educational resources selected for your practice.";
      el("previewDate").textContent = new Date().toLocaleDateString("en-US", { month: "short", day: "numeric" });
      el("emailPreviewFrame").srcdoc = previewHtml();
    }
    function refreshPreviewData() {
      var params = new URLSearchParams(window.location.search);
      params.set("previewContactId", el("previewContactId").value || "0033l000037NLyuAAG");
      params.delete("previewEnvironment");
      window.location.href = window.location.pathname + "?" + params.toString();
    }
    function togglePreviewContact() {
      var panel = el("previewContactPanel");
      var toggle = el("previewContactToggle");
      var isOpen = panel.className.indexOf("open") > -1;
      panel.className = isOpen ? "preview-contact-panel" : "preview-contact-panel open";
      toggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
    }
    ["subject", "preheader", "introBody"].forEach(function (id) {
      el(id).addEventListener("input", updatePreview);
    });
    el("previewContactToggle").addEventListener("click", togglePreviewContact);
    el("refreshPreviewData").addEventListener("click", refreshPreviewData);
    updatePreview();
  })();
</script>
