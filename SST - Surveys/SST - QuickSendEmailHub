              .replace(/>/g, "&gt;")
              .replace(/"/g, "&quot;");
          }
          var bodyResultStatus = Platform.Variable.GetValue("@quickSendEmailResultStatus");
          var bodyResultMessage = Platform.Variable.GetValue("@quickSendEmailResultMessage");
          var bodyAssetId = Platform.Variable.GetValue("@quickSendEmailAssetId");
