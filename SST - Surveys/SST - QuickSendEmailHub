<script>
  (function () {
    function el(id) {
      return document.getElementById(id);
    }
    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }
    function textToHtml(value) {
      return escapeHtml(value).replace(/\r\n|\r|\n/g, "<br>");
    }
    function imageHtml(imageUrl, linkUrl) {
      if (!imageUrl) return "";
      return "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0 0 18px;\"><tr><td align=\"center\"><a href=\"" + escapeHtml(linkUrl || "https://www.magmutual.com/learning-center/") + "\" target=\"_blank\"><img src=\"" + escapeHtml(imageUrl) + "\" alt=\"Learning Center resource\" border=\"0\" style=\"display:block;max-width:100%;height:auto;\"></a></td></tr></table>";
    }
    function previewHtml() {
      var headline = escapeHtml(el("headline").value || "Recommended Learning Center resources");
      var introBody = textToHtml(el("introBody").value);
      var closingBody = textToHtml(el("closingBody").value);
      return [
        "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;margin:0;padding:30px 0;\">",
        "<tr><td align=\"center\">",
        "<table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;max-width:100%;\">",
        "<tr><td style=\"font-family:Arial,Helvetica,sans-serif;color:#161616;font-size:14px;line-height:20px;padding:0 20px;\">",
        "<p style=\"margin:0 0 18px;\">Hello,</p>",
        "<h1 style=\"font-size:24px;line-height:30px;margin:0 0 18px;color:#161616;\">" + headline + "</h1>",
        "<p style=\"margin:0 0 18px;\">" + introBody + "</p>",
        imageHtml(el("primaryImageUrl").value, el("primaryImageLink").value),
        imageHtml(el("secondaryImageUrl").value, el("secondaryImageLink").value),
        "<p style=\"margin:0 0 18px;\">" + closingBody + "</p>",
        "<p style=\"margin:20px 0 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:20px;color:#161616;\">Best regards,<br><br><span style=\"font-style:italic;font-family:serif;font-size:20px;\">MagMutual</span><br>MagMutual Insurance</p>",
        "</td></tr>",
        "<tr><td align=\"center\" style=\"padding:30px 20px 0;font-family:Arial,Helvetica,sans-serif;font-size:9px;line-height:12px;color:#808080;\"><u>Unsubscribe</u><br>Member business address renders in SFMC send context.</td></tr>",
        "</table>",
        "</td></tr>",
        "</table>"
      ].join("");
    }
    function updatePreview() {
      el("previewSubject").textContent = el("subject").value || "Recommended Learning Center resources";
      el("previewPreheader").textContent = el("preheader").value || "Helpful educational resources selected for your practice.";
      el("previewDate").textContent = new Date().toLocaleDateString("en-US", { month: "short", day: "numeric" });
      el("emailPreviewFrame").srcdoc = previewHtml();
    }
    ["subject", "preheader", "headline", "introBody", "primaryImageUrl", "primaryImageLink", "secondaryImageUrl", "secondaryImageLink", "closingBody"].forEach(function (id) {
      el(id).addEventListener("input", updatePreview);
    });
    updatePreview();
  })();
</script>
