  .btn-create:hover {
    background: #000000;
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }
  .notice {
    margin-bottom: 20px;
    padding: 14px 16px;
    border: 1px solid;
    background: #ffffff;
  }
  .success {
    border-color: #24a148;
    color: #0e6027;
  }
  .error {
    border-color: #da1e28;
    color: #a2191f;
  }
  .hub-grid {
    align-items: start;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(300px, 420px) minmax(0, 1fr);
  }
  .preview-panel {
    border: 1px solid var(--border-color);
    background: #f4f4f4;
    min-height: calc(100vh - 220px);
  }
  .preview-header {
    align-items: center;
    background: #ffffff;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    gap: 12px;
    justify-content: space-between;
    padding: 14px 16px;
  }
  .preview-avatar {
    align-items: center;
    background: #e5e7eb;
    border-radius: 999px;
    color: var(--gray-700);
    display: flex;
    flex: 0 0 40px;
    font-size: 16px;
    font-weight: 700;
    height: 40px;
    justify-content: center;
    width: 40px;
  }
  .preview-message-meta {
    align-items: center;
    display: flex;
    flex: 1;
    gap: 12px;
    justify-content: space-between;
    min-width: 0;
  }
  .preview-message-copy {
    min-width: 0;
  }
  .preview-header strong,
  .preview-header span {
    display: block;
  }
  .preview-header strong {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .preview-header span {
    color: #525252;
    font-size: 13px;
    line-height: 18px;
    margin-top: 4px;
  }
  .preview-date {
    color: var(--gray-500);
    flex: 0 0 auto;
    font-size: 13px;
    line-height: 18px;
    white-space: nowrap;
  }
  .preview-frame {
    border: 0;
    display: block;
    min-height: calc(100vh - 290px);
    width: 100%;
  }
  @media only screen and (max-width: 900px) {
    .dashboard-layout {
      display: block;
    }
