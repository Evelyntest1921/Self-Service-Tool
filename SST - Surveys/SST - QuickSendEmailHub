    font-size: 14px;
    font-weight: 600;
    gap: 12px;
    padding: 10px 12px;
  }
  .nav-link.active {
    background: var(--gray-100);
    color: var(--gray-900);
  }
  .nav-icon {
    flex: 0 0 auto;
  }
  .main-content {
    flex: 1;
    height: 100vh;
    overflow: auto;
    padding: 25px 40px 48px;
  }
