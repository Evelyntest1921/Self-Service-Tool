    %%[
      VAR @activityData, @currentDate, @monthNames, @surveyActivity, @responseActivity
      SET @currentDate = Now()
      SET @monthNames = "Jan,Feb,Mar,Apr,May,Jun,Jul,Aug,Sep,Oct,Nov,Dec"
      
      /* Calculate real dates for the last 12 months */
      VAR @date1, @date2, @date3, @date4, @date5, @date6, @date7, @date8, @date9, @date10, @date11, @date12
      VAR @month1, @month2, @month3, @month4, @month5, @month6, @month7, @month8, @month9, @month10, @month11, @month12
      VAR @surveys1, @surveys2, @surveys3, @surveys4, @surveys5, @surveys6, @surveys7, @surveys8, @surveys9, @surveys10, @surveys11, @surveys12
      VAR @responses1, @responses2, @responses3, @responses4, @responses5, @responses6, @responses7, @responses8, @responses9, @responses10, @responses11, @responses12
      
      /* Generate real dates going back 12 months */
      SET @date12 = @currentDate
      SET @date11 = DateAdd(@currentDate, -1, "M")
      SET @date10 = DateAdd(@currentDate, -2, "M")
      SET @date9 = DateAdd(@currentDate, -3, "M")
      SET @date8 = DateAdd(@currentDate, -4, "M")
      SET @date7 = DateAdd(@currentDate, -5, "M")
      SET @date6 = DateAdd(@currentDate, -6, "M")
      SET @date5 = DateAdd(@currentDate, -7, "M")
      SET @date4 = DateAdd(@currentDate, -8, "M")
      SET @date3 = DateAdd(@currentDate, -9, "M")
      SET @date2 = DateAdd(@currentDate, -10, "M")
      SET @date1 = DateAdd(@currentDate, -11, "M")
      
      /* Format month labels */
      SET @month1 = Format(@date1, "MMM")
      SET @month2 = Format(@date2, "MMM")
      SET @month3 = Format(@date3, "MMM")
      SET @month4 = Format(@date4, "MMM")
      SET @month5 = Format(@date5, "MMM")
      SET @month6 = Format(@date6, "MMM")
      SET @month7 = Format(@date7, "MMM")
      SET @month8 = Format(@date8, "MMM")
      SET @month9 = Format(@date9, "MMM")
      SET @month10 = Format(@date10, "MMM")
      SET @month11 = Format(@date11, "MMM")
      SET @month12 = Format(@date12, "MMM")
      
      IF @dataExists == "true" THEN
        /* Real monthly aggregation based on LastUpdated field */
        
        /* Calculate target months in YYYY-MM format for filtering */
        VAR @targetMonth1, @targetMonth2, @targetMonth3, @targetMonth4, @targetMonth5, @targetMonth6
        VAR @targetMonth7, @targetMonth8, @targetMonth9, @targetMonth10, @targetMonth11, @targetMonth12
        
        SET @targetMonth1 = Format(@date1, "yyyy-MM")
        SET @targetMonth2 = Format(@date2, "yyyy-MM")
        SET @targetMonth3 = Format(@date3, "yyyy-MM")
        SET @targetMonth4 = Format(@date4, "yyyy-MM")
        SET @targetMonth5 = Format(@date5, "yyyy-MM")
        SET @targetMonth6 = Format(@date6, "yyyy-MM")
        SET @targetMonth7 = Format(@date7, "yyyy-MM")
        SET @targetMonth8 = Format(@date8, "yyyy-MM")
        SET @targetMonth9 = Format(@date9, "yyyy-MM")
        SET @targetMonth10 = Format(@date10, "yyyy-MM")
        SET @targetMonth11 = Format(@date11, "yyyy-MM")
        SET @targetMonth12 = Format(@date12, "yyyy-MM")
        
        /* Get all completed responses ordered by LastUpdated */
        VAR @allResponseRows, @allResponseCount
        SET @allResponseRows = LookupOrderedRows("SST_SP_Survey_Responses_DE", 50, "LastUpdated DESC", "Status", "Completed")
        
        
        SET @allResponseCount = RowCount(@allResponseRows)
        
        /* Initialize counters for each month */
        SET @responses1 = 0.1
        SET @responses2 = 0.1
        SET @responses3 = 0.1
        SET @responses4 = 0.1
        SET @responses5 = 0.1
        SET @responses6 = 0.1
        SET @responses7 = 0.1
        SET @responses8 = 0.1
        SET @responses9 = 0.1
        SET @responses10 = 0.1
        SET @responses11 = 0.1
        SET @responses12 = 0.1
        
        /* Loop through all responses and count by month */
        /* Debug info: Processing up to %%=v(@allResponseCount)=%% responses */
        IF @allResponseCount > 0 THEN
          VAR @i, @currentRow, @lastUpdated, @responseMonth
          VAR @debugCounter
          SET @debugCounter = 0
          
          FOR @i = 1 TO @allResponseCount DO
            SET @currentRow = Row(@allResponseRows, @i)
            SET @lastUpdated = Field(@currentRow, "LastUpdated")
            
            /* Enhanced timestamp processing for format: 2025-08-05 12:05:54.673 */
            VAR @parsedDate, @rawTimestamp
            SET @rawTimestamp = @lastUpdated
            
            /* Handle different timestamp formats and ensure proper parsing */
            IF NOT EMPTY(@lastUpdated) THEN
              /* AMPscript should automatically handle timestamp parsing */
              /* For timestamp "2025-08-05 12:05:54.673", Format should extract "2025-08" */
              SET @responseMonth = Format(@lastUpdated, "yyyy-MM")
              
              /* Track successful processing */
              SET @debugCounter = Add(@debugCounter, 1)
            ELSE
              SET @responseMonth = ""
            ENDIF
            
            /* Count responses for each target month */
            IF @responseMonth == @targetMonth1 THEN
              SET @responses1 = Add(@responses1, 1)
            ELSEIF @responseMonth == @targetMonth2 THEN
              SET @responses2 = Add(@responses2, 1)
            ELSEIF @responseMonth == @targetMonth3 THEN
              SET @responses3 = Add(@responses3, 1)
            ELSEIF @responseMonth == @targetMonth4 THEN
              SET @responses4 = Add(@responses4, 1)
            ELSEIF @responseMonth == @targetMonth5 THEN
              SET @responses5 = Add(@responses5, 1)
            ELSEIF @responseMonth == @targetMonth6 THEN
              SET @responses6 = Add(@responses6, 1)
            ELSEIF @responseMonth == @targetMonth7 THEN
              SET @responses7 = Add(@responses7, 1)
            ELSEIF @responseMonth == @targetMonth8 THEN
              SET @responses8 = Add(@responses8, 1)
            ELSEIF @responseMonth == @targetMonth9 THEN
              SET @responses9 = Add(@responses9, 1)
            ELSEIF @responseMonth == @targetMonth10 THEN
              SET @responses10 = Add(@responses10, 1)
            ELSEIF @responseMonth == @targetMonth11 THEN
              SET @responses11 = Add(@responses11, 1)
            ELSEIF @responseMonth == @targetMonth12 THEN
              SET @responses12 = Add(@responses12, 1)
            ENDIF
          NEXT @i
        ENDIF
       
        
        
      ELSE
        /* Demo data with realistic patterns */
        SET @surveys1 = 8
        SET @surveys2 = 12
        SET @surveys3 = 6
        SET @surveys4 = 15
        SET @surveys5 = 9
        SET @surveys6 = 14
        SET @surveys7 = 11
        SET @surveys8 = 7
