    <div class="surveys-grid">
      %%[
        VAR @rows, @rowCount, @i, @row, @name, @id, @status, @created, @responseCount
        
                IF @dataExists == "true" THEN
        
            SET @rows = LookupRows("SST_SP_Surveys_Master_DE", "SurveyStatus", "Active")
            SET @rowCount = RowCount(@rows)
        
        ENDIF
        
        IF @dataExists == "false" THEN
          /* Demo data when data extensions don't exist */
          SET @rowCount = 3
        ENDIF
        
        IF @rowCount > 0 THEN
          FOR @i = 1 TO @rowCount DO
            IF @dataExists == "true" THEN
              SET @row = Row(@rows, @i)
              SET @name = Field(@row, "SurveyName")
              SET @id = Field(@row, "SurveyID")
              SET @status = Field(@row, "SurveyStatus")
              SET @created = Field(@row, "SurveyCreatedDate")
              
              /* Get opens count for this specific survey where QuestionID = SURVEY_OPEN */
              SET @opensRows = LookupRows("SST_SP_Survey_Responses_DE", "SurveyID", @id)
              SET @responseCount = 0
              
              /* Count only records where QuestionID = SURVEY_OPEN */
              IF RowCount(@opensRows) > 0 THEN
                VAR @k, @currentRow, @questionId
                FOR @k = 1 TO RowCount(@opensRows) DO
                  SET @currentRow = Row(@opensRows, @k)
                  SET @questionId = Field(@currentRow, "QuestionID")
                  
                  IF @questionId == "SURVEY_OPEN" THEN
                    SET @responseCount = Add(@responseCount, 1)
                  ENDIF
                NEXT @k
              ENDIF
             
            ELSE
              /* Demo data */
              IF @i == 1 THEN
                SET @name = "Risk Management Training Q4 2024"
                SET @id = "DEMO001"
                SET @status = "Active"
