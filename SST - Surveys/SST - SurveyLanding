<script>
// Search functionality for surveys
function searchSurveys() {
  const searchInput = document.getElementById('surveySearch');
  const searchTerm = searchInput.value.toLowerCase();
  const surveyCards = document.querySelectorAll('.survey-card');
  let visibleCount = 0;

  surveyCards.forEach(card => {
    const surveyTitle = card.querySelector('.survey-title').textContent.toLowerCase();
    const surveyId = card.querySelector('.survey-id').textContent.toLowerCase();
    const surveyStatus = card.querySelector('.survey-status').textContent.toLowerCase();
    
    // Check if search term matches title, ID, or status
    const isMatch = surveyTitle.includes(searchTerm) || 
                   surveyId.includes(searchTerm) || 
                   surveyStatus.includes(searchTerm);
    
    if (isMatch) {
      card.style.display = 'block';
      visibleCount++;
    } else {
      card.style.display = 'none';
    }
  });

  // Show/hide no results message
  toggleNoResultsMessage(visibleCount === 0 && searchTerm !== '');
}

// Toggle filter dropdown (placeholder for future functionality)
function toggleFilter() {
  alert('Filter functionality coming soon! For now, use the search box to find surveys by name, ID, or status.');
}

// Show/hide no results message
function toggleNoResultsMessage(show) {
  let noResultsMsg = document.querySelector('.no-search-results');
  
  if (show && !noResultsMsg) {
    // Create no results message
    const surveysGrid = document.querySelector('.surveys-grid');
    noResultsMsg = document.createElement('div');
    noResultsMsg.className = 'no-search-results';
    noResultsMsg.innerHTML = `
      <div class="empty-state">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <h3>No surveys found</h3>
        <p>Try adjusting your search terms or clear the search to see all surveys.</p>
        <button class="btn-primary" onclick="clearSearch()">Clear Search</button>
      </div>
    `;
    surveysGrid.appendChild(noResultsMsg);
  } else if (!show && noResultsMsg) {
    noResultsMsg.remove();
  }
}

// Clear search functionality
function clearSearch() {
  document.getElementById('surveySearch').value = '';
  searchSurveys();
}

// Enhanced search with Enter key support
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('surveySearch');
  if (searchInput) {
    searchInput.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        searchSurveys();
      }
    });
  }
  
  // Initialize activity chart
  initializeActivityChart();
});

// Activity Chart Functionality
let activityChart = null;

function initializeActivityChart() {
  const canvas = document.getElementById('activityChart');
  if (!canvas) return;
  
  // Make canvas responsive
  resizeCanvas(canvas);
  
  const ctx = canvas.getContext('2d');
  const chartData = JSON.parse(document.getElementById('activityChartData').textContent);
  
  // Create initial chart with 12 months data
  createChart(ctx, chartData['12months']);
  
  // Add resize listener
  window.addEventListener('resize', function() {
    resizeCanvas(canvas);
    createChart(ctx, chartData[getActivePeriod()]);
  });
}

function resizeCanvas(canvas) {
  const container = canvas.parentElement;
  const containerRect = container.getBoundingClientRect();
  
  // Set canvas size based on container
  canvas.width = containerRect.width;
  canvas.height = containerRect.height;
  
  // Scale for high-DPI displays
  const dpr = window.devicePixelRatio || 1;
  canvas.width *= dpr;
  canvas.height *= dpr;
  
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);
  
  // Reset canvas style size
  canvas.style.width = containerRect.width + 'px';
  canvas.style.height = containerRect.height + 'px';
}

function getActivePeriod() {
  const activeBtn = document.querySelector('.activity-filter.active');
  return activeBtn ? activeBtn.getAttribute('data-period') : '12months';
}

function createChart(ctx, data) {
  // Get canvas dimensions
  const canvas = ctx.canvas;
  const containerRect = canvas.parentElement.getBoundingClientRect();
  const width = containerRect.width;
  const height = containerRect.height;
  
  // Clear canvas
  ctx.clearRect(0, 0, width, height);
  
  // Filter out months with zero responses
  const filteredData = {
    labels: [],
    responses: []
  };
  
  for (let i = 0; i < data.responses.length; i++) {
    if (data.responses[i] > 0) {
      filteredData.labels.push(data.labels[i]);
      filteredData.responses.push(data.responses[i]);
    }
  }
  
  // Check if we have data to display after filtering
  if (filteredData.responses.length === 0) {
    drawNoDataMessage(ctx, width, height);
    return;
  }
  
  // Use filtered data for the rest of the function
  data = filteredData;
  
  // Chart dimensions with better padding for full width
  const chartPadding = {
    top: 30,
    right: 40,
    bottom: 60,
    left: 70
  };
  const chartWidth = width - chartPadding.left - chartPadding.right;
  const chartHeight = height - chartPadding.top - chartPadding.bottom;
  
  // Find max values for scaling (only responses now)
  const maxResponses = Math.max(...data.responses);
  const scaledMaxValue = Math.max(maxResponses, 10);
  
  // Draw background
  ctx.fillStyle = '#fafafa';
  ctx.fillRect(0, 0, width, height);
  
  // Draw chart background
  ctx.fillStyle = '#ffffff';
  ctx.fillRect(chartPadding.left, chartPadding.top, chartWidth, chartHeight);
  
  // Draw grid lines
  ctx.strokeStyle = '#f3f4f6';
  ctx.lineWidth = 1;
  
  // Horizontal grid lines
  for (let i = 0; i <= 5; i++) {
    const y = chartPadding.top + (chartHeight / 5) * i;
    ctx.beginPath();
    ctx.moveTo(chartPadding.left, y);
    ctx.lineTo(chartPadding.left + chartWidth, y);
    ctx.stroke();
    
    // Y-axis labels
    ctx.fillStyle = '#6b7280';
    ctx.font = '11px Inter, sans-serif';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    const labelValue = Math.round((scaledMaxValue * (5 - i)) / 5);
    ctx.fillText(labelValue, chartPadding.left - 10, y);
  }
  
  // Vertical grid lines
  for (let i = 0; i < data.labels.length; i++) {
    const x = chartPadding.left + (chartWidth / (data.labels.length - 1)) * i;
    ctx.beginPath();
    ctx.moveTo(x, chartPadding.top);
    ctx.lineTo(x, chartPadding.top + chartHeight);
    ctx.stroke();
  }
  
  // Draw area fill for responses (gradient)
  const responseGradient = ctx.createLinearGradient(0, chartPadding.top, 0, chartPadding.top + chartHeight);
  responseGradient.addColorStop(0, 'rgba(16, 185, 129, 0.3)');
  responseGradient.addColorStop(1, 'rgba(16, 185, 129, 0.08)');
  
  ctx.fillStyle = responseGradient;
  ctx.beginPath();
  ctx.moveTo(chartPadding.left, chartPadding.top + chartHeight);
  
  data.responses.forEach((value, index) => {
    const x = chartPadding.left + (chartWidth / (data.responses.length - 1)) * index;
    const y = chartPadding.top + chartHeight - (value / scaledMaxValue) * chartHeight;
    if (index === 0) {
      ctx.lineTo(x, y);
    } else {
      ctx.lineTo(x, y);
    }
  });
  
  ctx.lineTo(chartPadding.left + chartWidth, chartPadding.top + chartHeight);
  ctx.closePath();
  ctx.fill();

  
  // Draw responses line
  ctx.strokeStyle = '#10b981';
  ctx.lineWidth = 3;
  ctx.beginPath();
  
  data.responses.forEach((value, index) => {
    const x = chartPadding.left + (chartWidth / (data.responses.length - 1)) * index;
    const y = chartPadding.top + chartHeight - (value / scaledMaxValue) * chartHeight;
    
    if (index === 0) {
      ctx.moveTo(x, y);
    } else {
      ctx.lineTo(x, y);
    }
  });
  ctx.stroke();
  

  
  // Draw response points with shadow
  ctx.shadowColor = 'rgba(16, 185, 129, 0.3)';
  ctx.fillStyle = '#10b981';
  data.responses.forEach((value, index) => {
    const x = chartPadding.left + (chartWidth / (data.responses.length - 1)) * index;
    const y = chartPadding.top + chartHeight - (value / scaledMaxValue) * chartHeight;
    
    ctx.beginPath();
    ctx.arc(x, y, 5, 0, 2 * Math.PI);
    ctx.fill();
    
    // White center
    ctx.fillStyle = '#ffffff';
    ctx.beginPath();
    ctx.arc(x, y, 2, 0, 2 * Math.PI);
    ctx.fill();
    ctx.fillStyle = '#10b981';
  });
  
  // Reset shadow
  ctx.shadowBlur = 0;
  
  // Draw X-axis labels
  ctx.fillStyle = '#6b7280';
  ctx.font = '12px Inter, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  
  data.labels.forEach((label, index) => {
    const x = chartPadding.left + (chartWidth / (data.labels.length - 1)) * index;
    const y = chartPadding.top + chartHeight + 15;
    ctx.fillText(label, x, y);
  });
  
  // Draw Y-axis title
  ctx.save();
  ctx.translate(15, chartPadding.top + chartHeight / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillStyle = '#6b7280';
  ctx.font = '12px Inter, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('Count', 0, 0);
  ctx.restore();
}

// Draw no data message
function drawNoDataMessage(ctx, width, height) {
  // Draw background
  ctx.fillStyle = '#fafafa';
  ctx.fillRect(0, 0, width, height);
  
  // Draw message
  ctx.fillStyle = '#9ca3af';
  ctx.font = '16px Inter, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('No response data available for the selected period', width / 2, height / 2 - 10);
  
  ctx.font = '14px Inter, sans-serif';
  ctx.fillStyle = '#6b7280';
  ctx.fillText('Chart will display when survey responses are received', width / 2, height / 2 + 15);
}

// Activity filter functionality
function filterActivity(period) {
  // Update active filter button
  document.querySelectorAll('.activity-filter').forEach(btn => {
    btn.classList.remove('active');
  });
  document.querySelector(`[data-period="${period}"]`).classList.add('active');
  
  // Get chart data and update chart
  const chartData = JSON.parse(document.getElementById('activityChartData').textContent);
  const canvas = document.getElementById('activityChart');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    createChart(ctx, chartData[period]);
  }
  
  // Update metrics based on period (simplified)
  updateMetricsForPeriod(period);
}

function updateMetricsForPeriod(period) {
  // Get the chart data to calculate real metrics for the selected period
  const chartData = getChartData();
  const currentData = chartData[period];
  
  if (!currentData) return;
  
  // Calculate totals for the selected period
  const totalResponses = currentData.responses.reduce((sum, val) => sum + val, 0);
  
  // Update the DOM with real calculated values
  const surveysElement = document.getElementById('metric-surveys');
  const responsesElement = document.getElementById('metric-responses');
  const surveysTrendElement = document.getElementById('metric-surveys-trend');
  const responsesTrendElement = document.getElementById('metric-responses-trend');
  
  if (surveysElement && responsesElement) {
    // For surveys, show total count (since we don't have time-based survey data yet)
    surveysElement.textContent = document.querySelector('.stat-value').textContent;
    responsesElement.textContent = totalResponses;
    
    // Update trend descriptions based on period
    const trendDescriptions = {
      '12months': {
        surveys: 'Total surveys',
        responses: 'Last 12 months'
      },
      '3months': {
        surveys: 'Total surveys', 
        responses: 'Last 3 months'
      },
      '30days': {
        surveys: 'Total surveys',
        responses: 'Last 30 days'
      }
    };
    
    if (surveysTrendElement) {
      surveysTrendElement.textContent = trendDescriptions[period].surveys;
    }
    if (responsesTrendElement) {
      responsesTrendElement.textContent = trendDescriptions[period].responses;
    }
  }
}

