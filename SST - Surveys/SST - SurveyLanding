// Show/hide no responses message
function toggleNoResponsesMessage(show) {
  let noResultsMsg = document.querySelector('.no-responses-message');
  
  if (show && !noResultsMsg) {
    // Create no results message
    const responsesGrid = document.querySelector('.responses-grid');
    noResultsMsg = document.createElement('div');
    noResultsMsg.className = 'no-responses-message';
    noResultsMsg.innerHTML = `
      <div class="empty-state">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <h3>No responses found</h3>
        <p>Try adjusting your search terms or clear the search to see all responses.</p>
        <button class="btn-primary" onclick="clearResponseSearch()">Clear Search</button>
      </div>
    `;
    responsesGrid.appendChild(noResultsMsg);
  } else if (!show && noResultsMsg) {
    noResultsMsg.remove();
  }
}

// Clear response search functionality
function clearResponseSearch() {
  document.getElementById('responseSearch').value = '';
  searchResponses();
}

// Filter team functionality
function filterTeam(filter) {
  // Update active filter button
  document.querySelectorAll('[data-team-filter]').forEach(btn => {
    btn.classList.remove('active');
  });
  document.querySelector(`[data-team-filter="${filter}"]`).classList.add('active');
  
  const teamCards = document.querySelectorAll('.team-card');
  
  teamCards.forEach(card => {
    const status = card.querySelector('.team-status').textContent.toLowerCase();
    const lastSeen = card.querySelector('.team-last-seen').textContent.toLowerCase();
    
    let shouldShow = true;
    
    if (filter === 'online') {
      shouldShow = status === 'online';
    } else if (filter === 'recent') {
      // Show users active in last 30 minutes
      shouldShow = lastSeen.includes('minutes ago') || lastSeen.includes('minute ago');
    }
    // 'all' shows everything
    
    card.style.display = shouldShow ? 'block' : 'none';
  });
}


