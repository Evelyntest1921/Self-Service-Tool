// Initialize reports chart
function initializeReportsChart() {
  const canvas = document.getElementById('reportsChart');
  if (!canvas) return;
  
  // Make canvas responsive
  resizeCanvas(canvas);
  
  const ctx = canvas.getContext('2d');
  const chartData = JSON.parse(document.getElementById('reportsChartData').textContent);
  
  // Create chart with 12 months data
  createChart(ctx, chartData['12months']);
  
  // Add resize listener
  window.addEventListener('resize', function() {
    resizeCanvas(canvas);
    createChart(ctx, chartData[getActivePeriod()]);
  });
}

// Search responses functionality
function searchResponses() {
  const searchInput = document.getElementById('responseSearch');
  const searchTerm = searchInput.value.toLowerCase();
  const responseCards = document.querySelectorAll('.response-card');
  let visibleCount = 0;

  responseCards.forEach(card => {
    const surveyName = card.querySelector('.response-survey h4').textContent.toLowerCase();
    const surveyId = card.querySelector('.response-id').textContent.toLowerCase();
    const contact = card.querySelector('.response-contact').textContent.toLowerCase();
    const status = card.querySelector('.response-status').textContent.toLowerCase();
    
    // Check if search term matches survey name, ID, contact, or status
    const isMatch = surveyName.includes(searchTerm) || 
                   surveyId.includes(searchTerm) || 
                   contact.includes(searchTerm) || 
                   status.includes(searchTerm);
    
    if (isMatch) {
      card.style.display = 'block';
      visibleCount++;
    } else {
      card.style.display = 'none';
    }
  });

  // Show/hide no results message
  toggleNoResponsesMessage(visibleCount === 0 && searchTerm !== '');
}

