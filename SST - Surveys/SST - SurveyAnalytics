        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --primary-color: #6366f1;
            --primary-dark: #4f46e5;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --info-color: #3b82f6;
            --danger-color: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-400: #9ca3af;
            --gray-500: #6b7280;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --gray-900: #111827;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }




        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }






        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--gray-50);
            color: var(--gray-900);
            line-height: 1.6;
        }




        /* Layout */
        .dashboard-layout {
            display: flex;
            min-height: 100vh;
        }




        /* Sidebar */
        .sidebar,
        .maker-sidebar {
            width: 280px;
            background: white;
            border-right: 1px solid var(--gray-200);
            display: flex;
            flex-direction: column;
            padding: 32px 0;
            box-shadow: var(--shadow-sm);
            flex-shrink: 0;
        }

        .maker-sidebar {
            padding: 28px 0;
            height: 100vh;
            overflow: hidden;
        }

        .maker-sidebar .sidebar-logo {
            margin-bottom: 12px;
            border-bottom: 1px solid #eee5e5;
            padding-bottom: 10px;
            align-self: center;
        }

        .maker-sidebar .sidebar-logo a {
            display: inline-block;
        }

        .maker-sidebar .sidebar-logo img {
            height: 40px;
        }

        .sidebar-nav span.nav-link.active {
            cursor: default;
        }




        .sidebar-logo {
            padding: 0 20px;
            margin-bottom: 40px;
        }




        .nav-section-title {
            font-size: 11px;
            font-weight: 600;
            color: var(--gray-400);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 0 32px;
            margin-bottom: 16px;
        }




        .sidebar-nav {
            flex: 1;
        }




        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 32px;
            color: var(--gray-600);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s ease;
            border-right: 3px solid transparent;
        }




        .nav-link:hover {
            background: var(--gray-50);
            color: var(--gray-900);
        }




        .nav-link.active {
            background: linear-gradient(90deg, rgb(119 120 196 / 10%) 0%, rgb(2 3 22 / 5%) 100%);
            color: #000000;
            border-right-color: #2c2c31;
        }




        .nav-icon {
            width: 20px;
            height: 20px;
            opacity: 0.7;
        }




        .nav-link.active .nav-icon {
            opacity: 1;
        }




        .sidebar-footer {
            padding: 0 32px;
            border-top: 1px solid var(--gray-200);
            padding-top: 24px;
        }




        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }




        .user-avatar {
            width: 40px;
            height: 40px;
            background: var(--primary-gradient);
            color: white;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 16px;
        }




        .user-name {
            font-weight: 600;
            color: var(--gray-900);
            font-size: 14px;
        }




        .user-email {
            color: var(--gray-500);
            font-size: 12px;
        }




        /* Main Content */
        .main-content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
            background: var(--gray-50);
        }




        /* Survey Header */
        .survey-header {
            margin-bottom: 32px;
        }




        .breadcrumb-section {
            padding: 4px 0 20px;
        }

        .breadcrumb-nav {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            font-size: 14px;
            gap: 4px;
        }

        .breadcrumb-section .breadcrumb-link {
            display: inline-flex;
            align-items: center;
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
        }

        .breadcrumb-section .breadcrumb-link:hover {
            color: #4f46e5;
            text-decoration: underline;
        }

        .breadcrumb-section .breadcrumb-link svg {
            flex-shrink: 0;
        }

        .breadcrumb-separator {
            margin: 0 8px;
            color: var(--gray-400);
            font-weight: 400;
            user-select: none;
        }

        .breadcrumb-section .breadcrumb-current {
            font-weight: 600;
            color: var(--gray-900);
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }




        .breadcrumb-link {
            color: var(--gray-500);
            text-decoration: none;
            transition: color 0.2s ease;
        }




        .breadcrumb-link:hover {
            color: var(--primary-color);
        }




        .breadcrumb-current {
            color: var(--gray-900);
            font-weight: 500;
        }




        .survey-title-section {
            background: white;
            border-radius: 12px;
            padding: 50px 32px;
            border: 1px solid var(--gray-200);
        }




        .survey-title-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }




        .survey-title-section h1 {
            font-size: 32px;
            font-weight: 700;
            color: var(--gray-900);
            margin: 0;
            flex: 1;
        }




        .survey-actions-header {
            display: flex;
            align-items: center;
            gap: 12px;
        }




        .btn-export {
            background: var(--primary-color);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }




        .btn-export:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }




        .btn-edit {
            background: #040710;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-decoration: none;
        }


        .btn-preview {
            background: #ffffff;
            border: 1px solid gray;
            color: black;


            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            text-decoration: none;
        }


        .btn-preview:hover {
            background: #2563eb;
            transform: translateY(-1px);
            color: white;
            text-decoration: none;
        }


        .btn-edit:hover {
            background: #2563eb;
            transform: translateY(-1px);
            color: white;
            text-decoration: none;
        }




        .btn-dropdown {
            background: var(--gray-100);
            color: var(--gray-700);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid var(--gray-200);
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
        }




        .btn-dropdown:hover {
            background: var(--gray-200);
            border-color: var(--gray-300);
        }




        .dropdown {
            position: relative;
            display: inline-block;
        }




        .dropdown-menu {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background: white;
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            box-shadow: var(--shadow-lg);
            min-width: 180px;
            z-index: 1000;
            margin-top: 4px;
        }




        .dropdown-menu.show {
            display: block;
        }




        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 12px 16px;
            border: none;
            background: none;
            color: var(--gray-700);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background-color 0.2s ease;
            text-align: left;
        }




        .dropdown-item:hover {
            background: var(--gray-50);
        }




        .dropdown-item.delete-item {
            color: var(--danger-color);
        }




        .dropdown-item.delete-item:hover {
            background: rgba(239, 68, 68, 0.1);
        }




        .btn-delete {
            background: var(--danger-color);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }




        .btn-delete:hover {
            background: #dc2626;
            transform: translateY(-1px);
        }




        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
        }




        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }




        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger-color);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }




        .btn-secondary {
            background: var(--gray-100);
            color: var(--gray-700);
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
        }




        .btn-secondary:hover {
            background: var(--gray-200);
        }




        .survey-meta-info {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }




        .survey-badge {
            background: var(--gray-100);
            color: var(--gray-600);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }




        .survey-status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: capitalize;
        }




        .survey-status-badge.status-Active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
        }




        .survey-status-badge.status-Inactive {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger-color);
        }




        .survey-status-badge.status-Draft {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
        }




        .survey-status-badge.status-Unknown {
            background: rgba(107, 114, 128, 0.1);
            color: var(--gray-500);
        }




        .response-count {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 14px;
        }




        .last-updated {
            color: var(--gray-500);
            font-size: 14px;
        }




        /* Metrics Grid */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }




        .metric-card {
            background: white;
            border-radius: 12px;
            padding: 10px 24px;
            border: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.2s ease;
        }




        .metric-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }




        .metric-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }




        .metric-icon.sent {
            /* background: rgba(59, 130, 246, 0.1); */
            color: #000000;
            /* border: 1px solid #e5e7eb; */
        }




        .metric-icon.opened {
            /*  background: rgba(245, 158, 11, 0.1); */
            /* border: 1px solid #e5e7eb;*/
            color: var(--warning-color);
        }




        .metric-icon.completed {
            /*  background: rgba(16, 185, 129, 0.1); */
            /* border: 1px solid #e5e7eb;*/
            color: var(--success-color);
        }




        .metric-icon.responses {
            /*   background: rgba(99, 102, 241, 0.1); */
            /* border: 1px solid #e5e7eb;*/
            color: var(--primary-color);
        }




        .metric-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--gray-900);
            line-height: 1;
            margin-bottom: 4px;
        }




        .metric-label {
            font-size: 14px;
            color: var(--gray-600);
            font-weight: 500;
            margin-bottom: 4px;
        }




        .metric-trend {
            font-size: 12px;
            color: var(--gray-500);
        }




        /* Insights Summary */
        .insights-summary {
            margin-bottom: 40px;
        }




        .insights-summary h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
            margin-bottom: 20px;
        }




        .insights-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }




        .insight-card {
            background: white;
            border-radius: 12px;
            padding: 10px 20px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 16px;
        }




        .insight-icon {
            font-size: 24px;
        }




        .insight-content h4 {
            font-size: 16px;
            font-weight: 600;
            color: var(--gray-900);
            margin-bottom: 4px;
        }




        .insight-content p {
            font-size: 14px;
            color: var(--gray-600);
            margin: 0;
        }




        /* Questions Section */
        .questions-section {
            margin-bottom: 40px;
        }




        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 32px;
        }




        .section-header h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
        }




        .view-toggle {
            display: flex;
            background: var(--gray-100);
            border-radius: 8px;
            padding: 4px;
        }




        .toggle-btn {
            background: transparent;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 14px;
            color: var(--gray-600);
        }




        .toggle-btn.active,
        .toggle-btn:hover {
            background: white;
            color: var(--gray-900);
            box-shadow: var(--shadow-sm);
        }




        .question-card {
            background: white;
            border-radius: 12px;
            padding: 20px 32px;
            border: 1px solid var(--gray-200);
            margin-bottom: 24px;
            transition: all 0.2s ease;
        }




        .question-card:hover {
            box-shadow: var(--shadow-md);
        }




        .question-header {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 24px;
        }




        .question-number {
            background: #040710;
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 16px;
            flex-shrink: 0;
        }




        .question-content {
            flex: 1;
        }




        .question-content h3 {
            font-size: 20px;
            font-weight: 600;
            color: var(--gray-900);
            line-height: 1.4;
            margin: 0 0 8px 0;
        }




        .question-type {
            font-size: 12px;
            color: var(--gray-500);
            background: var(--gray-100);
            padding: 4px 8px;
            border-radius: 12px;
            display: inline-block;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }




        .question-stats {
            background: var(--gray-50);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 24px;
        }




        .stat-summary {
            display: flex;
            gap: 32px;
            flex-wrap: wrap;
        }




        .stat-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }




        .stat-label {
            font-size: 12px;
            color: var(--gray-500);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }




        .stat-value {
            font-size: 20px;
            font-weight: 700;
            color: var(--gray-900);
        }




        .answer-bars {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }




        .answer-option {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }




        .option-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }




        .option-label {
            font-weight: 500;
            color: var(--gray-700);
            font-size: 14px;
        }




        .option-stats {
            font-size: 14px;
            color: var(--gray-500);
            font-weight: 500;
        }




        .progress-bar-modern {
            height: 10px;
            background: var(--gray-200);
            border-radius: 5px;
            overflow: hidden;
        }




        .progress-fill-modern {
            height: 100%;
            border-radius: 5px;
            transition: width 0.5s ease;
        }




        .progress-fill-modern.yes {
            background: var(--success-color);
        }


        .progress-fill-modern.no {
            background: var(--danger-color);
        }


        .progress-fill-modern.multiple-choice {
            background: var(--primary-color);
        }


        /* Text Response Styling */
        .text-responses-section {
            margin-top: 16px;
        }


        .text-responses-section h4 {
            font-size: 16px;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 16px;
        }


        .text-response-item {
            background: var(--gray-50);
            border: 1px solid var(--gray-200);
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 12px;
        }


        .text-response-content {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }


        .text-response-text {
            font-size: 14px;
            color: var(--gray-800);
            line-height: 1.5;
            font-style: italic;
            flex: 1;
        }


        /* Multiple Choice Response Styling */
        .answer-option .option-label {
            font-weight: 600;
            color: var(--gray-800);
        }


        .answer-option .option-stats {
            color: var(--gray-600);
            font-size: 13px;
        }


        /* Question Type Badge Styling */
        .question-type-badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }


        .question-type-badge.type-yesno {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
        }


        .question-type-badge.type-text {
            background: rgba(59, 130, 246, 0.1);
            color: var(--info-color);
        }


        .question-type-badge.type-likert {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
        }


        .question-type-badge.type-rating {
            background: rgba(139, 92, 246, 0.1);
            color: #8b5cf6;
        }


        .question-type-badge.type-multiple {
            background: rgba(99, 102, 241, 0.1);
            color: var(--primary-color);
        }


        .no-responses-note {
            border-radius: 12px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 16px;
        }




        .no-responses-note p {
            color: var(--gray-600);
            font-size: 14px;
            margin: 0;
        }




        /* Responses Section */
        .responses-section {
            margin-top: 40px;
        }




        .responses-section .section-header {
            margin-bottom: 24px;
        }




        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 32px;
        }




        .section-header h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--gray-900);
        }




        .table-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }




        .search-section {
            display: flex;
            align-items: center;
            gap: 12px;
        }




        .search-input {
            padding: 10px 16px;
            border: 1px solid var(--gray-300);
            border-radius: 8px;
            font-size: 14px;
            width: 250px;
            outline: none;
            transition: all 0.2s ease;
        }




        .search-input:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .btn-download {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px;
