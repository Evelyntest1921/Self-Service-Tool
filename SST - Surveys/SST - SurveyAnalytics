                            <div class="text-response-item">
                                <div class="text-response-content">
                                    <span class="text-response-text">No text responses recorded</span>
                                </div>
                            </div>
                            %%[ ENDIF ]%%
                        </div>


                        %%[ ELSEIF @questionType == "likert" OR @questionType == "rating" OR @questionType ==
                        "multiple" THEN ]%%
                        <!-- Multiple Choice Questions - Aggregate by defined options -->
                        %%[
                        /* Fetch defined options for this question */
                        VAR @optString, @optRows, @optCount, @o
                        SET @optString = Lookup("SST_SP_Survey_Questions_DE", "Options", "QuestionID", @questionId)


                        IF NOT EMPTY(@optString) THEN
                        SET @optRows = BuildRowSetFromString(@optString, "|")
                        SET @optCount = RowCount(@optRows)
                        ELSE
                        SET @optCount = 0
                        ENDIF
                        ]%%


                        %%[ IF @optCount > 0 THEN ]%%
                        %%[
                        VAR @maxCount, @o2, @optVal2, @optResponses2, @ri2
                        SET @maxCount = 0
                        FOR @o2 = 1 TO @optCount DO
                        SET @optVal2 = Field(Row(@optRows, @o2), 1)
                        SET @optResponses2 = 0
                        FOR @ri2 = 1 TO @count DO
                        SET @row = Row(@responses, @ri2)
                        IF Field(@row, "QuestionID") == @questionId THEN
                        IF Field(@row, "Response") == @optVal2 THEN
                        SET @optResponses2 = Add(@optResponses2, 1)
                        ENDIF
                        ENDIF
                        NEXT @ri2
                        IF @optResponses2 > @maxCount THEN
                        SET @maxCount = @optResponses2
                        ENDIF
                        NEXT @o2
                        ]%%
                        %%[ FOR @o = 1 TO @optCount DO
                        VAR @optVal, @optResponses
                        SET @optVal = Field(Row(@optRows, @o), 1)
                        SET @optResponses = 0


                        /* Count matches in responses for this option */
                        VAR @ri
                        FOR @ri = 1 TO @count DO
                        SET @row = Row(@responses, @ri)
                        IF Field(@row, "QuestionID") == @questionId THEN
                        IF Field(@row, "Response") == @optVal THEN
                        SET @optResponses = Add(@optResponses, 1)
                        ENDIF
                        ENDIF
                        NEXT @ri


                        /* Render only options that have at least one response */
                        IF @optResponses > 0 THEN
                        SET @barClass = IIF(@optResponses == @maxCount, "yes", "multiple-choice")
                        ]%%
                        <div class="answer-option">
                            <div class="option-info">
                                <span class="option-label">%%=v(@optVal)=%%</span>
                                <span class="option-stats">%%=v(@optResponses)=%% responses
                                    (%%=FormatNumber(Multiply(Divide(@optResponses, @responseCount), 100),
                                    0)=%%)</span>
                            </div>
                            <div class="progress-bar-modern">
                                <div class="progress-fill-modern %%=v(@barClass)=%%"
                                    style="width: %%=FormatNumber(Multiply(Divide(@optResponses, @responseCount), 100), 0)=%%%;">
                                </div>
                            </div>
                        </div>
                        %%[ ENDIF ]%%
                        %%[ NEXT @o ]%%
                        %%[ ELSE ]%%
                        <!-- No defined options; show total only -->
                        <div class="answer-option">
                            <div class="option-info">
                                <span class="option-label">Responses Received</span>
                                <span class="option-stats">%%=v(@responseCount)=%% total responses</span>
                            </div>
                            <div class="progress-bar-modern">
                                <div class="progress-fill-modern" style="width: 100%;"></div>
                            </div>
                        </div>
                        %%[ ENDIF ]%%


                        %%[ ELSE ]%%
                        <!-- Fallback for unknown question types -->
                        <div class="answer-option">
                            <div class="option-info">
                                <span class="option-label">Responses Received</span>
                                <span class="option-stats">%%=v(@responseCount)=%% total responses</span>
                            </div>
                            <div class="progress-bar-modern">
                                <div class="progress-fill-modern" style="width: 100%;"></div>
                            </div>
                        </div>
                        %%[ ENDIF ]%%
                    </div>
                    %%[ ELSE ]%%
                    <div class="no-responses-note">
                        <p>No responses recorded for this question yet.</p>
                    </div>
                    %%[ ENDIF ]%%
                </div>


                %%[ NEXT @q ]%%


                %%[ ELSE ]%%
                <div class="no-responses">
                    <div class="empty-state">
                        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor"
