                        <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                    </svg>
                    <span>Dashboard</span>
                </a>
                <a class="nav-link active" href="#" onclick="showSurveyAnalytics(); return false;">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" />
                    </svg>
                    <span>Survey Analytics</span>
                </a>
                <a class="nav-link" href="#" onclick="showReports(); return false;">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9 11H7v6h2v-6zm4 0h-2v6h2v-6zm4 0h-2v6h2v-6zM5 20h14V4H5v16zm14 2H5c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h14c1.1 0 2 .9 2 2v16c0 1.1-.9 2-2 2z" />
                    </svg>
                    <span>Reports</span>
                </a>
                <a class="nav-link" href="#" onclick="showResponses(); return false;">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20 6h-2.18c.11-.31.18-.65.18-1a2.996 2.996 0 0 0-5.5-1.65l-.5.67-.5-.68C10.96 2.54 10 2 10 2 10 2 9 3 8.18 4H4c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1z" />
                    </svg>
                    <span>Responses</span>
                </a>
                %%[ ENDIF ]%%
            </nav>
            %%[ IF @buildNavContext != "true" OR @isSurveyBuild != "true" THEN ]%%
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="user-avatar">S</div>
                    <div class="user-info">
                        <div class="user-name">Survey Admin</div>
                        <div class="user-email">admin@magmutual.com</div>
                    </div>
                </div>
            </div>
            %%[ ENDIF ]%%
        </aside>




        <!-- Main Content -->
        <main class="main-content">
            <!-- Survey Header with Breadcrumb -->
            <div class="survey-header">
                %%[ IF @buildNavContext == "true" AND @isSurveyBuild == "true" THEN ]%%
                <div class="breadcrumb-section">
                    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
                        <a href="%%=v(@hubUrl)=%%" class="breadcrumb-link">
                            <svg width="35" height="40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
                            Back
                        </a>
                        <span class="breadcrumb-separator" aria-hidden="true">/</span>
                        <span class="breadcrumb-current">Analytics</span>
                    </nav>
                </div>
                %%[ ELSE ]%%
                <div class="breadcrumb">
                    <a href="%%=v(@surveyHomeUrl)=%%" class="breadcrumb-link">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
                            style="margin-right: 5px; vertical-align: text-bottom;">
                            <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                        </svg>
                        Dashboard
                    </a>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" />
                    </svg>
                    <span class="breadcrumb-current">Survey Analytics</span>
                </div>
                %%[ ENDIF ]%%


                %%[ IF @deleteSuccess == "true" THEN ]%%
                <div class="alert alert-success">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    </svg>
                    Survey has been successfully deleted. Redirecting to dashboard...
                </div>
                <script>
                    setTimeout(function () {
                        window.location.href = '%%=v(@surveyHomeUrl)=%%';
                    }, 2000);
                </script>
                %%[ ELSEIF NOT EMPTY(@deleteError) THEN ]%%
                <div class="alert alert-error">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                    </svg>
                    %%=v(@deleteError)=%%
                </div>
                %%[ ENDIF ]%%


                %%[
                VAR @responses, @count, @surveyName, @surveyStatus


                /* Get responses from new SST_SP_Survey_Responses_DE */
                SET @responses = LookupRows("SST_SP_Survey_Responses_DE", "SurveyID", @surveyId)
                SET @count = RowCount(@responses)








                /* Get survey name and status from SST_SP_Surveys_Master_DE */
                SET @surveyName = Lookup("SST_SP_Surveys_Master_DE", "SurveyName", "SurveyID", @surveyId)
                SET @surveyStatus = Lookup("SST_SP_Surveys_Master_DE", "SurveyStatus", "SurveyID", @surveyId)



                /* Fallback if survey not found in master DE */
                IF EMPTY(@surveyName) THEN
                SET @surveyName = Concat("Survey ", @surveyId)
                ENDIF


                IF EMPTY(@surveyStatus) THEN
                SET @surveyStatus = "Unknown"
                ENDIF
                ]%%


                <div class="survey-title-section">
                    <div class="survey-title-row">
                        <h1>%%=v(@surveyName)=%%</h1>
                        <div class="survey-actions-header">


                            <a href="%%=Concat(@surveyTakeUrl, "?id=", @surveyId)=%%"
                                class="btn-preview" target="_blank">
                                📑
                                Preview
                            </a>
                            <a href="%%=Concat(@surveyStageUrl, "?mode=edit&surveyid=", @surveyId, IIF(@buildNavContext == "true" AND NOT Empty(@jid), Concat("&journeyId=", @jid), ""))=%%"
                                class="btn-edit">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path
                                        d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                </svg>
                                Edit Survey
                            </a>
                            <div class="dropdown">
                                <button class="btn-dropdown" onclick="toggleDropdown()">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                        <path
                                            d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" />
                                    </svg>
                                </button>
                                <div class="dropdown-menu" id="dropdownMenu">
                                    <form method="POST" action="%%=RequestParameter('PAGEURL')=%%"
                                        onsubmit="return confirmDelete()">
                                        <input type="hidden" name="deleteAction" value="delete">
                                        <input type="hidden" name="surveyid" value="%%=v(@surveyId)=%%">
                                        <button type="submit" class="dropdown-item delete-item">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                                <path
                                                    d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                                            </svg>
                                            Delete Survey
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="survey-meta-info">
                        <span class="survey-badge">Survey ID: %%=v(@surveyId)=%%</span>
                        <span class="survey-status-badge status-%%=v(@surveyStatus)=%%">%%=v(@surveyStatus)=%%</span>
                        <span class="response-count">%%=v(@count)=%% Total Responses</span>
                        <span class="last-updated">Last updated: %%=Format(Now(), "MMM dd, yyyy")=%%</span>
                    </div>
                </div>
            </div>




            <!-- Survey Overview Metrics -->
            %%[
            VAR @uniqueContacts, @openedCount, @completedCount


            /* Count unique contacts */
            SET @uniqueContacts = 0
            SET @contactSet = ""
            SET @responsesNoOpens = Subtract(@count, @uniqueContacts)


            FOR @i = 1 TO @count DO
            SET @row = Row(@responses, @i)
            SET @contact = Field(@row, "Contact")
            IF NOT EMPTY(@contact) AND IndexOf(@contactSet, @contact) == 0 THEN
            SET @contactSet = Concat(@contactSet, "|", @contact)
            SET @uniqueContacts = Add(@uniqueContacts, 1)
            ENDIF
            NEXT


            /* Count survey opens */
            SET @openedCount = 0
            
            
            FOR @i = 1 TO @count DO
            SET @row = Row(@responses, @i)
            SET @questionId = Field(@row, "QuestionID")
            IF @questionId == "SURVEY_OPEN" THEN
            SET @openedCount = Add(@openedCount, 1)
            ENDIF
            NEXT


            /* Count completed surveys */
            
            SET @completedCount = 0
            FOR @i = 1 TO @count DO
            SET @row = Row(@responses, @i)
            SET @status = Field(@row, "Status")
            IF @status == "Completed" THEN
            SET @completedCount = Add(@completedCount, 1)
            SET @completedCount = @openedCount
            ENDIF
            NEXT
            ]%%




            <!-- Survey Analytics Section (Default View) -->
            <div id="surveyAnalyticsSection">
                <div class="metrics-grid">
                    <div class="metric-card">
                        <div class="metric-icon sent">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                            </svg>
                        </div>
                        <div class="metric-content">
                            <div class="metric-value">%%=v(@uniqueContacts)=%%</div>
                            <div class="metric-label">Unique Respondents</div>
                            <div class="metric-trend">Based on response data</div>
                        </div>
                    </div>


                    <div class="metric-card">
                        <div class="metric-icon opened">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path
                                    d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" />
                            </svg>
                        </div>
                        <div class="metric-content">
                            <div class="metric-value">%%=v(@openedCount)=%%</div>
                            <div class="metric-label">Survey Opens</div>
                            <div class="metric-trend">Tracked automatically</div>
                        </div>
                    </div>


                    <div class="metric-card">
                        <div class="metric-icon completed">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                            </svg>
                        </div>
                        <div class="metric-content">
                            <div class="metric-value">%%=v(@completedCount)=%%</div>
                            <div class="metric-label">Completed Surveys</div>
                            <div class="metric-trend">Based on status field</div>
                        </div>
                    </div>


                    <div class="metric-card">
                        <div class="metric-icon responses">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                <path
                                    d="M20 6h-2.18c.11-.31.18-.65.18-1a2.996 2.996 0 0 0-5.5-1.65l-.5.67-.5-.68C10.96 2.54 10 2 10 2 10 2 9 3 8.18 4H4c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z" />
                            </svg>
                        </div>
                        <div class="metric-content">
                            <div class="metric-value">%%=v(@count)=%%</div>
                            <div class="metric-label">Total Responses</div>
                            <div class="metric-trend">All question responses</div>
                        </div>
                    </div>
                </div>










                <!-- Question Analysis Section -->
                %%[ IF @count > 0 THEN ]%%
                <div class="questions-section">
                    <div class="section-header">
                        <h2>Question Analysis</h2>
                        <div class="view-toggle">
                            <button class="toggle-btn active" data-view="chart">Chart View</button>
                            <button class="toggle-btn" data-view="table">Table View</button>
                        </div>
                    </div>


                    %%[
                    /* Get questions from SST_SP_Survey_Questions_DE */
                    VAR @questions, @questionCount
                    SET @questions = LookupRows("SST_SP_Survey_Questions_DE", "SurveyID", @surveyId)
                    SET @questionCount = RowCount(@questions)


                    /* Debug: Check if questions exist */
                    IF @questionCount == 0 THEN
                    SET @debugMessage = "No questions found in SST_SP_Survey_Questions_DE for SurveyID: " + @surveyId
                    ELSE
                    SET @debugMessage = "Found " + @questionCount + " questions"
                    ENDIF
                    ]%%


                    %%[ IF @questionCount > 0 THEN ]%%


                    <!-- Debug Info 
      <div style="background: #f0f0f0; padding: 10px; margin: 10px 0; border-radius: 5px; font-family: monospace; font-size: 12px;">
        <strong>Debug Info:</strong><br>
        Survey ID: %%=v(@surveyId)=%%<br>
        Questions Found: %%=v(@questionCount)=%%<br>
        Responses Found: %%=v(@count)=%%<br>
        Debug Message: %%=v(@debugMessage)=%%<br>
        <br>
        <strong>Questions in SST_SP_Survey_Questions_DE:</strong><br>
        %%[ FOR @i = 1 TO @questionCount DO
          SET @debugRow = Row(@questions, @i)
          SET @debugText = Field(@debugRow, "QuestionText")
          SET @debugId = Field(@debugRow, "QuestionID")
        ]%%
        %%=v(@i)=%%. %%=v(@debugText)=%% (ID: %%=v(@debugId)=%%)<br>
        %%[ NEXT @i ]%%
      </div> 
-->


                    %%[ FOR @q = 1 TO @questionCount DO
                    SET @questionRow = Row(@questions, @q)
                    SET @questionText = Field(@questionRow, "QuestionText")
                    SET @questionId = Field(@questionRow, "QuestionID")
                    SET @questionType = Field(@questionRow, "QuestionType")


                    /* Count responses for this question */
                    VAR @responseCount, @yesCount, @noCount, @textResponses, @otherResponses
                    SET @responseCount = 0
                    SET @yesCount = 0
                    SET @noCount = 0
                    SET @textResponses = ""
                    SET @otherResponses = ""


                    FOR @i = 1 TO @count DO
                    SET @responseRow = Row(@responses, @i)
                    SET @responseQuestionID = Field(@responseRow, "QuestionID")
                    SET @response = Field(@responseRow, "Response")


                    IF @responseQuestionID == @questionId AND NOT EMPTY(@response) THEN
                    SET @responseCount = Add(@responseCount, 1)


                    /* Count by response type */
                    IF @response == "Yes" THEN
                    SET @yesCount = Add(@yesCount, 1)
                    ELSEIF @response == "No" THEN
                    SET @noCount = Add(@noCount, 1)
                    ELSE
                    /* Store text responses for text-type questions */
                    IF @questionType == "text" THEN
                    SET @textResponses = Concat(@textResponses, "|", @response)
                    ELSE
                    /* Store other responses for multiple choice questions */
                    SET @otherResponses = Concat(@otherResponses, "|", @response)
                    ENDIF
                    ENDIF
                    ENDIF
                    NEXT
                    ]%%


                    <div class="question-card">
                        <div class="question-header">
                            <span class="question-number">%%=Format(@q, "00")=%%</span>
                            <div class="question-content">
                                <!-- <h3>%%=v(@questionText)=%%</h3> -->
                                <h3>
                                    %%=v(@questionText)=%%
                                </h3>
                                <!-- Debug: Question Text = "%%=v(@questionText)=%%" -->
                            </div>
                        </div>


                        <div class="question-stats">
                            <div class="stat-summary">
                                <div class="stat-item">
                                    <span class="stat-label">Total Responses</span>
                                    <span class="stat-value">%%=v(@responseCount)=%%</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-label">Response Rate</span>
                                    <span class="stat-value">%%=IIF(@uniqueContacts > 0,
                                        FormatNumber(Multiply(Divide(@responseCount, @uniqueContacts), 100), 0),
                                        0)=%%%</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-label">Question Type</span>
                                    <span class="stat-value">
                                        <span
                                            class="question-type-badge type-%%=v(@questionType)=%%">%%=v(@questionType)=%%</span>
                                    </span>
                                </div>
                            </div>
                        </div>


                        %%[ IF @responseCount > 0 THEN ]%%
                        <div class="answer-bars">
