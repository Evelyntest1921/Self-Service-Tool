    <script>
        // Modal styles
        const modalStyles = document.createElement('style');
        modalStyles.textContent = `
          .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 2000; }
          .modal-overlay.show { display: flex; }
          .modal-dialog { background: #fff; width: min(900px, 92vw); max-height: 85vh; border-radius: 12px; box-shadow: var(--shadow-xl); display: flex; flex-direction: column; }
          .modal-header { padding: 16px 20px; border-bottom: 1px solid var(--gray-200); display: flex; align-items: center; justify-content: space-between; }
          .modal-header h3 { margin: 0; font-size: 18px; font-weight: 600; }
          .modal-close { background: transparent; border: none; font-size: 22px; cursor: pointer; line-height: 1; }
          .modal-toolbar { padding: 12px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid var(--gray-200); }
          .modal-counter { color: var(--gray-600); font-size: 13px; }
          .modal-list { padding: 16px 20px; overflow: auto; flex: 1; display: grid; gap: 12px; }
          .modal-footer { padding: 12px 20px; border-top: 1px solid var(--gray-200); display: flex; gap: 8px; justify-content: flex-end; }
        `;
        document.head.appendChild(modalStyles);
        // Modal for viewing all text responses
        function openTextResponsesModal(questionId, totalCount) {
            const rawEl = document.getElementById('text-raw-' + questionId);
            const raw = rawEl ? rawEl.textContent : '';
            const responses = raw ? raw.split('|').filter(r => r && r.trim()) : [];


            ensureModal();
            const modal = document.getElementById('textResponsesModal');
            const list = document.getElementById('textModalList');
            const search = document.getElementById('textModalSearch');
            const counter = document.getElementById('textModalCounter');


            // state
            modal.dataset.questionId = questionId;
            modal.dataset.loaded = '0';
            modal.dataset.pageSize = '20';
            modal.dataset.all = JSON.stringify(responses);


            // reset
            list.innerHTML = '';
            search.value = '';
            counter.textContent = totalCount + ' responses';


            // initial render
            loadMoreTextModalItems();


            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
        }


        function closeTextResponsesModal() {
            const modal = document.getElementById('textResponsesModal');
            if (!modal) return;
            modal.classList.remove('show');
            document.body.style.overflow = '';
        }


        function ensureModal() {
            if (document.getElementById('textResponsesModal')) return;
            const modal = document.createElement('div');
            modal.id = 'textResponsesModal';
            modal.className = 'modal-overlay';
            modal.innerHTML = `
                <div class="modal-dialog">
                    <div class="modal-header">
                        <h3>All Text Responses</h3>
                        <button class="modal-close" onclick="closeTextResponsesModal()">×</button>
                    </div>
                    <div class="modal-toolbar">
                        <input id="textModalSearch" type="text" class="search-input" placeholder="Search responses..." oninput="filterTextModalItems()" />
                        <span id="textModalCounter" class="modal-counter"></span>
                    </div>
                    <div id="textModalList" class="modal-list"></div>
                    <div class="modal-footer">
                        <button class="btn-secondary" onclick="loadMoreTextModalItems()">Load more</button>
                        <button class="btn-edit" onclick="closeTextResponsesModal()">Close</button>
                    </div>
                </div>`;
            document.body.appendChild(modal);
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeTextResponsesModal();
            });
        }


        function filterTextModalItems() {
            const modal = document.getElementById('textResponsesModal');
            if (!modal) return;
            const search = document.getElementById('textModalSearch').value.toLowerCase();
            const all = JSON.parse(modal.dataset.all || '[]');
            const list = document.getElementById('textModalList');
            const counter = document.getElementById('textModalCounter');


            const filtered = search ? all.filter(t => (t || '').toLowerCase().includes(search)) : all;
            counter.textContent = filtered.length + ' responses';
            list.innerHTML = '';


            // reset loaded state for filtered set
            modal.dataset.loaded = '0';
            modal.dataset.filtered = JSON.stringify(filtered);
            loadMoreTextModalItems();
        }


        function loadMoreTextModalItems() {
            const modal = document.getElementById('textResponsesModal');
            if (!modal) return;
            const pageSize = parseInt(modal.dataset.pageSize || '20', 10);
            const already = parseInt(modal.dataset.loaded || '0', 10);
            const list = document.getElementById('textModalList');


            const filtered = modal.dataset.filtered ? JSON.parse(modal.dataset.filtered) : JSON.parse(modal.dataset.all || '[]');
            const next = filtered.slice(already, already + pageSize);


            next.forEach(txt => {
                if (!txt || !txt.trim()) return;
                const item = document.createElement('div');
                item.className = 'text-response-item';
                item.innerHTML = `<div class="text-response-content"><span class="text-response-text">"${escapeHtml(txt)}"</span></div>`;
                list.appendChild(item);
            });


            modal.dataset.loaded = String(already + next.length);
        }


        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }
        function confirmDelete() {
            var surveyName = '%%=v(@surveyName)=%%';
            return confirm('Are you sure you want to delete "' + surveyName + '"? This action cannot be undone and will permanently remove all survey data, questions, and responses.');
        }




        function toggleDropdown() {
            var dropdown = document.getElementById('dropdownMenu');
            dropdown.classList.toggle('show');
        }




        // Close dropdown when clicking outside
        window.onclick = function (event) {
            var dropdown = document.getElementById('dropdownMenu');
            var dropdownButton = event.target.closest('.btn-dropdown');


            if (!dropdownButton) {
                if (dropdown.classList.contains('show')) {
                    dropdown.classList.remove('show');
                }
            }
        }




        // Navigation Functions
        function showSurveyAnalytics() {
            // Hide all sections first
            hideAllSections();


            // Show survey analytics section (comprehensive view)
            document.getElementById('surveyAnalyticsSection').style.display = 'block';


            // Update breadcrumb
            updateBreadcrumb('Survey Analytics');


            // Update navigation active state
            updateNavigationActive('showSurveyAnalytics');


            // Scroll to top
            window.scrollTo(0, 0);
        }




        function showReports() {
            // Hide all sections first
            hideAllSections();


            // Show reports section
            document.getElementById('reportsSection').style.display = 'block';


            // Update breadcrumb
            updateBreadcrumb('Reports');


            // Update navigation active state
            updateNavigationActive('showReports');


            // Initialize reports chart with a small delay to ensure Chart.js is loaded
            setTimeout(() => {
                initializeReportsChart();
            }, 100);


            // Scroll to top
            window.scrollTo(0, 0);
        }




        function showResponses() {
            // Hide all sections first
            hideAllSections();


            // Show responses section
            document.getElementById('responsesSection').style.display = 'block';


            // Update breadcrumb
