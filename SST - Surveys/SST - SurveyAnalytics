            <div class="course-cards-grid">
                %%[
                /* Ensure questions are loaded for completion checks */
                VAR @questions
                SET @questions = LookupRows("SST_SP_Survey_Questions_DE", "SurveyID", @surveyId)
                SET @questionCount = RowCount(@questions)

                FOR @i = 1 TO @courseCount DO
                SET @currentCourse = Field(Row(@courseData, @i), 1)
                SET @courseResponses = 0
                SET @courseCompleted = 0
                SET @courseContacts = ""
                
                /* Calculate metrics for this course */
                FOR @j = 1 TO @count DO
                SET @row = Row(@responses, @j)
                SET @courseName = Field(@row, "CourseName")
                SET @contact = Field(@row, "Contact")
                SET @questionId = Field(@row, "QuestionID")
                SET @status = Field(@row, "Status")
                
                IF @courseName == @currentCourse AND @questionId != "SURVEY_OPEN" THEN
                SET @courseResponses = Add(@courseResponses, 1)
                
                /* Track unique contacts */
                IF IndexOf(@courseContacts, @contact) == 0 THEN
                IF EMPTY(@courseContacts) THEN
                SET @courseContacts = @contact
                ELSE
                SET @courseContacts = Concat(@courseContacts, "|", @contact)
                ENDIF
                ENDIF
                
                /* Count completed responses */
                IF @status == "Completed" THEN
                SET @courseCompleted = Add(@courseCompleted, 1)
                ENDIF
                ENDIF
                NEXT @j
                
                /* Count unique contacts */
                IF NOT EMPTY(@courseContacts) THEN
                SET @uniqueContacts = RowCount(BuildRowSetFromString(@courseContacts, "|"))
                ELSE
                SET @uniqueContacts = 0
                ENDIF
                
                /* Calculate completion rate as aggregate: courseResponses / (questionCount * uniqueContacts) */
                VAR @completionRate, @percentRaw
                IF @uniqueContacts > 0 AND @questionCount > 0 THEN
                  SET @percentRaw = Multiply(Divide(@courseResponses, Multiply(@questionCount, @uniqueContacts)), 100)
