                VAR @chartLabels, @chartData, @chartColors, @k
                SET @chartLabels = ""
                SET @chartData = ""
                SET @chartColors = ""
                
                /* Sort courses by response count (descending) */
                FOR @k = 1 TO @courseCount DO
                SET @currentCourse = Field(Row(@courseData, @k), 1)
                SET @courseResponses = 0
                
                /* Count responses for this course */
                FOR @j = 1 TO @count DO
                SET @row = Row(@responses, @j)
                SET @courseName = Field(@row, "CourseName")
                SET @questionId = Field(@row, "QuestionID")
                
                IF @courseName == @currentCourse AND @questionId != "SURVEY_OPEN" THEN
                SET @courseResponses = Add(@courseResponses, 1)
                ENDIF
                NEXT @j
                
                /* Build chart data */
                IF EMPTY(@chartLabels) THEN
                SET @chartLabels = @currentCourse
                SET @chartData = @courseResponses
                ELSE
                SET @chartLabels = Concat(@chartLabels, "|", @currentCourse)
                SET @chartData = Concat(@chartData, "|", @courseResponses)
                ENDIF
                NEXT @k
