        // Generate chart data for specific period using real response dates
        function generateChartDataForPeriod(days) {
            console.log('Generating chart data for period:', days, 'days');


            // Get actual response dates from AMPscript
            const responseDatesElement = document.getElementById('responseDates');
            const responseDates = responseDatesElement ? responseDatesElement.textContent : '';
            const actualDates = responseDates ? responseDates.split('|').filter(date => date.trim()) : [];


            console.log('Actual response dates for period:', actualDates);


            const now = new Date();
            const labels = [];
            const data = [];


            // Generate data points based on period
            let dataPoints;
            if (days <= 30) {
                dataPoints = 7; // Weekly for 30 days
            } else if (days <= 90) {
                dataPoints = 12; // Daily for 90 days
            } else if (days <= 365) {
                dataPoints = 12; // Monthly for 12 months
            } else {
                dataPoints = 6; // Default
            }


            for (let i = dataPoints - 1; i >= 0; i--) {
                const date = new Date(now.getTime() - (i * (days / dataPoints) * 24 * 60 * 60 * 1000));


                // Format labels based on period
                let label;
                if (days <= 30) {
                    label = date.toLocaleDateString('en-US', { weekday: 'short' });
                } else if (days <= 90) {
                    label = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                } else {
                    label = date.toLocaleDateString('en-US', { month: 'short' });
                }
                labels.push(label);


                // Count actual responses in this time period
                let periodCount = 0;
                actualDates.forEach(responseDate => {
                    try {
                        const responseDateTime = new Date(responseDate);
                        const timeDiff = now.getTime() - responseDateTime.getTime();
                        const daysDiff = timeDiff / (1000 * 60 * 60 * 24);


                        // Check if response falls within this period
                        if (daysDiff <= days) {
                            // For weekly view (30 days), group by week
                            if (days <= 30) {
                                const weekStart = new Date(date.getTime() - (7 * 24 * 60 * 60 * 1000));
                                const weekEnd = date;
                                if (responseDateTime >= weekStart && responseDateTime <= weekEnd) {
                                    periodCount++;
                                }
                            }
                            // For monthly view (365 days), group by month
                            else if (days <= 365) {
                                if (responseDateTime.getMonth() === date.getMonth() &&
                                    responseDateTime.getFullYear() === date.getFullYear()) {
                                    periodCount++;
                                }
                            }
                            // For daily view (90 days), group by day
                            else {
                                const dayStart = new Date(date.getTime() - (24 * 60 * 60 * 1000));
                                const dayEnd = date;
                                if (responseDateTime >= dayStart && responseDateTime <= dayEnd) {
                                    periodCount++;
                                }
                            }
                        }
                    } catch (e) {
                        console.warn('Invalid date format:', responseDate);
                    }
                });


                data.push(periodCount);
            }


            const result = { labels, data };
            console.log('Real period chart data:', result);
            return result;
        }




