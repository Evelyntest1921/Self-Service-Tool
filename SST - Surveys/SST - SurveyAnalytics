        // Fallback chart creation without Chart.js
        function createFallbackChart(canvas, chartData) {
            console.log('Creating fallback chart...');


            const { labels, data } = chartData;
            const ctx = canvas.getContext('2d');
            const width = canvas.width;
            const height = canvas.height;


            // Clear canvas
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, width, height);


            // Draw simple bar chart
            const barWidth = width / labels.length * 0.8;
            const barSpacing = width / labels.length * 0.2;
            const maxValue = Math.max(...data, 1);


            // Draw bars
            labels.forEach((label, index) => {
                const barHeight = (data[index] / maxValue) * (height - 60);
                const x = barSpacing + index * (barWidth + barSpacing);
                const y = height - 40 - barHeight;


                // Draw bar
                ctx.fillStyle = '#6366f1';
                ctx.fillRect(x, y, barWidth, barHeight);


                // Draw label
                ctx.fillStyle = '#6b7280';
                ctx.font = '12px Arial';
                ctx.textAlign = 'center';
                ctx.fillText(label, x + barWidth / 2, height - 10);


                // Draw value
                ctx.fillText(data[index], x + barWidth / 2, y - 5);
            });


            // Draw title
            ctx.fillStyle = '#111827';
            ctx.font = 'bold 16px Arial';
            ctx.textAlign = 'center';
            ctx.fillText('Survey Response Trends', width / 2, 20);
        }




