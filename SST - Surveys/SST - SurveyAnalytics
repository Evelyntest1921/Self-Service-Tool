%%[
VAR @surveyId, @errorFlag, @deleteAction, @deleteSuccess, @deleteError
VAR @navRows, @navRow, @surveyUrlRows, @surveyUrlRow, @hubUrl, @surveyHomeUrl, @surveyStageUrl, @surveyAnalyticsUrl, @surveyTakeUrl
VAR @jid, @BUILD_PAGE_SELF, @PERFORMANCE_URL, @detailRows, @detailRow, @isSurveyBuild, @buildNavContext, @buildNavActive
SET @surveyId = RequestParameter("surveyid")
SET @jid = Trim(RequestParameter("journeyId"))
SET @errorFlag = "false"
SET @deleteAction = RequestParameter("deleteAction")
SET @deleteSuccess = "false"
SET @deleteError = ""
SET @hubUrl = ""
SET @surveyHomeUrl = ""
SET @surveyStageUrl = ""
SET @surveyAnalyticsUrl = ""
SET @surveyTakeUrl = ""
SET @BUILD_PAGE_SELF = ""
SET @PERFORMANCE_URL = ""
SET @isSurveyBuild = "false"
SET @buildNavContext = "false"
SET @buildNavActive = "analytics"
SET @navRows = LookupRows("bd_sst_page_navigation","type","cloudpage")
IF RowCount(@navRows) > 0 THEN
  SET @navRow = Row(@navRows,1)
  SET @hubUrl = Field(@navRow,"ss_home")
  SET @BUILD_PAGE_SELF = Field(@navRow,"ss_edit")
  SET @PERFORMANCE_URL = Field(@navRow,"ss_performance")
ENDIF
SET @surveyUrlRows = LookupRows("SST_SP_Survey_Url_DE","user","admin")
IF RowCount(@surveyUrlRows) > 0 THEN
  SET @surveyUrlRow = Row(@surveyUrlRows,1)
  SET @surveyHomeUrl = Field(@surveyUrlRow,"dashboard")
  SET @surveyStageUrl = Field(@surveyUrlRow,"create")
  SET @surveyAnalyticsUrl = Field(@surveyUrlRow,"analytics")
  SET @surveyTakeUrl = Field(@surveyUrlRow,"take")
ENDIF
IF NOT Empty(@jid) THEN
  SET @buildNavContext = "true"
  SET @detailRows = LookupRows("Bd_journey_analytics","journeyId",@jid)
  IF RowCount(@detailRows) > 0 THEN
    IF IndexOf(Field(Row(@detailRows,1),"journeyType"),"Survey") > 0 THEN
      SET @isSurveyBuild = "true"
    ENDIF
  ENDIF
ENDIF




/* Handle delete action */
IF @deleteAction == "delete" THEN
TRY
/* Delete survey responses using DeleteData */
DeleteData("SST_SP_Survey_Responses_DE", "SurveyID", @surveyId)


/* Delete survey questions using DeleteData */
DeleteData("SST_SP_Survey_Questions_DE", "SurveyID", @surveyId)


/* Delete survey from master DE using DeleteData */
DeleteData("SST_SP_Surveys_Master_DE", "SurveyID", @surveyId)


SET @deleteSuccess = "true"
CATCH
SET @deleteError = "An error occurred while deleting the survey. Please try again."
ENDIF
ENDIF
]%%








<!-- Modern Survey Analytics Detail Page -->
