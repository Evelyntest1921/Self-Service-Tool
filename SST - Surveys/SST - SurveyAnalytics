            // Generate chart data based on actual response dates
            const now = new Date();
            const labels = [];
            const data = [];


            // Generate last 6 months of data
            for (let i = 5; i >= 0; i--) {
                const date = new Date(now.getFullYear(), now.getMonth() - i, 1);
                const monthLabel = date.toLocaleDateString('en-US', { month: 'short' });
                labels.push(monthLabel);


                // Count actual responses in this month
                let monthCount = 0;
                actualDates.forEach(responseDate => {
                    try {
                        const responseDateTime = new Date(responseDate);
                        if (responseDateTime.getMonth() === date.getMonth() &&
                            responseDateTime.getFullYear() === date.getFullYear()) {
                            monthCount++;
                        }
                    } catch (e) {
                        console.warn('Invalid date format:', responseDate);
                    }
                });


                data.push(monthCount);
            }


            const result = { labels, data };
            console.log('Real chart data:', result);
            return result;
        }




