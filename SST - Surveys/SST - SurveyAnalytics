            if (visibleRows.length === 0) {
                alert('No data to export');
                return;
            }

            // Create CSV content
            let csvContent = 'Contact,Name,Course Name,Question,Response,Question Type,Status,Last Updated\n';

            visibleRows.forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length >= 8) {
