%%[
VAR @submitted, @surveyId, @contact, @surveyName, @fullSurveyName, @questionCount, @questions, @isFirstVisit
SET @submitted = RequestParameter("submitted")
SET @surveyId = RequestParameter("id")
SET @contact = RequestParameter("contact")
SET @surveyName = RequestParameter("surveyName")
IF EMPTY(@surveyName) THEN
 SET @surveyName = Lookup("SST_SP_Surveys_Master_DE", "SurveyName", "SurveyID", @surveyId)
ENDIF
IF EMPTY(@surveyName) THEN
 SET @surveyName = Concat("Survey ", @surveyId)
ENDIF
SET @fullSurveyName = @surveyName








/* Check if this is the first visit to the survey */
SET @isFirstVisit = RequestParameter("firstVisit")
IF EMPTY(@isFirstVisit) THEN
SET @isFirstVisit = "true"
/* Log survey open event - only if we have valid parameters */
SET @alreadyOpened = Lookup("SST_SP_Survey_Responses_DE", "Status", "Contact", @contact)
IF NOT EMPTY(@contact) AND NOT EMPTY(@surveyId) AND EMPTY(@alreadyOpened) THEN
TRY
  UPSERTDE(
    "SST_SP_Survey_Responses_DE", 1, "Contact", @contact,
    "SurveyID", @surveyId,
    "QuestionID", "SURVEY_OPEN",
    "QuestionNumber", "0",
    "QuestionText", "Survey Opened",
    "QuestionType", "log",
    "Response", "Survey accessed by user",
    "Status", "Opened",
    "CourseName", @fullSurveyName,
    "LastUpdated", NOW()
  )
CATCH
  /* Silently handle any errors with the logging */
ENDIF
ENDIF
ENDIF








/* Load questions for this survey */
SET @questions = LookupRows("SST_SP_Survey_Questions_DE", "SurveyID", @surveyId)
SET @questionCount = RowCount(@questions)


/* Handle form submission */
IF @submitted == "true" THEN
VAR @status, @i, @questionNumber, @answer, @questionId
SET @status = "Completed"
/* Process each question response */
IF @questionCount > 0 THEN
FOR @i = 1 TO @questionCount DO
  SET @row = Row(@questions, @i)
  SET @questionNumber = Field(@row, "QuestionNumber")
  SET @questionId = Field(@row, "QuestionID")
  SET @questionText = Field(@row, "QuestionText")
  SET @questionType = Field(@row, "QuestionType")
  /* Get answer for this question */
  SET @answer = RequestParameter(Concat("q", @questionNumber))
         /* Save response to SST_SP_Survey_Responses_DE */
   IF NOT EMPTY(@contact) AND NOT EMPTY(@answer) THEN
     /* Use INSERTDE to create a new row for each response */
     INSERTDE(
       "SST_SP_Survey_Responses_DE",
       "Contact", @contact,
       "SurveyID", @surveyId,
       "QuestionID", @questionId,
       "QuestionNumber", @questionNumber,
       "QuestionText", @questionText,
       "QuestionType", @questionType,
       "Response", @answer,
       "Status", @status,
       "CourseName", @fullSurveyName,
       "LastUpdated", NOW()
     )
   ENDIF
NEXT @i
ENDIF
ENDIF
]%%
































































































































































































































































