<script>
// Enhanced radio option selection functionality
function setupRadioOptions() {
  const radioOptions = document.querySelectorAll('.radio-option');
  radioOptions.forEach(option => {
    option.addEventListener('click', function(e) {
      // Don't trigger if clicking directly on the radio input
      if (e.target.type === 'radio') {
        return;
      }
 
      const radio = this.querySelector('input[type="radio"]');
      if (radio) {
        // Uncheck all other radios in the same group
        const name = radio.name;
        const group = document.querySelectorAll(`input[name="${name}"]`);
        group.forEach(r => {
          r.checked = false;
          r.closest('.radio-option').classList.remove('selected');
        });
   
        // Check this radio and add selected class
        radio.checked = true;
        this.classList.add('selected');
   
        // Hide the question after a short delay
        setTimeout(() => {
          hideAnsweredQuestion(radio.name);
        }, 500);
   
        // Trigger change event to update progress
        radio.dispatchEvent(new Event('change'));
      }
    });
    // Handle direct radio input changes
    const radio = option.querySelector('input[type="radio"]');
    if (radio) {
      radio.addEventListener('change', function() {
        // Remove selected class from all options in this group
        const name = this.name;
        const group = document.querySelectorAll(`input[name="${name}"]`);
        group.forEach(r => {
          r.closest('.radio-option').classList.remove('selected');
        });
   
        // Add selected class to checked option
        if (this.checked) {
          this.closest('.radio-option').classList.add('selected');
     
          // Hide the question after a short delay
          setTimeout(() => {
            hideAnsweredQuestion(this.name);
          }, 500);
        }
      });
    }
  });
}
































































































































































































































































    // Function to store answers locally (will be saved on final submission)
function saveAnswer(questionName, answer) {
  console.log('Storing answer locally:', questionName, answer);
  // Store the answer to be saved on final form submission
  if (!window.pendingAnswers) {
    window.pendingAnswers = {};
  }
  window.pendingAnswers[questionName] = answer;
}
































































































































// Function to hide answered questions and show next batch
function hideAnsweredQuestion(questionName) {
  // Find the question card by looking for any input with this name
  const questionCard = document.querySelector(`[name="${questionName}"]`).closest('.question-card');
  if (questionCard) {
    // Prevent multiple processing of the same question
    if (questionCard.classList.contains('processing')) {
      console.log('Question already being processed:', questionName);
      return;
    }
    // Mark as processing to prevent duplicates
    questionCard.classList.add('processing');
    const currentQuestionNumber = parseInt(questionCard.dataset.question);
    const totalQuestions = document.querySelectorAll('.question-card').length;
 
    // Save the answer before hiding the question
    const input = questionCard.querySelector(`[name="${questionName}"]`);
    if (input) {
      let answer = '';
      if (input.type === 'radio' && input.checked) {
        answer = input.value;
      } else if (input.type === 'select-one') {
        answer = input.value;
      } else if (input.type === 'textarea') {
        answer = input.value;
      }
 
      if (answer) {
        saveAnswer(questionName, answer);
        console.log('Saved answer for', questionName, ':', answer);
     
        // Update progress immediately after saving answer
        debouncedUpdateProgress();
     
        // Check if all required questions are answered
        checkRequiredQuestionsAndShowSubmit();
      }
    }
    // For textareas, we already captured the answer above, so don't call captureAllVisibleAnswers
    // For other input types, capture any other visible answers before hiding
    const inputType = input ? input.type : '';
    if (inputType !== 'textarea') {
      captureAllVisibleAnswers();
    }
    // Add this question to the hidden questions history for back button functionality
    hiddenQuestionsHistory.push(questionCard);
 
    // Hide the answered question
    questionCard.classList.add('answered');
    // Don't remove from DOM, just hide it so we can show it again with back button
    setTimeout(() => {
      // Show next question
      showNextQuestions(currentQuestionNumber, totalQuestions);
    }, 300);
  }
}
































































































































// Function to capture all currently visible answers
function captureAllVisibleAnswers() {
  const visibleQuestions = document.querySelectorAll('.question-card:not(.answered)');
  console.log('Capturing answers from', visibleQuestions.length, 'visible questions');
  visibleQuestions.forEach(questionCard => {
    // Check for radio buttons
    const radioInputs = questionCard.querySelectorAll('input[type="radio"]:checked');
    radioInputs.forEach(radio => {
      if (radio.value) {
        // Only save if we don't already have this answer
        if (!window.pendingAnswers || !window.pendingAnswers[radio.name]) {
          saveAnswer(radio.name, radio.value);
          console.log('Captured radio answer:', radio.name, ':', radio.value);
        } else {
          console.log('Answer already captured for', radio.name, ':', window.pendingAnswers[radio.name]);
        }
      }
    });
    // Check for select dropdowns (now converted to radio buttons)
    const selectInputs = questionCard.querySelectorAll('select');
    selectInputs.forEach(select => {
      if (select.value && select.value.trim() !== '' && select.value !== 'Select an option') {
        // Only save if we don't already have this answer
        if (!window.pendingAnswers || !window.pendingAnswers[select.name]) {
          saveAnswer(select.name, select.value);
          console.log('Captured select answer:', select.name, ':', select.value);
        } else {
          console.log('Answer already captured for', select.name, ':', window.pendingAnswers[select.name]);
        }
      }
    });
    // REMOVED textarea capture from this function to prevent duplicate answers
    // Textarea answers are already captured in hideAnsweredQuestion() function
  });
  // Update progress after capturing all visible answers
  debouncedUpdateProgress();
}
































































































































// Function to show next question
function showNextQuestions(answeredQuestionNumber, totalQuestions) {
 console.log('Showing next question after question:', answeredQuestionNumber, 'Total questions:', totalQuestions);
  // Find all hidden questions
 const allQuestions = document.querySelectorAll('.question-card');
 const hiddenQuestions = Array.from(allQuestions).filter(q => q.style.display === 'none');
  console.log('Hidden questions found:', hiddenQuestions.length);
  // Show only the next question (first hidden question)
 if (hiddenQuestions.length > 0) {
   const nextQuestion = hiddenQuestions[0];
   nextQuestion.style.display = 'block';
   nextQuestion.classList.add('fade-in');
   console.log('Showing next question:', nextQuestion.dataset.question);
 }
  // Log remaining hidden questions
 const stillHidden = document.querySelectorAll('.question-card[style*="display: none"]').length;
 console.log('Questions still hidden:', stillHidden);
  // Update back button visibility
 updateBackButtonVisibility();
  // Check if current question is last and hide Next button
 checkIfLastQuestionAndHideNext();
}
































































































































































































































































    // Function to handle textarea changes
function setupOtherInputs() {
 // Handle textarea focus to hide previous textarea
 document.querySelectorAll('textarea').forEach((textarea, index) => {
    textarea.addEventListener('focus', function() {
      // Find all textareas
      const allTextareas = document.querySelectorAll('textarea');
 
      // Hide the previous textarea if it has content
      if (index > 0) {
        const previousTextarea = allTextareas[index - 1];
        if (previousTextarea.value && previousTextarea.value.trim() !== '') {
          // Only hide if not already being processed
          if (!previousTextarea.closest('.question-card').classList.contains('processing')) {
            hideAnsweredQuestion(previousTextarea.name);
          }
        }
      }
   
      // Update progress when textarea gets focus (user is working on it)
      debouncedUpdateProgress();
    });
 
    // Also update progress when textarea content changes
    textarea.addEventListener('input', function() {
      debouncedUpdateProgress();
    });
  });
















 // Wire up Next buttons for all question types
 document.querySelectorAll('.next-button').forEach(btn => {
   btn.addEventListener('click', function() {
     const qname = this.getAttribute('data-qname');
     const currentQuestion = document.querySelector('.question-card:not(.answered)');
     if (!currentQuestion) return;








     // Check if this is a required question
     const requiredInput = currentQuestion.querySelector(`[name="${qname}"][required]`);
     if (requiredInput) {
       // For required questions, check if they have an answer
       const radioInput = currentQuestion.querySelector(`input[name="${qname}"]:checked`);
       const textareaInput = currentQuestion.querySelector(`textarea[name="${qname}"]`);
    
       if (!radioInput && !textareaInput) {
         // Required question not answered, don't advance
         return;
       }
    
       if (textareaInput && !textareaInput.value.trim()) {
         // Required text question is empty, don't advance
         return;
       }
     }








     // Get the input value based on question type
     let value = '';
     const radioInput = currentQuestion.querySelector(`input[name="${qname}"]:checked`);
     const textareaInput = currentQuestion.querySelector(`textarea[name="${qname}"]`);
  
     if (radioInput) {
       value = radioInput.value;
     } else if (textareaInput) {
       value = textareaInput.value || '';
     }








     // Save and advance
     saveAnswer(qname, value);
     debouncedUpdateProgress();
     checkRequiredQuestionsAndShowSubmit();
     hideAnsweredQuestion(qname);
   });
 });
}
































































































































































































































































// Debounce function to prevent too frequent updates
let progressUpdateTimeout;
function debouncedUpdateProgress() {
 clearTimeout(progressUpdateTimeout);
 progressUpdateTimeout = setTimeout(updateProgress, 100);
}








// Back button functionality - store history of hidden questions
let hiddenQuestionsHistory = [];








// Function to go back to previous question
function goBackToPreviousQuestion() {
 if (hiddenQuestionsHistory.length > 0) {
   // Hide current question
   const currentQuestion = document.querySelector('.question-card:not(.answered)');
   if (currentQuestion) {
     currentQuestion.style.display = 'none';
   }
    // Get the last hidden question from history
   const lastHiddenQuestion = hiddenQuestionsHistory[hiddenQuestionsHistory.length - 1];
    // Show the last hidden question
   lastHiddenQuestion.style.display = 'block';
   lastHiddenQuestion.classList.remove('answered');
   lastHiddenQuestion.classList.remove('processing');
   lastHiddenQuestion.classList.add('fade-in');
    console.log('Went back to question:', lastHiddenQuestion.dataset.question);
    // Remove the last question from history since we're showing it now
   hiddenQuestionsHistory.pop();
    // Update back button visibility
   updateBackButtonVisibility();
    // Update progress
   debouncedUpdateProgress();
    // Check if current question is last and hide Next button
   checkIfLastQuestionAndHideNext();
 }
}








// Function to update back button visibility
function updateBackButtonVisibility() {
 // Hide all back buttons first
 document.querySelectorAll('.back-button').forEach(btn => {
   btn.style.display = 'none';
 });
  // Show back button only on the current question if there's a hidden question to go back to
 const currentQuestion = document.querySelector('.question-card:not(.answered)');
 if (currentQuestion && hiddenQuestionsHistory.length > 0) {
   const backButton = currentQuestion.querySelector('.back-button');
   if (backButton) {
     backButton.style.display = 'inline-block';
   }
 }
}








// Function to check if all required questions have been answered
function checkRequiredQuestionsAndShowSubmit() {
 const form = document.getElementById('surveyForm');
 if (!form) return;








 // Get all required fields
 const requiredFields = form.querySelectorAll('[required]');
 let allRequiredAnswered = true;








 requiredFields.forEach(field => {
   if (field.type === 'radio') {
     const name = field.name;
     const radioGroup = form.querySelectorAll(`input[name="${name}"]`);
     const checked = Array.from(radioGroup).some(radio => radio.checked);
     if (!checked) {
       allRequiredAnswered = false;
     }
   } else if (field.type === 'textarea') {
     if (!field.value || field.value.trim() === '') {
       allRequiredAnswered = false;
     }
   }
 });








 // Also check stored answers for required questions
 if (window.pendingAnswers) {
   requiredFields.forEach(field => {
     if (field.type === 'radio') {
       const name = field.name;
       if (!window.pendingAnswers[name]) {
         allRequiredAnswered = false;
       }
     } else if (field.type === 'textarea') {
       const name = field.name;
       if (!window.pendingAnswers[name] || window.pendingAnswers[name].trim() === '') {
         allRequiredAnswered = false;
       }
     }
   });
 }








 // Show or hide submit section
 const submitSection = document.getElementById('submitSection');
 if (submitSection) {
   submitSection.style.display = allRequiredAnswered ? 'block' : 'none';
 }
















 console.log('All required questions answered:', allRequiredAnswered);
}








// Function to check if current question is the last question and hide Next button
function checkIfLastQuestionAndHideNext() {
 const currentQuestion = document.querySelector('.question-card:not(.answered)');
 if (!currentQuestion) return;








 const currentQuestionNumber = parseInt(currentQuestion.dataset.question);
 const totalQuestions = window.totalSurveyQuestions || document.querySelectorAll('.question-card').length;
  // Hide/show Next button on current question based on whether it's the last question
 const nextButton = currentQuestion.querySelector('.next-button');
 if (nextButton) {
   nextButton.style.display = currentQuestionNumber >= totalQuestions ? 'none' : 'inline-block';
 }
}








// Progress bar functionality
function updateProgress() {
 const form = document.getElementById('surveyForm');
 if (!form) return;
  // Use a fixed total count from the beginning to avoid dynamic changes
 if (!window.totalSurveyQuestions) {
   const allQuestions = form.querySelectorAll('.question-card');
   window.totalSurveyQuestions = allQuestions.length;
 }
 const totalQuestions = window.totalSurveyQuestions;
  // Count answered questions by checking stored answers
 let answeredCount = 0;
 if (window.pendingAnswers) {
   answeredCount = Object.keys(window.pendingAnswers).length;
 }
  // Also count currently visible answered questions that aren't already stored
 const visibleQuestions = form.querySelectorAll('.question-card:not(.answered)');
 visibleQuestions.forEach(questionCard => {
   const radioInputs = questionCard.querySelectorAll('input[type="radio"]:checked');
   const textareas = questionCard.querySelectorAll('textarea');
    radioInputs.forEach(radio => {
     if (radio.value && radio.checked && (!window.pendingAnswers || !window.pendingAnswers[radio.name])) {
       answeredCount++;
     }
   });
    textareas.forEach(textarea => {
     if (textarea.value && textarea.value.trim() !== '' && (!window.pendingAnswers || !window.pendingAnswers[textarea.name])) {
       answeredCount++;
     }
   });
 });
  // Alternative counting method: count unique question names that have answers
 const allInputs = form.querySelectorAll('input[type="radio"]:checked, textarea');
 const answeredQuestionNames = new Set();
  allInputs.forEach(input => {
   if (input.type === 'radio' && input.checked) {
     answeredQuestionNames.add(input.name);
   } else if (input.type === 'textarea' && input.value && input.value.trim() !== '') {
     answeredQuestionNames.add(input.name);
   }
 });
  // Add stored answers to the set
 if (window.pendingAnswers) {
   Object.keys(window.pendingAnswers).forEach(questionName => {
     answeredQuestionNames.add(questionName);
   });
 }
  const uniqueAnsweredCount = answeredQuestionNames.size;
  // Debug: Log detailed counting information
 console.log('Stored answers count:', window.pendingAnswers ? Object.keys(window.pendingAnswers).length : 0);
 console.log('Visible answered questions count:', answeredCount - (window.pendingAnswers ? Object.keys(window.pendingAnswers).length : 0));
 console.log('Unique answered questions count:', uniqueAnsweredCount);
 // Get all questions for debugging (including hidden ones)
 const allQuestions = form.querySelectorAll('.question-card');
 console.log('All question names:', Array.from(allQuestions).map(q => {
   const inputs = q.querySelectorAll('input, textarea');
   return inputs.length > 0 ? inputs[0].name : 'no-input';
 }));
 console.log('Answered question names:', Array.from(answeredQuestionNames));
  // Use the more accurate unique counting method for progress calculation
 const rawProgress = totalQuestions > 0 ? (uniqueAnsweredCount / totalQuestions) * 100 : 0;
 const progress = Math.min(rawProgress, 100);
  // Warn if progress exceeds 100%
 if (rawProgress > 100) {
   console.warn('Progress exceeded 100%! Answered:', uniqueAnsweredCount, 'Total:', totalQuestions, 'Raw progress:', rawProgress.toFixed(1) + '%');
 }
  const progressFill = document.getElementById('progressFill');
 if (progressFill) {
   progressFill.style.width = progress + '%';
 }
  console.log('Progress update:', uniqueAnsweredCount, '/', totalQuestions, '=', progress.toFixed(1) + '%');
 console.log('Stored answers:', window.pendingAnswers ? Object.keys(window.pendingAnswers) : 'none');
 console.log('Visible questions:', visibleQuestions.length);
 console.log('Fixed total questions:', totalQuestions);
 console.log('Current visible question names:', Array.from(visibleQuestions).map(q => {
   const inputs = q.querySelectorAll('input, textarea');
   return inputs.length > 0 ? inputs[0].name : 'no-input';
 }));
  // Check if all required questions are answered and show/hide submit button
 checkRequiredQuestionsAndShowSubmit();
  // Check if current question is last and hide Next button
 checkIfLastQuestionAndHideNext();
}
































































































































































































































































