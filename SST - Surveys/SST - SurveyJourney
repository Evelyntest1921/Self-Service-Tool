<script>
 var form = document.getElementById('surveyForm') || document.querySelector('form[method="post"]');
 if (form && form.querySelector('#submitBtn')) {
   var btn = document.getElementById('submitBtn');
   var btnText = document.getElementById('btnText');
   var btnSpinner = document.getElementById('btnSpinner');
   form.addEventListener('submit', function() {
     btn.disabled = true;
     if (btnText) btnText.textContent = 'Creating...';
     if (btnSpinner) btnSpinner.style.display = 'inline-block';
   });
 }
 var showLogBtn = document.getElementById('showLogBtn');
 var apiLog = document.getElementById('apiLog');
 if (showLogBtn && apiLog) {
   showLogBtn.onclick = function() {
     apiLog.classList.toggle('is-visible');
     showLogBtn.textContent = apiLog.classList.contains('is-visible') ? 'Hide log' : 'Show log';
   };
 }
 var senderPanel = document.getElementById('senderSettingsPanel');
 var senderToggle = document.getElementById('senderSettingsToggle');
 if (senderPanel && senderToggle) {
   senderToggle.addEventListener('click', function() {
     var isOpen = senderPanel.classList.toggle('is-open');
     senderToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
   });
 }
 var emailCards = document.querySelectorAll('.email-card');
 emailCards.forEach(function(card) {
   card.addEventListener('click', function() {
     emailCards.forEach(function(c) { c.classList.remove('selected'); });
     card.classList.add('selected');
     var radio = card.querySelector('input[type="radio"]');
     if (radio) radio.checked = true;
   });
 });
</script>
</body>
