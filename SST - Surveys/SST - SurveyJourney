      border-radius: var(--radius-md);
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      font-size: 14px;
    }




    .btn-primary {
      background: var(--primary-color);
      color: white;
    }




    .btn-primary:hover {
      background: var(--primary-dark);
