 var form = document.querySelector('form[method="post"]');
 if (form && form.querySelector('#submitBtn')) {
   var btn = document.getElementById('submitBtn');
   var btnText = document.getElementById('btnText');
   var btnSpinner = document.getElementById('btnSpinner');
   form.addEventListener('submit', function(e) {
     var questions = document.querySelectorAll('.question-item');
     if (questions.length === 0) {
       e.preventDefault();
       alert('Please add at least one question to your survey');
       return;
     }
     var questionCountInput = document.createElement('input');
     questionCountInput.type = 'hidden';
     questionCountInput.name = 'questionCount';
     questionCountInput.value = questions.length;
     form.appendChild(questionCountInput);
     questions.forEach(function(question, index) {
       var questionNumber = index + 1;
       var typeInput = question.querySelector('input[name="questionType' + questionNumber + '"]');
       if (typeInput && typeInput.value === 'multiple') {
         var options = question.querySelectorAll('.option-input');
         var optionCountInput = document.createElement('input');
         optionCountInput.type = 'hidden';
         optionCountInput.name = 'optionCount' + questionNumber;
         optionCountInput.value = options.length;
         form.appendChild(optionCountInput);
       }
     });
     btn.disabled = true;
     if (btnText) btnText.textContent = 'Creating...';
     if (btnSpinner) btnSpinner.style.display = 'inline-block';
   });
 }
