.email-card input { display: none; }
.email-card-img {
  width: 100%;
  height: auto;
  display: block;
}
.email-card-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 22px;
  padding: 0 10px;
  font-size: 0.8125rem;
  font-weight: 700;
  color: #484848;
  line-height: 1.2;
  z-index: 2;
}
.email-card-id {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 6px;
  padding: 0 10px;
  font-size: 0.6875rem;
  color: #363232eb;
  z-index: 2;
}
.email-card::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 156px;
  background: linear-gradient(to top, rgb(255 255 255), #fcfeff);
