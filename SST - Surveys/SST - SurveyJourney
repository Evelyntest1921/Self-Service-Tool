<script runat="server">
var cleanupNeeded = Variable.GetValue("cleanupNeeded");
var eventDefId = Variable.GetValue("eventDefId");
var newEmailId = Variable.GetValue("newEmailId");
var subdomain = Variable.GetValue("subdomain");
var accessToken = Variable.GetValue("accessToken");
var resultText = Variable.GetValue("resultText");
if (cleanupNeeded == "1" && (eventDefId || newEmailId) && subdomain && accessToken) {
 var cleanupLog = "";
 if (eventDefId) {
 try {
   var eventName = Variable.GetValue("eventName");
   var getEventUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" + eventDefId;
   var getReq = new Script.Util.HttpRequest(getEventUrl);
   getReq.emptyContentHandling = 0;
   getReq.continueOnError = true;
   getReq.setHeader("Authorization", "Bearer " + accessToken);
   getReq.method = "GET";
   var getResp = getReq.send();
   var dataExtensionId = null;
   if ((getResp.statusCode == 200 || getResp.statusCode == 201) && getResp.content) {
     var eventObj = Platform.Function.ParseJSON(String(getResp.content));
     dataExtensionId = eventObj.dataExtensionId || eventObj.dataExtensionID || null;
   }
   var eventDeleteUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" + eventDefId;
   var eventReq = new Script.Util.HttpRequest(eventDeleteUrl);
   eventReq.emptyContentHandling = 0;
   eventReq.continueOnError = true;
   eventReq.setHeader("Authorization", "Bearer " + accessToken);
   eventReq.method = "DELETE";
   var eventResp = eventReq.send();
   if (eventResp.statusCode == 200 || eventResp.statusCode == 204) {
     cleanupLog = " Event definition deleted.";
   } else {
     cleanupLog = " Event delete HTTP " + eventResp.statusCode + ".";
   }
   if (dataExtensionId || eventName) {
     try {
       var deObjId = dataExtensionId;
       if (!deObjId && eventName) {
         var prox2 = new Script.Util.WSProxy();
         var deFilter = { Property: "Name", SimpleOperator: "equals", Value: eventName };
         var retrieveReq = prox2.retrieve("DataExtension", ["ObjectID"], deFilter);
         if (retrieveReq && retrieveReq.Results && retrieveReq.Results.length > 0 && retrieveReq.Results[0].ObjectID) {
           deObjId = retrieveReq.Results[0].ObjectID;
         }
       }
       if (deObjId) {
         var prox = new Script.Util.WSProxy();
         var deResult = prox.deleteItem("DataExtension", { "ObjectID": deObjId });
         if (deResult && deResult.Results && deResult.Results.length > 0 && deResult.Results[0].Status === "OK") {
           cleanupLog = cleanupLog + " Data extension deleted.";
         } else {
           cleanupLog = cleanupLog + " DE delete failed.";
         }
       }
     } catch (deEx) {
       cleanupLog = cleanupLog + " DE delete failed - " + (deEx.message || String(deEx));
     }
   }
 } catch (e) {
   cleanupLog = cleanupLog + " Cleanup failed - " + (e.message || String(e));
 }
 }
 if (newEmailId) {
 try {
   var assetDeleteUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + newEmailId;
   var assetReq = new Script.Util.HttpRequest(assetDeleteUrl);
   assetReq.emptyContentHandling = 0;
   assetReq.continueOnError = true;
   assetReq.setHeader("Authorization", "Bearer " + accessToken);
   assetReq.method = "DELETE";
   var assetResp = assetReq.send();
   if (assetResp.statusCode == 200 || assetResp.statusCode == 204) {
     cleanupLog = cleanupLog + " Email asset deleted.";
   } else {
     cleanupLog = cleanupLog + " Email delete HTTP " + assetResp.statusCode + ".";
   }
 } catch (e) {
   cleanupLog = cleanupLog + " Email delete failed - " + (e.message || String(e));
 }
 }
 Platform.Variable.SetValue("@resultText", resultText + cleanupLog);
}

function resolveDeRecordSj(prox, filter) {
 try {
  var rde = prox.retrieve("DataExtension", ["CustomerKey", "Name"], filter);
  if (rde && rde.Results && rde.Results.length > 0 && rde.Results[0].CustomerKey) {
   return {
    customerKey: String(rde.Results[0].CustomerKey),
    name: String(rde.Results[0].Name || "")
   };
  }
 } catch (deRecEx) {}
 return null;
}

function resolveDeMetaFromEventDefSj(sub, token, evId, eventName) {
 if (!evId || !sub || !token) {
  return { customerKey: "", name: "" };
 }
 try {
  var prox = new Script.Util.WSProxy();
  var getUrl =
   "https://" +
   sub +
   ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" +
   encodeURIComponent(String(evId));
  var getReq = new Script.Util.HttpRequest(getUrl);
  getReq.emptyContentHandling = 0;
  getReq.continueOnError = true;
  getReq.setHeader("Authorization", "Bearer " + token);
  getReq.method = "GET";
  var getResp = getReq.send();
  if ((getResp.statusCode == 200 || getResp.statusCode == 201) && getResp.content) {
   var evtObj = Platform.Function.ParseJSON(String(getResp.content));
   var deObjId = evtObj.dataExtensionId || evtObj.dataExtensionID || "";
   var deKeyHint =
    evtObj.dataExtensionKey ||
    evtObj.dataExtensionCustomerKey ||
    evtObj.criteria ||
    "";
   if (deKeyHint && typeof deKeyHint === "object" && deKeyHint.deKey) {
    deKeyHint = deKeyHint.deKey;
   }
   var candidates = [];
   if (deKeyHint) {
    candidates.push(String(deKeyHint));
   }
   if (deObjId) {
    candidates.push(String(deObjId));
   }
   var ci;
   for (ci = 0; ci < candidates.length; ci++) {
    var byKey = resolveDeRecordSj(prox, {
     Property: "CustomerKey",
     SimpleOperator: "equals",
     Value: candidates[ci]
    });
    if (byKey) {
     return byKey;
    }
   }
   if (deObjId) {
    var byId = resolveDeRecordSj(prox, {
     Property: "ObjectID",
     SimpleOperator: "equals",
     Value: String(deObjId)
    });
    if (byId) {
     return byId;
    }
   }
  }
  if (eventName) {
   var byName = resolveDeRecordSj(prox, {
    Property: "Name",
    SimpleOperator: "equals",
    Value: String(eventName)
   });
   if (byName) {
    return byName;
   }
  }
 } catch (evMetaEx) {}
 return { customerKey: "", name: "" };
}

var sjEventDefId =
 Platform.Variable.GetValue("@eventDefId") || Variable.GetValue("eventDefId") || "";
var sjSub =
 Platform.Variable.GetValue("@subdomain") || Variable.GetValue("subdomain") || "";
var sjToken =
 Platform.Variable.GetValue("@accessToken") || Variable.GetValue("accessToken") || "";
var sjEventName =
 Platform.Variable.GetValue("@eventName") || Variable.GetValue("eventName") || "";
if (sjEventDefId && sjSub && sjToken) {
 var sjDeMeta = resolveDeMetaFromEventDefSj(
  sjSub,
  sjToken,
  sjEventDefId,
  sjEventName
 );
 if (sjDeMeta.customerKey) {
  Platform.Variable.SetValue("@deCustomerKey", sjDeMeta.customerKey);
  Platform.Variable.SetValue("@entryDeName", sjDeMeta.name || sjEventName);
 }
}

</script>
