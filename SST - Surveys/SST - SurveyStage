  <script>
    let questionCounter = 0;
    let selectedQuestionType = '';
   
    // Load existing questions if in edit mode
    %%[ IF @mode == "edit" AND NOT EMPTY(@editQuestions) THEN ]%%
    const existingQuestionsData = [
      %%[
        VAR @questionCount, @i, @questionRow, @questionText, @questionType, @options, @required
        SET @questionCount = RowCount(@editQuestions)
        FOR @i = 1 TO @questionCount DO
          SET @questionRow = Row(@editQuestions, @i)
          SET @questionText = Field(@questionRow, "QuestionText")
          SET @questionType = Field(@questionRow, "QuestionType")
          SET @options = Field(@questionRow, "Options")
          SET @required = Field(@questionRow, "Required")
         
          /* Escape quotes in text for JavaScript */
          SET @questionText = Replace(@questionText, '"', '\"')
          SET @options = Replace(@options, '"', '\"')
      ]%%
      {
        number: %%=v(@i)=%%,
        text: "%%=v(@questionText)=%%",
        type: "%%=v(@questionType)=%%",
        options: "%%=v(@options)=%%",
        required: "%%=v(@required)=%%"
      }%%=IIF(@i < @questionCount, ",", "")=%%
      %%[ NEXT @i ]%%
    ];
   
    // Load existing questions on page load
    document.addEventListener('DOMContentLoaded', function() {
      console.log('Loading existing questions:', existingQuestionsData);
     
      if (existingQuestionsData && existingQuestionsData.length > 0) {
        existingQuestionsData.forEach(questionData => {
          questionCounter = questionData.number;
          selectedQuestionType = questionData.type;
         
          const questionHtml = createQuestionHTML(questionData.number, questionData.type, questionData.text, questionData.options);
          const questionsList = document.getElementById('questionsList');
          questionsList.insertAdjacentHTML('beforeend', questionHtml);
         
          // Populate the question text
          const questionInput = document.querySelector(`input[name="question${questionData.number}"]`);
          if (questionInput) {
            questionInput.value = questionData.text;
          }
         
          // Populate options for multiple choice questions
          if (questionData.type === 'multiple' && questionData.options) {
            const options = questionData.options.split('|');
            options.forEach((option, index) => {
              const optionInput = document.querySelector(`input[name="option${questionData.number}_${index + 1}"]`);
              if (optionInput) {
                optionInput.value = option;
              }
            });
          }
        });
      } else {
        console.log('No existing questions found or data is empty');
        // Add a default question if none exist
        addQuestion();
      }
    });
    %%[ ELSE ]%%
    // No edit mode - initialize normally
    document.addEventListener('DOMContentLoaded', function() {
      console.log('Not in edit mode - normal initialization');
    });
    %%[ ENDIF ]%%




         // Initialize question counter for edit mode
     document.addEventListener('DOMContentLoaded', function() {
       const questions = document.querySelectorAll('.question-item');
       questionCounter = questions.length;
     });




         // Add question function
     function addQuestion() {
       questionCounter++;
       const questionHtml = createQuestionHTML(questionCounter, 'likert'); // Default to likert
       
       const questionsList = document.getElementById('questionsList');
       questionsList.insertAdjacentHTML('beforeend', questionHtml);
     }
         // Create question HTML based on type
     function createQuestionHTML(number, type, existingText = '', existingOptions = '') {
       const baseHtml = `
         <div class="question-item" data-question="${number}">
           <div class="question-header">
             <div class="question-number">${number}</div>
             <div class="question-actions">
               <button type="button" class="btn-remove" onclick="removeQuestion(${number})">Remove</button>
             </div>
           </div>
           <div class="form-group">
             <label class="form-label">Question ${number}</label>
             <input type="text" class="form-input" name="question${number}" placeholder="Enter your question here" value="${existingText}" required>
           </div>
           <div class="form-group">
             <label class="form-label">Question Type</label>
             <select class="form-select question-type-select" onchange="updateQuestionType(${number}, this.value)">
               <option value="likert" ${type === 'likert' ? 'selected' : ''}>Likert Scale</option>
               <option value="rating" ${type === 'rating' ? 'selected' : ''}>Rating Scale</option>
               <option value="yesno" ${type === 'yesno' ? 'selected' : ''}>Yes/No</option>
               <option value="text" ${type === 'text' ? 'selected' : ''}>Text Input</option>
               <option value="multiple" ${type === 'multiple' ? 'selected' : ''}>Multiple Choice</option>
             </select>
             <input type="hidden" name="questionType${number}" value="${type}">
             <input type="hidden" name="required${number}" value="true">
           </div>
       `;




      let optionsHtml = '';
     
             switch(type) {
         case 'likert':
           optionsHtml = `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">Strongly Disagree</div>
                 <input type="text" class="option-input" name="option${number}_1" value="Strongly Disagree" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Disagree</div>
                 <input type="text" class="option-input" name="option${number}_2" value="Disagree" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Neutral</div>
                 <input type="text" class="option-input" name="option${number}_3" value="Neutral" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Agree</div>
                 <input type="text" class="option-input" name="option${number}_4" value="Agree" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Strongly Agree</div>
                 <input type="text" class="option-input" name="option${number}_5" value="Strongly Agree" readonly>
               </div>
             </div>
           `;
           break;
           
         case 'rating':
           optionsHtml = `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">⭐ Poor</div>
                 <input type="text" class="option-input" name="option${number}_1" value="Poor" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐ Fair</div>
                 <input type="text" class="option-input" name="option${number}_2" value="Fair" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐⭐ Good</div>
                 <input type="text" class="option-input" name="option${number}_3" value="Good" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐⭐⭐ Very Good</div>
                 <input type="text" class="option-input" name="option${number}_4" value="Very Good" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐⭐⭐⭐ Excellent</div>
                 <input type="text" class="option-input" name="option${number}_5" value="Excellent" readonly>
               </div>
             </div>
           `;
           break;
           
         case 'yesno':
           optionsHtml = `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">✅ Yes</div>
                 <input type="text" class="option-input" name="option${number}_1" value="Yes" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">❌ No</div>
                 <input type="text" class="option-input" name="option${number}_2" value="No" readonly>
               </div>
             </div>
           `;
           break;
           
         case 'text':
           optionsHtml = `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">📝 Text Response</div>
                 <textarea class="form-textarea" name="option${number}_1" placeholder="This will be a text area for open-ended responses" readonly></textarea>
               </div>
             </div>
           `;
           break;
         
                 case 'multiple':
           let multipleOptionsHtml = `<div class="question-options" id="options${number}">`;
           
           if (existingOptions) {
             const options = existingOptions.split('|');
             options.forEach((option, index) => {
               multipleOptionsHtml += `
                 <div class="option-item">
                   <div class="option-label">📋 Option ${index + 1}</div>
                   <input type="text" class="option-input" name="option${number}_${index + 1}" placeholder="Enter option text" value="${option}" required>
                   <button type="button" class="btn-remove-option" onclick="removeOption(${number}, ${index + 1})">×</button>
                 </div>
               `;
             });
           } else {
             multipleOptionsHtml += `
               <div class="option-item">
                 <div class="option-label">📋 Option 1</div>
                 <input type="text" class="option-input" name="option${number}_1" placeholder="Enter option text" required>
                 <button type="button" class="btn-remove-option" onclick="removeOption(${number}, 1)">×</button>
               </div>
               <div class="option-item">
                 <div class="option-label">📋 Option 2</div>
                 <input type="text" class="option-input" name="option${number}_2" placeholder="Enter option text" required>
                 <button type="button" class="btn-remove-option" onclick="removeOption(${number}, 2)">×</button>
               </div>
             `;
           }
           
           multipleOptionsHtml += `</div><button type="button" class="btn-add-option" onclick="addOption(${number})">Add Option</button>`;
           optionsHtml = multipleOptionsHtml;
           break;
      }




      return baseHtml + optionsHtml + '</div>';
    }




    // Remove question
    function removeQuestion(number) {
      const question = document.querySelector(`[data-question="${number}"]`);
      if (question) {
        question.remove();
        renumberQuestions();
      }
    }




    // Renumber questions after removal
    function renumberQuestions() {
      const questions = document.querySelectorAll('.question-item');
      questions.forEach((question, index) => {
        const number = index + 1;
        question.dataset.question = number;
        question.querySelector('.question-number').textContent = number;
        question.querySelector('input[name^="question"]').name = `question${number}`;
      });
      questionCounter = questions.length;
    }




         // Update question type and refresh options
     function updateQuestionType(questionNumber, newType) {
       const questionItem = document.querySelector(`[data-question="${questionNumber}"]`);
       const questionText = questionItem.querySelector(`input[name="question${questionNumber}"]`).value;
       
       // Update hidden input
       questionItem.querySelector(`input[name="questionType${questionNumber}"]`).value = newType;
       
       // Remove existing options
       const existingOptions = questionItem.querySelector('.question-options');
       if (existingOptions) {
         existingOptions.remove();
       }
       
       // Add new options based on type
       const optionsHtml = createOptionsHTML(questionNumber, newType);
       questionItem.insertAdjacentHTML('beforeend', optionsHtml);
     }
     
     // Create options HTML based on type
     function createOptionsHTML(number, type) {
       switch(type) {
         case 'likert':
           return `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">Strongly Disagree</div>
                 <input type="text" class="option-input" name="option${number}_1" value="Strongly Disagree" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Disagree</div>
                 <input type="text" class="option-input" name="option${number}_2" value="Disagree" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Neutral</div>
                 <input type="text" class="option-input" name="option${number}_3" value="Neutral" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Agree</div>
                 <input type="text" class="option-input" name="option${number}_4" value="Agree" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">Strongly Agree</div>
                 <input type="text" class="option-input" name="option${number}_5" value="Strongly Agree" readonly>
               </div>
             </div>
           `;
           
         case 'rating':
           return `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">⭐ Poor</div>
                 <input type="text" class="option-input" name="option${number}_1" value="Poor" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐ Fair</div>
                 <input type="text" class="option-input" name="option${number}_2" value="Fair" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐⭐ Good</div>
                 <input type="text" class="option-input" name="option${number}_3" value="Good" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐⭐⭐ Very Good</div>
                 <input type="text" class="option-input" name="option${number}_4" value="Very Good" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">⭐⭐⭐⭐⭐ Excellent</div>
                 <input type="text" class="option-input" name="option${number}_5" value="Excellent" readonly>
               </div>
             </div>
           `;
           
         case 'yesno':
           return `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">✅ Yes</div>
                 <input type="text" class="option-input" name="option${number}_1" value="Yes" readonly>
               </div>
               <div class="option-item">
                 <div class="option-label">❌ No</div>
                 <input type="text" class="option-input" name="option${number}_2" value="No" readonly>
               </div>
             </div>
           `;
           
         case 'text':
           return `
             <div class="question-options">
               <div class="option-item">
                 <div class="option-label">📝 Text Response</div>
                 <textarea class="form-textarea" name="option${number}_1" placeholder="This will be a text area for open-ended responses" readonly></textarea>
               </div>
             </div>
           `;
           
         case 'multiple':
           return `
             <div class="question-options" id="options${number}">
               <div class="option-item">
                 <div class="option-label">📋 Option 1</div>
                 <input type="text" class="option-input" name="option${number}_1" placeholder="Enter option text" required>
                 <button type="button" class="btn-remove-option" onclick="removeOption(${number}, 1)">×</button>
               </div>
               <div class="option-item">
                 <div class="option-label">📋 Option 2</div>
                 <input type="text" class="option-input" name="option${number}_2" placeholder="Enter option text" required>
                 <button type="button" class="btn-remove-option" onclick="removeOption(${number}, 2)">×</button>
               </div>
             </div>
             <button type="button" class="btn-add-option" onclick="addOption(${number})">Add Option</button>
           `;
           
         default:
           return '';
       }
     }




     // Add option for multiple choice
     function addOption(questionNumber) {
       const optionsContainer = document.getElementById(`options${questionNumber}`);
       const optionCount = optionsContainer.children.length + 1;
       
       const optionHtml = `
         <div class="option-item">
           <div class="option-label">📋 Option ${optionCount}</div>
           <input type="text" class="option-input" name="option${questionNumber}_${optionCount}" placeholder="Enter option text" required>
           <button type="button" class="btn-remove-option" onclick="removeOption(${questionNumber}, ${optionCount})">×</button>
         </div>
       `;
       
       optionsContainer.insertAdjacentHTML('beforeend', optionHtml);
     }




    // Remove option
    function removeOption(questionNumber, optionNumber) {
      const option = document.querySelector(`input[name="option${questionNumber}_${optionNumber}"]`).parentElement;
      if (option) {
        option.remove();
      }
    }




    // Preview survey
    function previewSurvey() {
      // This would open a preview modal or navigate to preview page
      alert('Preview functionality would show how the survey will look to respondents');
    }




    // Form validation and submission
    document.getElementById('surveyForm').addEventListener('submit', function(e) {
      const questions = document.querySelectorAll('.question-item');
      if (questions.length === 0) {
        e.preventDefault();
        alert('Please add at least one question to your survey');
        return;
      }
     
      // Add question count to form
      const questionCountInput = document.createElement('input');
      questionCountInput.type = 'hidden';
      questionCountInput.name = 'questionCount';
      questionCountInput.value = questions.length;
      this.appendChild(questionCountInput);
     
      // Add option counts for multiple choice questions
      questions.forEach((question, index) => {
        const questionNumber = index + 1;
        const questionType = question.querySelector(`input[name="questionType${questionNumber}"]`).value;
       
        if (questionType === 'multiple') {
          const options = question.querySelectorAll('.option-input');
          const optionCountInput = document.createElement('input');
          optionCountInput.type = 'hidden';
          optionCountInput.name = `optionCount${questionNumber}`;
          optionCountInput.value = options.length;
          this.appendChild(optionCountInput);
        }
      });
    });
  </script>
