%%[
VAR @errorFlag, @dataExists, @testCount, @mode, @surveyId, @editSurveyName, @editSurveyStatus, @editQuestions
VAR @navRows, @navRow, @hubUrl, @builderPageLabel, @jid, @BUILD_PAGE_SELF, @PERFORMANCE_URL, @SURVEY_STAGE_URL, @SURVEY_ANALYTICS_URL
VAR @detailRows, @detailRow, @isSurveyBuild, @buildNavContext, @buildNavActive, @surveyUrlRows, @surveyUrlRow
SET @errorFlag = "false"
SET @dataExists = "true"
SET @mode = RequestParameter("mode")
SET @surveyId = RequestParameter("surveyid")
SET @jid = Trim(RequestParameter("journeyId"))
SET @hubUrl = ""
SET @BUILD_PAGE_SELF = ""
SET @PERFORMANCE_URL = ""
SET @SURVEY_STAGE_URL = ""
SET @SURVEY_ANALYTICS_URL = ""
SET @isSurveyBuild = "false"
SET @buildNavContext = "false"
SET @buildNavActive = "edit-survey"
SET @navRows = LookupRows("bd_sst_page_navigation","type","cloudpage")
IF RowCount(@navRows) > 0 THEN
  SET @navRow = Row(@navRows,1)
  SET @hubUrl = Field(@navRow,"ss_home")
  SET @BUILD_PAGE_SELF = Field(@navRow,"ss_edit")
  SET @PERFORMANCE_URL = Field(@navRow,"ss_performance")
ENDIF
SET @surveyUrlRows = LookupRows("SST_SP_Survey_Url_DE","user","admin")
IF RowCount(@surveyUrlRows) > 0 THEN
  SET @surveyUrlRow = Row(@surveyUrlRows,1)
  SET @SURVEY_STAGE_URL = Field(@surveyUrlRow,"create")
  SET @SURVEY_ANALYTICS_URL = Field(@surveyUrlRow,"analytics")
ENDIF
IF Empty(@jid) AND NOT Empty(@surveyId) AND @surveyId != "N/A" AND @mode == "edit" THEN
  SET @detailRows = LookupRows("Bd_journey_analytics","surveyId",@surveyId)
  IF RowCount(@detailRows) > 0 THEN
    SET @jid = Trim(Field(Row(@detailRows,1),"journeyId"))
  ENDIF
ENDIF
IF NOT Empty(@jid) THEN
  SET @buildNavContext = "true"
  SET @detailRows = LookupRows("Bd_journey_analytics","journeyId",@jid)
  IF RowCount(@detailRows) > 0 THEN
    IF IndexOf(Field(Row(@detailRows,1),"journeyType"),"Survey") > 0 THEN
      SET @isSurveyBuild = "true"
    ENDIF
  ENDIF
ENDIF
SET @builderPageLabel = "Create Survey"
IF @mode == "edit" THEN
  SET @builderPageLabel = "Edit Survey"
ENDIF




/* Test data extension access - using SP_Survey_Questions_DE */
VAR @testAccess, @testAccessCount
SET @testAccess = LookupRows("SP_Survey_Questions_DE", "QuestionID", "TEST")
SET @testAccessCount = RowCount(@testAccess)
IF @testAccessCount >= 0 THEN
  SET @dataExists = "true"
ELSE
  SET @dataExists = "false"
ENDIF


/* Additional test - try to get any record */
VAR @anyRecord, @anyRecordCount
SET @anyRecord = LookupRows("SP_Survey_Questions_DE", "QuestionID", "")
SET @anyRecordCount = RowCount(@anyRecord)


/* Test with a specific field that we know exists */
VAR @testField, @testFieldCount
SET @testField = LookupRows("SP_Survey_Questions_DE", "SurveyID", "")
SET @testFieldCount = RowCount(@testField)


/* Test with a wildcard approach */
VAR @wildcardTest, @wildcardCount
SET @wildcardTest = LookupRows("SP_Survey_Questions_DE", "QuestionID", "*")
SET @wildcardCount = RowCount(@wildcardTest)




/* Load survey data for edit mode */
IF @mode == "edit" AND NOT EMPTY(@surveyId) THEN
  /* Get survey details from master DE */
  SET @editSurveyName = Lookup("SP_Surveys_Master_DE", "SurveyName", "SurveyID", @surveyId)
  SET @editSurveyStatus = Lookup("SP_Surveys_Master_DE", "SurveyStatus", "SurveyID", @surveyId)
 
  /* Get existing questions */
  SET @editQuestions = LookupRows("SP_Survey_Questions_DE", "SurveyID", @surveyId)
 
  /* Debug: Check if questions were found */
  VAR @questionCount
  SET @questionCount = RowCount(@editQuestions)
 
  /* Debug: Try to get any questions from the DE to test access */
  VAR @testQuestions, @testCount
  SET @testQuestions = LookupRows("SP_Survey_Questions_DE", "QuestionID", "")
  SET @testCount = RowCount(@testQuestions)
 
  /* Debug: Try alternative query method */
  VAR @altTestQuestions, @altTestCount
  SET @altTestQuestions = LookupRows("SP_Survey_Questions_DE", "SurveyID", "")
  SET @altTestCount = RowCount(@altTestQuestions)
 
  /* Debug: Test with the specific SurveyID */
  VAR @specificTest, @specificCount
  SET @specificTest = LookupRows("SP_Survey_Questions_DE", "SurveyID", @surveyId)
  SET @specificCount = RowCount(@specificTest)
 
  /* Debug: Get a sample SurveyID from the DE */
  VAR @sampleSurveyId
  IF @testCount > 0 THEN
    SET @sampleSurveyId = Field(Row(@testQuestions, 1), "SurveyID")
  ELSEIF @altTestCount > 0 THEN
    SET @sampleSurveyId = Field(Row(@altTestQuestions, 1), "SurveyID")
  ENDIF
ENDIF




/* Handle form submission */
VAR @submitted, @surveyName, @surveyDescription, @targetAudience
SET @submitted = RequestParameter("submitted")




IF @submitted == "true" THEN
  SET @surveyName = RequestParameter("surveyName")
  SET @surveyDescription = RequestParameter("surveyDescription")
  SET @targetAudience = RequestParameter("targetAudience")
 
  /* Use existing SurveyID for edit mode, generate new one for create mode */
  IF @mode == "edit" AND NOT EMPTY(@surveyId) THEN
    /* Keep existing SurveyID for editing */
  ELSE
    /* Generate unique SurveyID for new survey */
    SET @surveyId = Concat("SURV_", Format(Now(), "yyyyMMdd_HHmmss"))
  ENDIF
 
  /* Save survey metadata to SP_Surveys_Master_DE */
  IF NOT EMPTY(@surveyName) THEN
    UPSERTDE(
      "SP_Surveys_Master_DE", 1, "SurveyID", @surveyId,
      "SurveyName", @surveyName,
      "SurveyStatus", "Active",
      "SurveyCreatedDate", NOW()
    )
  ENDIF
 
  /* Process and save questions to Questions DE */
  VAR @questionCount, @i, @questionText, @questionType, @options, @required, @orderIndex, @questionId
  SET @questionCount = RequestParameter("questionCount")
 
  IF NOT EMPTY(@questionCount) THEN
    FOR @i = 1 TO @questionCount DO
      SET @questionText = RequestParameter(Concat("question", @i))
      SET @questionType = RequestParameter(Concat("questionType", @i))
      SET @required = RequestParameter(Concat("required", @i))
     
      /* Use existing QuestionID for edit mode, generate new one for create mode */
      IF @mode == "edit" AND NOT EMPTY(@surveyId) THEN
        /* Try to get existing QuestionID, otherwise generate new one */
        VAR @existingQuestionRow
        SET @existingQuestionRow = LookupRows("SP_Survey_Questions_DE", "SurveyID", @surveyId, "QuestionNumber", @i)
        IF RowCount(@existingQuestionRow) > 0 THEN
          SET @questionId = Field(Row(@existingQuestionRow, 1), "QuestionID")
        ELSE
          SET @questionId = Concat("Q", @surveyId, "_", @i)
        ENDIF
      ELSE
        /* Generate unique QuestionID for new survey */
        SET @questionId = Concat("Q", @surveyId, "_", @i)
      ENDIF
     
      /* Build options string based on question type */
      SET @options = ""
      IF @questionType == "likert" THEN
        SET @options = "Strongly Agree|Agree|Neutral|Disagree|Strongly Disagree"
      ELSEIF @questionType == "rating" THEN
        SET @options = "Excellent|Good|Fair|Poor"
      ELSEIF @questionType == "yesno" THEN
        SET @options = "Yes|No"
      ELSEIF @questionType == "text" THEN
        SET @options = "Text Input"
      ELSEIF @questionType == "multiple" THEN
        /* Collect multiple choice options */
        VAR @optionCount, @j, @optionText
        SET @optionCount = RequestParameter(Concat("optionCount", @i))
        IF NOT EMPTY(@optionCount) THEN
          FOR @j = 1 TO @optionCount DO
            SET @optionText = RequestParameter(Concat("option", @i, "_", @j))
            IF NOT EMPTY(@optionText) THEN
              IF @j == 1 THEN
                SET @options = @optionText
              ELSE
                SET @options = Concat(@options, "|", @optionText)
              ENDIF
            ENDIF
          NEXT @j
        ENDIF
      ENDIF
     
      /* Set required flag */
      IF @required == "true" THEN
        SET @required = "Yes"
      ELSE
        SET @required = "No"
      ENDIF
     
             /* Save question to SP_Survey_Questions_DE */
       IF NOT EMPTY(@questionText) THEN
         UPSERTDE(
           "SP_Survey_Questions_DE", 1, "QuestionID", @questionId,
           "SurveyID", @surveyId,
           "QuestionNumber", @i,
           "QuestionText", @questionText,
           "QuestionType", @questionType,
           "Options", @options,
           "Required", @required,
           "OrderIndex", @i
         )
       ENDIF
    NEXT @i
  ENDIF
ENDIF
]%%




