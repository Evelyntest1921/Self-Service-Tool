%%[
SET @createRequested = RequestParameter("create")
SET @deleteRequested = IIF(RequestParameter("deleteEmail") == "1","1","0")
SET @deleteEmailId = Trim(RequestParameter("deleteEmailId"))
SET @createMode = Trim(RequestParameter("mode"))
IF Empty(@createMode) THEN
SET @createMode = "rest207from4"
ENDIF
SET @itemBaseName = Trim(RequestParameter("itemBaseName"))
SET @emailSubjectLine = Trim(RequestParameter("emailSubjectLine"))
SET @sourceEmailId = Trim(RequestParameter("sourceEmailId"))
SET @categoryId = Trim(RequestParameter("categoryId"))
IF Empty(@categoryId) THEN
SET @categoryId = "58374"
ENDIF
SET @emailName = ""
IF NOT Empty(@itemBaseName) THEN
SET @slugName = Replace(@itemBaseName,'"','')
SET @slugName = Replace(@slugName," | ","_")
SET @slugName = Replace(@slugName,"|","_")
SET @slugName = Replace(@slugName," ","_")
SET @slugName = Replace(@slugName,".","_")
SET @slugName = Replace(@slugName,"/","_")
SET @emailName = @slugName
ENDIF
SET @showForm = "true"
IF NOT Empty(@createRequested) OR @deleteRequested == "1" THEN
SET @showForm = "false"
ENDIF
SET @resultText = ""
SET @authOk = "false"
SET @createResult = ""
IF @showForm != "true" THEN
IF @deleteRequested == "1" THEN
  SET @authRow = LookupRows("SFMC_AUTH","User","Admin")
  IF RowCount(@authRow) > 0 THEN
    SET @row = Row(@authRow,1)
    SET @clientId = Field(@row,"clientId")
    SET @clientSecret = Field(@row,"clientSecret")
    SET @subdomain = Field(@row,"subdomain")
    IF NOT Empty(@clientId) AND NOT Empty(@clientSecret) AND NOT Empty(@subdomain) THEN
      SET @authUrl = Concat("https://",@subdomain,".auth.marketingcloudapis.com/v2/token")
      SET @accountId = Trim(Field(@row,"accountId"))
      SET @authPayload = Concat('{"grant_type":"client_credentials","client_id":"',@clientId,'","client_secret":"',@clientSecret,'"')
      IF NOT Empty(@accountId) THEN
        SET @authPayload = Concat(@authPayload,',"account_id":"',@accountId,'"')
      ENDIF
      SET @authPayload = Concat(@authPayload,'}')
      SET @authStatus = HTTPPost2(@authUrl,"application/json",@authPayload,false,@authResponse,@authResponseHeader)
      IF @authStatus == 200 THEN
        SET @tokenPattern = '"access_token":"([^"]+)"'
        SET @accessToken = RegExMatch(@authResponse,@tokenPattern,1)
        IF NOT Empty(@accessToken) THEN
          SET @resultText = "Auth OK."
          SET @authOk = "true"
          SET @newEmailId = @deleteEmailId
        ELSE
          SET @resultText = "Auth FAILED: No access token."
        ENDIF
      ELSE
        SET @resultText = Concat("Auth FAILED: HTTP ",@authStatus)
      ENDIF
    ELSE
      SET @resultText = "Auth FAILED: Missing SFMC_AUTH credentials."
    ENDIF
  ELSE
    SET @resultText = "Auth FAILED: No SFMC_AUTH Admin row."
  ENDIF
ELSE
  IF Empty(@sourceEmailId) THEN
    SET @resultText = "Enter a source asset ID."
  ELSEIF Empty(@itemBaseName) THEN
    SET @resultText = "Enter a name for the test email."
  ELSE
    SET @authRow = LookupRows("SFMC_AUTH","User","Admin")
    IF RowCount(@authRow) > 0 THEN
      SET @row = Row(@authRow,1)
      SET @clientId = Field(@row,"clientId")
      SET @clientSecret = Field(@row,"clientSecret")
      SET @subdomain = Field(@row,"subdomain")
      IF NOT Empty(@clientId) AND NOT Empty(@clientSecret) AND NOT Empty(@subdomain) THEN
        SET @authUrl = Concat("https://",@subdomain,".auth.marketingcloudapis.com/v2/token")
        SET @accountId = Trim(Field(@row,"accountId"))
        SET @authPayload = Concat('{"grant_type":"client_credentials","client_id":"',@clientId,'","client_secret":"',@clientSecret,'"')
        IF NOT Empty(@accountId) THEN
          SET @authPayload = Concat(@authPayload,',"account_id":"',@accountId,'"')
        ENDIF
        SET @authPayload = Concat(@authPayload,'}')
        SET @authStatus = HTTPPost2(@authUrl,"application/json",@authPayload,false,@authResponse,@authResponseHeader)
        IF @authStatus == 200 THEN
          SET @tokenPattern = '"access_token":"([^"]+)"'
          SET @accessToken = RegExMatch(@authResponse,@tokenPattern,1)
          IF NOT Empty(@accessToken) THEN
            SET @resultText = "Auth OK."
            SET @authOk = "true"
          ELSE
            SET @resultText = "Auth FAILED: No access token."
          ENDIF
        ELSE
          SET @resultText = Concat("Auth FAILED: HTTP ",@authStatus)
        ENDIF
      ELSE
        SET @resultText = "Auth FAILED: Missing SFMC_AUTH credentials."
      ENDIF
    ELSE
      SET @resultText = "Auth FAILED: No SFMC_AUTH Admin row."
    ENDIF
  ENDIF
ENDIF
ENDIF
]%%
<script runat="server">
Platform.Load("core","1");
var authOk = Variable.GetValue("authOk");
var accessToken = Variable.GetValue("accessToken");
var subdomain = Variable.GetValue("subdomain");
var emailName = Variable.GetValue("emailName");
var sourceEmailId = Variable.GetValue("sourceEmailId");
var createMode = Variable.GetValue("createMode") || "rest207";
var categoryId = Variable.GetValue("categoryId") || "58374";
var deleteRequested = Variable.GetValue("deleteRequested");
var deleteEmailId = Variable.GetValue("deleteEmailId");
var resultText = Variable.GetValue("resultText");
var createResult = "";
var newEmailId = "";
var legacyEmailId = "";
var debugLog = "";
function cloneObject(obj) {
if (!obj || typeof obj !== "object") return null;
var json = Platform.Function.Stringify(obj);
return json ? Platform.Function.ParseJSON(json) : null;
}
function objectKeys(obj) {
var keys = [];
if (!obj || typeof obj !== "object") return keys;
for (var key in obj) {
  if (obj.hasOwnProperty(key)) keys.push(key);
}
return keys;
}
function safeLength(value) {
if (value === null || value === undefined) return 0;
return String(value).length;
}
function truncateString(value, maxLength) {
var str = value ? String(value) : "";
if (str.length <= maxLength) return str;
return str.substring(0, maxLength) + "...[truncated]";
}
function fetchAssetById(assetId, subdomainValue, accessTokenValue) {
var result = { ok: false, statusCode: 0, responseText: "", asset: null };
var parsedId = parseInt(assetId, 10);
if (isNaN(parsedId) || !subdomainValue || !accessTokenValue) return result;
try {
  var assetUrl = "https://" + subdomainValue + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + parsedId;
  var req = new Script.Util.HttpRequest(assetUrl);
  req.emptyContentHandling = 0;
  req.retries = 2;
  req.continueOnError = true;
  req.setHeader("Authorization", "Bearer " + accessTokenValue);
  req.method = "GET";
  req.contentType = "application/json";
  var resp = req.send();
  result.statusCode = resp.statusCode;
  result.responseText = resp.content ? String(resp.content) : "";
  if ((resp.statusCode == 200 || resp.statusCode == 201) && result.responseText) {
    result.asset = Platform.Function.ParseJSON(result.responseText);
    result.ok = true;
  }
} catch (e) {
  result.responseText = e.message || String(e);
}
return result;
}
function postAssetPayload(subdomainValue, accessTokenValue, payload) {
var result = { statusCode: 0, responseText: "" };
var assetUrl = "https://" + subdomainValue + ".rest.marketingcloudapis.com/asset/v1/content/assets";
var postReq = new Script.Util.HttpRequest(assetUrl);
postReq.emptyContentHandling = 0;
postReq.retries = 2;
postReq.continueOnError = true;
postReq.setHeader("Authorization", "Bearer " + accessTokenValue);
postReq.method = "POST";
postReq.contentType = "application/json";
postReq.postData = Platform.Function.Stringify(payload);
var postResp = postReq.send();
result.statusCode = postResp.statusCode;
result.responseText = postResp.content ? String(postResp.content) : "";
return result;
}
function extractCreatedAssetId(responseText) {
var idMatch = responseText ? responseText.match(/"id"\s*:\s*"?([^",}\s]+)"?/) : null;
return idMatch ? String(idMatch[1]) : "";
}
function extractLegacyEmailId(assetObj) {
if (!assetObj || typeof assetObj !== "object") return "";
var candidates = [
  assetObj.data && assetObj.data.email && assetObj.data.email.legacy && assetObj.data.email.legacy.legacyId,
  assetObj.data && assetObj.data.email && assetObj.data.email.legacy && assetObj.data.email.legacy.id,
  assetObj.data && assetObj.data.email && assetObj.data.email.legacyId,
  assetObj.legacyData && assetObj.legacyData.legacyId,
  assetObj.legacyId
];
var i, candidate;
for (i = 0; i < candidates.length; i++) {
  candidate = candidates[i];
  if (candidate !== null && candidate !== undefined && String(candidate) !== "") {
    return String(candidate);
  }
}
return "";
}
function stripHtmlTags(html) {
return String(html || "").replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
}
function buildTemplateReference(source, fallbackContent, fallbackSlots) {
if (!source || typeof source !== "object") return null;
var ref = {
  assetType: { id: 4, name: "template" }
};
var sourceId = parseInt(source.id, 10);
if (!isNaN(sourceId)) {
  ref.id = sourceId;
}
if (source.assetType && source.assetType.id) {
  ref.assetType.id = parseInt(source.assetType.id, 10);
}
if (source.assetType && source.assetType.name) {
  ref.assetType.name = source.assetType.name;
}
ref.content = source.content || fallbackContent || "";
ref.slots = (source.slots && typeof source.slots === "object") ? cloneObject(source.slots) : cloneObject(fallbackSlots || {});
return ref;
}
function buildFromTemplate4Payload(templateAsset, targetName, subjectlineContent, preheaderContent, textContent, htmlContent, htmlSlots, categoryIdValue) {
var templateRef = buildTemplateReference(templateAsset, templateAsset.content || htmlContent, templateAsset.slots || htmlSlots);
var templateSlots = (templateAsset.slots && typeof templateAsset.slots === "object") ? cloneObject(templateAsset.slots) : cloneObject(htmlSlots || {});
var payload = {
  name: targetName,
  assetType: { id: 207, name: "htmlemail" },
  channels: (templateAsset.channels && typeof templateAsset.channels === "object") ? cloneObject(templateAsset.channels) : { email: true, web: false },
  views: {
    subjectline: { content: subjectlineContent || "Survey" },
    preheader: { content: preheaderContent || "" },
    html: {
      template: templateRef,
      content: templateAsset.content || htmlContent || "",
      slots: templateSlots || {}
    },
    text: { content: textContent || "" }
  },
  data: {
    email: {
      options: {
        characterEncoding: "utf-8"
      }
    }
  }
};
var parsedCategory = parseInt(categoryIdValue, 10);
if (!isNaN(parsedCategory)) {
  payload.category = { id: parsedCategory };
} else if (templateAsset.category && templateAsset.category.id) {
  payload.category = { id: templateAsset.category.id };
}
return payload;
}
function buildRest208Payload(targetName, subjectlineContent, htmlContent, textContent, categoryIdValue) {
var payload = {
  name: targetName,
  assetType: { id: 208, name: "htmlemail" },
  channels: { email: true, web: false },
  views: {
    subjectline: { content: subjectlineContent || "Survey" },
    preheader: { content: "" },
    html: { content: htmlContent || "" },
    text: { content: textContent || stripHtmlTags(htmlContent) }
  },
  data: {
    email: {
      options: {
        characterEncoding: "utf-8"
      }
    }
  }
};
var parsedCategory = parseInt(categoryIdValue, 10);
if (!isNaN(parsedCategory)) {
  payload.category = { id: parsedCategory };
}
return payload;
}
function buildCloned207Payload(sourceAsset, targetName, subjectlineContent, preheaderContent, textContent, sourceTemplate, resolvedTemplateAsset, sourceSlots, categoryIdValue) {
var templateSource = resolvedTemplateAsset || sourceTemplate;
var templateContent = (templateSource && templateSource.content) ? templateSource.content : "";
var templateSlots = (templateSource && templateSource.slots && typeof templateSource.slots === "object") ? cloneObject(templateSource.slots) : {};
var sourceHtmlContent = (sourceAsset && sourceAsset.views && sourceAsset.views.html && sourceAsset.views.html.content) ? sourceAsset.views.html.content : (sourceAsset.content || templateContent);
var emailSlots = (sourceSlots && typeof sourceSlots === "object") ? cloneObject(sourceSlots) : {};
var payload = {
  name: targetName,
  assetType: { id: 207, name: "htmlemail" },
  channels: (sourceAsset.channels && typeof sourceAsset.channels === "object") ? cloneObject(sourceAsset.channels) : { email: true, web: false },
  views: {
    subjectline: { content: subjectlineContent || "Survey" },
    preheader: { content: preheaderContent || "" },
    html: {
      content: sourceHtmlContent,
      slots: emailSlots,
      template: {
        id: parseInt(sourceTemplate.id, 10),
        assetType: { id: 4, name: "template" },
        content: templateContent,
        slots: templateSlots
      }
    },
    text: { content: textContent || "" }
  },
  data: {
    email: {
      options: {
        characterEncoding: "utf-8"
      }
    }
  }
};
var parsedCategory = parseInt(categoryIdValue, 10);
if (!isNaN(parsedCategory)) {
  payload.category = { id: parsedCategory };
} else if (sourceAsset.category && sourceAsset.category.id) {
  payload.category = { id: sourceAsset.category.id };
}
return payload;
}
function summarizeSourceAsset(asset) {
if (!asset) return "null";
var htmlView = (asset.views && asset.views.html) ? asset.views.html : {};
var assetTypeId = (asset.assetType && asset.assetType.id) ? parseInt(asset.assetType.id, 10) : 0;
var slotKeys = objectKeys(htmlView.slots);
if (!slotKeys.length && asset.slots) {
  slotKeys = objectKeys(asset.slots);
}
return truncateString(Platform.Function.Stringify({
  id: asset.id || "",
  assetTypeId: assetTypeId,
  contentLength: safeLength(asset.content || htmlView.content),
  slotKeys: slotKeys,
  templateId: (htmlView.template && htmlView.template.id) ? htmlView.template.id : "",
  categoryId: (asset.category && asset.category.id) ? asset.category.id : ""
}), 1200);
}
if (deleteRequested == "1" && authOk == "true" && accessToken && subdomain && deleteEmailId) {
try {
  newEmailId = String(deleteEmailId);
  var deleteUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + deleteEmailId;
  var deleteReq = new Script.Util.HttpRequest(deleteUrl);
  deleteReq.emptyContentHandling = 0;
  deleteReq.retries = 2;
  deleteReq.continueOnError = true;
  deleteReq.setHeader("Authorization", "Bearer " + accessToken);
  deleteReq.method = "DELETE";
  var deleteResp = deleteReq.send();
  if (deleteResp.statusCode == 200 || deleteResp.statusCode == 204) {
    createResult = "Delete OK.";
  } else {
    createResult = "Delete FAILED: HTTP " + deleteResp.statusCode;
  }
} catch (deleteEx) {
  createResult = "Delete FAILED: " + (deleteEx.message || String(deleteEx));
}
} else if (authOk == "true" && accessToken && subdomain && emailName && sourceEmailId) {
try {
  var sourceFetch = fetchAssetById(sourceEmailId, subdomain, accessToken);
  debugLog = "Source fetch HTTP " + sourceFetch.statusCode + ". " + summarizeSourceAsset(sourceFetch.asset);
  if (!sourceFetch.ok || !sourceFetch.asset) {
    createResult = "Source asset fetch FAILED.";
  } else {
    var sourceAsset = sourceFetch.asset;
    var sourceViews = sourceAsset.views || {};
    var htmlView = sourceViews.html || {};
    var emailSubjectForAsset = Platform.Variable.GetValue("@emailSubjectLine") || "";
    var subjectlineContent = emailSubjectForAsset || ((sourceViews.subjectline && sourceViews.subjectline.content) ? sourceViews.subjectline.content : "Survey");
    var preheaderContent = (sourceViews.preheader && sourceViews.preheader.content) ? sourceViews.preheader.content : "";
    var textContent = (sourceViews.text && sourceViews.text.content) ? sourceViews.text.content : "";
    var htmlContent = htmlView.content || sourceAsset.content || "";
    var htmlSlots = (htmlView.slots && typeof htmlView.slots === "object") ? htmlView.slots : ((sourceAsset.slots && typeof sourceAsset.slots === "object") ? sourceAsset.slots : {});
    var sourceTemplate = (htmlView.template && typeof htmlView.template === "object") ? htmlView.template : null;
    var assetTypeId = (sourceAsset.assetType && sourceAsset.assetType.id) ? parseInt(sourceAsset.assetType.id, 10) : 0;
    var payload = null;
    var resolvedTemplateAsset = null;
    if (createMode === "rest208") {
      payload = buildRest208Payload(emailName, subjectlineContent, htmlContent, textContent, categoryId);
      debugLog += " Mode: rest208 (SOAP HTMLBody + IsHTMLPaste equivalent). HTML length: " + safeLength(htmlContent) + ".";
    } else if (createMode === "rest207from4") {
      if (assetTypeId !== 4) {
        createResult = "rest207from4 FAILED: Expected parent template asset type 4, got type " + assetTypeId + ". Set source to your Content Builder template ID (e.g. 56191).";
      } else {
        payload = buildFromTemplate4Payload(
          sourceAsset,
          emailName,
          subjectlineContent,
          preheaderContent,
          textContent,
          htmlContent,
          htmlSlots,
          categoryId
        );
        debugLog += " Mode: rest207from4 (create from parent template only). Template " + (sourceAsset.id || sourceEmailId) + ". Content length: " + safeLength(sourceAsset.content || htmlContent) + ". Slots: " + objectKeys(htmlSlots).join(",") + ".";
      }
    } else {
      if (!sourceTemplate || !sourceTemplate.id) {
        createResult = "rest207 FAILED: Source asset has no views.html.template ref. Use survey-template email (type 207) or switch mode to rest207from4 with a type 4 template ID.";
      } else {
        var fetchedTemplate = fetchAssetById(sourceTemplate.id, subdomain, accessToken);
        if (!fetchedTemplate.ok || !fetchedTemplate.asset) {
          createResult = "rest207 FAILED: Parent template fetch HTTP " + fetchedTemplate.statusCode;
        } else {
          resolvedTemplateAsset = fetchedTemplate.asset;
          payload = buildCloned207Payload(
            sourceAsset,
            emailName,
            subjectlineContent,
            preheaderContent,
            textContent,
            sourceTemplate,
            resolvedTemplateAsset,
            htmlSlots,
            categoryId
          );
          debugLog += " Mode: rest207 (clone survey-template email). Parent template " + sourceTemplate.id + ". HTML length: " + safeLength(htmlContent) + ". Slots: " + objectKeys(htmlSlots).join(",") + ".";
        }
      }
    }
    if (payload) {
      var postResult = postAssetPayload(subdomain, accessToken, payload);
      debugLog += " POST HTTP " + postResult.statusCode + ". Payload summary: " + truncateString(Platform.Function.Stringify({
        name: payload.name,
        assetType: payload.assetType,
        category: payload.category || null,
        subjectlineLength: safeLength(payload.views.subjectline.content),
        htmlContentLength: safeLength(payload.views.html.content),
        slotCount: objectKeys(payload.views.html.slots || {}).length,
        templateId: (payload.views.html.template && payload.views.html.template.id) ? payload.views.html.template.id : null
      }), 800);
      if (postResult.statusCode == 200 || postResult.statusCode == 201) {
        newEmailId = extractCreatedAssetId(postResult.responseText);
        var createdAsset = null;
        try {
          createdAsset = Platform.Function.ParseJSON(postResult.responseText);
        } catch (parseEx) {
          createdAsset = null;
        }
        legacyEmailId = extractLegacyEmailId(createdAsset);
        if (!legacyEmailId && newEmailId) {
          var createdFetch = fetchAssetById(newEmailId, subdomain, accessToken);
          if (createdFetch.ok && createdFetch.asset) {
            legacyEmailId = extractLegacyEmailId(createdFetch.asset);
            debugLog += " Verify fetch HTML length: " + safeLength((createdFetch.asset.views && createdFetch.asset.views.html) ? createdFetch.asset.views.html.content : "");
          }
        }
        createResult = "Create OK (" + createMode + ").";
      } else {
        createResult = "Create FAILED (" + createMode + "): HTTP " + postResult.statusCode + " - " + truncateString(postResult.responseText, 500);
      }
    }
  }
} catch (e) {
  createResult = "Create FAILED: " + (e.message || String(e));
}
}
Platform.Variable.SetValue("@newEmailId", newEmailId);
Platform.Variable.SetValue("@legacyEmailId", legacyEmailId);
Platform.Variable.SetValue("@createResult", createResult);
Platform.Variable.SetValue("@debugLog", debugLog);
</script>
%%[
SET @resultText = Concat(@resultText," ",@createResult)
IF NOT Empty(@newEmailId) THEN
SET @resultText = Concat(@resultText," Asset ID: ",@newEmailId)
ENDIF
IF NOT Empty(@legacyEmailId) THEN
SET @resultText = Concat(@resultText," Legacy Email ID: ",@legacyEmailId)
ENDIF
IF NOT Empty(@debugLog) THEN
SET @resultText = Concat(@resultText," Debug: ",@debugLog)
ENDIF
]%%
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Test Survey Email Create</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
:root {
--primary: #6366f1;
--border: #e5e7eb;
--text: #111827;
--muted: #6b7280;
--bg: #f9fafb;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Inter, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; }
.wrap { max-width: 760px; margin: 40px auto; padding: 0 20px 48px; }
h1 { font-size: 1.5rem; margin-bottom: 8px; }
.lead { color: var(--muted); margin-bottom: 24px; font-size: 0.95rem; }
.card { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 24px; }
label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; }
input, select { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 0.95rem; margin-bottom: 16px; }
.actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px; }
