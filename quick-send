 SET @analyticsJourneyName = IIF(NOT Empty(@journeyName), @journeyName, @emailName)
 SET @analyticsJourneyId = IIF(NOT Empty(@journeyId), @journeyId, Concat("email:",@newEmailId))
 SET @analyticsJourneyType = @builderPageLabel
 IF @createEmailOnly == "1" THEN
   SET @analyticsJourneyType = Concat(Substring(@builderPageLabel,1,32)," | email-only")
