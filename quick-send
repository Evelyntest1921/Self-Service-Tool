         content: templateContent,
         slots: templateSlots
       }
     },
     text: {}
   },
   data: {
     email: {
       options: {}
     }
   }
 };
 if (sourceAsset.category && sourceAsset.category.id) {
   payload.category = { id: sourceAsset.category.id };
 }
 if (sourceAsset.data && sourceAsset.data.email && sourceAsset.data.email.options && typeof sourceAsset.data.email.options === "object") {
   payload.data.email.options = cloneObject(sourceAsset.data.email.options);
 }
 applyTextSettings(payload, textContent);
 return payload;
}
if (deleteRequested == "1" && authOk == "true" && accessToken && subdomain && deleteEmailId) {
 try {
   newEmailId = String(deleteEmailId);
   var deleteUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + deleteEmailId;
   var deleteReq = new Script.Util.HttpRequest(deleteUrl);
   deleteReq.emptyContentHandling = 0;
   deleteReq.retries = 2;
   deleteReq.continueOnError = true;
   deleteReq.setHeader("Authorization", "Bearer " + accessToken);
   deleteReq.method = "DELETE";
   var deleteResp = deleteReq.send();
   if (deleteResp.statusCode == 200 || deleteResp.statusCode == 204) {
     step3bResult = " Step 3b OK - Email deleted.";
   } else {
     step3bResult = " Step 3b FAILED - Email delete HTTP " + deleteResp.statusCode + ".";
   }
 } catch (deleteEx) {
   step3bResult = " Step 3b FAILED - Email delete failed: " + (deleteEx.message || String(deleteEx));
 }
} else if (authOk == "true" && accessToken && subdomain && emailName && sourceEmailId) {
 try {
   var templateUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + sourceEmailId;
   var getReq = new Script.Util.HttpRequest(templateUrl);
   getReq.emptyContentHandling = 0;
   getReq.retries = 2;
   getReq.continueOnError = true;
   getReq.setHeader("Authorization", "Bearer " + accessToken);
   getReq.method = "GET";
   getReq.contentType = "application/json";
   var getResp = getReq.send();
   var templateStatus = getResp.statusCode;
   var templateResponse = getResp.content ? String(getResp.content) : "";
   if (templateStatus == 200 && templateResponse) {
     var template = Platform.Function.ParseJSON(templateResponse);
     var sourceViews = template.views || {};
     var htmlView = sourceViews.html || {};
     var emailSubjectForAsset = Platform.Variable.GetValue("@emailSubjectLine") || "";
