<script runat="server">
Platform.Load("core","1");
var senderProfileIdReq = Platform.Variable.GetValue("@senderProfileId") || "";
var senderProfileConfigOk = "false";
var senderProfileOptionsHtml = "";
var defaultSenderProfileId = "";

function escSenderOpt(s) {
  if (s === null || s === undefined) return "";
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/"/g, "&quot;")
    .replace(/</g, "&lt;");
}

function senderProfileIdFromRow(row) {
  if (!row) return "";
  if (row.ObjectID) {
    var oid = String(row.ObjectID).replace(/^\s+|\s+$/g, "");
    if (oid) return oid;
  }
  if (row.CustomerKey) {
    var ck = String(row.CustomerKey).replace(/^\s+|\s+$/g, "");
    if (ck) return ck;
  }
  return "";
}

function senderProfileLabelFromRow(row) {
  if (!row) return "";
  var name = row.Name ? String(row.Name).replace(/^\s+|\s+$/g, "") : "";
  var fromName = row.FromName ? String(row.FromName).replace(/^\s+|\s+$/g, "") : "";
  var fromAddress = row.FromAddress ? String(row.FromAddress).replace(/^\s+|\s+$/g, "") : "";
  if (name) return name;
  if (fromName && fromAddress) return fromName + " <" + fromAddress + ">";
  if (fromName) return fromName;
  if (fromAddress) return fromAddress;
  return senderProfileIdFromRow(row);
}

function normalizeWsResults(results) {
  var out = [];
  if (!results) return out;
  if (typeof results.length === "number") {
    var i;
    for (i = 0; i < results.length; i++) out.push(results[i]);
    return out;
  }
  if (results.CustomerKey || results.ObjectID || results.Name) out.push(results);
  return out;
}

function retrieveAllSenderProfiles() {
  var prox = new Script.Util.WSProxy();
  var props = ["Name", "FromName", "FromAddress", "CustomerKey", "ObjectID"];
  var filter = {
    Property: "CustomerKey",
    SimpleOperator: "like",
    Value: "%"
  };
  var rows = [];
  var resp = prox.retrieve("SenderProfile", props, filter);
  while (resp) {
    rows = rows.concat(normalizeWsResults(resp.Results));
    if (resp.HasMoreResults) {
      resp = prox.retrieveMore();
    } else {
      break;
    }
  }
  return rows;
}

try {
  var senderRows = retrieveAllSenderProfiles();
  senderRows.sort(function (a, b) {
    return senderProfileLabelFromRow(a).localeCompare(senderProfileLabelFromRow(b));
  });
  var si;
  for (si = 0; si < senderRows.length; si++) {
    var spId = senderProfileIdFromRow(senderRows[si]);
    if (!spId) continue;
    if (!defaultSenderProfileId) defaultSenderProfileId = spId;
    senderProfileConfigOk = "true";
  }
  var selectedSenderProfileId = senderProfileIdReq || defaultSenderProfileId;
  for (si = 0; si < senderRows.length; si++) {
    var spIdOpt = senderProfileIdFromRow(senderRows[si]);
    if (!spIdOpt) continue;
    var spLabel = senderProfileLabelFromRow(senderRows[si]);
    var selectedAttr = spIdOpt === selectedSenderProfileId ? " selected" : "";
    senderProfileOptionsHtml +=
      '<option value="' +
      escSenderOpt(spIdOpt) +
      '"' +
      selectedAttr +
      ">" +
      escSenderOpt(spLabel) +
      "</option>";
  }
  Platform.Variable.SetValue("@senderProfileId", selectedSenderProfileId);
} catch (senderLoadErr) {
  senderProfileConfigOk = "false";
  senderProfileOptionsHtml = "";
}

Platform.Variable.SetValue("@senderProfileConfigOk", senderProfileConfigOk);
Platform.Variable.SetValue("@senderProfileOptionsHtml", senderProfileOptionsHtml);

var sendClassificationIdReq = Platform.Variable.GetValue("@sendClassificationId") || "";
var sendClassificationConfigOk = "false";
var sendClassificationOptionsHtml = "";
var defaultSendClassificationId = "";

function sendClassificationIdFromRow(row) {
  if (!row) return "";
  if (row.ObjectID) {
    var scOid = String(row.ObjectID).replace(/^\s+|\s+$/g, "");
    if (scOid) return scOid;
  }
  if (row.CustomerKey) {
    var scCk = String(row.CustomerKey).replace(/^\s+|\s+$/g, "");
    if (scCk) return scCk;
  }
  return "";
}

function sendClassificationLabelFromRow(row) {
  if (!row) return "";
  var scName = row.Name ? String(row.Name).replace(/^\s+|\s+$/g, "") : "";
  var scType = row.SendClassificationType
    ? String(row.SendClassificationType).replace(/^\s+|\s+$/g, "")
    : "";
  if (scName && scType) return scName + " (" + scType + ")";
  if (scName) return scName;
  if (row.CustomerKey) return String(row.CustomerKey).replace(/^\s+|\s+$/g, "");
  return sendClassificationIdFromRow(row);
}

function retrieveAllSendClassifications() {
  var prox = new Script.Util.WSProxy();
  var props = ["Name", "CustomerKey", "ObjectID", "SendClassificationType"];
  var rows = [];
  var resp = prox.retrieve("SendClassification", props);
  while (resp) {
    rows = rows.concat(normalizeWsResults(resp.Results));
    if (resp.HasMoreResults) {
      resp = prox.retrieveMore();
    } else {
      break;
    }
  }
  return rows;
}

try {
  var scRows = retrieveAllSendClassifications();
  scRows.sort(function (a, b) {
    return sendClassificationLabelFromRow(a).localeCompare(sendClassificationLabelFromRow(b));
  });
  var sci;
  for (sci = 0; sci < scRows.length; sci++) {
    var scId = sendClassificationIdFromRow(scRows[sci]);
    if (!scId) continue;
    if (!defaultSendClassificationId) defaultSendClassificationId = scId;
    sendClassificationConfigOk = "true";
  }
  var selectedSendClassificationId = sendClassificationIdReq || defaultSendClassificationId;
  for (sci = 0; sci < scRows.length; sci++) {
    var scIdOpt = sendClassificationIdFromRow(scRows[sci]);
    if (!scIdOpt) continue;
    var scLabel = sendClassificationLabelFromRow(scRows[sci]);
    var scSelectedAttr = scIdOpt === selectedSendClassificationId ? " selected" : "";
    sendClassificationOptionsHtml +=
      '<option value="' +
      escSenderOpt(scIdOpt) +
      '"' +
      scSelectedAttr +
      ">" +
      escSenderOpt(scLabel) +
      "</option>";
  }
  Platform.Variable.SetValue("@sendClassificationId", selectedSendClassificationId);
} catch (scLoadErr) {
  sendClassificationConfigOk = "false";
  sendClassificationOptionsHtml = "";
}

Platform.Variable.SetValue("@sendClassificationConfigOk", sendClassificationConfigOk);
Platform.Variable.SetValue("@sendClassificationOptionsHtml", sendClassificationOptionsHtml);
</script>
<script runat="server">
Platform.Load("core","1");
var authOk = Variable.GetValue("authOk");
var accessToken = Variable.GetValue("accessToken");
var subdomain = Variable.GetValue("subdomain");
var emailName = Variable.GetValue("emailName");
var sourceEmailId = Variable.GetValue("sourceEmailId");
var deleteRequested = Variable.GetValue("deleteRequested");
var deleteEmailId = Variable.GetValue("deleteEmailId");
var resultText = Variable.GetValue("resultText");
var newEmailId = "";
var journeyEmailId = "";
var step3bResult = " Step 3b SKIP - Email not duplicated: Template fetch failed.";
function cloneObject(obj) {
 if (!obj || typeof obj !== "object") return null;
 var json = Platform.Function.Stringify(obj);
 return json ? Platform.Function.ParseJSON(json) : null;
}
function objectKeys(obj) {
 var keys = [];
 if (!obj || typeof obj !== "object") return keys;
 for (var key in obj) {
   if (obj.hasOwnProperty(key)) {
     keys.push(key);
   }
 }
 return keys;
}
function safeLength(value) {
 if (value === null || value === undefined) return 0;
 return String(value).length;
}
function truncateString(value, maxLength) {
 var str = value ? String(value) : "";
 if (str.length <= maxLength) return str;
 return str.substring(0, maxLength) + "...[truncated]";
}
function summarizeTemplateRef(templateRef) {
 if (!templateRef || typeof templateRef !== "object") return null;
 return {
   id: templateRef.id || "",
   assetTypeId: (templateRef.assetType && templateRef.assetType.id) ? templateRef.assetType.id : "",
   assetTypeName: (templateRef.assetType && templateRef.assetType.name) ? templateRef.assetType.name : "",
   contentLength: safeLength(templateRef.content),
   slotKeys: objectKeys(templateRef.slots)
 };
}
function summarizeHtmlView(htmlView) {
 if (!htmlView || typeof htmlView !== "object") return null;
 return {
   contentLength: safeLength(htmlView.content),
   slotKeys: objectKeys(htmlView.slots),
   template: summarizeTemplateRef(htmlView.template)
 };
}
function summarizeEmailOptions(dataObj) {
 if (!dataObj || !dataObj.email || !dataObj.email.options) return null;
 return cloneObject(dataObj.email.options);
}
function fetchAssetById(assetId, subdomainValue, accessTokenValue) {
 var result = {
   ok: false,
   statusCode: 0,
   responseText: "",
   asset: null
 };
 var parsedId = parseInt(assetId, 10);
 if (isNaN(parsedId) || !subdomainValue || !accessTokenValue) {
   return result;
 }
 try {
   var assetUrl = "https://" + subdomainValue + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + parsedId;
   var req = new Script.Util.HttpRequest(assetUrl);
   req.emptyContentHandling = 0;
   req.retries = 2;
   req.continueOnError = true;
   req.setHeader("Authorization", "Bearer " + accessTokenValue);
   req.method = "GET";
   req.contentType = "application/json";
   var resp = req.send();
   result.statusCode = resp.statusCode;
   result.responseText = resp.content ? String(resp.content) : "";
   if ((resp.statusCode == 200 || resp.statusCode == 201) && result.responseText) {
     result.asset = Platform.Function.ParseJSON(result.responseText);
     result.ok = true;
   }
 } catch (e) {
   result.responseText = e.message || String(e);
 }
 return result;
}
function extractLegacyEmailId(assetObj) {
 if (!assetObj || typeof assetObj !== "object") return "";
 var candidates = [
   assetObj.data && assetObj.data.email && assetObj.data.email.legacy && assetObj.data.email.legacy.legacyId,
   assetObj.data && assetObj.data.email && assetObj.data.email.legacy && assetObj.data.email.legacy.id,
   assetObj.data && assetObj.data.email && assetObj.data.email.legacyId,
   assetObj.data && assetObj.data.legacy && assetObj.data.legacy.legacyId,
   assetObj.legacyData && assetObj.legacyData.legacyId,
   assetObj.legacy && assetObj.legacy.legacyId,
   assetObj.legacyId
 ];
 for (var i = 0; i < candidates.length; i++) {
   var candidate = candidates[i];
   if (candidate !== null && candidate !== undefined && String(candidate) !== "") {
     return String(candidate);
   }
 }
 return "";
}
function buildTemplateReference(source, fallbackContent, fallbackSlots) {
 if (!source || typeof source !== "object") return null;
 var ref = {
   assetType: { id: 4 }
 };
 var sourceId = parseInt(source.id, 10);
 if (!isNaN(sourceId)) {
   ref.id = sourceId;
 }
 if (source.assetType && source.assetType.id) {
   ref.assetType.id = parseInt(source.assetType.id, 10);
 }
 if (source.assetType && source.assetType.name) {
   ref.assetType.name = source.assetType.name;
 }
 ref.content = source.content || fallbackContent || "";
 ref.slots = (source.slots && typeof source.slots === "object") ? cloneObject(source.slots) : cloneObject(fallbackSlots || {});
 return ref;
}
function buildBasePayload(sourceAsset, targetName, targetAssetTypeId) {
 var payload = {
   name: targetName,
   assetType: {
     id: targetAssetTypeId
   }
 };
 if (targetAssetTypeId === 207 || targetAssetTypeId === 208) {
   payload.assetType.name = "htmlemail";
 } else if (sourceAsset.assetType && sourceAsset.assetType.name) {
   payload.assetType.name = sourceAsset.assetType.name;
 }
 if (sourceAsset.category && sourceAsset.category.id) {
   payload.category = { id: sourceAsset.category.id };
 }
 if (sourceAsset.channels && typeof sourceAsset.channels === "object") {
   payload.channels = cloneObject(sourceAsset.channels);
 }
 if (sourceAsset.views && typeof sourceAsset.views === "object") {
   payload.views = cloneObject(sourceAsset.views);
 }
 if (sourceAsset.data && typeof sourceAsset.data === "object") {
   payload.data = cloneObject(sourceAsset.data);
 }
 return payload;
}
function ensureEmailOptions(payload) {
 if (!payload.data || typeof payload.data !== "object") {
   payload.data = {};
 }
 if (!payload.data.email || typeof payload.data.email !== "object") {
   payload.data.email = {};
 }
 if (!payload.data.email.options || typeof payload.data.email.options !== "object") {
   payload.data.email.options = {};
 }
 if (!payload.data.email.options.characterEncoding) {
   payload.data.email.options.characterEncoding = "utf-8";
 }
}
function hasTextContent(value) {
 return value !== null && value !== undefined && String(value).replace(/\s+/g, "").length > 0;
}
function applyTextSettings(payload, textContent) {
 ensureEmailOptions(payload);
 if (!payload.views || typeof payload.views !== "object") {
   payload.views = {};
 }
 if (hasTextContent(textContent)) {
   payload.views.text = { content: String(textContent) };
 } else {
   if (payload.views.text) {
     delete payload.views.text;
   }
   if (payload.data && payload.data.email && payload.data.email.options && payload.data.email.options.generateFrom !== undefined) {
     delete payload.data.email.options.generateFrom;
   }
 }
}
function buildCloned207Payload(sourceAsset, targetName, subjectlineContent, preheaderContent, textContent, sourceTemplate, resolvedTemplateAsset, sourceSlots) {
 var templateSource = resolvedTemplateAsset || sourceTemplate;
 var templateContent = (templateSource && templateSource.content) ? templateSource.content : "";
 var templateSlots = (templateSource && templateSource.slots && typeof templateSource.slots === "object") ? cloneObject(templateSource.slots) : {};
 var sourceHtmlContent = (sourceAsset && sourceAsset.views && sourceAsset.views.html && sourceAsset.views.html.content) ? sourceAsset.views.html.content : (sourceAsset.content || templateContent);
 var emailSlots = (sourceSlots && typeof sourceSlots === "object") ? cloneObject(sourceSlots) : {};
 var payload = {
   name: targetName,
   assetType: { id: 207, name: "htmlemail" },
   channels: (sourceAsset.channels && typeof sourceAsset.channels === "object") ? cloneObject(sourceAsset.channels) : { email: true, web: false },
   views: {
     subjectline: { content: subjectlineContent || "Campaign Event" },
     preheader: { content: preheaderContent || "" },
     html: {
       content: sourceHtmlContent,
       slots: emailSlots,
       template: {
         id: parseInt(sourceTemplate.id, 10),
