       <div class="question-header">
         <div class="question-number">1</div>
         <div class="question-text">Name</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="itemBaseName" value="%%=v(@itemBaseName)=%%" placeholder="e.g. SBU | Cross-sell (also used as journey title; file-safe slug uses underscores)">
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">2</div>
         <div class="question-text">Journey description (optional)</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="journeyDescription" value="%%=v(@journeyDescription)=%%" placeholder="Stored on the journey definition API payload">
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">3</div>
         <div class="question-text">Email subject line</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="emailSubjectLine" value="%%=v(@emailSubjectLine)=%%" placeholder="Defaults to Campaign Event if left blank">
       </div>
       <div class="form-group">
         <label for="bccEmail" style="font-size:0.875rem;color:#6b7280;display:block;margin-bottom:6px;">BCC on triggered send (optional)</label>
         <input id="bccEmail" type="text" class="textarea-control" name="bccEmail" value="%%=v(@bccEmail)=%%" placeholder="Leave blank for no BCC">
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">4</div>
         <div class="question-text">Sender profile</div>
       </div>
       <div class="form-group">
%%[ IF @senderProfileConfigOk == "true" THEN ]%%
         <select id="senderProfileId" class="select-control" name="senderProfileId">
           %%=TreatAsContent(@senderProfileOptionsHtml)=%%
         </select>
%%[ ELSE ]%%
         <div class="maker-alert" role="alert">Could not load sender profiles from Marketing Cloud.</div>
%%[ ENDIF ]%%
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">5</div>
         <div class="question-text">Send classification</div>
       </div>
       <div class="form-group">
%%[ IF @sendClassificationConfigOk == "true" THEN ]%%
         <select id="sendClassificationId" class="select-control" name="sendClassificationId">
           %%=TreatAsContent(@sendClassificationOptionsHtml)=%%
         </select>
%%[ ELSE ]%%
         <div class="maker-alert" role="alert">Could not load send classifications from Marketing Cloud.</div>
%%[ ENDIF ]%%
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">6</div>
         <div class="question-text">Campaign ID</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="campaignId" value="%%=v(@campaignId)=%%" placeholder="e.g. 701WL00000pFzUEYA0 — used to update Campaign Member status">
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">7</div>
         <div class="question-text">Choose Email Template</div>
       </div>
       <div class="email-cards">
         %%[ IF @templateConfigOk == "true" THEN
           FOR @ti = 1 TO @templateCount DO
             SET @templateRow = Row(@templateRows,@ti)
             SET @cardEmailId = Trim(Field(@templateRow,"email_id"))
             SET @cardEmailName = Field(@templateRow,"email_name")
             SET @cardEmailPreview = Field(@templateRow,"email_preview")
             SET @cardLabel = @cardEmailName
             IF Length(@cardLabel) > 10 THEN
               SET @cardLabel = Concat(Substring(@cardLabel,1,10),"...")
             ENDIF
         ]%%
         <label class="email-card %%[ IF @emailId == @cardEmailId THEN ]%%selected%%[ ENDIF ]%%" data-email-id="%%=v(@cardEmailId)=%%">
           <input type="radio" name="emailId" value="%%=v(@cardEmailId)=%%" %%[ IF @emailId == @cardEmailId THEN ]%%checked%%[ ENDIF ]%%>
           <img class="email-card-img" src="%%=v(@cardEmailPreview)=%%" alt="%%=v(@cardEmailName)=%%">
           <div class="email-card-label">%%=v(@cardLabel)=%%</div>
           <div class="email-card-id">ID: %%=v(@cardEmailId)=%%</div>
         </label>
         %%[ NEXT @ti ELSE ]%%
         <div class="maker-alert" role="alert">Template config missing in `bd_sst_email_templates` (email_type=template).</div>
         %%[ ENDIF ]%%
       </div>
       <div class="submit-section">
         <input type="hidden" name="create" value="1">
         <button type="submit" class="submit-button" id="submitBtn">
           <span id="btnText"> Create </span>
           <span id="btnSpinner" class="spinner" style="display:none"></span>
         </button>
       </div>
     </div>
   </form>
    </div>
%%[ ELSE ]%%
    <div class="maker-page-heading">
      <div class="maker-page-heading-icon maker-result-status %%[ IF IndexOf(@resultText,"FAILED") > 0 THEN ]%%is-error%%[ ELSE ]%%is-success%%[ ENDIF ]%%" aria-hidden="true">
%%[ IF IndexOf(@resultText,"FAILED") > 0 THEN ]%%
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
%%[ ELSE ]%%
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
%%[ ENDIF ]%%
      </div>
      <div class="maker-page-heading-text">
        <h1 class="maker-page-title">%%=IIF(IndexOf(@resultText,"FAILED") > 0,"Could not complete setup","Build finished")=%%</h1>
      </div>
    </div>
    <p class="maker-page-subtitle">
%%[ IF IndexOf(@resultText,"FAILED") > 0 THEN ]%%
Review the technical log below, adjust your inputs if needed, and try again.
%%[ ELSEIF @createEmailOnly == "1" THEN ]%%
Your email asset is in Content Builder. Use the link below when you are ready to edit or send tests.
%%[ ELSE ]%%
Your journey and email are in Marketing Cloud. Open them below or return to the builder to start another run.
%%[ ENDIF ]%%
    </p>
    <div class="maker-form-shell">
      <div class="maker-result-inner">
        <dl class="maker-result-dl">
%%[ IF @createEmailOnly != "1" THEN ]%%
          <dt>Data extension</dt>
          <dd>%%=IIF(NOT Empty(@eventName), @eventName, "—")=%%</dd>
          <dt>Journey</dt>
          <dd>%%=IIF(NOT Empty(@journeyName), @journeyName, "—")=%%</dd>
%%[ ENDIF ]%%
          <dt>Email name</dt>
          <dd>%%=IIF(NOT Empty(@emailName), @emailName, "—")=%%</dd>
        </dl>
        <div class="maker-result-actions">
%%[ IF @createEmailOnly != "1" AND NOT Empty(@journeyId) THEN ]%%
          <a href="https://mc.s13.exacttarget.com/cloud/#app/Journey%20Builder/%23%%=v(@journeyId)=%%/1" target="_blank" rel="noopener noreferrer" class="maker-btn maker-btn--primary">Open journey</a>
%%[ ENDIF ]%%
          <a href="https://mc.s13.exacttarget.com/cloud/#app/Content%20Builder/" target="_blank" rel="noopener noreferrer" class="maker-btn maker-btn--secondary">Open Content Builder</a>
        </div>
        <div class="maker-result-log-wrap">
          <pre class="maker-result-log" id="apiLog">%%=v(@resultText)=%%</pre>
        </div>
        <div class="maker-result-actions maker-result-actions--footer">
          <form method="post" action="" style="margin:0">
%%[ IF NOT Empty(@flow) THEN ]%%
            <input type="hidden" name="flow" value="%%=v(@flow)=%%">
%%[ ENDIF ]%%
            <button type="submit" class="maker-btn maker-btn--secondary">Back to builder</button>
          </form>
          <button type="button" class="maker-btn maker-btn--ghost" id="showLogBtn">Show log</button>
        </div>
      </div>
    </div>
%%[ ENDIF ]%%
    </div>
    <footer class="maker-main-footer">
      <span>Self Service</span>
      <span>© 2026 All rights reserved | MagMutual</span>
    </footer>
  </main>
</div>
<script>
(function(){
 var form = document.querySelector('form[method="post"]');
 if (form && form.querySelector('#submitBtn')) {
   var btn = document.getElementById('submitBtn');
   var btnText = document.getElementById('btnText');
   var btnSpinner = document.getElementById('btnSpinner');
   form.addEventListener('submit', function() {
     btn.disabled = true;
     if (btnText) btnText.textContent = 'Creating...';
     if (btnSpinner) btnSpinner.style.display = 'inline-block';
   });
 }
 var cards = document.querySelectorAll('.email-card');
 cards.forEach(function(card) {
   card.addEventListener('click', function() {
     cards.forEach(function(c) { c.classList.remove('selected'); });
     card.classList.add('selected');
     card.querySelector('input[type="radio"]').checked = true;
   });
 });
 var showLogBtn = document.getElementById('showLogBtn');
 var apiLog = document.getElementById('apiLog');
 if (showLogBtn && apiLog) {
   showLogBtn.onclick = function() {
     apiLog.classList.toggle('is-visible');
     showLogBtn.textContent = apiLog.classList.contains('is-visible') ? 'Hide log' : 'Show log';
   };
 }
})();
</script>
</body>
</html>














































