   SET @campaignNameSafe = Replace(@campaignName,'"','')
   SET @campaignNameSafe = Replace(@campaignNameSafe," | ","_")
   SET @campaignNameSafe = Replace(@campaignNameSafe," ","_")
   SET @campaignNameSafe = Replace(@campaignNameSafe,"|","_")
   SET @dateStr = Concat(Format(Now(),"yyyy"),"_",Format(Now(),"MM"),"_",Format(Now(),"dd"))
   SET @eventName = Concat(@campaignNameSafe,"_Auto_Created_",@dateStr)
   SET @journeyName = Concat(@campaignNameSafe,"_Auto_Created_",@dateStr)
   SET @emailName = Concat(@eventName,"_Email")
