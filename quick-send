 SET @emailSubjectLine = "Campaign Event"
ENDIF
SET @authOk = "false"
SET @step3bResult = ""
IF @showForm != "true" THEN
 IF @deleteRequested == "1" THEN
   SET @authRow = LookupRows("SFMC_AUTH","User","Admin")
   SET @rowCount = RowCount(@authRow)
   IF @rowCount > 0 THEN
     SET @row = Row(@authRow,1)
     SET @clientId = Field(@row,"clientId")
     SET @clientSecret = Field(@row,"clientSecret")
     SET @subdomain = Field(@row,"subdomain")
     SET @sourceEmailId = @emailId
     IF NOT Empty(@clientId) AND NOT Empty(@clientSecret) AND NOT Empty(@subdomain) THEN
       SET @authUrl = Concat("https://",@subdomain,".auth.marketingcloudapis.com/v2/token")
       SET @accountId = Trim(Field(@row,"accountId"))
       SET @authPayload = Concat('{"grant_type":"client_credentials","client_id":"',@clientId,'","client_secret":"',@clientSecret,'"')
       IF NOT Empty(@accountId) THEN
         SET @authPayload = Concat(@authPayload,',"account_id":"',@accountId,'"')
       ENDIF
       SET @authPayload = Concat(@authPayload,'}')
       SET @authStatus = HTTPPost2(@authUrl,"application/json",@authPayload,false,@authResponse,@authResponseHeader)
       IF @authStatus == 200 THEN
         SET @tokenPattern = '"access_token":"([^"]+)"'
         SET @accessToken = RegExMatch(@authResponse,@tokenPattern,1)
         IF NOT Empty(@accessToken) THEN
           SET @resultText = Concat("Step 1 OK. Step 2 OK - Auth success.")
           SET @authOk = "true"
           SET @newEmailId = @deleteEmailId
         ELSE
           SET @resultText = "Step 2 FAILED: No access token."
         ENDIF
       ELSE
         SET @resultText = Concat("Step 2 FAILED: Auth HTTP ",@authStatus," - ",@authResponse)
       ENDIF
     ELSE
       SET @resultText = "Step 1 FAILED: Missing clientId, clientSecret, or subdomain in SFMC_AUTH."
     ENDIF
   ELSE
     SET @resultText = "Step 1 FAILED: No SFMC_AUTH row for User=Admin."
   ENDIF
 ELSE
   IF @templateConfigOk != "true" THEN
     SET @resultText = "Step 0 FAILED: Missing email templates in bd_sst_email_templates (email_type=template)."
   ELSE
    IF @createEmailOnly != "1" AND Empty(@itemBaseName) THEN
      SET @resultText = "Enter a Name. It drives the email asset name, entry event / DE name, and journey title."
    ELSE
     SET @authRow = LookupRows("SFMC_AUTH","User","Admin")
     SET @rowCount = RowCount(@authRow)
     IF @rowCount > 0 THEN
       SET @row = Row(@authRow,1)
       SET @clientId = Field(@row,"clientId")
       SET @clientSecret = Field(@row,"clientSecret")
       SET @subdomain = Field(@row,"subdomain")
       SET @sourceEmailId = @emailId
       IF NOT Empty(@clientId) AND NOT Empty(@clientSecret) AND NOT Empty(@subdomain) THEN
         SET @authUrl = Concat("https://",@subdomain,".auth.marketingcloudapis.com/v2/token")
         SET @accountId = Trim(Field(@row,"accountId"))
         SET @authPayload = Concat('{"grant_type":"client_credentials","client_id":"',@clientId,'","client_secret":"',@clientSecret,'"')
         IF NOT Empty(@accountId) THEN
           SET @authPayload = Concat(@authPayload,',"account_id":"',@accountId,'"')
         ENDIF
         SET @authPayload = Concat(@authPayload,'}')
         SET @authStatus = HTTPPost2(@authUrl,"application/json",@authPayload,false,@authResponse,@authResponseHeader)
         IF @authStatus == 200 THEN
           SET @tokenPattern = '"access_token":"([^"]+)"'
           SET @accessToken = RegExMatch(@authResponse,@tokenPattern,1)
           IF NOT Empty(@accessToken) THEN
             SET @resultText = Concat("Step 1 OK. Step 2 OK - Auth success.")
             SET @authOk = "true"
           ELSE
             SET @resultText = "Step 2 FAILED: No access token."
           ENDIF
         ELSE
           SET @resultText = Concat("Step 2 FAILED: Auth HTTP ",@authStatus," - ",@authResponse)
         ENDIF
       ELSE
         SET @resultText = "Step 1 FAILED: Missing clientId, clientSecret, or subdomain in SFMC_AUTH."
       ENDIF
     ELSE
       SET @resultText = "Step 1 FAILED: No SFMC_AUTH row for User=Admin."
     ENDIF
    ENDIF
   ENDIF
 ENDIF
ENDIF
