           const specialtyClickedData = '%%=v(@specialtyClickedData)=%%';
           const specialtyTotalData = '%%=v(@specialtyTotalData)=%%';    

           const labels = specialtyLabels ? specialtyLabels.split(',') : [];
           const opened = specialtyOpenedData ? specialtyOpenedData.split(',').map(Number) : [];
           const didNotOpen = specialtyDidNotOpenData ? specialtyDidNotOpenData.split(',').map(Number) : [];
           const bounced = specialtyBouncedData ? specialtyBouncedData.split(',').map(Number) : [];
           const clicked = specialtyClickedData ? specialtyClickedData.split(',').map(Number) : [];
           const totals = specialtyTotalData ? specialtyTotalData.split(',').map(Number) : [];    

           if (labels.length === 0) {
               ctx.parentElement.innerHTML = '<div style="text-align: center; padding: 40px; color: var(--text-secondary);">No specialty data available</div>';
               return;
           }    

           const proportionalOpened = opened.map((val, index) => {
               const total = totals[index] || 1;
               const sum = opened[index];
               return sum > 0 ? sum : 0;
           });    

           const proportionalDidNotOpen = didNotOpen.map((val, index) => {
               const total = totals[index] || 1;
               const sum = didNotOpen[index];
               return sum > 0 ? sum : 0;
           });    

           const proportionalBounced = bounced.map((val, index) => {
               const total = totals[index] || 1;
               const sum = bounced[index];
               return sum > 0 ? sum : 0;
           });  

           const proportionalClicked = clicked.map((val, index) => {
               const total = totals[index] || 1;
               const sum = clicked[index];
               return sum > 0 ? sum : 0;
           });    

           new Chart(ctx, {
               type: 'bar',
               data: {
                   labels: labels,
                   datasets: [
                       {
                           label: 'Opened',
                           data: proportionalOpened,
                           backgroundColor: '#3fc699',
                           borderWidth: 0
                       },
                       {
                           label: 'Did Not Open',
                           data: proportionalDidNotOpen,
                           backgroundColor: '#000000',
                           borderWidth: 0
                       },
                       {
                           label: 'Bounced',
                           data: proportionalBounced,
                           backgroundColor: 'rgba(220, 38, 38, 0.8)',
                           borderWidth: 0
                       },
                       {
                           label: 'Clicked',
                           data: proportionalClicked,
                           backgroundColor: 'rgba(99, 102, 241, 0.8)',
                           borderWidth: 0
                       }
                   ]
               },
               options: {
                   responsive: true,
                   maintainAspectRatio: false,
                   plugins: {
                       tooltip: {
                           callbacks: {
                               afterBody: function (context) {
                                   const i = context[0].dataIndex;
                                   if (context[0].datasetIndex === 0) {
                                       return [
                                           'Did Not Open: ' + didNotOpen[i].toLocaleString(),
                                           'Bounced: ' + bounced[i].toLocaleString(),
                                           'Clicked: ' + clicked[i].toLocaleString(),
                                           'Total: ' + totals[i].toLocaleString()
                                       ];
                                   }
                                   return [];
                               }
                           }
                       }
                   },
                   scales: {
                       x: {
                           stacked: true
                       },
                       y: {
                           stacked: true,
                           beginAtZero: true,
                           maxBarThickness: 60
                       }
                   }
               }
           });
       } 

       let allResponses = [];
       let filteredResponses = [];
       let currentPage = 1;
       const rowsPerPage = 10; 

       function parseCustomDate(dateString) {
           if (!dateString || dateString === 'N/A') return null;
           try {
               const trimmed = dateString.trim();
               const parts = trimmed.split(/\s+/);
               if (parts.length >= 3) {
                   const month = parts[0];
                   let day = parts[1].replace(/,/g, '').replace(/[^0-9]/g, '');
                   let year = parts[2].replace(/,/g, '').replace(/[^0-9]/g, '');
                   let hour24 = 0;
                   let minutes = 0;
                   if (parts.length >= 4) {
                       if (parts[3].includes(':') || parts[3].toUpperCase().includes('AM') || parts[3].toUpperCase().includes('PM')) {
                           const timePart = parts[3];
                           const upperTime = timePart.toUpperCase();
                           const hasAM = upperTime.includes('AM');
                           const hasPM = upperTime.includes('PM');
                           const ampm = hasPM ? 'PM' : (hasAM ? 'AM' : '');
                           const timeStr = timePart.replace(/AM|PM/gi, '').trim();
                           const timeParts = timeStr.split(':').map(Number);
                           if (timeParts.length >= 2 && !isNaN(timeParts[0]) && !isNaN(timeParts[1])) {
                               hour24 = timeParts[0];
                               minutes = timeParts[1] || 0;
                               if (ampm === 'PM' && hour24 !== 12) hour24 = hour24 + 12;
                               if (ampm === 'AM' && hour24 === 12) hour24 = 0;
                           }
                       } else if (parts.length >= 5 && (parts[4].toUpperCase().includes('AM') || parts[4].toUpperCase().includes('PM'))) {
                           const timePart = parts[3] + ' ' + parts[4];
                           const upperTime = timePart.toUpperCase();
                           const hasAM = upperTime.includes('AM');
                           const hasPM = upperTime.includes('PM');
                           const ampm = hasPM ? 'PM' : (hasAM ? 'AM' : '');
                           const timeStr = parts[3].replace(/AM|PM/gi, '').trim();
                           const timeParts = timeStr.split(':').map(Number);
                           if (timeParts.length >= 2 && !isNaN(timeParts[0]) && !isNaN(timeParts[1])) {
                               hour24 = timeParts[0];
                               minutes = timeParts[1] || 0;
                               if (ampm === 'PM' && hour24 !== 12) hour24 = hour24 + 12;
                               if (ampm === 'AM' && hour24 === 12) hour24 = 0;
                           }
                       }
                   }
                   const monthIndex = getMonthIndex(month);
                   const dayNum = parseInt(day);
                   const yearNum = parseInt(year);
                   if (!isNaN(monthIndex) && !isNaN(dayNum) && dayNum > 0 && dayNum <= 31 && !isNaN(yearNum) && yearNum >= 1900 && yearNum <= 2100) {
                       const dateObj = new Date(yearNum, monthIndex, dayNum, hour24, minutes, 0);
                       if (!isNaN(dateObj.getTime())) {
                           return dateObj;
                       }
                   }
               }
               return null;
           } catch (e) {
               return null;
           }
       }    

       function getMonthIndex(monthAbbr) {
           const months = {
               'Jan': 0, 'Feb': 1, 'Mar': 2, 'Apr': 3, 'May': 4, 'Jun': 5,
               'Jul': 6, 'Aug': 7, 'Sep': 8, 'Oct': 9, 'Nov': 10, 'Dec': 11
           };
           return months[monthAbbr] !== undefined ? months[monthAbbr] : 0;
       }    

       function parseResponsesData() {
           const responsesData = '%%=v(@responsesData)=%%';
           if (!responsesData || responsesData === '') {
               return [];
           }
           const responseEntries = responsesData.split('|||').filter(entry => entry.trim() !== '');
           const responses = responseEntries.map(entry => {
               const parts = entry.split(':::');
               return {
                   contactId: parts[0] || 'N/A',
                   email: parts[1] || 'N/A',
                   date: parts[2] || 'N/A',
                   engagement: (parts[3] && parts[3] !== 'N/A') ? parts[3].trim() : 'N/A',
                   primarySpecialty: (parts[4] && parts[4] !== 'N/A') ? parts[4].trim() : '',
                   state: (parts[5] && parts[5] !== 'N/A') ? parts[5].trim() : '',
                   jobId: parts[6] && parts[6] !== 'N/A' ? parts[6] : '',
                   accountName: parts[7] && parts[7] !== 'N/A' ? parts[7] : '',
                   firstName: parts[8] && parts[8] !== 'N/A' ? parts[8] : '',
                   lastName: parts[9] && parts[9] !== 'N/A' ? parts[9] : '',
                   designation: parts[10] && parts[10] !== 'N/A' ? parts[10] : '',
                   role: parts[11] && parts[11] !== 'N/A' ? parts[11] : '',
                   mobile: parts[12] && parts[12] !== 'N/A' ? parts[12] : '',
                   auth0UserId: parts[13] && parts[13] !== 'N/A' ? parts[13] : '',
                   openDate: parts[14] && parts[14] !== 'N/A' ? parts[14] : '',
                   viewEmailUrl: parts[15] && parts[15] !== 'N/A' ? parts[15] : '',
                   emailHistory: parts[16] && parts[16] !== 'N/A' ? parts[16] : '',
                   courseHistory: parts[17] && parts[17] !== 'N/A' ? parts[17] : ''
               };
           });
           return responses.sort((a, b) => {
               if (a.date === 'N/A' && b.date === 'N/A') return 0;
               if (a.date === 'N/A') return 1;
               if (b.date === 'N/A') return -1;
               const dateA = parseCustomDate(a.date);
               const dateB = parseCustomDate(b.date);
               if (!dateA && !dateB) return 0;
               if (!dateA) return 1;
               if (!dateB) return -1;
               return dateB.getTime() - dateA.getTime();
           });
       } 

       function formatDate(dateString) {
           if (!dateString || dateString === 'N/A') return 'N/A';
           try {
               const date = parseCustomDate(dateString);
               if (!date) return dateString;
               return date.toLocaleDateString('en-US', {
                   year: 'numeric',
                   month: 'short',
                   day: 'numeric',
                   hour: '2-digit',
                   minute: '2-digit'
               });
           } catch (e) {
               return dateString;
           }
       } 

       function truncateText(text, maxLength) {
           if (!text || text.trim() === '' || text === 'N/A') return '';
           if (text.length <= maxLength) return text;
           return text.substring(0, maxLength) + '...';
       } 

       function isToday(dateString) {
           if (!dateString || dateString === 'N/A') return false;
           try {
               const date = parseCustomDate(dateString);
               if (!date) return false;
               const today = new Date();
               return date.getDate() === today.getDate() &&
                      date.getMonth() === today.getMonth() &&
                      date.getFullYear() === today.getFullYear();
           } catch (e) {
               return false;
           }
       }

       function applyFilters() {
           const filterEngagementEl = document.getElementById('filterEngagement');
           const filterStateEl = document.getElementById('filterState');
           const filterSpecialtyEl = document.getElementById('filterSpecialty');
           const filterDateEl = document.getElementById('filterDate');
           
           if (!filterEngagementEl || !filterStateEl || !filterSpecialtyEl || !filterDateEl) {
               return;
           }
           
           const filterEngagement = filterEngagementEl.value ? filterEngagementEl.value.trim() : '';
           const filterState = filterStateEl.value ? filterStateEl.value.trim() : '';
           const filterSpecialty = filterSpecialtyEl.value ? filterSpecialtyEl.value.trim() : '';
           const filterDate = filterDateEl.value ? filterDateEl.value.trim() : '';
           
           filteredResponses = allResponses.filter(response => {
               if (filterEngagement !== '') {
                   const responseEngagement = (response.engagement || '').trim();
                   if (responseEngagement === 'N/A' || responseEngagement !== filterEngagement) {
                       return false;
                   }
               }
               
               if (filterState !== '') {
                   const responseState = (response.state || '').trim();
                   if (responseState === '' || responseState !== filterState) {
                       return false;
                   }
               }
               
               if (filterSpecialty !== '') {
                   const responseSpecialty = (response.primarySpecialty || '').trim();
                   if (responseSpecialty === '' || responseSpecialty !== filterSpecialty) {
                       return false;
                   }
               }
               
               if (filterDate === 'today') {
                   if (!isToday(response.date)) {
                       return false;
                   }
               }
               
               return true;
           });
           
           currentPage = 1;
           renderResponsesTable();
           renderPagination();
       } 

       function populateFilters() {
           const filterEngagement = document.getElementById('filterEngagement');
           const filterState = document.getElementById('filterState');
           const filterSpecialty = document.getElementById('filterSpecialty'); 

           const allUniqueStates = [...new Set(allResponses.map(r => r.state).filter(s => s && s.trim() !== ''))].sort();
           allUniqueStates.forEach(state => {
               const option = document.createElement('option');
               option.value = state;
               option.textContent = state;
               filterState.appendChild(option);
           }); 

           const allUniqueSpecialties = [...new Set(allResponses.map(r => r.primarySpecialty).filter(s => s && s.trim() !== ''))].sort();
           allUniqueSpecialties.forEach(specialty => {
               const option = document.createElement('option');
               option.value = specialty;
               option.textContent = specialty.length > 50 ? specialty.substring(0, 50) + '...' : specialty;
               filterSpecialty.appendChild(option);
           }); 

           filterEngagement.addEventListener('change', applyFilters);
           filterState.addEventListener('change', applyFilters);
           filterSpecialty.addEventListener('change', applyFilters);
           const filterDate = document.getElementById('filterDate');
           filterDate.addEventListener('change', applyFilters);
       } 

