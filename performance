IF NOT Empty(@bouncedValue) THEN
IF Empty(@bouncedUnique) THEN
SET @bouncedUnique = @bouncedValue
SET @bouncedCounts = "1"
ELSE
SET @bouncedUniqueArray = BuildRowsetFromString(@bouncedUnique, "|||")
SET @found2 = 0
SET @foundIndex2 = 0
FOR @n = 1 TO RowCount(@bouncedUniqueArray) DO
SET @uniqueRow2 = Row(@bouncedUniqueArray, @n)
SET @uniqueValue2 = Trim(Field(@uniqueRow2, 1))
IF @uniqueValue2 == @bouncedValue THEN
SET @found2 = 1
SET @foundIndex2 = @n
