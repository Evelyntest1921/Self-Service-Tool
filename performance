<script runat="server">
Platform.Load("core", "1");

var action = String(Request.GetFormField("do") || Request.GetQueryStringParameter("do") || "");
var confirm = String(Request.GetFormField("confirm") || Request.GetQueryStringParameter("confirm") || "");
var automationId = String(Variable.GetValue("@triggerAutomationId") || "");

if (action === "triggerAutomation" && confirm === "1") {
  try {
    if (!automationId) {
      Variable.SetValue("@triggerAutomationStatus", "FAILED");
      Variable.SetValue("@triggerAutomationResult", "FAILED: missing automation id.");
    } else {
      var prox = new Script.Util.WSProxy();
      var perform = prox.performItem("Program", { ObjectID: automationId }, "start", {});
      var topStatus = perform && perform.Status ? String(perform.Status) : "";
      var itemCode = perform && perform.Results && perform.Results.length > 0 && perform.Results[0].StatusCode ? String(perform.Results[0].StatusCode) : "";
      var itemMsg = perform && perform.Results && perform.Results.length > 0 && perform.Results[0].StatusMessage ? String(perform.Results[0].StatusMessage) : "";

      if (topStatus === "OK" || itemCode === "OK") {
        Variable.SetValue("@triggerAutomationStatus", "OK");
        Variable.SetValue("@triggerAutomationResult", "Success: automation has been successfully triggered. ID " + automationId + ".");
      } else {
        Variable.SetValue("@triggerAutomationStatus", "FAILED");
        Variable.SetValue("@triggerAutomationResult", "FAILED: SOAP start rejected. topStatus=" + topStatus + " itemCode=" + itemCode + " itemMsg=" + itemMsg);
      }
    }
  } catch (e) {
    Variable.SetValue("@triggerAutomationStatus", "FAILED");
    Variable.SetValue("@triggerAutomationResult", "FAILED: " + (e && e.message ? e.message : String(e)));
  }
}

var syncAutomationId = String(Variable.GetValue("@syncAutomationIdVar") || "");

if (action === "syncAutomation" && confirm === "1") {
  try {
    if (!syncAutomationId) {
      Variable.SetValue("@syncAutomationStatus", "FAILED");
      Variable.SetValue("@syncAutomationResult", "FAILED: missing sync automation id.");
    } else {
      var proxSync = new Script.Util.WSProxy();
      var performSync = proxSync.performItem("Program", { ObjectID: syncAutomationId }, "start", {});
      var topStatusSync = performSync && performSync.Status ? String(performSync.Status) : "";
      var itemCodeSync = performSync && performSync.Results && performSync.Results.length > 0 && performSync.Results[0].StatusCode ? String(performSync.Results[0].StatusCode) : "";
      var itemMsgSync = performSync && performSync.Results && performSync.Results.length > 0 && performSync.Results[0].StatusMessage ? String(performSync.Results[0].StatusMessage) : "";

      if (topStatusSync === "OK" || itemCodeSync === "OK") {
        Variable.SetValue("@syncAutomationStatus", "OK");
        Variable.SetValue("@syncAutomationResult", "Success: sync automation has been successfully triggered. ID " + syncAutomationId + ".");
      } else {
        Variable.SetValue("@syncAutomationStatus", "FAILED");
        Variable.SetValue("@syncAutomationResult", "FAILED: SOAP start rejected. topStatus=" + topStatusSync + " itemCode=" + itemCodeSync + " itemMsg=" + itemMsgSync);
      }
    }
  } catch (e) {
    Variable.SetValue("@syncAutomationStatus", "FAILED");
    Variable.SetValue("@syncAutomationResult", "FAILED: " + (e && e.message ? e.message : String(e)));
  }
}
