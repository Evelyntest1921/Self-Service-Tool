SET @stateCount = 0
IF NOT Empty(@stateEngagementMap) THEN
SET @stateMapKeys = BuildRowsetFromString(@stateEngagementMap, "|||")
SET @stateCount = RowCount(@stateMapKeys)
FOR @stateMapIdx = 1 TO RowCount(@stateMapKeys) DO
SET @stateMapRow = Row(@stateMapKeys, @stateMapIdx)
SET @stateMapValue = Field(@stateMapRow, 1)
SET @stateParts = BuildRowsetFromString(@stateMapValue, ":::")
