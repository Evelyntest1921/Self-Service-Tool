           display: none;
       }
       .add-contact-section.visible {
           display: block;
       }
       .add-contact-section .contact-form-row {
           display: flex;
           align-items: flex-end;
           gap: 12px;
           flex-wrap: wrap;
           justify-content: flex-end;
       }
       .add-contact-section .contact-form-group {
           display: flex;
           flex-direction: column;
           gap: 8px;
           min-width: auto;
