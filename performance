       function downloadFilteredData() {
           const dataToDownload = filteredResponses.length > 0 ? filteredResponses : allResponses;
           if (dataToDownload.length === 0) {
               alert('No data to download');
               return;
           }
           const headers = ['Contact_Id', 'Email', 'LastSent', 'Engagement', 'Primary_Specialty', 'Related_Account_Primary_State', 'JobID', 'Related_Account_Name', 'First_Name', 'Last_Name', 'Designation', 'Role', 'Mobile', 'Auth0UserId', 'Campaign', 'view_email_url', 'emailHistory', 'courseHistory'];
           const csvRows = [headers.join(',')];
           dataToDownload.forEach(response => {
               const row = [
                   `"${(response.contactId || '').replace(/"/g, '""')}"`,
                   `"${(response.email || '').replace(/"/g, '""')}"`,
                   `"${(response.date || '').replace(/"/g, '""')}"`,
                   `"${(response.engagement || '').replace(/"/g, '""')}"`,
                   `"${(response.primarySpecialty || '').replace(/"/g, '""')}"`,
                   `"${(response.state || '').replace(/"/g, '""')}"`,
                   `"${(response.jobId || '').replace(/"/g, '""')}"`,
                   `"${(response.accountName || '').replace(/"/g, '""')}"`,
                   `"${(response.firstName || '').replace(/"/g, '""')}"`,
                   `"${(response.lastName || '').replace(/"/g, '""')}"`,
                   `"${(response.designation || '').replace(/"/g, '""')}"`,
                   `"${(response.role || '').replace(/"/g, '""')}"`,
                   `"${(response.mobile || '').replace(/"/g, '""')}"`,
                   `"${(response.auth0UserId || '').replace(/"/g, '""')}"`,
                   `"${(response.openDate || '').replace(/"/g, '""')}"`,
                   `"${(response.viewEmailUrl || '').replace(/"/g, '""')}"`,
                   `"${(response.emailHistory || '').replace(/"/g, '""')}"`,
                   `"${(response.courseHistory || '').replace(/"/g, '""')}"`
               ];
               csvRows.push(row.join(','));
           });
           const csvContent = csvRows.join('\n');
           const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
           const link = document.createElement('a');
           const url = URL.createObjectURL(blob);
           link.setAttribute('href', url);
           link.setAttribute('download', `Push_Advice_Email_Engagement_${new Date().toISOString().split('T')[0]}.csv`);
           link.style.visibility = 'hidden';
           document.body.appendChild(link);
           link.click();
           document.body.removeChild(link);
       } 

       function renderResponsesTable() {
           const tbody = document.getElementById('responsesTableBody');
           if (!tbody) return;
           const dataToShow = filteredResponses.length > 0 ? filteredResponses : allResponses;
           const startIndex = (currentPage - 1) * rowsPerPage;
           const endIndex = startIndex + rowsPerPage;
           const pageData = dataToShow.slice(startIndex, endIndex);
           if (pageData.length === 0) {
               tbody.innerHTML = '<tr><td colspan="12" style="text-align: center; padding: 24px; color: var(--text-secondary);">No records found</td></tr>';
               return;
           }
           tbody.innerHTML = pageData.map(response => {
               const formattedDate = formatDate(response.date);
               const formattedOpenDate = formatDate(response.openDate);
               const engagementDisplay = response.engagement && response.engagement.trim() !== '' ? response.engagement : '-';
               const engagementClass = engagementDisplay.toLowerCase().replace(/\s+/g, '-');
               const hasViewEmailUrl = response.viewEmailUrl && response.viewEmailUrl !== 'N/A' && response.viewEmailUrl.trim() !== '';
             const hasEmailHistory = response.emailHistory && response.emailHistory !== 'N/A' && response.emailHistory.trim() !== '';
             const hasCourseHistory = response.courseHistory && response.courseHistory !== 'N/A' && response.courseHistory.trim() !== '';
               return `
                    <tr style="${response.lastName === 'SMS' ? 'background: #000000;' : ''}">
                    <td>${response.contactId}</td>
                    <td>${response.email}</td>
                    <td>${formattedDate}</td>
                    <td><span class="engagement-badge engagement-${engagementClass}">${engagementDisplay}</span></td>
                    <td>${response.primarySpecialty || '-'}</td>
                    <td>${response.state || '-'}</td>
                    <td>${response.jobId || '-'}</td>
                    <td>${truncateText(response.accountName, 20)}</td>
                    <td>${response.firstName || '-'}</td>
                    <td>${response.lastName || '-'}</td>
                    <td>${formattedOpenDate}</td>
                   <td>
  ${hasCourseHistory 
    ? `<a href="#" onclick="window.open('${response.courseHistory}', '_blank'); return false;" style="
        font-size: 50px;
        color: black;
        text-decoration: none;
      ">📃</a>` 
    : '-'}
</td>

                    <td>${hasEmailHistory ? `<button class="history-button" onclick="window.open('${response.emailHistory}', '_blank')">All Emails</button>` : '-'}</td>
                     <td>${hasViewEmailUrl ? `<button class="open-button" onclick="window.open('${response.viewEmailUrl}', '_blank')">Preview</button>` : '-'}</td>
                </tr>
            `;
           }).join('');
       } 

       function renderPagination() {
           const paginationContainer = document.getElementById('pagination');
           if (!paginationContainer) return;
           const dataToShow = filteredResponses.length > 0 ? filteredResponses : allResponses;
           const totalPages = Math.ceil(dataToShow.length / rowsPerPage);
           if (totalPages <= 1) {
               paginationContainer.innerHTML = `<div class="pagination-info">Showing ${dataToShow.length} of ${dataToShow.length} records</div>`;
               return;
           }
           const startIndex = (currentPage - 1) * rowsPerPage + 1;
           const endIndex = Math.min(currentPage * rowsPerPage, dataToShow.length);
           let paginationHTML = '';
           paginationHTML += `<button class="pagination-button" ${currentPage === 1 ? 'disabled' : ''} onclick="goToPage(${currentPage - 1})">Previous</button>`;
           const maxVisiblePages = 5;
           let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
           let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
           if (endPage - startPage < maxVisiblePages - 1) {
               startPage = Math.max(1, endPage - maxVisiblePages + 1);
           }
           if (startPage > 1) {
               paginationHTML += `<button class="pagination-button" onclick="goToPage(1)">1</button>`;
               if (startPage > 2) {
                   paginationHTML += `<span class="pagination-info">...</span>`;
               }
           }
           for (let i = startPage; i <= endPage; i++) {
               paginationHTML += `<button class="pagination-button ${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
           }
           if (endPage < totalPages) {
               if (endPage < totalPages - 1) {
                   paginationHTML += `<span class="pagination-info">...</span>`;
               }
               paginationHTML += `<button class="pagination-button" onclick="goToPage(${totalPages})">${totalPages}</button>`;
           }
           paginationHTML += `<button class="pagination-button" ${currentPage === totalPages ? 'disabled' : ''} onclick="goToPage(${currentPage + 1})">Next</button>`;
           paginationHTML += `<div class="pagination-info">Showing ${startIndex}-${endIndex} of ${dataToShow.length} records</div>`;
           paginationContainer.innerHTML = paginationHTML;
       } 

       function goToPage(page) {
           const dataToShow = filteredResponses.length > 0 ? filteredResponses : allResponses;
           const totalPages = Math.ceil(dataToShow.length / rowsPerPage);
           if (page < 1 || page > totalPages) return;
           currentPage = page;
           renderResponsesTable();
           renderPagination();
           window.scrollTo({ top: document.getElementById('downloadBtn').offsetTop - 200, behavior: 'smooth' });
       } 

       document.addEventListener('DOMContentLoaded', function () {
           createResponseChart();
           createOpensClicksChart();
           createCombinedEngagementChart();
           createStateChart();
           createSpecialtyChart();
           allResponses = parseResponsesData();
           filteredResponses = [];
           populateFilters();
           renderResponsesTable();
           renderPagination();

           const triggerSection = document.getElementById('triggerSection');
           if (triggerSection && triggerSection.querySelector('.trigger-result')) {
               triggerSection.classList.add('visible');
               triggerSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
           }

          const triggerForm = document.getElementById('triggerForm');
          if (triggerForm) {
              triggerForm.addEventListener('submit', function () {
                  showTriggerLoading();
              });
          }

          const syncSection = document.getElementById('syncSection');
          if (syncSection && syncSection.querySelector('.sync-result')) {
              syncSection.classList.add('visible');
              syncSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }

          const syncForm = document.getElementById('syncForm');
          if (syncForm) {
              syncForm.addEventListener('submit', function () {
                  showSyncLoading();
              });
          }
      });
   </script>
