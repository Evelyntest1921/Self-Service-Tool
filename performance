IF NOT Empty(@openedData) THEN
SET @openedArray = BuildRowsetFromString(@openedData, "|||")
SET @openedArrayCount = RowCount(@openedArray)
FOR @j = 1 TO @openedArrayCount DO
SET @openedRow = Row(@openedArray, @j)
SET @openedValue = Trim(Field(@openedRow, 1))
IF NOT Empty(@openedValue) THEN
IF Empty(@openedUnique) THEN
SET @openedUnique = @openedValue
SET @openedCounts = "1"
ELSE
SET @openedUniqueArray = BuildRowsetFromString(@openedUnique, "|||")
SET @found = 0
SET @foundIndex = 0
FOR @k = 1 TO RowCount(@openedUniqueArray) DO
SET @uniqueRow = Row(@openedUniqueArray, @k)
SET @uniqueValue = Trim(Field(@uniqueRow, 1))
IF @uniqueValue == @openedValue THEN
SET @found = 1
SET @foundIndex = @k
ENDIF
NEXT @k
IF @found == 0 THEN
SET @openedUnique = Concat(@openedUnique, "|||", @openedValue)
SET @openedCounts = Concat(@openedCounts, "|||", "1")
ELSE
SET @openedCountArray = BuildRowsetFromString(@openedCounts, "|||")
SET @newCounts = ""
FOR @l = 1 TO RowCount(@openedCountArray) DO
SET @countRow = Row(@openedCountArray, @l)
SET @countValue = Field(@countRow, 1)
IF @l == @foundIndex THEN
SET @countValue = Add(@countValue, 1)
ENDIF
IF Empty(@newCounts) THEN
SET @newCounts = @countValue
ELSE
SET @newCounts = Concat(@newCounts, "|||", @countValue)
ENDIF
NEXT @l
SET @openedCounts = @newCounts
ENDIF
ENDIF
ENDIF
NEXT @j
ENDIF 

