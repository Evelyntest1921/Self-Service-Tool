       }
       .add-contact-section .contact-form-group label {
           font-size: 0.875rem;
           font-weight: 600;
           color: var(--text-primary);
       }
       .add-contact-section input[type="text"].contact-id-input {
           padding: 10px 12px;
           border: 1px solid var(--border-color);
           background: var(--bg-primary);
