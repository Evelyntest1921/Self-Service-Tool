       function createResponseChart() {
           const ctx = document.getElementById('responseChart');
           if (!ctx) return;
           const dateData = '%%=v(@dateData)=%%';
           const dateCounts = {};
           if (dateData && dateData !== '') {
               const dates = dateData.split(',').filter(date => date.trim() !== '');
               dates.forEach(date => {
                   const trimmedDate = date.trim();
                   if (trimmedDate) {
                       const parsedDate = parseCustomDate(trimmedDate);
                       if (parsedDate && !isNaN(parsedDate.getTime())) {
                           const dateOnly = parsedDate.toLocaleDateString('en-US', {
                               year: 'numeric',
                               month: 'short',
                               day: 'numeric'
                           });
                           dateCounts[dateOnly] = (dateCounts[dateOnly] || 0) + 1;
                       } else {
                           const parts = trimmedDate.split(' ');
                           if (parts.length >= 3) {
                               const dateOnly = parts[0] + ' ' + parts[1] + ' ' + parts[2];
                               dateCounts[dateOnly] = (dateCounts[dateOnly] || 0) + 1;
                           }
                       }
                   }
               });
           }
           const sortedDates = Object.keys(dateCounts).sort((a, b) => {
               const dateA = parseCustomDate(a);
               const dateB = parseCustomDate(b);
               if (!dateA && !dateB) return a.localeCompare(b);
               if (!dateA) return 1;
               if (!dateB) return -1;
               return dateA.getTime() - dateB.getTime();
           });
           const counts = sortedDates.map(date => dateCounts[date]);
           const allValues = counts.filter(v => !isNaN(v));
           const maxValue = allValues.length > 0 ? Math.max(...allValues) : 1;
           const stepSize = Math.max(1, Math.ceil(maxValue / 10));
