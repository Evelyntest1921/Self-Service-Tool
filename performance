       function buildDateCounts(dateDataStr) {
           const dateCounts = {};
           if (!dateDataStr || dateDataStr === '') return dateCounts;
           const dates = dateDataStr.split(',').filter(date => date.trim() !== '');
           dates.forEach(date => {
               const trimmedDate = date.trim();
               if (trimmedDate) {
                   const parsedDate = parseCustomDate(trimmedDate);
                   if (parsedDate && !isNaN(parsedDate.getTime())) {
                       const dateOnly = parsedDate.toLocaleDateString('en-US', {
                           year: 'numeric',
                           month: 'short',
                           day: 'numeric'
                       });
                       dateCounts[dateOnly] = (dateCounts[dateOnly] || 0) + 1;
                   } else {
                       const parts = trimmedDate.split(' ');
                       if (parts.length >= 3) {
                           const dateOnly = parts[0] + ' ' + parts[1] + ' ' + parts[2];
                           dateCounts[dateOnly] = (dateCounts[dateOnly] || 0) + 1;
                       }
