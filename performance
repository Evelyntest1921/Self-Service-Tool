       function createStateChart() {
           const ctx = document.getElementById('stateChart');
           if (!ctx) return; 

           const stateLabels = '%%=v(@stateLabels)=%%';
           const stateOpenedData = '%%=v(@stateOpenedData)=%%';
           const stateDidNotOpenData = '%%=v(@stateDidNotOpenData)=%%';
           const stateBouncedData = '%%=v(@stateBouncedData)=%%';
           const stateClickedData = '%%=v(@stateClickedData)=%%';
           const stateTotalData = '%%=v(@stateTotalData)=%%'; 

           const labels = stateLabels ? stateLabels.split(',') : [];
           const opened = stateOpenedData ? stateOpenedData.split(',').map(Number) : [];
           const didNotOpen = stateDidNotOpenData ? stateDidNotOpenData.split(',').map(Number) : [];
           const bounced = stateBouncedData ? stateBouncedData.split(',').map(Number) : [];
           const clicked = stateClickedData ? stateClickedData.split(',').map(Number) : [];
           const totals = stateTotalData ? stateTotalData.split(',').map(Number) : []; 

           if (labels.length === 0) {
               ctx.parentElement.innerHTML = '<div style="text-align: center; padding: 40px; color: var(--text-secondary);">No state data available</div>';
               return;
           } 

           const proportionalOpened = opened.map((val, index) => {
               const total = totals[index] || 1;
               const sum = opened[index];
               return sum > 0 ? sum : 0;
           }); 

           const proportionalDidNotOpen = didNotOpen.map((val, index) => {
               const total = totals[index] || 1;
               const sum = didNotOpen[index];
               return sum > 0 ? sum : 0;
           }); 

           const proportionalBounced = bounced.map((val, index) => {
               const total = totals[index] || 1;
               const sum = bounced[index];
               return sum > 0 ? sum : 0;
           });  

           const proportionalClicked = clicked.map((val, index) => {
               const total = totals[index] || 1;
               const sum = clicked[index];
               return sum > 0 ? sum : 0;
           }); 

           new Chart(ctx, {
               type: 'bar',
               data: {
                   labels: labels,
                   datasets: [
                       {
                           label: 'Opened',
                           data: proportionalOpened,
                           backgroundColor: '#3fc699',
                           borderWidth: 0
                       },
                       {
                           label: 'Did Not Open',
                           data: proportionalDidNotOpen,
                           backgroundColor: '#000000',
                           borderWidth: 0
                       },
                       {
                           label: 'Bounced',
                           data: proportionalBounced,
                           backgroundColor: 'rgba(220, 38, 38, 0.8)',
                           borderWidth: 0
                       },
                       {
                           label: 'Clicked',
                           data: proportionalClicked,
                           backgroundColor: 'rgba(99, 102, 241, 0.8)',
                           borderWidth: 0
                       }
                   ]
               },
               options: {
                   responsive: true,
                   maintainAspectRatio: false,
                   plugins: {
                       tooltip: {
                           callbacks: {
                               afterBody: function (context) {
                                   const i = context[0].dataIndex;
                                   if (context[0].datasetIndex === 0) {
                                       return [
                                           'Did Not Open: ' + didNotOpen[i].toLocaleString(),
                                           'Bounced: ' + bounced[i].toLocaleString(),
                                           'Clicked: ' + clicked[i].toLocaleString(),
                                           'Total: ' + totals[i].toLocaleString()
                                       ];
                                   }
                                   return [];
                               }
                           }
                       }
                   },
                   scales: {
                       x: {
                           stacked: true
                       },
                       y: {
                           stacked: true,
                           beginAtZero: true,
                           maxBarThickness: 60
                       }
                   }
               }
           });
       } 

