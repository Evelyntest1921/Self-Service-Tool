    if (typeof r.length === "number") {
      var out = [];
      var i;
      for (i = 0; i < r.length; i++) out.push(r[i]);
      return out;
    }
    if (typeof r === "object" && rowHasDeFields(r)) return [r];
    return [];
  }

  function retrieveDeRows(deKey) {
    var keys = [];
    var seen = {};
    var variants = [deKey, String(deKey).toLowerCase(), String(deKey).toUpperCase()];
    var i, k, rows;
    for (i = 0; i < variants.length; i++) {
      k = variants[i];
      if (!k || seen[k]) continue;
      seen[k] = true;
      keys.push(k);
    }
    for (i = 0; i < keys.length; i++) {
      try {
        rows = coerceSendLogRows(DataExtension.Init(keys[i]).Rows.Retrieve());
        if (rows.length) return rows;
      } catch (e0) {}
    }
    for (i = 0; i < keys.length; i++) {
      try {
        rows = coerceSendLogRows(
          (new Script.Util.WSProxy()).retrieve(
            "DataExtensionObject[" + keys[i] + "]",
            ["MonthIndex", "MonthStart", "Specialty", "Responses", "Clicks", "Opens", "Bounces", "Unsubscribed", "DidNotOpen", "MonthLabel"],
            {
              Property: "Specialty",
              SimpleOperator: "isNotNull"
            }
          )
        );
        if (rows.length) return rows;
      } catch (e1) {}
    }
    return [];
  }

  function setChartVar(key, val) {
    try {
      Platform.Variable.SetValue("@" + key, val);
    } catch (e0) {}
    try {
      Platform.Variable.SetValue(key, val);
    } catch (e1) {}
  }

  function loadSendLogSeries(deKey) {
    var out = { labels: [], responses: [], hasData: false };
    try {
      var rows = retrieveDeRows(deKey);
      rows.sort(function (a, b) {
        var ai = parseInt(fieldValSendLog(a, ["MonthIndex", "monthIndex"]), 10) || 0;
        var bi = parseInt(fieldValSendLog(b, ["MonthIndex", "monthIndex"]), 10) || 0;
        if (ai < bi) return -1;
        if (ai > bi) return 1;
        return 0;
      });
      var i, label, resp, respNum;
      for (i = 0; i < rows.length; i++) {
        label = fieldValSendLog(rows[i], ["MonthLabel", "monthLabel"]);
        resp = fieldValSendLog(rows[i], ["Responses", "responses"]);
        respNum = parseInt(resp, 10);
        if (isNaN(respNum)) respNum = 0;
        out.labels.push(label != null ? String(label) : "");
        out.responses.push(respNum);
        if (respNum > 0) out.hasData = true;
      }
    } catch (e0) {}
    return out;
  }

  function seriesToJsonKey(series, keyName) {
    var labels = [];
    var i;
    for (i = 0; i < series.labels.length; i++) {
      labels.push('"' + escJsonSendLog(series.labels[i]) + '"');
    }
    return (
      '  "' + keyName + '": {\n' +
      '    "labels": [' + labels.join(", ") + '],\n' +
      '    "responses": [' + series.responses.join(", ") + '],\n' +
      '    "hasData": ' + (series.hasData ? "true" : "false") + '\n' +
      '  }'
    );
  }

  var s12 = loadSendLogSeries("sst_de_send_log_12_months");
  var s6 = loadSendLogSeries("sst_de_send_log_6_months");
  var s30 = loadSendLogSeries("sst_de_send_log_30_days");
  var chartJson =
    "{\n" +
    seriesToJsonKey(s12, "12months") + ",\n" +
    seriesToJsonKey(s6, "6months") + ",\n" +
    seriesToJsonKey(s30, "30days") + "\n" +
    "}";

  setChartVar("sendLogChartJson", chartJson);
  </script>
