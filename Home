<script runat="server" language="javascript">
Platform.Load("Core", "1.1");

var DE_EXTERNAL_KEY = "Bd_journey_analytics";
var DE_RETRIEVE_KEY = String(DE_EXTERNAL_KEY).toLowerCase();
var MAX_GRID = 48;
var BUILD_DETAIL_URL = Platform.Variable.GetValue("@buildDetailUrl") || "";

function esc(s) {
  if (s == null || s === undefined) return "";
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/"/g, "&quot;");
}

function msFromRow(r) {
  var ud = r["updateDate"] != null ? r["updateDate"] : r["UpdateDate"];
  if (ud === null || ud === undefined || ud === "") return 0;
  try {
    if (typeof ud === "object" && ud.getTime) return ud.getTime();
    var p = Platform.Function.ParseDate(ud);
    if (p && p.getTime) return p.getTime();
  } catch (e2) {}
  return 0;
}

function setV(key, val) {
  var s = val == null ? "" : String(val);
  try {
    Platform.Variable.SetValue(key, s);
  } catch (e0) {}
  try {
    Platform.Variable.SetValue("@" + key, s);
  } catch (e1) {}
}

function lenArrayish(x) {
  if (x == null) return -1;
  if (typeof x.length === "number") return x.length;
  return -1;
}

function coerceRows(raw) {
  if (raw == null) return [];
  var r = raw;
  if (r.Results && typeof r.Results.length === "number") r = r.Results;
  var n = lenArrayish(r);
  if (n < 0) return [];
  var out = [];
  var i;
  for (i = 0; i < n; i++) out.push(r[i]);
  return out;
}

try {
  var rows = [];
  var deObj = null;
  try {
    deObj = DataExtension.Init(DE_RETRIEVE_KEY);
    rows = coerceRows(deObj.Rows.Retrieve());
  } catch (ie0) {
    try {
      deObj = DataExtension.Init(DE_EXTERNAL_KEY);
      rows = coerceRows(deObj.Rows.Retrieve());
    } catch (ie1) {}
  }

  if (!rows.length) {
    setV("recentBuildsOk", "true");
    setV("jaEmpty", "1");
    setV("jaRecentBuildsMarkup", "");
    setV("jaBuildsLoadError", "");
  } else {
    rows.sort(function (a, b) {
      return msFromRow(b) - msFromRow(a);
    });

    var nGrid = rows.length > MAX_GRID ? MAX_GRID : rows.length;
    var gx, r, nm, jidv, tp, emn, emid, cr;
    var parts = [];
    for (gx = 0; gx < nGrid; gx++) {
      r = rows[gx];
      nm =
        r["journeyName"] ||
        r["JourneyName"] ||
        r["emailName"] ||
        r["EmailName"] ||
        "Untitled journey";
      jidv =
        r["journeyId"] != null ? String(r["journeyId"]) :
        r["JourneyId"] != null ? String(r["JourneyId"]) :
        r["JourneyID"] != null ? String(r["JourneyID"]) : "";
      tp = r["journeyType"] != null ? String(r["journeyType"]) : "";
      emn = r["emailName"] != null ? String(r["emailName"]) : "";
      emid = r["emailId"] != null ? String(r["emailId"]) : "";
      try {
        var udx = r["updateDate"] != null ? r["updateDate"] : r["UpdateDate"];
        cr = udx ? Platform.Function.FormatDate(udx, "yyyy-MM-dd HH:mm") : "";
      } catch (e3) {
        cr = "";
      }
      var detailHref =
        jidv !== ""
          ? BUILD_DETAIL_URL + "?journeyId=" + encodeURIComponent(jidv)
          : BUILD_DETAIL_URL;
      parts.push(
        '<div class="survey-card">' +
          '<div class="survey-header">' +
          '<div class="survey-icon">📋</div>' +
          '<div class="survey-status status-Active">' +
          esc(tp.length > 28 ? tp.substring(0, 28) + "…" : tp) +
          "</div>" +
          "</div>" +
          '<h3 class="survey-title">' +
          esc(String(nm).length > 20 ? String(nm).substring(0, 20) + "..." : String(nm)) +
          "</h3>" +
          '<div class="survey-meta">' +
          '<span class="survey-id">ID: ' + esc(jidv) + '</span>' +
          '<span class="survey-date">' + esc(cr) + "</span>" +
          "</div>" +
          '<div class="survey-progress">' +
          '<div class="progress-info">' +
          "<span>" + esc(emn || "Email") + "</span>" +
          '<span class="progress-percentage">Asset ' + esc(emid || "—") + "</span>" +
          "</div>" +
          '<div class="progress-bar">' +
          '<div class="progress-fill" style="width:35%;">' +
          "</div>" +
          "</div>" +
          "</div>" +
          '<div class="survey-actions">' +
          '<a href="' +
          detailHref +
          '" class="btn-secondary">Manage build</a>' +
          '<button class="btn-icon" title="More options">' +
          '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>' +
          "</button>" +
          "</div>" +
          "</div>"
      );
    }
    setV("jaRecentBuildsMarkup", parts.join(""));
    setV("jaEmpty", "0");
    setV("recentBuildsOk", "true");
    setV("jaBuildsLoadError", "");
  }
} catch (e) {
  var errMsg = "Could not read recent builds.";
  try {
    errMsg = e.message != null && e.message !== "" ? String(e.message) : String(e);
    if (errMsg.length > 400) errMsg = errMsg.substring(0, 400);
  } catch (err2) {}
  setV("jaBuildsLoadError", errMsg);
  setV("recentBuildsOk", "false");
  setV("jaEmpty", "1");
  setV("jaRecentBuildsMarkup", "");
}

</script>
