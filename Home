// Show/hide no responses message
function toggleNoResponsesMessage(show) {
  let noResultsMsg = document.querySelector('.no-responses-message');
  
  if (show && !noResultsMsg) {
    // Create no results message
    const responsesGrid = document.querySelector('.responses-grid');
    noResultsMsg = document.createElement('div');
    noResultsMsg.className = 'no-responses-message';
    noResultsMsg.innerHTML = `
      <div class="empty-state">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <h3>No activity rows found</h3>
        <p>Adjust your search or clear it to reload the subscriber log demo.</p>
        <button class="btn-primary" onclick="clearResponseSearch()">Clear search</button>
      </div>
    `;
    responsesGrid.appendChild(noResultsMsg);
  } else if (!show && noResultsMsg) {
    noResultsMsg.remove();
  }
}

