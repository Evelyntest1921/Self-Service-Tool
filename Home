  function updateDeployChecklistProgress() {
    var inputs = document.querySelectorAll('.deploy-checklist-input');
    var progressEl = document.getElementById('deployChecklistProgress');
    if (!inputs.length || !progressEl) return;
    var done = 0;
    inputs.forEach(function (input) {
      if (input.checked) done++;
    });
    progressEl.textContent = done + ' of ' + inputs.length + ' complete';
  }
  
  function initDeployChecklist() {
    var inputs = document.querySelectorAll('.deploy-checklist-input');
    if (!inputs.length) return;
    inputs.forEach(function (input) {
      var item = input.closest('.deploy-checklist-item');
      if (item) item.classList.toggle('is-checked', input.checked);
      if (input._deployChecklistBound) return;
      input._deployChecklistBound = true;
      input.addEventListener('change', function () {
        var row = input.closest('.deploy-checklist-item');
        if (row) row.classList.toggle('is-checked', input.checked);
        updateDeployChecklistProgress();
      });
    });
    updateDeployChecklistProgress();
  }
  
  document.addEventListener('DOMContentLoaded', function () {
    initDeployChecklist();
    var resetBtn = document.getElementById('deployChecklistResetBtn');
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        document.querySelectorAll('.deploy-checklist-input').forEach(function (input) {
          input.checked = false;
          var item = input.closest('.deploy-checklist-item');
          if (item) item.classList.remove('is-checked');
        });
        updateDeployChecklistProgress();
      });
    }
  });
  
