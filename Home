SET @envDisplayName = ""
SET @envDisplayEmail = ""
SET @envAvatarLetter = ""
SET @envSwitchLabel = ""
SET @navRows = LookupRows("bd_sst_page_navigation","type","cloudpage")
IF RowCount(@navRows) > 0 THEN
  SET @navRow = Row(@navRows,1)
  SET @hubUrl = Field(@navRow,"ss_home")
  SET @buildDetailUrl = Field(@navRow,"ss_edit")
  SET @emailOnlyUrl = Field(@navRow,"ss_email_only")
  SET @quickSendUrl = Field(@navRow,"ss_quick_send")
  SET @campaignOnlyUrl = Field(@navRow,"ss_campaign_only")
  SET @campaignAutomationUrl = Field(@navRow,"ss_campaign_automation")
  SET @environment = Trim(Lowercase(Field(@navRow,"environment")))
  SET @environmentSwitchUrl = Trim(Field(@navRow,"environment_switch"))
ENDIF
IF @environment == "uat" THEN
  SET @envDisplayName = "UAT"
  SET @envDisplayEmail = "UAT+admin@magmutual.com"
  SET @envAvatarLetter = "U"
  SET @envSwitchLabel = "Switch to production environment"
