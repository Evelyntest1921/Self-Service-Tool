  function splitPipeNumbers(raw) {
    if (!raw) return [];
    return raw.split('|').map(function (v) {
      var n = parseInt(v, 10);
      return isNaN(n) ? 0 : n;
    });
  }

  function getSpecialtyChartData() {
    var canvas = document.getElementById('reportsSpecialtyChart');
    if (canvas) {
      var labelsRaw = canvas.getAttribute('data-labels');
      if (labelsRaw) {
        return {
          labels: labelsRaw.split('|'),
          opened: splitPipeNumbers(canvas.getAttribute('data-opened')),
          didNotOpen: splitPipeNumbers(canvas.getAttribute('data-didnotopen')),
          bounced: splitPipeNumbers(canvas.getAttribute('data-bounced')),
          clicked: splitPipeNumbers(canvas.getAttribute('data-clicked')),
          totals: splitPipeNumbers(canvas.getAttribute('data-totals'))
        };
      }
    }
    var el = document.getElementById('specialtyChartData');
    if (!el) return null;
    var raw = (el.textContent || el.innerText || "").replace(/^\uFEFF/, "").trim();
    if (!raw) return null;
    try {
      return JSON.parse(raw);
    } catch (e) {
      return null;
    }
  }

