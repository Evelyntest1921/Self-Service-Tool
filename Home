  SET @monthClicksOut = ""
  SET @monthUnsubOut = ""
  SET @monthBouncedOut = ""
  SET @browseMode = "0"
  SET @jaBrowseMarkup = ""
  SET @jaBrowsePagination = ""
  SET @jaBuildsPagination = ""
