  VAR @addJourneyId, @addJourneyName
  VAR @authRow, @authStatus, @authUrl, @authPayload, @authResponse, @authResponseHeader, @tokenPattern, @accountId, @clientId, @clientSecret, @subdomain, @accessToken
  SET @sendLogChartJson = ""
