  SET @envDisplayName = "PROD"
  SET @envDisplayEmail = "admin@magmutual.com"
  SET @envAvatarLetter = "P"
  SET @envSwitchLabel = "Switch to UAT environment"
ENDIF

IF @redirect == "true" THEN
  Redirect(@hubUrl)
ENDIF

