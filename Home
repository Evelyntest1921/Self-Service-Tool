  let homeSpecialtyChart = null;
  let homeOpenClickChart = null;

  function getSendLogChartData() {
    var el = document.getElementById('activityChartData');
    if (!el) return null;
    try {
      return JSON.parse(el.textContent);
    } catch (e) {
      return null;
    }
  }

  function getActivePeriod(scope) {
    var root = scope || document;
    var activeBtn = root.querySelector('.activity-filter.active');
    return activeBtn ? activeBtn.getAttribute('data-period') : '12months';
  }

  function renderEngagementTrendChart(canvasId, periodData) {
    var canvas = document.getElementById(canvasId);
    if (!canvas || typeof Chart === 'undefined') return;

    if (homeEngagementCharts[canvasId]) {
      homeEngagementCharts[canvasId].destroy();
      homeEngagementCharts[canvasId] = null;
    }

