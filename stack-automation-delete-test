<script runat="server">
/*
  Automation delete test — WSProxy deleteItem("Automation", …)
  Paste into an Automation Studio Script Activity only (pure SSJS).

  Per Stack Exchange, delete works from Script Activity, not CloudPages:
  https://salesforce.stackexchange.com/questions/75711/how-can-an-automation-be-deleted-using-exacttarget-soap-api/262131

  1. Create or pick a throwaway automation.
  2. Set TEST_OBJECT_ID and/or TEST_CUSTOMER_KEY below.
  3. Run with DRY_RUN = true first (lookup only).
  4. Set DRY_RUN = false to attempt deleteItem.
  5. Read output in the Script Activity log.
*/
Platform.Load("core", "1");

var TEST_OBJECT_ID = "";
var TEST_CUSTOMER_KEY = "";
var DRY_RUN = true;

var resultLines = [];
var debugLines = [];

function strTrim(v) {
  return v === null || v === undefined ? "" : String(v).replace(/^\s+|\s+$/g, "");
}

function soapDeleteStatus(result) {
  if (!result || !result.Results || !result.Results.length) {
    return { ok: false, detail: "deleteItem returned no Results." };
  }
  var row = result.Results[0];
  var status = row.Status ? String(row.Status) : "";
  var statusCode = row.StatusCode ? String(row.StatusCode) : "";
  var statusMsg = row.StatusMessage ? String(row.StatusMessage) : "";
  var errMsg = row.ErrorMessage ? String(row.ErrorMessage) : "";
  if (status === "OK" || statusCode === "OK") {
    return { ok: true, detail: statusMsg || "OK" };
  }
  var successText = (statusMsg + " " + errMsg).toLowerCase();
  if (
    successText.indexOf("deleted") >= 0 &&
    successText.indexOf("denied") < 0 &&
    successText.indexOf("could not find") < 0 &&
    successText.indexOf("error") < 0
  ) {
    return { ok: true, detail: statusMsg || errMsg || "deleted" };
  }
  return {
    ok: false,
    detail: errMsg || statusMsg || row.ErrorCode || status || "deleteItem did not report OK."
  };
}

function formatAutomationRow(row) {
  if (!row) {
    return "(not found)";
  }
  return [
    "ObjectID=" + (row.ObjectID || ""),
    "ProgramID=" + (row.ProgramID || ""),
    "CustomerKey=" + (row.CustomerKey || ""),
    "Name=" + (row.Name || ""),
    "Status=" + (row.Status !== undefined && row.Status !== null ? row.Status : ""),
    "IsActive=" + (row.IsActive !== undefined && row.IsActive !== null ? row.IsActive : "")
  ].join(" | ");
}

function getAutomationById(prox, objectId) {
  var id = String(objectId);
  var resp = prox.retrieve(
    "Automation",
    ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
    { Property: "ObjectID", SimpleOperator: "equals", Value: id }
  );
  if (resp && resp.Results && resp.Results.length > 0) {
    return resp.Results[0];
  }
  resp = prox.retrieve(
    "Automation",
    ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
    { Property: "ProgramID", SimpleOperator: "equals", Value: id }
  );
  if (resp && resp.Results && resp.Results.length > 0) {
    return resp.Results[0];
  }
  return null;
}

function resolveAutomationObjectId(prox, customerKey, objectIdHint) {
  var key = strTrim(customerKey);
  if (key && prox) {
    var byKey = prox.retrieve(
      "Automation",
      ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
      { Property: "CustomerKey", SimpleOperator: "equals", Value: key }
    );
    if (byKey && byKey.Results && byKey.Results.length > 0) {
      if (byKey.Results[0].ObjectID) {
        return { row: byKey.Results[0], resolvedId: String(byKey.Results[0].ObjectID) };
      }
      if (byKey.Results[0].ProgramID) {
        return { row: byKey.Results[0], resolvedId: String(byKey.Results[0].ProgramID) };
      }
    }
  }
  var hint = strTrim(objectIdHint);
  if (hint && prox) {
    var byObj = getAutomationById(prox, hint);
    if (byObj) {
      return {
        row: byObj,
        resolvedId: String(byObj.ObjectID || byObj.ProgramID || hint)
      };
    }
    var byProgram = prox.retrieve(
      "Automation",
      ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
      { Property: "ProgramID", SimpleOperator: "equals", Value: hint }
    );
    if (byProgram && byProgram.Results && byProgram.Results.length > 0) {
      var progRow = byProgram.Results[0];
      return {
        row: progRow,
        resolvedId: String(progRow.ObjectID || progRow.ProgramID || hint)
      };
    }
  }
  return { row: null, resolvedId: "" };
}

function tryDeleteAutomation(prox, resolvedId, customerKey) {
  var errors = [];
  if (resolvedId) {
    try {
      var byObj = prox.deleteItem("Automation", { ObjectID: resolvedId });
      var objStatus = soapDeleteStatus(byObj);
      if (objStatus.ok) {
        return { ok: true, msg: "DELETE OK (ObjectID " + resolvedId + ")." };
      }
      errors.push("ObjectID " + objStatus.detail);
    } catch (objEx) {
      errors.push("ObjectID " + (objEx.message || String(objEx)));
    }
  }
  var key = strTrim(customerKey);
  if (key) {
    try {
      var proxKey = new Script.Util.WSProxy();
      var byKey = proxKey.deleteItem("Automation", { CustomerKey: key });
      var keyStatus = soapDeleteStatus(byKey);
      if (keyStatus.ok) {
        return { ok: true, msg: "DELETE OK (CustomerKey " + key + ")." };
      }
      errors.push("CustomerKey " + keyStatus.detail);
    } catch (keyEx) {
      errors.push("CustomerKey " + (keyEx.message || String(keyEx)));
    }
  }
  if (errors.length) {
    return { ok: false, msg: errors.join(" | ") };
  }
  return { ok: false, msg: "No ObjectID or CustomerKey to delete." };
}

var objectId = strTrim(TEST_OBJECT_ID);
var customerKey = strTrim(TEST_CUSTOMER_KEY);
var dryRun = DRY_RUN === true;

if (!objectId && !customerKey) {
  resultLines.push("Set TEST_OBJECT_ID and/or TEST_CUSTOMER_KEY at the top of this script.");
} else {
  try {
    var prox = new Script.Util.WSProxy();
    var resolved = resolveAutomationObjectId(prox, customerKey, objectId);
    var resolvedId = resolved.resolvedId;
    var beforeRow = resolved.row;

    resultLines.push("DRY_RUN: " + (dryRun ? "true (lookup only)" : "false (will delete)"));
    debugLines.push("Lookup: " + formatAutomationRow(beforeRow));
    debugLines.push("Resolved delete id: " + (resolvedId || "(none)"));

    if (!beforeRow) {
      resultLines.push("Automation NOT FOUND for supplied ObjectID/CustomerKey.");
    } else if (dryRun) {
      resultLines.push("Lookup OK. Set DRY_RUN = false to attempt deleteItem.");
    } else {
      var delResult = tryDeleteAutomation(prox, resolvedId, customerKey);
      if (delResult.ok) {
        resultLines.push(delResult.msg);
        var afterRow = resolvedId ? getAutomationById(prox, resolvedId) : null;
        debugLines.push("After delete lookup: " + formatAutomationRow(afterRow));
      } else {
        resultLines.push("DELETE FAILED — " + delResult.msg);
      }
    }
  } catch (runEx) {
    resultLines.push("ERROR: " + (runEx.message || String(runEx)));
  }
}

var output = resultLines.join("\n");
if (debugLines.length) {
  output += "\n\n" + debugLines.join("\n");
}
Write(output);
</script>
