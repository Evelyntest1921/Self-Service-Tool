<script runat="server">
/*
  bd_sst_automation_purge worker — Automation Studio Script Activity only.

  Reads rows from bd_sst_automation_purge (customerKey, automationName),
  deletes each automation via WSProxy.deleteItem, removes the queue row on success,
  and logs each run to test_log.

  Schedule this automation to run on a short interval (e.g. every 15 minutes).
  edit-build queues automations here during stack build purge (CloudPage cannot delete).
*/
Platform.Load("core", "1");

var PURGE_QUEUE_DE = "bd_sst_automation_purge";
var LOG_DE = "test_log";
var LOG_FIELD = "log";
var LOG_MAX_LEN = 4000;

var resultLines = [];
var debugLines = [];

function strTrim(v) {
  return v === null || v === undefined ? "" : String(v).replace(/^\s+|\s+$/g, "");
}

function writeTestLog(text) {
  var msg = text === null || text === undefined ? "" : String(text);
  if (msg.length > LOG_MAX_LEN) {
    msg = msg.substring(0, LOG_MAX_LEN - 3) + "...";
  }
  try {
    Platform.Function.InsertData(LOG_DE, [LOG_FIELD], [msg]);
    return { ok: true };
  } catch (logEx) {
    return { ok: false, error: logEx.message || String(logEx) };
  }
}

function soapDeleteStatus(result) {
  if (!result || !result.Results || !result.Results.length) {
    return { ok: false, detail: "deleteItem returned no Results." };
  }
  var row = result.Results[0];
  var status = row.Status ? String(row.Status) : "";
  var statusCode = row.StatusCode ? String(row.StatusCode) : "";
  var statusMsg = row.StatusMessage ? String(row.StatusMessage) : "";
  var errMsg = row.ErrorMessage ? String(row.ErrorMessage) : "";
  if (status === "OK" || statusCode === "OK") {
    return { ok: true, detail: statusMsg || "OK" };
  }
  var successText = (statusMsg + " " + errMsg).toLowerCase();
  if (
    successText.indexOf("deleted") >= 0 &&
    successText.indexOf("denied") < 0 &&
    successText.indexOf("could not find") < 0 &&
    successText.indexOf("error") < 0
  ) {
    return { ok: true, detail: statusMsg || errMsg || "deleted" };
  }
  return {
    ok: false,
    detail: errMsg || statusMsg || row.ErrorCode || status || "deleteItem did not report OK."
  };
}

function fetchPurgeQueueRows() {
  var de = DataExtension.Init(PURGE_QUEUE_DE);
  var rows = de.Rows.Retrieve(["customerKey", "automationName"]);
  if (!rows || !rows.length) {
    return [];
  }
  var out = [];
  for (var i = 0; i < rows.length; i++) {
    out.push({
      customerKey: rows[i].customerKey ? String(rows[i].customerKey) : "",
      automationName: rows[i].automationName ? String(rows[i].automationName) : ""
    });
  }
  return out;
}

function removePurgeQueueRow(customerKey, automationName) {
  var key = strTrim(customerKey);
  var name = strTrim(automationName);
  try {
    if (key) {
      Platform.Function.DeleteData(PURGE_QUEUE_DE, ["customerKey"], [key]);
      return { ok: true };
    }
    if (name) {
      Platform.Function.DeleteData(PURGE_QUEUE_DE, ["automationName"], [name]);
      return { ok: true };
    }
    return { ok: false, error: "No customerKey or automationName for row removal." };
  } catch (delEx) {
    return { ok: false, error: delEx.message || String(delEx) };
  }
}

function getAutomationById(prox, objectId) {
  var id = String(objectId);
  var resp = prox.retrieve(
    "Automation",
    ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
    { Property: "ObjectID", SimpleOperator: "equals", Value: id }
  );
  if (resp && resp.Results && resp.Results.length > 0) {
    return resp.Results[0];
  }
  resp = prox.retrieve(
    "Automation",
    ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
    { Property: "ProgramID", SimpleOperator: "equals", Value: id }
  );
  if (resp && resp.Results && resp.Results.length > 0) {
    return resp.Results[0];
  }
  return null;
}

function resolveAutomationForPurge(prox, customerKey, automationName) {
  var key = strTrim(customerKey);
  if (key) {
    var byKey = prox.retrieve(
      "Automation",
      ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
      { Property: "CustomerKey", SimpleOperator: "equals", Value: key }
    );
    if (byKey && byKey.Results && byKey.Results.length > 0) {
      var row = byKey.Results[0];
      return {
        row: row,
        resolvedId: String(row.ObjectID || row.ProgramID || ""),
        deleteKey: key
      };
    }
  }
  var name = strTrim(automationName);
  if (name) {
    var byName = prox.retrieve(
      "Automation",
      ["ObjectID", "ProgramID", "CustomerKey", "Name", "Status", "IsActive"],
      { Property: "Name", SimpleOperator: "equals", Value: name }
    );
    if (byName && byName.Results && byName.Results.length > 0) {
      var nameRow = byName.Results[0];
      return {
        row: nameRow,
        resolvedId: String(nameRow.ObjectID || nameRow.ProgramID || ""),
        deleteKey: strTrim(nameRow.CustomerKey || key)
      };
    }
  }
  return { row: null, resolvedId: "", deleteKey: key };
}

function tryDeleteAutomation(prox, resolvedId, customerKey) {
  var errors = [];
  if (resolvedId) {
    try {
      var byObj = prox.deleteItem("Automation", { ObjectID: resolvedId });
      var objStatus = soapDeleteStatus(byObj);
      if (objStatus.ok) {
        return { ok: true, msg: "DELETE OK (ObjectID " + resolvedId + ")." };
      }
      errors.push("ObjectID " + objStatus.detail);
    } catch (objEx) {
      errors.push("ObjectID " + (objEx.message || String(objEx)));
    }
  }
  var key = strTrim(customerKey);
  if (key) {
    try {
      var proxKey = new Script.Util.WSProxy();
      var byKey = proxKey.deleteItem("Automation", { CustomerKey: key });
      var keyStatus = soapDeleteStatus(byKey);
      if (keyStatus.ok) {
        return { ok: true, msg: "DELETE OK (CustomerKey " + key + ")." };
      }
      errors.push("CustomerKey " + keyStatus.detail);
    } catch (keyEx) {
      errors.push("CustomerKey " + (keyEx.message || String(keyEx)));
    }
  }
  if (errors.length) {
    return { ok: false, msg: errors.join(" | ") };
  }
  return { ok: false, msg: "No ObjectID or CustomerKey to delete." };
}

function processQueueRow(prox, queueRow) {
  var customerKey = strTrim(queueRow.customerKey);
  var automationName = strTrim(queueRow.automationName);
  var label =
    (customerKey || "(no key)") + " / " + (automationName || "(no name)");

  if (!customerKey && !automationName) {
    return label + " — SKIP empty row.";
  }

  var resolved = resolveAutomationForPurge(prox, customerKey, automationName);
  if (!resolved.row) {
    var staleRemove = removePurgeQueueRow(customerKey, automationName);
    if (staleRemove.ok) {
      return label + " — NOT FOUND, queue row removed.";
    }
    return (
      label +
      " — NOT FOUND, queue row remove FAILED: " +
      (staleRemove.error || "unknown")
    );
  }

  var delResult = tryDeleteAutomation(prox, resolved.resolvedId, resolved.deleteKey);
  if (!delResult.ok) {
    return label + " — DELETE FAILED: " + delResult.msg;
  }

  var rowRemove = removePurgeQueueRow(customerKey, automationName);
  if (!rowRemove.ok) {
    return (
      label +
      " — " +
      delResult.msg +
      " Queue row remove FAILED: " +
      (rowRemove.error || "unknown")
    );
  }
  return label + " — " + delResult.msg + " Queue row removed.";
}

try {
  var queueRows = fetchPurgeQueueRows();
  resultLines.push(
    "bd_sst_automation_purge worker — " + queueRows.length + " row(s)."
  );
  if (!queueRows.length) {
    resultLines.push("No queued automations.");
  } else {
    var prox = new Script.Util.WSProxy();
    for (var q = 0; q < queueRows.length; q++) {
      debugLines.push(processQueueRow(prox, queueRows[q]));
    }
  }
} catch (runEx) {
  resultLines.push("ERROR: " + (runEx.message || String(runEx)));
}

var output = resultLines.join("\n");
if (debugLines.length) {
  output += "\n\n" + debugLines.join("\n");
}

var logResult = writeTestLog(output);
if (!logResult.ok) {
  output += "\n\n[test_log insert FAILED] " + logResult.error;
}
Write(output);
</script>
