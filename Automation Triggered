<script runat="server">
var cleanupNeeded = Variable.GetValue("cleanupNeeded");
var eventDefId = Variable.GetValue("eventDefId");
var newEmailId = Variable.GetValue("newEmailId");
var subdomain = Variable.GetValue("subdomain");
var accessToken = Variable.GetValue("accessToken");
var resultText = Variable.GetValue("resultText");
if (cleanupNeeded == "1" && (eventDefId || newEmailId) && subdomain && accessToken) {
 var cleanupLog = "";
 if (eventDefId) {
 try {
   var eventName = Variable.GetValue("eventName");
   var getEventUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" + eventDefId;
   var getReq = new Script.Util.HttpRequest(getEventUrl);
   getReq.emptyContentHandling = 0;
   getReq.continueOnError = true;
   getReq.setHeader("Authorization", "Bearer " + accessToken);
   getReq.method = "GET";
   var getResp = getReq.send();
   var dataExtensionId = null;
   if ((getResp.statusCode == 200 || getResp.statusCode == 201) && getResp.content) {
     var eventObj = Platform.Function.ParseJSON(String(getResp.content));
     dataExtensionId = eventObj.dataExtensionId || eventObj.dataExtensionID || null;
   }
   var eventDeleteUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" + eventDefId;
   var eventReq = new Script.Util.HttpRequest(eventDeleteUrl);
   eventReq.emptyContentHandling = 0;
   eventReq.continueOnError = true;
   eventReq.setHeader("Authorization", "Bearer " + accessToken);
   eventReq.method = "DELETE";
   var eventResp = eventReq.send();
   if (eventResp.statusCode == 200 || eventResp.statusCode == 204) {
     cleanupLog = " Event definition deleted.";
   } else {
     cleanupLog = " Event delete HTTP " + eventResp.statusCode + ".";
   }
   if (dataExtensionId || eventName) {
     try {
       var deObjId = dataExtensionId;
       if (!deObjId && eventName) {
         var prox2 = new Script.Util.WSProxy();
         var deFilter = { Property: "Name", SimpleOperator: "equals", Value: eventName };
         var retrieveReq = prox2.retrieve("DataExtension", ["ObjectID"], deFilter);
         if (retrieveReq && retrieveReq.Results && retrieveReq.Results.length > 0 && retrieveReq.Results[0].ObjectID) {
           deObjId = retrieveReq.Results[0].ObjectID;
         }
       }
       if (deObjId) {
         var prox = new Script.Util.WSProxy();
         var deResult = prox.deleteItem("DataExtension", { "ObjectID": deObjId });
         if (deResult && deResult.Results && deResult.Results.length > 0 && deResult.Results[0].Status == "OK") {
           cleanupLog = cleanupLog + " Data extension deleted.";
         } else {
           cleanupLog = cleanupLog + " DE delete failed.";
         }
       }
     } catch (deEx) {
       cleanupLog = cleanupLog + " DE delete failed - " + (deEx.message || String(deEx));
     }
   }
 } catch (e) {
   cleanupLog = cleanupLog + " Cleanup failed - " + (e.message || String(e));
 }
 }
 if (newEmailId) {
 try {
   var assetDeleteUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + newEmailId;
   var assetReq = new Script.Util.HttpRequest(assetDeleteUrl);
