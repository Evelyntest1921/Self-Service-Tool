<script runat="server">
Platform.Load("core","1");

function stackEventSchemaFields() {
  return [
    { name: "ContactId", dataType: "Text", maxLength: "50", isNullable: true },
    { name: "Email", dataType: "EmailAddress", maxLength: "254", isNullable: true },
    { name: "CampaignId", dataType: "Text", maxLength: "50", isNullable: true },
    { name: "AccountId", dataType: "Text", maxLength: "50", isNullable: true },
    { name: "Account_Owner_Name", dataType: "Text", maxLength: "50", isNullable: true },
    { name: "Account_Owner_Email", dataType: "Text", maxLength: "254", isNullable: true },
    { name: "MemberId", dataType: "Text", maxLength: "50", isNullable: true },
    { name: "Status", dataType: "Text", maxLength: "50", isNullable: true },
    { name: "State", dataType: "Text", maxLength: "50", isNullable: true },
    { name: "AccountOwnerId", dataType: "Text", maxLength: "50", isNullable: true }
  ];
}

function stackRetrieveDeByFilter(prox, filter) {
  var resp = prox.retrieve("DataExtension", ["ObjectID", "CustomerKey", "Name"], filter);
  if (resp && resp.Results && resp.Results.length > 0 && resp.Results[0].ObjectID) {
    return {
      objectId: String(resp.Results[0].ObjectID),
      customerKey: String(resp.Results[0].CustomerKey || ""),
      name: String(resp.Results[0].Name || "")
    };
  }
  return null;
}
function stackResolveExistingDe(prox, customerKey, deName) {
  var byKey = customerKey
    ? stackRetrieveDeByFilter(prox, {
        Property: "CustomerKey",
        SimpleOperator: "equals",
        Value: String(customerKey)
      })
    : null;
  if (byKey) {
    return byKey;
  }
  if (deName) {
    return stackRetrieveDeByFilter(prox, {
      Property: "Name",
      SimpleOperator: "equals",
      Value: String(deName)
    });
  }
  return null;
}

function stackParseJsonSafe(text) {
  try {
    return Platform.Function.ParseJSON(String(text || ""));
  } catch (e0) {
    return null;
  }
}

function stackMapSchemaFieldToSoap(fieldDef) {
  var name = fieldDef.name;
  var fieldType = "Text";
  if (fieldDef.dataType === "EmailAddress") {
   fieldType = "EmailAddress";
  } else if (fieldDef.dataType === "Date") {
   fieldType = "Date";
  }
  var soapField = {
   Name: name,
   FieldType: fieldType,
   IsNillable: true,
   IsRequired: false
  };
  if (fieldDef.maxLength) {
   soapField.MaxLength = parseInt(String(fieldDef.maxLength), 10);
  }
  if (name === "MemberId") {
   soapField.IsPrimaryKey = true;
   soapField.IsRequired = true;
   soapField.IsNillable = false;
  } else if (name === "ContactId") {
   soapField.IsRequired = true;
   soapField.IsNillable = false;
  }
  return soapField;
}


function stackExpectedFieldNames() {
  var schema = stackEventSchemaFields();
  var expected = {};
  var i;
  for (i = 0; i < schema.length; i++) {
   expected[String(schema[i].name).toLowerCase()] = schema[i].name;
  }
  return expected;
}


function stackNormalizeWsRows(results) {
  var rows = [];
  if (!results) {
   return rows;
  }
  if (typeof results.length === "number") {
   var i;
   for (i = 0; i < results.length; i++) {
    rows.push(results[i]);
   }
   return rows;
  }
  if (results.Name || results.ObjectID || results.CustomerKey) {
   rows.push(results);
  }
  return rows;
}


function stackGetDeFieldNames(prox, customerKey) {
  var names = {};
  try {
   var resp = prox.retrieve("DataExtensionField", ["Name"], {
    Property: "DataExtension.CustomerKey",
    SimpleOperator: "equals",
    Value: String(customerKey)
   });
   var rows = stackNormalizeWsRows(resp && resp.Results ? resp.Results : null);
   var i;
   for (i = 0; i < rows.length; i++) {
    if (rows[i] && rows[i].Name) {
     names[String(rows[i].Name).toLowerCase()] = String(rows[i].Name);
    }
   }
  } catch (fieldEx) {}
  return names;
}


function stackValidateDeSchema(prox, customerKey) {
  var actual = stackGetDeFieldNames(prox, customerKey);
  var expected = stackExpectedFieldNames();
  var missing = [];
  var extra = [];
  var name;
  var actualCount = 0;
  for (name in actual) {
   if (actual.hasOwnProperty(name)) {
    actualCount++;
   }
  }
  if (actualCount === 0) {
   return {
    ok: false,
    message:
     "Could not read entry DE fields for CustomerKey=" +
     String(customerKey) +
     "."
   };
  }
  for (name in expected) {
   if (expected.hasOwnProperty(name) && !actual[name]) {
    missing.push(expected[name]);
   }
  }
  for (name in actual) {
   if (actual.hasOwnProperty(name) && !expected[name]) {
    extra.push(actual[name]);
   }
  }
  if (missing.length > 0 || extra.length > 0) {
   var parts = [];
   if (missing.length > 0) {
    parts.push("missing " + missing.join(", "));
   }
   if (extra.length > 0) {
    parts.push("legacy " + extra.join(", "));
   }
   return {
    ok: false,
    message:
     "Entry DE schema mismatch (" +
     parts.join("; ") +
     "). Delete the existing DE or use a new build name."
   };
  }
  return { ok: true };
}


function stackEventSchemaFieldOrder() {
  var schema = stackEventSchemaFields();
  var order = [];
  var i;
  for (i = 0; i < schema.length; i++) {
   if (schema[i].name === "MemberId") {
    order.push(schema[i].name);
   }
  }
  for (i = 0; i < schema.length; i++) {
   if (schema[i].name !== "MemberId") {
    order.push(schema[i].name);
   }
  }
  return order;
}


function stackBuildSoapDeFields() {
  var order = stackEventSchemaFieldOrder();
  var schema = stackEventSchemaFields();
  var byName = {};
  var fields = [];
  var i;
  for (i = 0; i < schema.length; i++) {
   byName[schema[i].name] = schema[i];
  }
  for (i = 0; i < order.length; i++) {
   if (byName[order[i]]) {
    fields.push(stackMapSchemaFieldToSoap(byName[order[i]]));
   }
  }
  return fields;
}


function stackResolveDeCategoryId(prox) {
 var categoryId = 0;
 try {
  var rows = Platform.Function.LookupRows(
   "Bd_journey_analytics",
   "journeyType",
   "Journey + Automation"
  );
  if (rows && rows.length > 0) {
   var ri;
   for (ri = 0; ri < rows.length; ri++) {
    var deKey = rows[ri].deId;
    if (!deKey) {
     continue;
    }
    deKey = String(deKey);
    if (deKey.toUpperCase() === "N/A") {
     continue;
    }
    var rde = prox.retrieve(
     "DataExtension",
     ["CategoryID"],
     {
      Property: "CustomerKey",
      SimpleOperator: "equals",
      Value: deKey
     }
    );
    if (
     rde &&
     rde.Results &&
     rde.Results.length > 0 &&
     rde.Results[0].CategoryID !== null &&
     rde.Results[0].CategoryID !== undefined
    ) {
     categoryId = parseInt(String(rde.Results[0].CategoryID), 10);
     if (!isNaN(categoryId) && categoryId > 0) {
      return categoryId;
     }
    }
   }
  }
 } catch (lookupEx) {}

 try {
  var folders = prox.retrieve(
   "DataFolder",
   ["ID", "Name", "ContentType"],
   {
    Property: "ContentType",
    SimpleOperator: "equals",
    Value: "dataextension"
   }
  );
  if (folders && folders.Results && folders.Results.length > 0) {
   var fi;
   for (fi = 0; fi < folders.Results.length; fi++) {
    var fname = String(folders.Results[fi].Name || "");
    if (fname === "Data Extensions") {
     categoryId = parseInt(String(folders.Results[fi].ID), 10);
     if (!isNaN(categoryId) && categoryId > 0) {
      return categoryId;
     }
    }
   }
   categoryId = parseInt(String(folders.Results[0].ID), 10);
   if (!isNaN(categoryId) && categoryId > 0) {
    return categoryId;
   }
  }
 } catch (folderEx) {}

 return 0;
}


function stackCreateEntryDeViaSoap(prox, customerKey, deName) {
  var ck = String(customerKey || "");
  var name = String(deName || ck || "Entry DE");
  if (!ck) {
   return { ok: false, message: "Entry DE CustomerKey is required." };
  }
  var categoryId = stackResolveDeCategoryId(prox);
  var deConfig = {
   Name: name,
   CustomerKey: ck,
   Description: "Stack entry DE created via Journey Maker",
   Fields: stackBuildSoapDeFields(),
   IsSendable: true,
   IsTestable: true,
   SendableDataExtensionField: {
    Name: "ContactId",
    FieldType: "Text"
   },
   SendableSubscriberField: {
    Name: "Subscriber Key"
   }
  };
  if (categoryId > 0) {
   deConfig.CategoryID = categoryId;
  }
  var createResp = null;
  try {
   createResp = prox.createItem("DataExtension", deConfig);
  } catch (createEx) {
   return {
    ok: false,
    message:
     "Entry DE SOAP create threw: " + (createEx.message || String(createEx))
   };
  }
  var createRows = stackNormalizeWsRows(createResp && createResp.Results ? createResp.Results : null);
  var status =
   createResp && createResp.Status ? String(createResp.Status) : "UNKNOWN";
  var msg =
   createRows.length > 0 && createRows[0].StatusMessage
    ? String(createRows[0].StatusMessage)
    : "No status message returned.";
  if (status !== "OK") {
   return {
    ok: false,
    message: "Entry DE SOAP create failed. " + msg
   };
  }
  var objectId = "";
  if (createRows.length > 0) {
   var row = createRows[0];
   objectId = row.ObjectID
    ? String(row.ObjectID)
    : row.NewObjectID
    ? String(row.NewObjectID)
    : row.NewID
    ? String(row.NewID)
    : "";
  }
  if (!objectId) {
   var resolved = stackResolveExistingDe(prox, ck, name);
   if (resolved && resolved.objectId) {
    objectId = resolved.objectId;
   }
  }
  if (!objectId) {
   return {
    ok: false,
    message:
     "Entry DE created but ObjectID was not returned. CustomerKey=" + ck + "."
   };
  }
  var verified = stackRetrieveDeByFilter(prox, {
   Property: "ObjectID",
   SimpleOperator: "equals",
   Value: objectId
  });
  if (!verified || !verified.customerKey) {
   verified = stackResolveExistingDe(prox, ck, name);
  }
  if (!verified || !verified.customerKey) {
   return {
    ok: false,
    message:
     "Entry DE created but CustomerKey could not be verified. ObjectID=" +
     objectId +
     "."
   };
  }
  var keyNote =
   verified.customerKey !== ck
    ? " Actual CustomerKey=" +
      verified.customerKey +
      " (requested " +
      ck +
      ")."
    : "";
  return {
   ok: true,
   objectId: verified.objectId || objectId,
   customerKey: verified.customerKey,
   name: verified.name || name,
   message: keyNote + " MemberId is primary key; ContactId is sendable contact key."
  };
}


function stackEnsureEntryDe(prox, token, subdomain, customerKey, deName) {
  var name = String(deName || customerKey || "Entry DE");
  var existing = stackResolveExistingDe(prox, customerKey, name);
  if (existing) {
   var repairKey = existing.customerKey || String(customerKey || "");
   var schemaCheck = stackValidateDeSchema(prox, repairKey);
   if (!schemaCheck.ok) {
    return { ok: false, message: schemaCheck.message };
   }
   return {
    ok: true,
    skipped: true,
    objectId: existing.objectId,
    customerKey: repairKey,
    name: existing.name || name,
    message: ""
   };
  }

  var created = stackCreateEntryDeViaSoap(prox, customerKey, name);
  if (!created.ok) {
   return created;
  }
  return {
   ok: true,
   skipped: false,
   objectId: created.objectId,
   customerKey: created.customerKey,
   name: created.name,
   message: created.message || ""
  };
}


function stackHttpJson(token, subdomain, method, url, bodyObj) {
  var req = new Script.Util.HttpRequest(url);
  req.emptyContentHandling = 0;
  req.retries = 1;
