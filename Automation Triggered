.maker-btn--danger:hover { background: #fef2f2; border-color: #f87171; }
.maker-result-log {
  margin-top: 12px;
  padding: 14px 16px;
  background: #1e1e1e;
  color: #d4d4d4;
  font-size: 0.8125rem;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  white-space: pre-wrap;
  word-break: break-word;
  border-radius: var(--radius-md);
  max-height: 280px;
  overflow-y: auto;
  display: none;
}
.maker-result-log.is-visible { display: block; margin-top: 20px; }

.maker-alert {
  width: 100%;
  padding: 12px 16px;
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: var(--radius-md);
  color: #991b1b;
  font-size: 0.9375rem;
  line-height: 1.5;
}

.survey-header { background: transparent; color: inherit; padding: 0; text-align: start; margin: 0; }
.logo { margin: 0 0 20px 0; border-bottom: 1px solid #e5e7eb; padding-bottom: 16px; }
.logo img { height: 40px; }
.survey-title { font-size: 1.875rem; font-weight: 700; margin-bottom: 8px; }
.question-card { padding: 24px; margin-bottom: 0; }
.question-header {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
  padding-top: 24px;
  border-top: 1px solid #e5e7eb;
}
.question-header:first-of-type {
  padding-top: 8px;
  border-top: none;
}
.question-number { color: black; width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 600; margin-right: 16px; flex-shrink: 0; border: 1px solid #0000001a;}
.question-text { font-size: 1.125rem; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
.form-group { margin-bottom: 16px; }
.select-control, .textarea-control { width: 100%; padding: 12px 16px; border: 1px solid var(--border-color); border-radius: 0px); font-size: 1rem; background: var(--bg-primary); transition: all 0.2s ease; font-family: inherit; }
.select-control:focus, .textarea-control:focus { outline: none; border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1); }
.submit-section { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border-color); }
.submit-button { background: #0e0e1d; color: white; border: none; padding: 16px 32px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.submit-button:hover { background: var(--primary-dark); transform: translateY(-1px); box-shadow: var(--shadow-md); }
.submit-button:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.spinner { border: 2px solid rgba(255,255,255,0.3); border-top: 2px solid white; border-radius: 50%; width: 20px; height: 20px; animation: spin 1s linear infinite; display: inline-block; margin-left: 8px; vertical-align: middle; }
.email-cards { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 24px; }
.email-card {
  flex: 1;
  min-width: 180px;
  max-width: 280px;
  position: relative;
  border: 1px solid var(--border-color);
  cursor: pointer;
  transition: all 0.2s ease;
  background: var(--bg-secondary);
  text-align: left;
  overflow: hidden;
  display: block;
  box-sizing: border-box;
  padding: 0;
}
.email-card:hover { border-color: var(--primary-color); box-shadow: var(--shadow-md); }
.email-card.selected { border: 2px solid #53575a; }
.email-card input { display: none; }
.email-card-img {
  width: 100%;
  height: auto;
  display: block;
}
.email-card-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 22px;
  padding: 0 10px;
  font-size: 0.8125rem;
  font-weight: 700;
  color: #484848;
  line-height: 1.2;
  z-index: 2;
}
.email-card-id {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 6px;
  padding: 0 10px;
  font-size: 0.6875rem;
  color: #363232eb;
  z-index: 2;
}
.email-card::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 156px;
  background: linear-gradient(to top, rgb(255 255 255), #fcfeff);
  pointer-events: none;
  z-index: 1;
}
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
@media (max-width: 768px) {
  body { padding: 0; }
  .survey-title { font-size: 1.5rem; }
  .maker-sidebar {
    width: 100%;
    flex-direction: row;
    overflow-x: auto;
    align-items: center;
    min-height: 0;
  }
  .maker-sidebar .sidebar-logo { margin-bottom: 0; flex-shrink: 0; padding-right: 16px; }
  .maker-sidebar .sidebar-nav { display: flex; flex-direction: row; gap: 4px; padding: 8px 0; flex: 1; flex-wrap: nowrap; }
  .maker-sidebar .nav-section-title { display: none; }
  .maker-sidebar .nav-link { white-space: nowrap; padding: 8px 16px; border-right: none; border-radius: 8px; }
  .dashboard-layout { flex-direction: column; height: auto; overflow: visible; }
  .maker-sidebar { height: auto; overflow: visible; }
  .maker-main { height: auto; overflow: visible; }
  .maker-main-inner { overflow: visible; padding: 16px !important; }
  .maker-main-footer { padding: 14px 16px; }
}
</style>
</head>
<body>
<div class="dashboard-layout">
  <aside class="maker-sidebar sidebar" aria-label="Primary">
    <div class="sidebar-logo">
      <a href="%%=v(@hubUrl)=%%"><img src="https://www.magmutual.com/_next/image?url=%2Fmagmutual-egg.svg&w=640&q=75" alt="MagMutual" style="filter: invert(1);"></a>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section"><span class="nav-section-title">MENU</span></div>
      <span class="nav-link active" role="presentation">
        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 17h2v-5H3v5zm8 5h2V6h-2v16zM13 9h8V7h-8v2zM3 5v4h14V5H3zm8 14h10v-2H11v2zM13 17h8v-2h-8v2z"/></svg>
        %%=v(@builderPageLabel)=%%
      </span>
    </nav>
  </aside>
  <main class="maker-main">
    <div class="maker-main-inner">
    <div class="breadcrumb-section">
      <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <a href="%%=v(@hubUrl)=%%" class="breadcrumb-link">
          <svg width="35" height="40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          Back
        </a>
        <span class="breadcrumb-separator" aria-hidden="true">/</span>
%%[ IF @showForm == "true" THEN ]%%
        <span class="breadcrumb-current">%%=v(@builderPageLabel)=%%</span>
%%[ ELSE ]%%
        <span class="breadcrumb-current">%%=Concat(@builderPageLabel," • Result")=%%</span>
%%[ ENDIF ]%%
      </nav>
    </div>
%%[ IF @showForm == "true" THEN ]%%
    <div class="maker-page-heading">
      <div class="maker-page-heading-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 17h2v-5H3v5zm8 5h2V6h-2v16zM13 9h8V7h-8v2zM3 5v4h14V5H3zm8 14h10v-2H11v2zM13 17h8v-2h-8v2z"/></svg>
      </div>
      <div class="maker-page-heading-text">
        <h1 class="maker-page-title">Journey + Automation</h1>
      </div>
    </div>
    <p class="maker-page-subtitle">One <strong>Campaign Name</strong> is used for the journey, entry event, data extension, query, automation, and email.<br>
      <strong>Salesforce Campaign ID</strong> filters the query and updates Campaign Member status in the journey.</p>
    <div class="maker-form-shell">
   <form method="post" action="">
     %%[ IF NOT Empty(@flow) THEN ]%%
     <input type="hidden" name="flow" value="%%=v(@flow)=%%">
     %%[ ENDIF ]%%
     <div class="question-card">
       <div class="question-header">
         <div class="question-number">1</div>
         <div class="question-text">Campaign name</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="stackCampaignName" value="%%=v(@stackCampaignName)=%%" placeholder="e.g. SBU Cross-sell Q3 — used for journey, DE, query, automation, and email" required>
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">2</div>
         <div class="question-text">Salesforce Campaign ID</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="campaignId" value="%%=v(@campaignId)=%%" placeholder="e.g. 701WL00000pFzUEYA0 — INNER JOIN filter in query + Campaign Member update" required>
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">3</div>
         <div class="question-text">Account owner User ID (optional)</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="sfUserId" value="%%=v(@sfUserId)=%%" placeholder="Optional — adds AND u.id = '...' on the User_Salesforce join">
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">4</div>
         <div class="question-text">Journey description (optional)</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="journeyDescription" value="%%=v(@journeyDescription)=%%" placeholder="Stored on the journey definition API payload">
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">5</div>
         <div class="question-text">Email subject line</div>
       </div>
       <div class="form-group">
         <input type="text" class="textarea-control" name="emailSubjectLine" value="%%=v(@emailSubjectLine)=%%" placeholder="Defaults to Campaign Event if left blank">
       </div>
       <div class="form-group">
         <label for="bccEmail" style="font-size:0.875rem;color:#6b7280;display:block;margin-bottom:6px;">BCC on triggered send (optional)</label>
         <input id="bccEmail" type="text" class="textarea-control" name="bccEmail" value="%%=v(@bccEmail)=%%" placeholder="Leave blank for no BCC">
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">6</div>
         <div class="question-text">Sender profile</div>
       </div>
       <div class="form-group">
%%[ IF @senderProfileConfigOk == "true" THEN ]%%
         <select id="senderProfileId" class="select-control" name="senderProfileId">
           %%=TreatAsContent(@senderProfileOptionsHtml)=%%
         </select>
%%[ ELSE ]%%
         <div class="maker-alert" role="alert">Could not load sender profiles from Marketing Cloud.</div>
%%[ ENDIF ]%%
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">7</div>
         <div class="question-text">Send classification</div>
       </div>
       <div class="form-group">
%%[ IF @sendClassificationConfigOk == "true" THEN ]%%
         <select id="sendClassificationId" class="select-control" name="sendClassificationId">
           %%=TreatAsContent(@sendClassificationOptionsHtml)=%%
         </select>
%%[ ELSE ]%%
         <div class="maker-alert" role="alert">Could not load send classifications from Marketing Cloud.</div>
%%[ ENDIF ]%%
       </div>
       <div class="question-header" style="margin-top: 24px;">
         <div class="question-number">8</div>
         <div class="question-text">Choose Email Template</div>
       </div>
       <div class="email-cards">
         %%[ IF @templateConfigOk == "true" THEN
           FOR @ti = 1 TO @templateCount DO
             SET @templateRow = Row(@templateRows,@ti)
             SET @cardEmailId = Trim(Field(@templateRow,"email_id"))
             SET @cardEmailName = Field(@templateRow,"email_name")
             SET @cardEmailPreview = Field(@templateRow,"email_preview")
             SET @cardLabel = @cardEmailName
             IF Length(@cardLabel) > 10 THEN
               SET @cardLabel = Concat(Substring(@cardLabel,1,10),"...")
             ENDIF
         ]%%
         <label class="email-card %%[ IF @emailId == @cardEmailId THEN ]%%selected%%[ ENDIF ]%%" data-email-id="%%=v(@cardEmailId)=%%">
           <input type="radio" name="emailId" value="%%=v(@cardEmailId)=%%" %%[ IF @emailId == @cardEmailId THEN ]%%checked%%[ ENDIF ]%%>
           <img class="email-card-img" src="%%=v(@cardEmailPreview)=%%" alt="%%=v(@cardEmailName)=%%">
           <div class="email-card-label">%%=v(@cardLabel)=%%</div>
           <div class="email-card-id">ID: %%=v(@cardEmailId)=%%</div>
         </label>
         %%[ NEXT @ti ELSE ]%%
         <div class="maker-alert" role="alert">Template config missing in `bd_sst_email_templates` (email_type=template).</div>
         %%[ ENDIF ]%%
       </div>
       <div class="submit-section">
         <input type="hidden" name="create" value="1">
         <button type="submit" class="submit-button" id="submitBtn">
           <span id="btnText"> Create stack </span>
           <span id="btnSpinner" class="spinner" style="display:none"></span>
         </button>
       </div>
     </div>
   </form>
    </div>
%%[ ELSE ]%%
    <div class="maker-page-heading">
      <div class="maker-page-heading-icon maker-result-status %%[ IF IndexOf(@resultText,"FAILED") > 0 THEN ]%%is-error%%[ ELSE ]%%is-success%%[ ENDIF ]%%" aria-hidden="true">
%%[ IF IndexOf(@resultText,"FAILED") > 0 THEN ]%%
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
%%[ ELSE ]%%
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
%%[ ENDIF ]%%
      </div>
      <div class="maker-page-heading-text">
        <h1 class="maker-page-title">%%=IIF(@deleteAllRequested == "1","Delete all finished",IIF(IndexOf(@resultText,"FAILED") > 0,"Could not complete setup","Build finished"))=%%</h1>
      </div>
    </div>
    <p class="maker-page-subtitle">
%%[ IF @deleteAllRequested == "1" THEN ]%%
Review the log below for each removed asset, then return to the builder to start another run.
%%[ ELSEIF IndexOf(@resultText,"FAILED") > 0 THEN ]%%
Review the technical log below, adjust your inputs if needed, and try again.
%%[ ELSE ]%%
Your data extension, query automation, journey, and email are in Marketing Cloud. Open them below or return to the builder to start another run.
%%[ ENDIF ]%%
    </p>
    <div class="maker-form-shell">
      <div class="maker-result-inner">
        <dl class="maker-result-dl">
%%[ IF NOT Empty(@journeyId) OR NOT Empty(@eventDefId) THEN ]%%
          <dt>Data extension</dt>
          <dd>%%=IIF(NOT Empty(@eventName), @eventName, "—")=%% %%[ IF NOT Empty(@deCustomerKey) THEN ]%%(CustomerKey: %%=v(@deCustomerKey)=%%)%%[ ENDIF ]%%</dd>
          <dt>Query</dt>
          <dd>%%=IIF(NOT Empty(@queryKey), @queryKey, "—")=%%</dd>
          <dt>Automation</dt>
          <dd>%%=IIF(NOT Empty(@automationId), Concat(@stackCampaignName, " (", @automationId, ")"), IIF(NOT Empty(@stackCampaignName), @stackCampaignName, "—"))=%%</dd>
          <dt>Journey</dt>
          <dd>%%=IIF(NOT Empty(@journeyName), @journeyName, "—")=%%</dd>
          <dt>Email</dt>
          <dd>%%=IIF(NOT Empty(@emailName), @emailName, "—")=%%</dd>
%%[ ENDIF ]%%
        </dl>
        <div class="maker-result-actions">
%%[ IF NOT Empty(@journeyId) THEN ]%%
          <a href="https://mc.s13.exacttarget.com/cloud/#app/Journey%20Builder/%23%%=v(@journeyId)=%%/1" target="_blank" rel="noopener noreferrer" class="maker-btn maker-btn--primary">Open journey</a>
%%[ ENDIF ]%%
          <a href="https://mc.s13.exacttarget.com/cloud/#app/Content%20Builder/" target="_blank" rel="noopener noreferrer" class="maker-btn maker-btn--secondary">Open Content Builder</a>
%%[ IF NOT Empty(@automationId) THEN ]%%
          <a href="https://mc.s13.exacttarget.com/cloud/#app/Automation%20Studio/" target="_blank" rel="noopener noreferrer" class="maker-btn maker-btn--secondary js-automation-home-link" data-automation-name="%%=Replace(Replace(v(@stackCampaignName),'"','&quot;'),'&','&amp;')=%%" title="%%[ IF NOT Empty(@stackCampaignName) THEN ]%%Copies automation name to clipboard%%[ ELSE ]%%Opens Automation Studio%%[ ENDIF ]%%">Open automation</a>
%%[ ENDIF ]%%
%%[ IF NOT Empty(@newEmailId) OR NOT Empty(@journeyId) OR NOT Empty(@automationId) THEN ]%%
          <form method="post" action="" style="margin:0;display:inline" onsubmit="return confirm('Delete the journey, automation, query, entry event, data extension, email, and analytics log row for this build?');">
            <input type="hidden" name="deleteAll" value="1">
            <input type="hidden" name="deleteJourneyId" value="%%=v(@journeyId)=%%">
            <input type="hidden" name="deleteEventDefId" value="%%=v(@eventDefId)=%%">
            <input type="hidden" name="deleteAutomationId" value="%%=v(@automationId)=%%">
            <input type="hidden" name="deleteQueryKey" value="%%=v(@queryKey)=%%">
            <input type="hidden" name="deleteEmailId" value="%%=v(@newEmailId)=%%">
            <input type="hidden" name="deleteEventName" value="%%=v(@eventName)=%%">
            <button type="submit" class="maker-btn maker-btn--danger">Delete all</button>
          </form>
%%[ ENDIF ]%%
        </div>
        <div class="maker-result-log-wrap">
          <pre class="maker-result-log" id="apiLog">%%=v(@resultText)=%%</pre>
        </div>
        <div class="maker-result-actions maker-result-actions--footer">
          <form method="post" action="" style="margin:0">
%%[ IF NOT Empty(@flow) THEN ]%%
            <input type="hidden" name="flow" value="%%=v(@flow)=%%">
%%[ ENDIF ]%%
            <button type="submit" class="maker-btn maker-btn--secondary">Back to builder</button>
          </form>
          <button type="button" class="maker-btn maker-btn--ghost" id="showLogBtn">Show log</button>
        </div>
      </div>
    </div>
%%[ ENDIF ]%%
    </div>
    <footer class="maker-main-footer">
      <span>Self Service</span>
      <span>© 2026 All rights reserved | MagMutual</span>
    </footer>
  </main>
</div>
<script>
(function(){
 var form = document.querySelector('form[method="post"]');
 if (form && form.querySelector('#submitBtn')) {
   var btn = document.getElementById('submitBtn');
   var btnText = document.getElementById('btnText');
   var btnSpinner = document.getElementById('btnSpinner');
   form.addEventListener('submit', function() {
     btn.disabled = true;
     if (btnText) btnText.textContent = 'Creating...';
     if (btnSpinner) btnSpinner.style.display = 'inline-block';
   });
 }
 var cards = document.querySelectorAll('.email-card');
 cards.forEach(function(card) {
   card.addEventListener('click', function() {
     cards.forEach(function(c) { c.classList.remove('selected'); });
     card.classList.add('selected');
     card.querySelector('input[type="radio"]').checked = true;
   });
 });
 var showLogBtn = document.getElementById('showLogBtn');
 var apiLog = document.getElementById('apiLog');
 if (showLogBtn && apiLog) {
   showLogBtn.onclick = function() {
     apiLog.classList.toggle('is-visible');
     showLogBtn.textContent = apiLog.classList.contains('is-visible') ? 'Hide log' : 'Show log';
   };
 }
 function copyText(text) {
  if (!text) {
   return;
  }
  if (navigator.clipboard && navigator.clipboard.writeText) {
   navigator.clipboard.writeText(text).catch(function () {
    fallbackCopy(text);
   });
   return;
  }
  fallbackCopy(text);
 }
 function fallbackCopy(text) {
  var ta = document.createElement('textarea');
  ta.value = text;
  ta.setAttribute('readonly', '');
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try {
   document.execCommand('copy');
  } catch (copyErr) {}
  document.body.removeChild(ta);
 }
 var autoLinks = document.querySelectorAll('.js-automation-home-link');
 var ai;
 for (ai = 0; ai < autoLinks.length; ai++) {
  autoLinks[ai].addEventListener('click', function () {
   var name = this.getAttribute('data-automation-name') || '';
   if (name) {
    copyText(name);
   }
  });
 }
})();
</script>
</body>
</html>