   }
   if (deleteJourneyId) {
     var jDelUrl =
       "https://" +
       subdomain +
       ".rest.marketingcloudapis.com/interaction/v1/interactions/" +
       encodeURIComponent(String(deleteJourneyId));
     var jSt = purgeHttpDel(accessToken, subdomain, jDelUrl);
     if (jSt == 200 || jSt == 204) {
       purgePart("[Journey] DELETE OK.");
     } else {
       purgePart("[Journey] DELETE HTTP " + jSt + ".");
     }
   } else {
     purgePart("[Journey] SKIP - no id.");
   }
   if (deleteEventDefId) {
     var dataExtensionId = null;
     try {
       var getEventUrl =
         "https://" +
         subdomain +
         ".rest.marketingcloudapis.com/interaction/v1/eventDefinitions/" +
         deleteEventDefId;
       var getReq = new Script.Util.HttpRequest(getEventUrl);
       getReq.emptyContentHandling = 0;
       getReq.continueOnError = true;
       getReq.setHeader("Authorization", "Bearer " + accessToken);
       getReq.method = "GET";
       var getResp = getReq.send();
       if ((getResp.statusCode == 200 || getResp.statusCode == 201) && getResp.content) {
         var eventObj = Platform.Function.ParseJSON(String(getResp.content));
         dataExtensionId = eventObj.dataExtensionId || eventObj.dataExtensionID || null;
       }
       var evSt = purgeHttpDel(accessToken, subdomain, getEventUrl);
       if (evSt == 200 || evSt == 204) {
         purgePart("[Entry event] DELETE OK.");
       } else {
         purgePart("[Entry event] DELETE HTTP " + evSt + ".");
       }
     } catch (evEx) {
       purgePart("[Entry event] FAILED: " + (evEx.message || String(evEx)));
     }
     try {
       var deObjId = dataExtensionId;
       var evName = deleteEventNameParam || "";
       if (!deObjId && evName) {
         var proxDe = new Script.Util.WSProxy();
         var deFilter = { Property: "Name", SimpleOperator: "equals", Value: String(evName) };
         var rde = proxDe.retrieve("DataExtension", ["ObjectID"], deFilter);
         if (rde && rde.Results && rde.Results.length > 0 && rde.Results[0].ObjectID) {
           deObjId = rde.Results[0].ObjectID;
         }
       }
       if (deObjId) {
         var proxDeDel = new Script.Util.WSProxy();
         var deResult = proxDeDel.deleteItem("DataExtension", { ObjectID: deObjId });
         if (deResult && deResult.Results && deResult.Results.length > 0 && deResult.Results[0].Status == "OK") {
           purgePart("[Data extension] DELETE OK.");
         } else {
           purgePart("[Data extension] deleteItem did not report OK.");
         }
       } else {
         purgePart("[Data extension] SKIP - no ObjectID resolved.");
       }
     } catch (deEx) {
       purgePart("[Data extension] FAILED: " + (deEx.message || String(deEx)));
     }
   } else {
     purgePart("[Entry event] SKIP - no id.");
   }
   if (deleteEmailIdParam) {
     var emailDelUrl =
       "https://" +
       subdomain +
       ".rest.marketingcloudapis.com/asset/v1/content/assets/" +
       deleteEmailIdParam;
     var emSt = purgeHttpDel(accessToken, subdomain, emailDelUrl);
     if (emSt == 200 || emSt == 204) {
       purgePart("[Email] DELETE OK.");
       Platform.Variable.SetValue("@deleteAllEmailOk", "true");
     } else {
       purgePart("[Email] DELETE HTTP " + emSt + ".");
       Platform.Variable.SetValue("@deleteAllEmailOk", "false");
     }
   } else {
     purgePart("[Email] SKIP - no id.");
     Platform.Variable.SetValue("@deleteAllEmailOk", "false");
   }
 } catch (purgeEx) {
   purgePart("DELETE ALL FAILED: " + (purgeEx.message || String(purgeEx)));
   Platform.Variable.SetValue("@deleteAllEmailOk", "false");
 }
 step3bResult = " Delete all: " + purgeLog.join(" ");
 Platform.Variable.SetValue("@deleteAllLog", purgeLog.join(" "));
} else if (authOk == "true" && accessToken && subdomain && emailName && sourceEmailId) {
 try {
   var templateUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets/" + sourceEmailId;
   var getReq = new Script.Util.HttpRequest(templateUrl);
   getReq.emptyContentHandling = 0;
   getReq.retries = 2;
   getReq.continueOnError = true;
   getReq.setHeader("Authorization", "Bearer " + accessToken);
   getReq.method = "GET";
   getReq.contentType = "application/json";
   var getResp = getReq.send();
   var templateStatus = getResp.statusCode;
   var templateResponse = getResp.content ? String(getResp.content) : "";
   if (templateStatus == 200 && templateResponse) {
     var template = Platform.Function.ParseJSON(templateResponse);
     var sourceViews = template.views || {};
     var htmlView = sourceViews.html || {};
     var emailSubjectForAsset = Platform.Variable.GetValue("@emailSubjectLine") || "";
     var subjectlineContent = emailSubjectForAsset || ((sourceViews.subjectline && sourceViews.subjectline.content) ? sourceViews.subjectline.content : "Campaign Event");
     var preheaderContent = (sourceViews.preheader && sourceViews.preheader.content) ? sourceViews.preheader.content : "";
     var textContent = (sourceViews.text && sourceViews.text.content) ? sourceViews.text.content : "";
     var htmlContent = htmlView.content || template.content || "";
     var htmlSlots = (htmlView.slots && typeof htmlView.slots === "object") ? htmlView.slots : ((template.slots && typeof template.slots === "object") ? template.slots : {});
     var sourceTemplate = (htmlView.template && typeof htmlView.template === "object") ? htmlView.template : null;
     var assetTypeId = (template.assetType && template.assetType.id) ? parseInt(template.assetType.id, 10) : 207;
     var slotKeys = objectKeys(htmlSlots);
     var payload = null;
     var resolvedTemplateAsset = null;
     var debugPrefix = " Source assetType: " + assetTypeId + ". Has template ref: " + (sourceTemplate ? "yes" : "no") + ". Slot keys: " + (slotKeys.length ? slotKeys.join(",") : "none") + ".";
     var payloadDebug = "";
     if (assetTypeId === 4) {
       var templateRef = buildTemplateReference(template, template.content || htmlContent, template.slots || htmlSlots);
       var templateSlots = (template.slots && typeof template.slots === "object") ? cloneObject(template.slots) : cloneObject(htmlSlots || {});
       payload = {
         name: emailName,
         assetType: { name: "htmlemail", id: 207 },
         channels: (template.channels && typeof template.channels === "object") ? cloneObject(template.channels) : { email: true, web: false },
         views: {
           subjectline: { content: subjectlineContent },
           preheader: { content: preheaderContent },
           html: {
             template: templateRef,
             content: template.content || htmlContent || "",
             slots: templateSlots || {}
           },
           text: {}
         }
       };
       applyTextSettings(payload, textContent);
       if (template.category && template.category.id) {
         payload.category = { id: template.category.id };
       }
     } else if (assetTypeId === 207) {
       if (sourceTemplate) {
         var fetchedTemplate = fetchAssetById(sourceTemplate.id, subdomain, accessToken);
         if (fetchedTemplate.ok && fetchedTemplate.asset) {
           resolvedTemplateAsset = fetchedTemplate.asset;
           payload = buildCloned207Payload(template, emailName, subjectlineContent, preheaderContent, textContent, sourceTemplate, resolvedTemplateAsset, htmlSlots);
         } else {
           step3bResult = " Step 3b SKIP - Email not duplicated: Template asset fetch failed for template ID " + sourceTemplate.id + " with HTTP " + fetchedTemplate.statusCode + " - " + (fetchedTemplate.responseText || "No response body.") + debugPrefix;
         }
       } else {
         step3bResult = " Step 3b SKIP - Email not duplicated: Source asset is template-based email but views.html.template is missing." + debugPrefix;
       }
     } else if (assetTypeId === 208) {
       payload = buildBasePayload(template, emailName, 208);
       if (!payload.channels) {
         payload.channels = { email: true, web: false };
       }
       if (!payload.views || typeof payload.views !== "object") {
         payload.views = {};
       }
       payload.views.subjectline = payload.views.subjectline || { content: subjectlineContent };
       payload.views.preheader = payload.views.preheader || { content: preheaderContent };
       payload.views.html = payload.views.html || { content: htmlContent };
       applyTextSettings(payload, textContent);
     } else {
       step3bResult = " Step 3b SKIP - Email not duplicated: Unsupported source asset type " + assetTypeId + "." + debugPrefix;
     }
     if (payload && !step3bResult.match(/views\.html\.template is missing|Unsupported source asset type/)) {
       var debugObj = {
         source: {
           assetTypeId: assetTypeId,
           subjectlineLength: safeLength(subjectlineContent),
           preheaderLength: safeLength(preheaderContent),
           textLength: safeLength(textContent),
           html: summarizeHtmlView(htmlView),
           emailOptions: summarizeEmailOptions(template.data),
           resolvedTemplate: resolvedTemplateAsset ? {
             id: resolvedTemplateAsset.id || "",
             contentLength: safeLength(resolvedTemplateAsset.content),
             slotKeys: objectKeys(resolvedTemplateAsset.slots)
           } : null
         },
         outgoing: {
           assetType: payload.assetType || null,
           category: payload.category || null,
           channels: payload.channels || null,
           subjectlineLength: (payload.views && payload.views.subjectline) ? safeLength(payload.views.subjectline.content) : 0,
           preheaderLength: (payload.views && payload.views.preheader) ? safeLength(payload.views.preheader.content) : 0,
           textLength: (payload.views && payload.views.text) ? safeLength(payload.views.text.content) : 0,
           html: summarizeHtmlView(payload.views ? payload.views.html : null),
           emailOptions: summarizeEmailOptions(payload.data)
         }
       };
       payloadDebug = truncateString(Platform.Function.Stringify(debugObj), 2500);
       var assetUrl = "https://" + subdomain + ".rest.marketingcloudapis.com/asset/v1/content/assets";
       var postReq = new Script.Util.HttpRequest(assetUrl);
       postReq.emptyContentHandling = 0;
       postReq.retries = 2;
       postReq.continueOnError = true;
       postReq.setHeader("Authorization", "Bearer " + accessToken);
       postReq.method = "POST";
       postReq.contentType = "application/json";
       postReq.postData = Platform.Function.Stringify(payload);
       var postResp = postReq.send();
       var assetStatus = postResp.statusCode;
       var assetResponse = postResp.content ? String(postResp.content) : "";
       if ((assetStatus == 200 || assetStatus == 201) && assetResponse) {
         var idMatch = assetResponse.match(/"id"\s*:\s*"?([^",}\s]+)"?/);
         if (idMatch) {
           newEmailId = String(idMatch[1]);
           var createdAsset = null;
           try {
             createdAsset = Platform.Function.ParseJSON(assetResponse);
           } catch (parseEx) {
             createdAsset = null;
           }
           journeyEmailId = extractLegacyEmailId(createdAsset);
           if (!journeyEmailId && newEmailId) {
             var createdAssetFetch = fetchAssetById(newEmailId, subdomain, accessToken);
             if (createdAssetFetch.ok && createdAssetFetch.asset) {
               journeyEmailId = extractLegacyEmailId(createdAssetFetch.asset);
             }
           }
           if (journeyEmailId) {
             step3bResult = " Step 3b OK - Email duplicated.";
           } else {
             step3bResult = " Step 3b SKIP - Email duplicated but legacy email ID was not available for Journey Builder.";
           }
         } else {
           step3bResult = " Step 3b SKIP - Email duplicated but new ID was not returned." + debugPrefix + " Response: " + assetResponse + " Debug: " + payloadDebug;
         }
       } else {
         step3bResult = " Step 3b SKIP - Email not duplicated: HTTP " + assetStatus + " - " + (assetResponse || "No response body.") + debugPrefix + " Debug: " + payloadDebug;
       }
     }
   } else {
     step3bResult = " Step 3b SKIP - Email not duplicated: Template fetch HTTP " + templateStatus + " - " + (templateResponse || "No response body.");
   }
 } catch (e) {
   step3bResult = " Step 3b SKIP - Email not duplicated: " + (e.message || String(e));
 }
}
Platform.Variable.SetValue("@newEmailId", newEmailId);
Platform.Variable.SetValue("@journeyEmailId", journeyEmailId);
Platform.Variable.SetValue("@step3bResult", step3bResult);
</script>
