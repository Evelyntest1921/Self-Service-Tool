function postCreateAutomation(opts) {
  try {
  var token = opts.token;
  var subdomain = opts.subdomain;
  var automationName = opts.automationName;
  var automationKey = opts.automationKey;
  var queryObjectId = String(opts.queryObjectId || "");
  var frequency = opts.frequency || "hourly";
  var timezoneId = opts.timezoneId || "1";
  var startDate = opts.startDate || "";
  var startOffset = opts.startOffset || "-05:00";

  if (!queryObjectId) {
    return { ok: false, message: "Step 7 FAILED - query activity ObjectID not available." };
  }

  if (!startDate) {
    var nowVal = new Date();
    nowVal.setMinutes(0, 0, 0);
    nowVal.setHours(nowVal.getHours() + 1);
    function pad(n) {
      return (n < 10 ? "0" : "") + n;
    }
    startDate =
      nowVal.getFullYear() +
      "-" +
      pad(nowVal.getMonth() + 1) +
      "-" +
      pad(nowVal.getDate()) +
      "T" +
      pad(nowVal.getHours()) +
      ":" +
      pad(nowVal.getMinutes());
  }

  var off = String(startOffset || "-05:00");
  if (off.charAt(0) != "-" && off.charAt(0) != "+") {
    off = "-" + off;
  }
  var startDateForApi = String(startDate);
  if (startDateForApi.length == 16) {
    startDateForApi += ":00" + off;
  } else if (
    startDateForApi.indexOf("T") > 0 &&
    startDateForApi.indexOf("+") < 0 &&
    startDateForApi.indexOf("-", 11) < 0 &&
    startDateForApi.length == 19
  ) {
    startDateForApi += off;
  }
  var startDateLocal = postStripTimezoneFromIso(startDateForApi);
  var endDateLocal = startDateLocal;

  function pad2(n) {
    return (n < 10 ? "0" : "") + n;
  }
  var untilCompact = "";
  var dmatch = startDateForApi.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (dmatch) {
    var y0 = parseInt(dmatch[1], 10);
    var m0 = parseInt(dmatch[2], 10) - 1;
    var d0 = parseInt(dmatch[3], 10);
    var dUntil = new Date(y0, m0, d0);
    dUntil.setDate(dUntil.getDate() + 365);
    untilCompact =
      String(dUntil.getFullYear()) +
      pad2(dUntil.getMonth() + 1) +
      pad2(dUntil.getDate());
  } else {
    var fallback = new Date();
    fallback.setDate(fallback.getDate() + 365);
    untilCompact =
      String(fallback.getFullYear()) +
      pad2(fallback.getMonth() + 1) +
      pad2(fallback.getDate());
  }

  var endpoint = "https://" + subdomain + ".rest.marketingcloudapis.com/automation/v1/automations";
  var tzId = parseInt(String(timezoneId), 10);
  if (isNaN(tzId) || tzId < 1) {
    tzId = 1;
  }
  var recurRule = "";
  if (frequency == "hourly") {
    recurRule = "FREQ=HOURLY;INTERVAL=1;UNTIL=" + untilCompact;
  } else if (frequency == "daily") {
    recurRule = "FREQ=DAILY;INTERVAL=1;UNTIL=" + untilCompact;
  } else if (frequency == "weekly") {
    recurRule = "FREQ=WEEKLY;INTERVAL=1;BYDAY=MO;UNTIL=" + untilCompact;
  } else {
    return { ok: false, message: "Step 7 FAILED - invalid frequency." };
  }

  var byKeyEndpoint = endpoint + "/key:" + encodeURIComponent(String(automationKey));
  var keyLookup = postHttpJson(token, subdomain, "GET", byKeyEndpoint, null);
  var existingObj = keyLookup.status == 200 ? postParseJson(keyLookup.body) : null;
  var automationId = "";
  var createdNow = false;

  if (existingObj && existingObj.id) {
    automationId = String(existingObj.id);
  } else {
    var recurAttempts = [recurRule];
    if (frequency == "hourly") {
      recurAttempts.push("FREQ=HOURLY;COUNT=1;INTERVAL=1");
      recurAttempts.push("FREQ=MINUTELY;INTERVAL=60;UNTIL=" + untilCompact);
    }
    var createStatus = 0;
    var createBody = "";
    var usedRecur = recurRule;
    var ri;
    for (ri = 0; ri < recurAttempts.length; ri++) {
      usedRecur = recurAttempts[ri];
      var createSchedule = postBuildScheduleWrite(
        usedRecur,
        startDateLocal,
        endDateLocal,
        tzId
      );
      var createJson = postBuildAutomationPostBody(
        automationName,
        automationKey,
        queryObjectId,
        createSchedule
      );
      var cr = postHttpJson(token, subdomain, "POST", endpoint, createJson);
      createStatus = cr.status;
      createBody = cr.body;
      if (createStatus == 200 || createStatus == 201 || createStatus == 202) {
        recurRule = usedRecur;
        break;
      }
      var dupName =
        createBody.indexOf("Name already exists") >= 0 ||
        createBody.indexOf("already exists") >= 0;
      if (dupName) {
        var keyRetry = postHttpJson(token, subdomain, "GET", byKeyEndpoint, null);
        if (keyRetry.status == 200) {
          var retryObj = postParseJson(keyRetry.body);
          if (retryObj && retryObj.id) {
            automationId = String(retryObj.id);
            createdNow = false;
            break;
          }
        }
      }
    }
    if (automationId) {
    } else if (!(createStatus == 200 || createStatus == 201 || createStatus == 202)) {
      return {
        ok: false,
        message:
          "Step 7 FAILED - create automation HTTP " +
          createStatus +
          " - " +
          createBody +
          " (icalRecur tried: " +
          usedRecur +
          ", queryObjectId=" +
          queryObjectId +
          ")."
      };
    }
    if (!automationId) {
      var createObj = postParseJson(createBody);
      automationId = createObj && createObj.id ? String(createObj.id) : "";
      createdNow = true;
    }
  }

  if (!automationId) {
    return { ok: false, message: "Step 7 FAILED - automation ID not available." };
  }

  var patchEndpoint = endpoint + "/" + encodeURIComponent(automationId);
  var scheduleNote = "";
  try {
    var patchSchedule = postBuildScheduleWrite(
      recurRule,
      startDateLocal,
      endDateLocal,
      tzId
    );
    postHttpJson(
      token,
      subdomain,
      "PATCH",
      patchEndpoint,
      postBuildSchedulePatchBody(patchSchedule)
    );
    var verify = postHttpJson(token, subdomain, "GET", patchEndpoint, null);
    var verifyObj = verify.status == 200 ? postParseJson(verify.body) : null;
    var finalRecur = postExtractIcalFromVerify(verifyObj);
    scheduleNote = finalRecur
      ? " icalRecur=" + finalRecur + "."
      : " Schedule not verified in API response; confirm in Automation Studio.";
  } catch (patchEx) {
    scheduleNote =
      " Schedule PATCH skipped (" +
      (patchEx.message || String(patchEx)) +
      "); confirm in Automation Studio.";
  }
  return {
    ok: true,
    automationId: automationId,
    message:
      "Step 7 OK - automation " +
      (createdNow ? "created" : "updated existing") +
      ". key=" +
      automationKey +
      " id=" +
      automationId +
      " queryObjectId=" +
      queryObjectId +
      "." +
      scheduleNote +
      " Activate or change schedule in Edit Build."
  };
  } catch (autoEx) {
    return {
      ok: false,
      message:
        "Step 7 FAILED - automation threw: " + (autoEx.message || String(autoEx))
    };
  }
}

